domain SysDomain
  freq_mhz: 100
end domain SysDomain

regfile IntRegs
  param NREGS: const = 32;
  param T: type = UInt<8>;
  port clk: in Clock<SysDomain>;
  port rst: in Reset<Sync>;
  ports[2] read
    addr: in UInt<5>;
    data: out UInt<8>;
  end ports read
  ports[1] write
    en: in Bool;
    addr: in UInt<5>;
    data: in UInt<8>;
  end ports write
  init [0] = 0;
  forward write_before_read: true;
end regfile IntRegs
