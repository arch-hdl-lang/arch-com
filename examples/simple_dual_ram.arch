domain SysDomain
  freq_mhz: 100
end domain SysDomain

ram DualMem
  kind simple_dual;
  latency 1;
  param DEPTH: const = 128;
  param WIDTH: type = UInt<8>;
  port clk: in Clock<SysDomain>;
  store
    buf: Vec<WIDTH, DEPTH>;
  end store
  ports rd_port
    en: in Bool;
    addr: in UInt<7>;
    data: out WIDTH;
  end ports rd_port
  ports wr_port
    en: in Bool;
    addr: in UInt<7>;
    data: in WIDTH;
  end ports wr_port
end ram DualMem
