domain SysDomain
  freq_mhz: 100
end domain SysDomain

fifo TxQueue
  param DEPTH: const = 16;
  param T: type = UInt<8>;
  port clk: in Clock<SysDomain>;
  port rst: in Reset<Sync>;
  port push_valid: in Bool;
  port push_ready: out Bool;
  port push_data: in T;
  port pop_valid: out Bool;
  port pop_ready: in Bool;
  port pop_data: out T;
  port full: out Bool;
  port empty: out Bool;
end fifo TxQueue
