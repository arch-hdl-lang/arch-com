domain SrcDomain
  freq_mhz: 100
end domain SrcDomain

domain DstDomain
  freq_mhz: 250
end domain DstDomain

synchronizer BusSync
  kind handshake;
  param STAGES: const = 2;
  port src_clk: in Clock<SrcDomain>;
  port dst_clk: in Clock<DstDomain>;
  port rst: in Reset<Sync>;
  port data_in: in UInt<32>;
  port data_out: out UInt<32>;
end synchronizer BusSync
