domain SysDomain
  freq_mhz: 100
end domain SysDomain

ram SimpleMem
  kind single;
  latency 1;
  write: no_change;
  init: zero;
  param DEPTH: const = 256;
  param T: type = UInt<8>;
  port clk: in Clock<SysDomain>;
  store
    data: Vec<T, DEPTH>;
  end store
  ports access
    en: in Bool;
    wen: in Bool;
    addr: in UInt<8>;
    wdata: in T;
    rdata: out T;
  end ports access
end ram SimpleMem
