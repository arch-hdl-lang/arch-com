// Test: function construct
// Xtime: GF(2^8) multiply by 2

function Xtime(a: UInt<8>) -> UInt<8>
  let shifted: UInt<8> = a << 1;
  return match a & 0x80
    0x80 => shifted ^ 0x1b,
    _    => shifted,
  end match;
end function Xtime

module XtimeTest
  port a: in UInt<8>;
  port y: out UInt<8>;

  comb
    y = Xtime(a);
  end comb
end module XtimeTest
