module ClkDiv2
  port clk_in:  in Clock<SysDomain>;
  port rst:     in Reset<Sync>;
  port clk_out: out Clock<SysDomain>;

  reg toggle: Bool reset rst => false;

  default seq on clk_in rising;

  seq
    toggle <= ~toggle;
  end seq

  comb
    clk_out = toggle.as_clock<SysDomain>();
  end comb
end module ClkDiv2
