// Test: generate_for loop expanding ports
// `generate_for i in 0..1` creates two copies of req_i and gnt_i.

domain SysDomain
  freq_mhz: 100
end domain SysDomain

module GenDemo
  port clk: in Clock<SysDomain>;
  port rst: in Reset<Sync>;

  generate_for i in 0..1
    port req_i: in Bool;
    port gnt_i: out Bool;
  end generate_for

  comb
    gnt_0 = req_0;
    gnt_1 = req_1;
  end comb

end module GenDemo
