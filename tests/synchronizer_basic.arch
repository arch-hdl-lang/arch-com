domain FastDomain
  freq_mhz: 200
end domain FastDomain

domain SlowDomain
  freq_mhz: 50
end domain SlowDomain

synchronizer FlagSync
  param STAGES: const = 2;
  port src_clk: in Clock<FastDomain>;
  port dst_clk: in Clock<SlowDomain>;
  port rst: in Reset<Async>;
  port data_in: in Bool;
  port data_out: out Bool;
end synchronizer FlagSync
