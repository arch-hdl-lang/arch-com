// VerilogEval Prob038: 4-bit counter 0-15, sync reset to 0
domain SysDomain
end domain SysDomain

module TopModule
  port clk: in Clock<SysDomain>;
  port reset: in Reset<Sync>;
  port q: out UInt<4>;

  reg count_r: UInt<4> init 0 reset reset=0;

  seq on clk rising
    count_r <= (count_r + 1).trunc<4>();
  end seq

  comb
    q = count_r;
  end comb
end module TopModule
