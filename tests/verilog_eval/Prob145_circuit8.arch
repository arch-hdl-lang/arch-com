// VerilogEval Prob145: p is positive-level latch of a, q captures a on negedge
domain SysDomain
end domain SysDomain

module TopModule
  port clock: in Clock<SysDomain>;
  port a: in Bool;
  port p: out Bool;
  port q: out Bool;

  reg p_r: Bool;
  reg q_r: Bool;

  latch on clock
    p_r <= a;
  end latch

  seq on clock falling
    q_r <= a;
  end seq

  comb
    p = p_r;
    q = q_r;
  end comb
end module TopModule
