// VerilogEval Prob145: p=a when clock high, p holds on negedge; q captures p on negedge
domain SysDomain
end domain SysDomain

module TopModule
  port clock: in Clock<SysDomain>;
  port a: in Bool;
  port p: out Bool;
  port q: out Bool;

  reg p_r: Bool;
  reg q_r: Bool;

  seq on clock falling
    p_r <= a;
    q_r <= a;
  end seq

  comb
    if clock
      p = a;
    else
      p = p_r;
    end if
    q = q_r;
  end comb
end module TopModule
