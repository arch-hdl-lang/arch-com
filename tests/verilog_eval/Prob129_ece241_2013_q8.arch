// VerilogEval Prob129: Mealy FSM detecting overlapping 101, async active-low reset
fsm TopModule
  port clk: in Clock<SysDomain>;
  port aresetn: in Reset<Async, Low>;
  port x: in Bool;
  port z: out Bool;

  state [S0, S1, S10]
  default state S0;
  default
    comb z = false;
  end default

  state S0 -> S1 when x;

  state S1 -> S10 when ~x;

  state S10
    comb
      z = false;
      if x
        z = true;
      end if
    end comb
    -> S1 when x;
    -> S0 when ~x;
  end state S10
end fsm TopModule
