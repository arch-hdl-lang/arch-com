// VerilogEval Prob129: Mealy FSM detecting overlapping 101, async active-low reset
domain SysDomain
end domain SysDomain

fsm TopModule
  port clk: in Clock<SysDomain>;
  port aresetn: in Reset<Async, Low>;
  port x: in Bool;
  port z: out Bool;

  state S0, S1, S10;
  default state S0;

  state S0
    comb
      z = false;
    end comb
    transition to S1 when x;
  end state S0

  state S1
    comb
      z = false;
    end comb
    transition to S10 when ~x;
  end state S1

  state S10
    comb
      z = false;
      if x
        z = true;
      end if
    end comb
    transition to S1 when x;
    transition to S0 when ~x;
  end state S10
end fsm TopModule
