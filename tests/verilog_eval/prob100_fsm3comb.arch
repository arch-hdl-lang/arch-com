// VerilogEval Prob100: FSM combinational logic only
// State encoding: A=0, B=1, C=2, D=3
module TopModule
  port in: in Bool;
  port state: in UInt<2>;
  port next_state: out UInt<2>;
  port out: out Bool;

  comb
    if state == 0
      // State A
      if in
        next_state = 1;
      else
        next_state = 0;
      end if
    elsif state == 1
      // State B
      if in
        next_state = 1;
      else
        next_state = 2;
      end if
    elsif state == 2
      // State C
      if in
        next_state = 3;
      else
        next_state = 0;
      end if
    else
      // State D
      if in
        next_state = 1;
      else
        next_state = 2;
      end if
    end if
    out = (state == 3);
  end comb
end module TopModule
