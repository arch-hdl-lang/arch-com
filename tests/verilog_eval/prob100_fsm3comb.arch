// VerilogEval Prob100: FSM combinational logic only
// State encoding: A=0, B=1, C=2, D=3
module TopModule
  port in: in Bool;
  port state: in UInt<2>;
  port next_state: out UInt<2>;
  port out: out Bool;

  comb
    if state == 0
      // State A
      next_state = in ? 1 : 0;
    elsif state == 1
      // State B
      next_state = in ? 1 : 2;
    elsif state == 2
      // State C
      next_state = in ? 3 : 0;
    else
      // State D
      next_state = in ? 1 : 2;
    end if
    out = (state == 3);
  end comb
end module TopModule
