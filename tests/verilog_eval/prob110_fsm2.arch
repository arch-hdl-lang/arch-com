// VerilogEval Prob110: JK flip-flop as Moore FSM, async reset
fsm TopModule
  port clk: in Clock<SysDomain>;
  port areset: in Reset<Async>;
  port j: in Bool;
  port k: in Bool;
  port out: out Bool;

  state Off, On;
  default state Off;

  state Off
    comb out = false;
    transition to On when j;
  end state Off

  state On
    comb out = true;
    transition to Off when k;
  end state On

end fsm TopModule
