// VerilogEval Prob063: 4-bit shift register / down counter
// Shift: data enters at LSB, shifts left: q <= {q[2:0], data}
module TopModule
  port clk: in Clock<SysDomain>;
  port shift_ena: in Bool;
  port count_ena: in Bool;
  port data: in Bool;
  port reg q: out UInt<4>;

  default seq on clk rising;

  seq
    if shift_ena
      q[0] <= data;
      q[1] <= q[0];
      q[2] <= q[1];
      q[3] <= q[2];
    elsif count_ena
      q <= (q - 1).trunc<4>();
    end if
  end seq
end module TopModule
