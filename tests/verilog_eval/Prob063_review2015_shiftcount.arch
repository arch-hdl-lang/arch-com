// VerilogEval Prob063: 4-bit shift register / down counter
// Shift: data enters at LSB, shifts left: q <= {q[2:0], data}
domain SysDomain
end domain SysDomain

module TopModule
  port clk: in Clock<SysDomain>;
  port shift_ena: in Bool;
  port count_ena: in Bool;
  port data: in Bool;
  port q: out UInt<4>;

  reg sr: UInt<4>;

  seq on clk rising
    if shift_ena
      sr[0] <= data;
      sr[1] <= sr[0];
      sr[2] <= sr[1];
      sr[3] <= sr[2];
    elsif count_ena
      sr <= (sr - 1).trunc<4>();
    end if
  end seq

  comb
    q = sr;
  end comb
end module TopModule
