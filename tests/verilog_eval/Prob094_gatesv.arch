module TopModule
  port in: in UInt<4>;
  port out_both: out UInt<4>;
  port out_any: out UInt<4>;
  port out_different: out UInt<4>;
  comb
    out_both[0] = in[0] & in[1];
    out_both[1] = in[1] & in[2];
    out_both[2] = in[2] & in[3];
    out_both[3] = 0;
    out_any[0] = 0;
    out_any[1] = in[1] | in[0];
    out_any[2] = in[2] | in[1];
    out_any[3] = in[3] | in[2];
    out_different[0] = in[0] ^ in[1];
    out_different[1] = in[1] ^ in[2];
    out_different[2] = in[2] ^ in[3];
    out_different[3] = in[3] ^ in[0];
  end comb
end module TopModule
