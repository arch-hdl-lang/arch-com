module TopModule
  port in_sig: in UInt<4>;
  port out_both: out UInt<4>;
  port out_any: out UInt<4>;
  port out_different: out UInt<4>;
  comb
    out_both[0] = in_sig[0] & in_sig[1];
    out_both[1] = in_sig[1] & in_sig[2];
    out_both[2] = in_sig[2] & in_sig[3];
    out_both[3] = 0;
    out_any[0] = 0;
    out_any[1] = in_sig[1] | in_sig[0];
    out_any[2] = in_sig[2] | in_sig[1];
    out_any[3] = in_sig[3] | in_sig[2];
    out_different[0] = in_sig[0] ^ in_sig[1];
    out_different[1] = in_sig[1] ^ in_sig[2];
    out_different[2] = in_sig[2] ^ in_sig[3];
    out_different[3] = in_sig[3] ^ in_sig[0];
  end comb
end module TopModule
