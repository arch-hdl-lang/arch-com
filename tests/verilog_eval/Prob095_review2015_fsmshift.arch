// VerilogEval Prob095: FSM that asserts shift_ena for 4 cycles after reset
fsm TopModule
  port clk: in Clock<SysDomain>;
  port reset: in Reset<Sync>;
  port shift_ena: out Bool;

  state [B0, B1, B2, B3, Done]
  default state B0;
  default
    let shift_ena = true;
  end default

  state B0 -> B1 when true;

  state B1 -> B2 when true;

  state B2 -> B3 when true;

  state B3 -> Done when true;

  state Done
    let shift_ena = false;
    -> Done when true;
  end state Done

end fsm TopModule
