// VerilogEval Prob060: 4-stage shift register, active-low sync reset
domain SysDomain
end domain SysDomain

module TopModule
  port clk: in Clock<SysDomain>;
  port resetn: in Bool;
  port in: in Bool;
  port out: out Bool;

  reg sr: UInt<4> init 0 reset none;

  seq on clk rising
    if ~resetn
      sr <= 0;
    else
      sr <= (sr << 1).trunc<4>() | in.zext<4>();
    end if
  end seq

  comb
    out = sr[3:3];
  end comb
end module TopModule
