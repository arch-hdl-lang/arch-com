domain SysDomain
end domain SysDomain

module TopModule
  port clk: in Clock<SysDomain>;
  port a: in Bool;
  port b: in Bool;
  port out_assign: out Bool;
  port out_always_comb: out Bool;
  port reg out_always_ff: out Bool;

  seq on clk rising
    out_always_ff <= a ^ b;
  end seq

  comb
    out_assign = a ^ b;
    out_always_comb = a ^ b;
  end comb
end module TopModule
