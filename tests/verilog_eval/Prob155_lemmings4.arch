// VerilogEval Prob155: Lemmings walk/fall/dig/splatter FSM with async reset
// Fall >= 20 cycles then hit ground = splat (dead forever)
domain SysDomain
end domain SysDomain

fsm TopModule
  port clk: in Clock<SysDomain>;
  port areset: in Reset<Async>;
  port bump_left: in Bool;
  port bump_right: in Bool;
  port ground: in Bool;
  port dig: in Bool;
  port walk_left: out Bool;
  port walk_right: out Bool;
  port aaah: out Bool;
  port digging: out Bool;

  reg fall_count: UInt<5> reset areset=0;

  state WalkLeft, WalkRight, FallLeft, FallRight, DigLeft, DigRight, Splat;
  default state WalkLeft;

  default
    comb
      walk_left = false;
      walk_right = false;
      aaah = false;
      digging = false;
    end comb
  end default

  state WalkLeft
    comb
      walk_left = true;
    end comb
    seq on clk rising
      fall_count <= 0;
    end seq
    transition to FallLeft when ~ground;
    transition to DigLeft when ground & dig;
    transition to WalkRight when ground & ~dig & bump_left;
  end state WalkLeft

  state WalkRight
    comb
      walk_right = true;
    end comb
    seq on clk rising
      fall_count <= 0;
    end seq
    transition to FallRight when ~ground;
    transition to DigRight when ground & dig;
    transition to WalkLeft when ground & ~dig & bump_right;
  end state WalkRight

  state FallLeft
    comb
      aaah = true;
    end comb
    seq on clk rising
      if fall_count < 20
        fall_count <= (fall_count + 1).trunc<5>();
      end if
    end seq
    transition to Splat when ground & (fall_count >= 20);
    transition to WalkLeft when ground & (fall_count < 20);
  end state FallLeft

  state FallRight
    comb
      aaah = true;
    end comb
    seq on clk rising
      if fall_count < 20
        fall_count <= (fall_count + 1).trunc<5>();
      end if
    end seq
    transition to Splat when ground & (fall_count >= 20);
    transition to WalkRight when ground & (fall_count < 20);
  end state FallRight

  state DigLeft
    comb
      digging = true;
    end comb
    seq on clk rising
      fall_count <= 0;
    end seq
    transition to FallLeft when ~ground;
  end state DigLeft

  state DigRight
    comb
      digging = true;
    end comb
    seq on clk rising
      fall_count <= 0;
    end seq
    transition to FallRight when ~ground;
  end state DigRight

  state Splat
    seq on clk rising
      fall_count <= 0;
    end seq
    transition to Splat when ground;
    transition to Splat when ~ground;
  end state Splat
end fsm TopModule
