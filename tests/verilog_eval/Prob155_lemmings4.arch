// VerilogEval Prob155: Lemmings walk/fall/dig/splatter FSM with async reset
// Fall >= 20 cycles then hit ground = splat (dead forever)
fsm TopModule
  port clk: in Clock<SysDomain>;
  port areset: in Reset<Async>;
  port bump_left: in Bool;
  port bump_right: in Bool;
  port ground: in Bool;
  port dig: in Bool;
  port walk_left: out Bool;
  port walk_right: out Bool;
  port aaah: out Bool;
  port digging: out Bool;

  reg fall_count: UInt<5> reset areset=>0;

  state [WalkLeft, WalkRight, FallLeft, FallRight, DigLeft, DigRight, Splat]
  default state WalkLeft;
  default seq on clk rising;
  default
    comb walk_left = false;
    comb walk_right = false;
    comb aaah = false;
    comb digging = false;
  end default

  state WalkLeft
    comb walk_left = true;
    seq
      fall_count <= 0;
    end seq
    -> FallLeft when ~ground;
    -> DigLeft when ground & dig;
    -> WalkRight when ground & ~dig & bump_left;
  end state WalkLeft

  state WalkRight
    comb walk_right = true;
    seq
      fall_count <= 0;
    end seq
    -> FallRight when ~ground;
    -> DigRight when ground & dig;
    -> WalkLeft when ground & ~dig & bump_right;
  end state WalkRight

  state FallLeft
    comb aaah = true;
    seq
      fall_count <= fall_count < 20 ? (fall_count + 1).trunc<5>() : fall_count;
    end seq
    -> Splat when ground & (fall_count >= 20);
    -> WalkLeft when ground & (fall_count < 20);
  end state FallLeft

  state FallRight
    comb aaah = true;
    seq
      fall_count <= fall_count < 20 ? (fall_count + 1).trunc<5>() : fall_count;
    end seq
    -> Splat when ground & (fall_count >= 20);
    -> WalkRight when ground & (fall_count < 20);
  end state FallRight

  state DigLeft
    comb digging = true;
    seq
      fall_count <= 0;
    end seq
    -> FallLeft when ~ground;
  end state DigLeft

  state DigRight
    comb digging = true;
    seq
      fall_count <= 0;
    end seq
    -> FallRight when ~ground;
  end state DigRight

  state Splat
    seq
      fall_count <= 0;
    end seq
    -> Splat when ground;
    -> Splat when ~ground;
  end state Splat
end fsm TopModule
