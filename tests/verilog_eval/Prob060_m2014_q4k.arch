// VerilogEval Prob060: 4-stage shift register, active-low sync reset
module TopModule
  port clk: in Clock<SysDomain>;
  port resetn: in Bool;
  port in: in Bool;
  port out: out Bool;

  default seq on clk rising;

  reg sr: UInt<4> init 0 reset none;

  seq
    sr <= ~resetn ? 0 : ((sr << 1).trunc<4>() | in.zext<4>());
  end seq

  comb
    out = sr[3:3];
  end comb
end module TopModule
