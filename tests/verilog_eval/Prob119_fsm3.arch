fsm TopModule
  port clk: in Clock<SysDomain>;
  port areset: in Reset<Async>;
  port in: in Bool;
  port out: out Bool;

  state A, B, C, D;
  default state A;
  default
    comb out = false;
  end default

  state A transition to B when in;

  state B transition to C when ~in;

  state C
    transition to D when in;
    transition to A when ~in;
  end state C

  state D
    comb out = true;
    transition to B when in;
    transition to C when ~in;
  end state D
end fsm TopModule
