fsm TopModule
  port clk: in Clock<SysDomain>;
  port areset: in Reset<Async>;
  port in: in Bool;
  port out: out Bool;

  state [A, B, C, D]
  default state A;
  default
    comb out = false;
  end default

  state A -> B when in;

  state B -> C when ~in;

  state C
    -> D when in;
    -> A when ~in;
  end state C

  state D
    comb out = true;
    -> B when in;
    -> C when ~in;
  end state D
end fsm TopModule
