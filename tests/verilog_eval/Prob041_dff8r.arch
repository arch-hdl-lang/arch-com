domain SysDomain
end domain SysDomain

module TopModule
  port clk: in Clock<SysDomain>;
  port reset_sig: in Reset<Sync>;
  port d: in UInt<8>;
  port q: out UInt<8>;

  reg q_r: UInt<8> reset reset_sig=0;

  seq on clk rising
    q_r <= d;
  end seq

  comb
    q = q_r;
  end comb
end module TopModule
