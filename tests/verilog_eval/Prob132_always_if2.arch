module TopModule
  port cpu_overheated: in Bool;
  port shut_off_computer: out Bool;
  port arrived: in Bool;
  port gas_tank_empty: in Bool;
  port keep_driving: out Bool;
  comb
    if cpu_overheated
      shut_off_computer = 1;
    else
      shut_off_computer = 0;
    end if
    if ~arrived
      keep_driving = ~gas_tank_empty;
    else
      keep_driving = 0;
    end if
  end comb
end module TopModule
