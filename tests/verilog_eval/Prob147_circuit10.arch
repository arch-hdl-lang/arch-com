// VerilogEval Prob147: Sequential circuit from waveform
// next_state = (a & b) | (state & (a ^ b))
// q = a ^ b ^ state
domain SysDomain
end domain SysDomain

module TopModule
  port clk: in Clock<SysDomain>;
  port a: in Bool;
  port b: in Bool;
  port reg state: out Bool;
  port q: out Bool;

  seq on clk rising
    state <= (a & b) | (state & (a ^ b));
  end seq

  comb
    q = a ^ b ^ state;
  end comb
end module TopModule
