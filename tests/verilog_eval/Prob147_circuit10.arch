// VerilogEval Prob147: Sequential circuit from waveform
// next_state = (a & b) | (state & (a ^ b))
// q = a ^ b ^ state
module TopModule
  port clk: in Clock<SysDomain>;
  port a: in Bool;
  port b: in Bool;
  port reg state: out Bool;
  port q: out Bool;

  default seq on clk rising;

  seq
    state <= (a & b) | (state & (a ^ b));
  end seq

  comb
    q = a ^ b ^ state;
  end comb
end module TopModule
