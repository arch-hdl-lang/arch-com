module TopModule
  port clk: in Clock<SysDomain>;
  port areset: in Reset<Async>;
  port load: in Bool;
  port ena: in Bool;
  port data: in UInt<4>;
  port q: out pipe_reg<UInt<4>, 1> reset areset=>0;

  default seq on clk rising;

  seq
    if load
      q <= data;
    elsif ena
      q[3] <= 0;
      q[2] <= q[3];
      q[1] <= q[2];
      q[0] <= q[1];
    end if
  end seq
end module TopModule
