module TopModule
  port a: in UInt<8>;
  port b: in UInt<8>;
  port c: in UInt<8>;
  port d: in UInt<8>;
  port min: out UInt<8>;

  wire ab_min: UInt<8>;
  wire cd_min: UInt<8>;

  comb
    ab_min = a < b ? a : b;
    cd_min = c < d ? c : d;
    min = ab_min < cd_min ? ab_min : cd_min;
  end comb
end module TopModule
