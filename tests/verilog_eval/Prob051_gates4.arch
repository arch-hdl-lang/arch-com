module TopModule
  port in_sig: in UInt<4>;
  port out_and: out Bool;
  port out_or: out Bool;
  port out_xor: out Bool;
  comb
    out_and = in_sig[0] & in_sig[1] & in_sig[2] & in_sig[3];
    out_or = in_sig[0] | in_sig[1] | in_sig[2] | in_sig[3];
    out_xor = in_sig[0] ^ in_sig[1] ^ in_sig[2] ^ in_sig[3];
  end comb
end module TopModule
