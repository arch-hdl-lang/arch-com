// VerilogEval Prob156: Full timer FSM - detect 1101, shift 4-bit delay, count down, done+ack
domain SysDomain
end domain SysDomain

fsm TopModule
  port clk: in Clock<SysDomain>;
  port reset: in Reset<Sync>;
  port data: in Bool;
  port ack: in Bool;
  port count: out UInt<4>;
  port counting: out Bool;
  port done: out Bool;

  reg delay_r: UInt<4> reset reset=0;
  reg cnt_r: UInt<4> reset reset=0;
  reg sub_cnt: UInt<10> reset reset=0;

  state S, S1, S11, S110, B0, B1, B2, B3, Count_St, Done_St;
  default state S;

  default
    comb
      count = 0;
      counting = false;
      done = false;
    end comb
  end default

  state S
    transition to S1 when data;
  end state S

  state S1
    transition to S11 when data;
    transition to S when ~data;
  end state S1

  state S11
    transition to S110 when ~data;
  end state S11

  state S110
    transition to B0 when data;
    transition to S when ~data;
  end state S110

  state B0
    seq on clk rising
      delay_r[3] <= data;
    end seq
    transition to B1 when true;
  end state B0

  state B1
    seq on clk rising
      delay_r[2] <= data;
    end seq
    transition to B2 when true;
  end state B1

  state B2
    seq on clk rising
      delay_r[1] <= data;
    end seq
    transition to B3 when true;
  end state B2

  state B3
    seq on clk rising
      delay_r[0] <= data;
      cnt_r[3] <= delay_r[3];
      cnt_r[2] <= delay_r[2];
      cnt_r[1] <= delay_r[1];
      cnt_r[0] <= data;
      sub_cnt <= 0;
    end seq
    transition to Count_St when true;
  end state B3

  state Count_St
    comb
      counting = true;
      count = cnt_r;
    end comb
    seq on clk rising
      if (sub_cnt == 999) & (cnt_r == 0)
        sub_cnt <= sub_cnt;
        cnt_r <= cnt_r;
      elsif sub_cnt == 999
        sub_cnt <= 0;
        cnt_r <= (cnt_r - 1).trunc<4>();
      else
        sub_cnt <= (sub_cnt + 1).trunc<10>();
      end if
    end seq
    transition to Done_St when (sub_cnt == 999) & (cnt_r == 0);
  end state Count_St

  state Done_St
    comb
      done = true;
      count = cnt_r;
    end comb
    transition to S when ack;
  end state Done_St
end fsm TopModule
