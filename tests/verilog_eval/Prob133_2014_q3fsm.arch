// VerilogEval Prob133: FSM waits for s=1, then counts w over 3-cycle windows
domain SysDomain
end domain SysDomain

fsm TopModule
  port clk: in Clock<SysDomain>;
  port reset: in Reset<Sync>;
  port s: in Bool;
  port w: in Bool;
  port z: out Bool;

  reg cnt: UInt<2> reset reset=0;

  state A, B1, B2, B3, Out;
  default state A;

  state A
    comb
      z = false;
    end comb
    seq on clk rising
      cnt <= 0;
    end seq
    transition to B1 when s;
  end state A

  state B1
    comb
      z = false;
    end comb
    seq on clk rising
      if w
        cnt <= 1;
      else
        cnt <= 0;
      end if
    end seq
    transition to B2 when true;
  end state B1

  state B2
    comb
      z = false;
    end comb
    seq on clk rising
      if w
        cnt <= (cnt + 1).trunc<2>();
      end if
    end seq
    transition to B3 when true;
  end state B2

  state B3
    comb
      z = false;
    end comb
    seq on clk rising
      if w
        cnt <= (cnt + 1).trunc<2>();
      end if
    end seq
    transition to Out when true;
  end state B3

  state Out
    comb
      z = false;
      if cnt == 2
        z = true;
      end if
    end comb
    seq on clk rising
      if w
        cnt <= 1;
      else
        cnt <= 0;
      end if
    end seq
    transition to B2 when true;
  end state Out
end fsm TopModule
