// VerilogEval Prob133: FSM waits for s=1, then counts w over 3-cycle windows
domain SysDomain
end domain SysDomain

module TopModule
  port clk: in Clock<SysDomain>;
  port rst: in Reset<Sync>;
  port s_sig: in Bool;
  port w: in Bool;
  port z: out Bool;

  // States: 0=A (wait for s), 1=B1 (cycle 1 of 3), 2=B2 (cycle 2), 3=B3 (cycle 3), 4=output
  reg state_r: UInt<3> reset rst=0;
  reg count_r: UInt<2> reset rst=0;

  wire next_state: UInt<3>;
  wire next_count: UInt<2>;

  comb
    next_count = count_r;
    next_state = state_r;
    if state_r == 0
      // State A: wait for s
      next_count = 0;
      if s_sig
        next_state = 1;
      end if
    elsif state_r == 1
      // B1: first cycle
      if w
        next_count = 1;
      else
        next_count = 0;
      end if
      next_state = 2;
    elsif state_r == 2
      // B2: second cycle
      if w
        next_count = (count_r + 1).trunc<2>();
      end if
      next_state = 3;
    elsif state_r == 3
      // B3: third cycle
      if w
        next_count = (count_r + 1).trunc<2>();
      end if
      next_state = 4;
    elsif state_r == 4
      // Output cycle, then start next window
      if w
        next_count = 1;
      else
        next_count = 0;
      end if
      next_state = 2;
    else
      next_state = 0;
      next_count = 0;
    end if
  end comb

  seq on clk rising
    state_r <= next_state;
    count_r <= next_count;
  end seq

  comb
    if (state_r == 4) & (count_r == 2)
      z = true;
    else
      z = false;
    end if
  end comb
end module TopModule
