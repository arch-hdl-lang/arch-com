module TopModule
  port sel: in UInt<3>;
  port data0: in UInt<4>;
  port data1: in UInt<4>;
  port data2: in UInt<4>;
  port data3: in UInt<4>;
  port data4: in UInt<4>;
  port data5: in UInt<4>;
  port out: out UInt<4>;
  comb
    if sel == 0
      out = data0;
    elsif sel == 1
      out = data1;
    elsif sel == 2
      out = data2;
    elsif sel == 3
      out = data3;
    elsif sel == 4
      out = data4;
    elsif sel == 5
      out = data5;
    else
      out = 0;
    end if
  end comb
end module TopModule
