// VerilogEval Prob146: Serial receiver with data output
// Start bit (0), 8 data bits LSB-first, stop bit (1). Assert done when stop=1.
domain SysDomain
end domain SysDomain

fsm TopModule
  port clk: in Clock<SysDomain>;
  port reset: in Reset<Sync>;
  port in: in Bool;
  port out_byte: out UInt<8>;
  port done: out Bool;

  reg data_reg: UInt<8> reset reset=0;

  state Bit0, Bit1, Bit2, Bit3, Bit4, Bit5, Bit6, Bit7, Idle, Stop, Ok, Err;
  default state Idle;

  default
    comb
      out_byte = 0;
      done = false;
    end comb
  end default

  state Idle
    transition to Bit0 when ~in;
  end state Idle

  state Bit0
    seq on clk rising
      data_reg <= {in, data_reg[7:1]};
    end seq
    transition to Bit1 when true;
  end state Bit0

  state Bit1
    seq on clk rising
      data_reg <= {in, data_reg[7:1]};
    end seq
    transition to Bit2 when true;
  end state Bit1

  state Bit2
    seq on clk rising
      data_reg <= {in, data_reg[7:1]};
    end seq
    transition to Bit3 when true;
  end state Bit2

  state Bit3
    seq on clk rising
      data_reg <= {in, data_reg[7:1]};
    end seq
    transition to Bit4 when true;
  end state Bit3

  state Bit4
    seq on clk rising
      data_reg <= {in, data_reg[7:1]};
    end seq
    transition to Bit5 when true;
  end state Bit4

  state Bit5
    seq on clk rising
      data_reg <= {in, data_reg[7:1]};
    end seq
    transition to Bit6 when true;
  end state Bit5

  state Bit6
    seq on clk rising
      data_reg <= {in, data_reg[7:1]};
    end seq
    transition to Bit7 when true;
  end state Bit6

  state Bit7
    seq on clk rising
      data_reg <= {in, data_reg[7:1]};
    end seq
    transition to Stop when true;
  end state Bit7

  state Stop
    transition to Ok when in;
    transition to Err when ~in;
  end state Stop

  state Ok
    comb
      done = true;
      out_byte = data_reg;
    end comb
    transition to Idle when in;
    transition to Bit0 when ~in;
  end state Ok

  state Err
    transition to Idle when in;
  end state Err
end fsm TopModule
