// VerilogEval Prob146: Serial receiver with data output
// Start bit (0), 8 data bits LSB-first, stop bit (1). Assert done when stop=1.
fsm TopModule
  port clk: in Clock<SysDomain>;
  port reset: in Reset<Sync>;
  port in: in Bool;
  port out_byte: out UInt<8>;
  port done: out Bool;

  reg data_reg: UInt<8> reset reset=>0;

  state [Idle, Bit0, Bit1, Bit2, Bit3, Bit4, Bit5, Bit6, Bit7, Stop, Ok, Err]
  default state Idle;
  default seq on clk rising;
  default
    let out_byte = 0;
    let done = false;
  end default

  state Idle -> Bit0 when ~in;

  state Bit0
    seq
      data_reg <= {in, data_reg[7:1]};
    end seq
    -> Bit1 when true;
  end state Bit0

  state Bit1
    seq
      data_reg <= {in, data_reg[7:1]};
    end seq
    -> Bit2 when true;
  end state Bit1

  state Bit2
    seq
      data_reg <= {in, data_reg[7:1]};
    end seq
    -> Bit3 when true;
  end state Bit2

  state Bit3
    seq
      data_reg <= {in, data_reg[7:1]};
    end seq
    -> Bit4 when true;
  end state Bit3

  state Bit4
    seq
      data_reg <= {in, data_reg[7:1]};
    end seq
    -> Bit5 when true;
  end state Bit4

  state Bit5
    seq
      data_reg <= {in, data_reg[7:1]};
    end seq
    -> Bit6 when true;
  end state Bit5

  state Bit6
    seq
      data_reg <= {in, data_reg[7:1]};
    end seq
    -> Bit7 when true;
  end state Bit6

  state Bit7
    seq
      data_reg <= {in, data_reg[7:1]};
    end seq
    -> Stop when true;
  end state Bit7

  state Stop
    -> Ok when in;
    -> Err when ~in;
  end state Stop

  state Ok
    comb
      done = true;
      out_byte = data_reg;
    end comb
    -> Idle when in;
    -> Bit0 when ~in;
  end state Ok

  state Err -> Idle when in;
end fsm TopModule
