module TopModule
  port a: in UInt<5>;
  port b: in UInt<5>;
  port c: in UInt<5>;
  port d: in UInt<5>;
  port e: in UInt<5>;
  port f: in UInt<5>;
  port w: out UInt<8>;
  port x: out UInt<8>;
  port y: out UInt<8>;
  port z: out UInt<8>;

  let cat: UInt<32> = {a, b, c, d, e, f, 2'b11};

  comb
    w = cat[31:24];
    x = cat[23:16];
    y = cat[15:8];
    z = cat[7:0];
  end comb
end module TopModule
