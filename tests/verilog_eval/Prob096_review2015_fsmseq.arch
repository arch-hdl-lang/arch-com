// VerilogEval Prob096: Detect 1101 sequence, assert start_shifting forever
fsm TopModule
  port clk: in Clock<SysDomain>;
  port reset: in Reset<Sync>;
  port data: in Bool;
  port start_shifting: out Bool;

  state [S, S1, S11, S110, Done]
  default state S;
  default
    comb start_shifting = false;
  end default

  state S -> S1 when data;

  state S1
    -> S11 when data;
    -> S when ~data;
  end state S1

  state S11
    -> S11 when data;
    -> S110 when ~data;
  end state S11

  state S110
    -> Done when data;
    -> S when ~data;
  end state S110

  state Done
    comb start_shifting = true;
    -> Done when true;
  end state Done

end fsm TopModule
