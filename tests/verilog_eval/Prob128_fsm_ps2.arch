// VerilogEval Prob128: PS/2 mouse 3-byte message boundary detection
fsm TopModule
  port clk: in Clock<SysDomain>;
  port reset: in Reset<Sync>;
  port in: in UInt<8>;
  port done: out Bool;

  state [Byte1, Byte2, Byte3, DoneS]
  default state Byte1;
  default
    let done = false;
  end default

  state Byte1 -> Byte2 when in[3];

  state Byte2 -> Byte3 when true;

  state Byte3 -> DoneS when true;

  state DoneS
    let done = true;
    -> Byte2 when in[3];
    -> Byte1 when ~in[3];
  end state DoneS

end fsm TopModule
