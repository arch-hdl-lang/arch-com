// VerilogEval Prob154: PS/2 3-byte message FSM with data output
// Find byte with in[3]=1, collect 3 bytes, assert done
fsm TopModule
  port clk: in Clock<SysDomain>;
  port reset: in Reset<Sync>;
  port in: in UInt<8>;
  port out_bytes: out UInt<24>;
  port done: out Bool;

  reg out_r: UInt<24> reset reset=>0;

  state Find, Got1, Got2, Done_St;
  default state Find;
  default seq on clk rising;
  default
    comb out_bytes = 0;
    comb done = false;
  end default

  state Find
    seq out_r <= {out_r[15:0], in};
    transition to Got1 when in[3];
  end state Find

  state Got1
    seq out_r <= {out_r[15:0], in};
    transition to Got2 when true;
  end state Got1

  state Got2
    seq out_r <= {out_r[15:0], in};
    transition to Done_St when true;
  end state Got2

  state Done_St
    comb
      done = true;
      out_bytes = out_r;
    end comb
    seq out_r <= {out_r[15:0], in};
    transition to Got1 when in[3];
    transition to Find when ~in[3];
  end state Done_St
end fsm TopModule
