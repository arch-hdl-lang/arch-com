// VerilogEval Prob154: PS/2 3-byte message FSM with data output
// Find byte with in[3]=1, collect 3 bytes, assert done
domain SysDomain
end domain SysDomain

fsm TopModule
  port clk: in Clock<SysDomain>;
  port reset: in Reset<Sync>;
  port in: in UInt<8>;
  port out_bytes: out UInt<24> default 0;
  port done: out Bool default false;

  reg out_r: UInt<24> reset reset=0;

  state Find, Got1, Got2, Done_St;
  default state Find;

  state Find
    seq on clk rising
      out_r <= {out_r[15:0], in};
    end seq
    transition to Got1 when in[3];
  end state Find

  state Got1
    seq on clk rising
      out_r <= {out_r[15:0], in};
    end seq
    transition to Got2 when true;
  end state Got1

  state Got2
    seq on clk rising
      out_r <= {out_r[15:0], in};
    end seq
    transition to Done_St when true;
  end state Got2

  state Done_St
    comb
      done = true;
      out_bytes = out_r;
    end comb
    seq on clk rising
      out_r <= {out_r[15:0], in};
    end seq
    transition to Got1 when in[3];
    transition to Find when ~in[3];
  end state Done_St
end fsm TopModule
