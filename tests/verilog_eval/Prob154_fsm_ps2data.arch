// VerilogEval Prob154: PS/2 3-byte message FSM with data output
// Find byte with in[3]=1, collect 3 bytes, assert done
domain SysDomain
end domain SysDomain

module TopModule
  port clk: in Clock<SysDomain>;
  port rst: in Reset<Sync>;
  port in_sig: in UInt<8>;
  port out_bytes: out UInt<24>;
  port done: out Bool;

  reg state_reg: UInt<2> reset rst=0;
  // 24-bit shift register: always shift in new byte
  reg out_r: UInt<24> reset rst=0;

  // States: 0=FIND, 1=GOT1, 2=GOT2, 3=DONE
  // Always shift in: out_r <= {out_r[15:0], in}
  seq on clk rising
    for i in 0..15
      out_r[i + 8] <= out_r[i];
    end for
    for i in 0..7
      out_r[i] <= in_sig[i];
    end for

    if state_reg == 0
      if in_sig[3]
        state_reg <= 1;
      end if
    elsif state_reg == 1
      state_reg <= 2;
    elsif state_reg == 2
      state_reg <= 3;
    else
      if in_sig[3]
        state_reg <= 1;
      else
        state_reg <= 0;
      end if
    end if
  end seq

  comb
    done = (state_reg == 3);
    // Output shift register when done, else 0
    if state_reg == 3
      for i in 0..23
        out_bytes[i] = out_r[i];
      end for
    else
      for i in 0..23
        out_bytes[i] = false;
      end for
    end if
  end comb
end module TopModule
