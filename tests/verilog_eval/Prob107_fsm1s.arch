fsm TopModule
  port clk: in Clock<SysDomain>;
  port reset: in Reset<Sync>;
  port in: in Bool;
  port out: out Bool;

  state [A, B]
  default state B;

  state A
    comb out = false;
    -> B when ~in;
  end state A

  state B
    comb out = true;
    -> A when ~in;
  end state B
end fsm TopModule
