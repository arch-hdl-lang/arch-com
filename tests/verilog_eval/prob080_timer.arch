// VerilogEval Prob080: Down counter timer
module TopModule
  port clk: in Clock<SysDomain>;
  port load: in Bool;
  port data: in UInt<10>;
  port tc: out Bool;

  default seq on clk rising;

  reg count_val: UInt<10> init 0 reset none;

  seq
    if load == 1
      count_val <= data;
    elsif count_val != 0
      count_val <= (count_val - 1).trunc<10>();
    end if
  end seq

  comb
    tc = (count_val == 0);
  end comb
end module TopModule
