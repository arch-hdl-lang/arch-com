domain SysDomain
end domain SysDomain

module TopModule
  port clk: in Clock<SysDomain>;
  port enable: in Bool;
  port s_sig: in Bool;
  port a_sig: in Bool;
  port b_sig: in Bool;
  port c_sig: in Bool;
  port z_sig: out Bool;

  reg sr: UInt<8>;

  seq on clk rising
    if enable
      sr[0] <= s_sig;
      for i in 1..7
        sr[i] <= sr[i - 1];
      end for
    end if
  end seq

  wire sel: UInt<3>;

  comb
    sel[2] = a_sig;
    sel[1] = b_sig;
    sel[0] = c_sig;
    z_sig = sr[sel];
  end comb
end module TopModule
