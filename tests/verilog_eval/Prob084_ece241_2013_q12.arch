domain SysDomain
end domain SysDomain

module TopModule
  port clk: in Clock<SysDomain>;
  port enable: in Bool;
  port S: in Bool;
  port A: in Bool;
  port B: in Bool;
  port C: in Bool;
  port Z: out Bool;

  reg sr: UInt<8>;

  seq on clk rising
    if enable
      sr[0] <= S;
      for i in 1..7
        sr[i] <= sr[i - 1];
      end for
    end if
  end seq

  let sel: UInt<3> = {A, B, C};

  comb
    Z = sr[sel];
  end comb
end module TopModule
