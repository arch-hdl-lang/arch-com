// VerilogEval Prob150: One-hot FSM combinational logic
// state[9:0]: S=0, S1=1, S11=2, S110=3, B0=4, B1=5, B2=6, B3=7, Count=8, Wait=9
module TopModule
  port d: in Bool;
  port done_counting: in Bool;
  port ack: in Bool;
  port state: in UInt<10>;
  port B3_next: out Bool;
  port S_next: out Bool;
  port S1_next: out Bool;
  port Count_next: out Bool;
  port Wait_next: out Bool;
  port done: out Bool;
  port counting: out Bool;
  port shift_ena: out Bool;

  comb
    S_next = (state[0] & ~d) | (state[1] & ~d) | (state[3] & ~d) | (state[9] & ack);
    S1_next = state[0] & d;
    B3_next = state[6];
    Count_next = state[7] | (state[8] & ~done_counting);
    Wait_next = (state[8] & done_counting) | (state[9] & ~ack);
    shift_ena = state[4] | state[5] | state[6] | state[7];
    counting = state[8];
    done = state[9];
  end comb
end module TopModule
