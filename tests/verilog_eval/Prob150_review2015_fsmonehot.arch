// VerilogEval Prob150: One-hot FSM combinational logic
// state[9:0]: S=0, S1=1, S11=2, S110=3, B0=4, B1=5, B2=6, B3=7, Count=8, Wait=9
module TopModule
  port d: in Bool;
  port done_counting: in Bool;
  port ack: in Bool;
  port state_sig: in UInt<10>;
  port b3_next: out Bool;
  port s_next: out Bool;
  port s1_next: out Bool;
  port count_next: out Bool;
  port wait_next: out Bool;
  port done: out Bool;
  port counting: out Bool;
  port shift_ena: out Bool;

  comb
    s_next = (state_sig[0] & ~d) | (state_sig[1] & ~d) | (state_sig[3] & ~d) | (state_sig[9] & ack);
    s1_next = state_sig[0] & d;
    b3_next = state_sig[6];
    count_next = state_sig[7] | (state_sig[8] & ~done_counting);
    wait_next = (state_sig[8] & done_counting) | (state_sig[9] & ~ack);
    shift_ena = state_sig[4] | state_sig[5] | state_sig[6] | state_sig[7];
    counting = state_sig[8];
    done = state_sig[9];
  end comb
end module TopModule
