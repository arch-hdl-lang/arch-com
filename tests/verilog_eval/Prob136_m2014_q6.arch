fsm TopModule
  port clk: in Clock<SysDomain>;
  port reset: in Reset<Sync>;
  port w: in Bool;
  port z: out Bool;

  state A, B, C, D, E, F;
  default state A;
  default
    comb z = false;
  end default

  state A transition to B when ~w;

  state B
    transition to C when ~w;
    transition to D when w;
  end state B

  state C
    transition to E when ~w;
    transition to D when w;
  end state C

  state D
    transition to F when ~w;
    transition to A when w;
  end state D

  state E
    comb z = true;
    transition to D when w;
  end state E

  state F
    comb z = true;
    transition to C when ~w;
    transition to D when w;
  end state F
end fsm TopModule
