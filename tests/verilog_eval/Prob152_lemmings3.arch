// VerilogEval Prob152: Lemmings walk/fall/dig FSM with async reset
fsm TopModule
  port clk: in Clock<SysDomain>;
  port areset: in Reset<Async>;
  port bump_left: in Bool;
  port bump_right: in Bool;
  port ground: in Bool;
  port dig: in Bool;
  port walk_left: out Bool;
  port walk_right: out Bool;
  port aaah: out Bool;
  port digging: out Bool;

  state [WalkLeft, WalkRight, FallLeft, FallRight, DigLeft, DigRight]
  default state WalkLeft;
  default
    let walk_left = false;
    let walk_right = false;
    let aaah = false;
    let digging = false;
  end default

  state WalkLeft
    let walk_left = true;
    -> FallLeft when ~ground;
    -> DigLeft when ground & dig;
    -> WalkRight when ground & ~dig & bump_left;
  end state WalkLeft

  state WalkRight
    let walk_right = true;
    -> FallRight when ~ground;
    -> DigRight when ground & dig;
    -> WalkLeft when ground & ~dig & bump_right;
  end state WalkRight

  state FallLeft
    let aaah = true;
    -> WalkLeft when ground;
  end state FallLeft

  state FallRight
    let aaah = true;
    -> WalkRight when ground;
  end state FallRight

  state DigLeft
    let digging = true;
    -> FallLeft when ~ground;
  end state DigLeft

  state DigRight
    let digging = true;
    -> FallRight when ~ground;
  end state DigRight
end fsm TopModule
