// VerilogEval Prob152: Lemmings walk/fall/dig FSM with async reset
domain SysDomain
end domain SysDomain

fsm TopModule
  port clk: in Clock<SysDomain>;
  port areset: in Reset<Async>;
  port bump_left: in Bool;
  port bump_right: in Bool;
  port ground: in Bool;
  port dig: in Bool;
  port walk_left: out Bool default false;
  port walk_right: out Bool default false;
  port aaah: out Bool default false;
  port digging: out Bool default false;

  state WalkLeft, WalkRight, FallLeft, FallRight, DigLeft, DigRight;
  default state WalkLeft;

  state WalkLeft
    comb
      walk_left = true;
    end comb
    transition to FallLeft when ~ground;
    transition to DigLeft when ground & dig;
    transition to WalkRight when ground & ~dig & bump_left;
  end state WalkLeft

  state WalkRight
    comb
      walk_right = true;
    end comb
    transition to FallRight when ~ground;
    transition to DigRight when ground & dig;
    transition to WalkLeft when ground & ~dig & bump_right;
  end state WalkRight

  state FallLeft
    comb
      aaah = true;
    end comb
    transition to WalkLeft when ground;
  end state FallLeft

  state FallRight
    comb
      aaah = true;
    end comb
    transition to WalkRight when ground;
  end state FallRight

  state DigLeft
    comb
      digging = true;
    end comb
    transition to FallLeft when ~ground;
  end state DigLeft

  state DigRight
    comb
      digging = true;
    end comb
    transition to FallRight when ~ground;
  end state DigRight
end fsm TopModule
