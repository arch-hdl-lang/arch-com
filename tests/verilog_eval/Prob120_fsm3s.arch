// VerilogEval Prob120: 4-state Moore FSM, sync reset
fsm TopModule
  port clk: in Clock<SysDomain>;
  port reset: in Reset<Sync>;
  port in: in Bool;
  port out: out Bool;

  state [A, B, C, D]
  default state A;
  default
    comb out = false;
  end default

  state A -> B when in;

  state B
    -> B when in;
    -> C when ~in;
  end state B

  state C
    -> D when in;
    -> A when ~in;
  end state C

  state D
    comb out = true;
    -> B when in;
    -> C when ~in;
  end state D

end fsm TopModule
