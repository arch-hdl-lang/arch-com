// VerilogEval Prob045: 8-bit any-edge detect
module TopModule
  port clk: in Clock<SysDomain>;
  port in: in UInt<8>;
  port anyedge: out pipe_reg<UInt<8>, 1> init 0 reset none;

  default seq on clk rising;

  reg d_last: UInt<8> init 0 reset none;

  seq
    d_last <= in;
    anyedge <= in ^ d_last;
  end seq
end module TopModule
