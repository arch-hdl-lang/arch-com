// VerilogEval Prob139: Motor controller FSM, active-low sync reset (resetn)
// States: A(reset), SetF, X1, X0, X01, SetG1, SetG2, GoodG, BadG
fsm TopModule
  port clk: in Clock<SysDomain>;
  port resetn: in Reset<Sync, Low>;
  port x: in Bool;
  port y: in Bool;
  port f: out Bool;
  port g: out Bool;

  state [A, SetF, X1, X0, X01, SetG1, SetG2, GoodG, BadG]
  default state A;
  default
    comb f = false;
    comb g = false;
  end default

  state A -> SetF when true;

  state SetF
    comb f = true;
    -> X1 when true;
  end state SetF

  state X1 -> X0 when x;

  state X0 -> X01 when ~x;

  state X01
    -> SetG1 when x;
    -> X1 when ~x;
  end state X01

  state SetG1
    comb g = true;
    -> GoodG when y;
    -> SetG2 when ~y;
  end state SetG1

  state SetG2
    comb g = true;
    -> GoodG when y;
    -> BadG when ~y;
  end state SetG2

  state GoodG
    comb g = true;
    -> GoodG when true;
  end state GoodG

  state BadG -> BadG when true;
end fsm TopModule
