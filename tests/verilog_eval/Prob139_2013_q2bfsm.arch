// VerilogEval Prob139: Motor controller FSM, active-low sync reset (resetn)
// States: A(reset), SetF, X1, X0, X01, SetG1, SetG2, GoodG, BadG
domain SysDomain
end domain SysDomain

fsm TopModule
  port clk: in Clock<SysDomain>;
  port resetn: in Reset<Sync, Low>;
  port x: in Bool;
  port y: in Bool;
  port f: out Bool default false;
  port g: out Bool default false;

  state A, SetF, X1, X0, X01, SetG1, SetG2, GoodG, BadG;
  default state A;

  state A
    transition to SetF when true;
  end state A

  state SetF
    comb
      f = true;
    end comb
    transition to X1 when true;
  end state SetF

  state X1
    transition to X0 when x;
  end state X1

  state X0
    transition to X01 when ~x;
  end state X0

  state X01
    transition to SetG1 when x;
    transition to X1 when ~x;
  end state X01

  state SetG1
    comb
      g = true;
    end comb
    transition to GoodG when y;
    transition to SetG2 when ~y;
  end state SetG1

  state SetG2
    comb
      g = true;
    end comb
    transition to GoodG when y;
    transition to BadG when ~y;
  end state SetG2

  state GoodG
    comb
      g = true;
    end comb
    transition to GoodG when true;
  end state GoodG

  state BadG
    transition to BadG when true;
  end state BadG
end fsm TopModule
