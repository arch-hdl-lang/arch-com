module TopModule
  port do_sub: in Bool;
  port a: in UInt<8>;
  port b: in UInt<8>;
  port out: out UInt<8>;
  port result_is_zero: out Bool;
  comb
    if do_sub
      out = (a - b).trunc<8>();
    else
      out = (a + b).trunc<8>();
    end if
    result_is_zero = (out == 0);
  end comb
end module TopModule
