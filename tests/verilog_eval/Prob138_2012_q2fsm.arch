// VerilogEval Prob138: 6-state FSM, input w, output z
fsm TopModule
  port clk: in Clock<SysDomain>;
  port reset: in Reset<Sync>;
  port w: in Bool;
  port z: out Bool;

  state [A, B, C, D, E, F]
  default state A;
  default
    comb z = false;
  end default

  state A -> B when w;

  state B
    -> C when w;
    -> D when ~w;
  end state B

  state C
    -> E when w;
    -> D when ~w;
  end state C

  state D
    -> F when w;
    -> A when ~w;
  end state D

  state E
    comb z = true;
    -> E when w;
    -> D when ~w;
  end state E

  state F
    comb z = true;
    -> C when w;
    -> D when ~w;
  end state F

end fsm TopModule
