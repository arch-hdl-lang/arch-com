// VerilogEval Prob142: Lemmings walk/fall FSM with async reset
fsm TopModule
  port clk: in Clock<SysDomain>;
  port areset: in Reset<Async>;
  port bump_left: in Bool;
  port bump_right: in Bool;
  port ground: in Bool;
  port walk_left: out Bool;
  port walk_right: out Bool;
  port aaah: out Bool;

  state WalkLeft, WalkRight, FallLeft, FallRight;
  default state WalkLeft;
  default
    comb walk_left = false;
    comb walk_right = false;
    comb aaah = false;
  end default

  state WalkLeft
    comb walk_left = true;
    transition to FallLeft when ~ground;
    transition to WalkRight when ground & bump_left;
  end state WalkLeft

  state WalkRight
    comb walk_right = true;
    transition to FallRight when ~ground;
    transition to WalkLeft when ground & bump_right;
  end state WalkRight

  state FallLeft
    comb aaah = true;
    transition to WalkLeft when ground;
  end state FallLeft

  state FallRight
    comb aaah = true;
    transition to WalkRight when ground;
  end state FallRight
end fsm TopModule
