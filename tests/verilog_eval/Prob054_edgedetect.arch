// VerilogEval Prob054: 8-bit positive edge detection (registered output)
domain SysDomain
end domain SysDomain

module TopModule
  port clk: in Clock<SysDomain>;
  port in_sig: in UInt<8>;
  port pedge: out UInt<8>;

  reg prev: UInt<8>;
  reg pedge_r: UInt<8>;

  seq on clk rising
    prev <= in_sig;
    pedge_r <= in_sig & (~prev);
  end seq

  comb
    pedge = pedge_r;
  end comb
end module TopModule
