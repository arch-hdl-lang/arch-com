// VerilogEval Prob054: 8-bit positive edge detection (registered output)
module TopModule
  port clk: in Clock<SysDomain>;
  port in: in UInt<8>;
  port reg pedge: out UInt<8>;

  default seq on clk rising;

  reg prev: UInt<8>;

  seq
    prev <= in;
    pedge <= in & (~prev);
  end seq
end module TopModule
