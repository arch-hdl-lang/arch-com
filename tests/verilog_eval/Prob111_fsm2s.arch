fsm TopModule
  port clk: in Clock<SysDomain>;
  port reset: in Reset<Sync>;
  port j: in Bool;
  port k: in Bool;
  port out: out Bool;

  state OFF, ON;
  default state OFF;

  state OFF
    comb out = false;
    transition to ON when j;
  end state OFF

  state ON
    comb out = true;
    transition to OFF when k;
  end state ON
end fsm TopModule
