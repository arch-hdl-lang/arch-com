domain SysDomain
end domain SysDomain

fsm TopModule
  port clk: in Clock<SysDomain>;
  port reset: in Reset<Sync>;
  port j: in Bool;
  port k: in Bool;
  port out: out Bool default false;

  state OFF, ON;
  default state OFF;

  state OFF
    transition to ON when j;
  end state OFF

  state ON
    comb
      out = true;
    end comb
    transition to OFF when k;
  end state ON
end fsm TopModule
