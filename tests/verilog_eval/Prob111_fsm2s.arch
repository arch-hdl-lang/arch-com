domain SysDomain
end domain SysDomain

module TopModule
  port clk: in Clock<SysDomain>;
  port reset: in Reset<Sync>;
  port j: in Bool;
  port k: in Bool;
  port out: out Bool;

  reg st: Bool reset reset=0;

  seq on clk rising
    if ~st
      if j
        st <= 1;
      end if
    else
      if k
        st <= 0;
      end if
    end if
  end seq

  comb
    out = st;
  end comb
end module TopModule
