module TopModule
  port a: in UInt<16>;
  port b: in UInt<16>;
  port c: in UInt<16>;
  port d: in UInt<16>;
  port e: in UInt<16>;
  port f: in UInt<16>;
  port g: in UInt<16>;
  port h: in UInt<16>;
  port i: in UInt<16>;
  port sel: in UInt<4>;
  port out: out UInt<16>;
  comb
    if sel == 0
      out = a;
    elsif sel == 1
      out = b;
    elsif sel == 2
      out = c;
    elsif sel == 3
      out = d;
    elsif sel == 4
      out = e;
    elsif sel == 5
      out = f;
    elsif sel == 6
      out = g;
    elsif sel == 7
      out = h;
    elsif sel == 8
      out = i;
    else
      out = 0xffff;
    end if
  end comb
end module TopModule
