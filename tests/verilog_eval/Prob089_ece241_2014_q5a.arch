domain SysDomain
end domain SysDomain

fsm TopModule
  port clk: in Clock<SysDomain>;
  port areset: in Reset<Async>;
  port x: in Bool;
  port z: out Bool default false;

  state A, B, C, D;
  default state A;

  state A
    transition to B when x;
  end state A

  state B
    comb
      z = true;
    end comb
    transition to D when x;
    transition to C when ~x;
  end state B

  state C
    comb
      z = true;
    end comb
    transition to D when x;
  end state C

  state D
    transition to C when ~x;
  end state D
end fsm TopModule
