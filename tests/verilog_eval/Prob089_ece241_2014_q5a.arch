domain SysDomain
end domain SysDomain

module TopModule
  port clk: in Clock<SysDomain>;
  port areset: in Reset<Async>;
  port x: in Bool;
  port z: out Bool;

  reg st: UInt<2> reset areset=0;

  seq on clk rising
    if st == 0
      if x
        st <= 1;
      end if
    elsif st == 1
      if x
        st <= 3;
      else
        st <= 2;
      end if
    elsif st == 2
      if x
        st <= 3;
      end if
    elsif st == 3
      if ~x
        st <= 2;
      end if
    end if
  end seq

  comb
    if (st == 1) | (st == 2)
      z = 1;
    else
      z = 0;
    end if
  end comb
end module TopModule
