fsm TopModule
  port clk: in Clock<SysDomain>;
  port areset: in Reset<Async>;
  port x: in Bool;
  port z: out Bool;

  state A, B, C, D;
  default state A;
  default
    comb z = false;
  end default

  state A transition to B when x;

  state B
    comb z = true;
    transition to D when x;
    transition to C when ~x;
  end state B

  state C
    comb z = true;
    transition to D when x;
  end state C

  state D transition to C when ~x;
end fsm TopModule
