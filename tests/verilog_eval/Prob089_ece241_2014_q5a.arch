fsm TopModule
  port clk: in Clock<SysDomain>;
  port areset: in Reset<Async>;
  port x: in Bool;
  port z: out Bool;

  state [A, B, C, D]
  default state A;
  default
    comb z = false;
  end default

  state A -> B when x;

  state B
    comb z = true;
    -> D when x;
    -> C when ~x;
  end state B

  state C
    comb z = true;
    -> D when x;
  end state C

  state D -> C when ~x;
end fsm TopModule
