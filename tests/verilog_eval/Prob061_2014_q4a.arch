// VerilogEval Prob061: Shift register stage with load
domain SysDomain
end domain SysDomain

module TopModule
  port clk: in Clock<SysDomain>;
  port w: in Bool;
  port R: in Bool;
  port E: in Bool;
  port L: in Bool;
  port reg Q: out Bool;

  seq on clk rising
    if L
      Q <= R;
    elsif E
      Q <= w;
    end if
  end seq
end module TopModule
