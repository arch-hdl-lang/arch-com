// VerilogEval Prob061: Shift register stage with load
domain SysDomain
end domain SysDomain

module TopModule
  port clk: in Clock<SysDomain>;
  port w: in Bool;
  port R: in Bool;
  port E: in Bool;
  port L: in Bool;
  port Q: out Bool;

  reg q_r: Bool;

  seq on clk rising
    if L
      q_r <= R;
    elsif E
      q_r <= w;
    end if
  end seq

  comb
    Q = q_r;
  end comb
end module TopModule
