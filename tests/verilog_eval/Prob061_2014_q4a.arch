// VerilogEval Prob061: Shift register stage with load
module TopModule
  port clk: in Clock<SysDomain>;
  port w: in Bool;
  port R: in Bool;
  port E: in Bool;
  port L: in Bool;
  port Q: out pipe_reg<Bool, 1>;

  default seq on clk rising;

  seq
    if L
      Q <= R;
    elsif E
      Q <= w;
    end if
  end seq
end module TopModule
