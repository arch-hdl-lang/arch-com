// VerilogEval Prob040: Decade counter (0-9), sync reset
domain SysDomain
end domain SysDomain

module TopModule
  port clk: in Clock<SysDomain>;
  port rst: in Reset<Sync>;
  port q: out UInt<4>;

  reg count_r: UInt<4> init 0 reset rst=0;

  seq on clk rising
    if count_r == 9
      count_r <= 0;
    else
      count_r <= (count_r + 1).trunc<4>();
    end if
  end seq

  comb
    q = count_r;
  end comb
end module TopModule
