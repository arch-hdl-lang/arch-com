// VerilogEval Prob044: Bitwise OR, logical OR, NOT of 3-bit vectors
module TopModule
  port a: in UInt<3>;
  port b: in UInt<3>;
  port out_or_bitwise: out UInt<3>;
  port out_or_logical: out Bool;
  port out_not: out UInt<6>;

  comb
    out_or_bitwise = a | b;
    out_or_logical = (a[0] | a[1] | a[2]) | (b[0] | b[1] | b[2]);
    out_not = {~b, ~a};
  end comb
end module TopModule
