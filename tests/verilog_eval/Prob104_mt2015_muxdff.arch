domain SysDomain
end domain SysDomain

module TopModule
  port clk: in Clock<SysDomain>;
  port l_sig: in Bool;
  port q_in: in Bool;
  port r_in: in Bool;
  port q_sig: out Bool;

  reg q_r: Bool;

  seq on clk rising
    if l_sig
      q_r <= r_in;
    else
      q_r <= q_in;
    end if
  end seq

  comb
    q_sig = q_r;
  end comb
end module TopModule
