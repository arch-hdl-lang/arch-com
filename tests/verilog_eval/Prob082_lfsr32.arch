module TopModule
  port clk: in Clock<SysDomain>;
  port reset: in Reset<Sync>;
  port reg q: out UInt<32> reset reset=1;

  default seq on clk rising;

  wire q_next: UInt<32>;

  comb
    q_next[31] = q[0];
    for i in 1..31
      q_next[i] = q[i + 1];
    end for
    q_next[21] = q[22] ^ q[0];
    q_next[1] = q[2] ^ q[0];
    q_next[0] = q[1] ^ q[0];
  end comb

  seq q <= q_next;
end module TopModule
