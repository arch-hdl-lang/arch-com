fsm TopModule
  port clk: in Clock<SysDomain>;
  port areset: in Reset<Async>;
  port in: in Bool;
  port out: out Bool;

  state [A, B]
  default state B;

  state A
    let out = false;
    -> B when ~in;
  end state A

  state B
    let out = true;
    -> A when ~in;
  end state B
end fsm TopModule
