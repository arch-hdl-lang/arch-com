domain SysDomain
end domain SysDomain

module TopModule
  port clk: in Clock<SysDomain>;
  port areset: in Reset<Async>;
  port in: in Bool;
  port out: out Bool;

  reg st: Bool reset areset=1;

  seq on clk rising
    if st
      if ~in
        st <= 0;
      end if
    else
      if ~in
        st <= 1;
      end if
    end if
  end seq

  comb
    out = st;
  end comb
end module TopModule
