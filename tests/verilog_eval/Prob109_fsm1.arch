fsm TopModule
  port clk: in Clock<SysDomain>;
  port areset: in Reset<Async>;
  port in: in Bool;
  port out: out Bool;

  state A, B;
  default state B;

  state A
    comb out = false;
    transition to B when ~in;
  end state A

  state B
    comb out = true;
    transition to A when ~in;
  end state B
end fsm TopModule
