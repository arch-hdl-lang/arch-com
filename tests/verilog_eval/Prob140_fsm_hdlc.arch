// VerilogEval Prob140: HDLC framing FSM - disc, flag, err detection
fsm TopModule
  port clk: in Clock<SysDomain>;
  port reset: in Reset<Sync>;
  port in: in Bool;
  port disc: out Bool;
  port flag: out Bool;
  port err: out Bool;

  state [S0, S1, S2, S3, S4, S5, S6, Serr, Sdisc, Sflag]
  default state S0;
  default
    let disc = false;
    let flag = false;
    let err = false;
  end default

  state S0 -> S1 when in;

  state S1
    -> S2 when in;
    -> S0 when ~in;
  end state S1

  state S2
    -> S3 when in;
    -> S0 when ~in;
  end state S2

  state S3
    -> S4 when in;
    -> S0 when ~in;
  end state S3

  state S4
    -> S5 when in;
    -> S0 when ~in;
  end state S4

  state S5
    -> S6 when in;
    -> Sdisc when ~in;
  end state S5

  state S6
    -> Serr when in;
    -> Sflag when ~in;
  end state S6

  state Serr
    let err = true;
    -> Serr when in;
    -> S0 when ~in;
  end state Serr

  state Sdisc
    let disc = true;
    -> S1 when in;
    -> S0 when ~in;
  end state Sdisc

  state Sflag
    let flag = true;
    -> S1 when in;
    -> S0 when ~in;
  end state Sflag

end fsm TopModule
