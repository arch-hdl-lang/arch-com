module TopModule
  port clk: in Clock<SysDomain>;
  port reset: in Reset<Sync>;
  port ena: out UInt<3>;
  port q: out UInt<16>;

  default seq on clk rising;

  reg ones: UInt<4> reset reset=0;
  reg tens: UInt<4> reset reset=0;
  reg hund: UInt<4> reset reset=0;
  reg thou: UInt<4> reset reset=0;

  seq
    if ones == 9
      ones <= 0;
      if tens == 9
        tens <= 0;
        if hund == 9
          hund <= 0;
          thou <= thou == 9 ? 0 : (thou + 1).trunc<4>();
        else
          hund <= (hund + 1).trunc<4>();
        end if
      else
        tens <= (tens + 1).trunc<4>();
      end if
    else
      ones <= (ones + 1).trunc<4>();
    end if
  end seq

  comb
    q = {thou, hund, tens, ones};
    ena[0] = (ones == 9);
    ena[1] = (ones == 9) & (tens == 9);
    ena[2] = (ones == 9) & (tens == 9) & (hund == 9);
  end comb
end module TopModule
