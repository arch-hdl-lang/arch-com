// VerilogEval Prob079: One-hot FSM combinational logic
module TopModule
  port in: in Bool;
  port state: in UInt<4>;
  port next_state: out UInt<4>;
  port out: out Bool;

  wire ns0: Bool;
  wire ns1: Bool;
  wire ns2: Bool;
  wire ns3: Bool;

  comb
    ns0 = (state[0] & ~in) | (state[2] & ~in);
    ns1 = (state[0] & in) | (state[1] & in) | (state[3] & in);
    ns2 = (state[1] & ~in) | (state[3] & ~in);
    ns3 = state[2] & in;
    next_state = {ns3, ns2, ns1, ns0};
    out = state[3];
  end comb
end module TopModule
