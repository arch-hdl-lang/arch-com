domain SysDomain
end domain SysDomain

fsm TopModule
  port clk: in Clock<SysDomain>;
  port areset: in Reset<Async>;
  port x: in Bool;
  port z: out Bool;

  state A, B;
  default state A;

  state A
    comb
      z = x;
    end comb
    transition to B when x;
  end state A

  state B
    comb
      z = ~x;
    end comb
    transition to B when true;
  end state B
end fsm TopModule
