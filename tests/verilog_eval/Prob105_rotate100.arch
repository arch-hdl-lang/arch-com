domain SysDomain
end domain SysDomain

module TopModule
  port clk: in Clock<SysDomain>;
  port load: in Bool;
  port ena: in UInt<2>;
  port data: in UInt<100>;
  port reg q: out UInt<100>;

  seq on clk rising
    if load
      q <= data;
    elsif ena == 1
      q <= {q[0], q[99:1]};
    elsif ena == 2
      q <= {q[98:0], q[99]};
    end if
  end seq
end module TopModule
