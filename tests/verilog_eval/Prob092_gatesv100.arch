module TopModule
  port in_sig: in UInt<100>;
  port out_both: out UInt<100>;
  port out_any: out UInt<100>;
  port out_different: out UInt<100>;
  comb
    for i in 0..98
      out_both[i] = in_sig[i] & in_sig[i + 1];
    end for
    out_both[99] = 0;
    out_any[0] = 0;
    for i in 1..99
      out_any[i] = in_sig[i] | in_sig[i - 1];
    end for
    for i in 0..98
      out_different[i] = in_sig[i] ^ in_sig[i + 1];
    end for
    out_different[99] = in_sig[99] ^ in_sig[0];
  end comb
end module TopModule
