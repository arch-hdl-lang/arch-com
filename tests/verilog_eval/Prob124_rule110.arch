module TopModule
  port clk: in Clock<SysDomain>;
  port load: in Bool;
  port data: in UInt<512>;
  port reg q: out UInt<512>;

  default seq on clk rising;

  wire q_next: UInt<512>;
  wire left_i: Bool;
  wire center_i: Bool;
  wire right_i: Bool;

  comb
    // Boundary: i=0 (right neighbor is 0)
    left_i = q[1];
    center_i = q[0];
    right_i = 0;
    q_next[0] = ~((left_i & center_i & right_i) | (~left_i & ~center_i & ~right_i) | (left_i & ~center_i & ~right_i));

    // Inner cells
    for i in 1..510
      left_i = q[i + 1];
      center_i = q[i];
      right_i = q[i - 1];
      q_next[i] = ~((left_i & center_i & right_i) | (~left_i & ~center_i & ~right_i) | (left_i & ~center_i & ~right_i));
    end for

    // Boundary: i=511 (left neighbor is 0)
    left_i = 0;
    center_i = q[511];
    right_i = q[510];
    q_next[511] = ~((left_i & center_i & right_i) | (~left_i & ~center_i & ~right_i) | (left_i & ~center_i & ~right_i));
  end comb

  seq q <= load ? data : q_next;
end module TopModule
