fsm TopModule
  port clk: in Clock<SysDomain>;
  port reset: in Reset<Sync>;
  port x: in Bool;
  port z: out Bool;

  state [A, B, C, D, E]
  default state A;
  default
    comb z = false;
  end default

  state A -> B when x;

  state B -> E when x;

  state C -> B when x;

  state D
    comb z = true;
    -> C when x;
    -> B when ~x;
  end state D

  state E
    comb z = true;
    -> D when ~x;
  end state E
end fsm TopModule
