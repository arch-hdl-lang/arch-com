domain SysDomain
end domain SysDomain

fsm TopModule
  port clk: in Clock<SysDomain>;
  port reset: in Reset<Sync>;
  port x: in Bool;
  port z: out Bool default false;

  state A, B, C, D, E;
  default state A;

  state A
    transition to B when x;
  end state A

  state B
    transition to E when x;
  end state B

  state C
    transition to B when x;
  end state C

  state D
    comb
      z = true;
    end comb
    transition to C when x;
    transition to B when ~x;
  end state D

  state E
    comb
      z = true;
    end comb
    transition to D when ~x;
  end state E
end fsm TopModule
