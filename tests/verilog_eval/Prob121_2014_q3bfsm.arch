fsm TopModule
  port clk: in Clock<SysDomain>;
  port reset: in Reset<Sync>;
  port x: in Bool;
  port z: out Bool;

  state A, B, C, D, E;
  default state A;
  default
    comb z = false;
  end default

  state A transition to B when x;

  state B transition to E when x;

  state C transition to B when x;

  state D
    comb z = true;
    transition to C when x;
    transition to B when ~x;
  end state D

  state E
    comb z = true;
    transition to D when ~x;
  end state E
end fsm TopModule
