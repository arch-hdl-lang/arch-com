module TopModule
  port in_sig: in Bool;
  port state_sig: in UInt<10>;
  port next_state: out UInt<10>;
  port out1: out Bool;
  port out2: out Bool;
  comb
    next_state[0] = ~in_sig & (state_sig[0] | state_sig[1] | state_sig[2] | state_sig[3] | state_sig[4] | state_sig[7] | state_sig[8] | state_sig[9]);
    next_state[1] = in_sig & (state_sig[0] | state_sig[8] | state_sig[9]);
    next_state[2] = in_sig & state_sig[1];
    next_state[3] = in_sig & state_sig[2];
    next_state[4] = in_sig & state_sig[3];
    next_state[5] = in_sig & state_sig[4];
    next_state[6] = in_sig & state_sig[5];
    next_state[7] = in_sig & (state_sig[6] | state_sig[7]);
    next_state[8] = ~in_sig & state_sig[5];
    next_state[9] = ~in_sig & state_sig[6];
    out1 = state_sig[8] | state_sig[9];
    out2 = state_sig[7] | state_sig[9];
  end comb
end module TopModule
