// VerilogEval Prob148: 4-state priority arbiter, active-low sync reset (resetn)
fsm TopModule
  port clk: in Clock<SysDomain>;
  port resetn: in Reset<Sync, Low>;
  port r: in UInt<3>;
  port g: out UInt<3>;

  state [Idle, Grant0, Grant1, Grant2]
  default state Idle;
  default
    comb g = 0;
  end default

  state Idle
    -> Grant0 when r[0];
    -> Grant1 when ~r[0] & r[1];
    -> Grant2 when ~r[0] & ~r[1] & r[2];
  end state Idle

  state Grant0
    comb g = 1;
    -> Idle when ~r[0];
  end state Grant0

  state Grant1
    comb g = 2;
    -> Idle when ~r[1];
  end state Grant1

  state Grant2
    comb g = 4;
    -> Idle when ~r[2];
  end state Grant2
end fsm TopModule
