fsm TopModule
  port clk: in Clock<SysDomain>;
  port areset: in Reset<Async>;
  port bump_left: in Bool;
  port bump_right: in Bool;
  port walk_left: out Bool;
  port walk_right: out Bool;

  state [WalkLeft, WalkRight]
  default state WalkLeft;
  default
    let walk_left = false;
    let walk_right = false;
  end default

  state WalkLeft
    let walk_left = true;
    -> WalkRight when bump_left;
  end state WalkLeft

  state WalkRight
    let walk_right = true;
    -> WalkLeft when bump_right;
  end state WalkRight
end fsm TopModule
