module TopModule
  port code: in UInt<8>;
  port out: out UInt<4>;
  port valid: out Bool;
  comb
    valid = 1;
    if code == 0x45
      out = 0;
    elsif code == 0x16
      out = 1;
    elsif code == 0x1e
      out = 2;
    elsif code == 0x26
      out = 3;
    elsif code == 0x25
      out = 4;
    elsif code == 0x2e
      out = 5;
    elsif code == 0x36
      out = 6;
    elsif code == 0x3d
      out = 7;
    elsif code == 0x3e
      out = 8;
    elsif code == 0x46
      out = 9;
    else
      out = 0;
      valid = 0;
    end if
  end comb
end module TopModule
