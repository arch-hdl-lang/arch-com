// VerilogEval Prob120: 4-state Moore FSM, sync reset
domain SysDomain
end domain SysDomain

fsm TopModule
  port clk: in Clock<SysDomain>;
  port reset: in Reset<Sync>;
  port in: in Bool;
  port out: out Bool;

  state A, B, C, D;
  default state A;

  state A
    comb
      out = false;
    end comb
    transition to B when in;
  end state A

  state B
    comb
      out = false;
    end comb
    transition to B when in;
    transition to C when ~in;
  end state B

  state C
    comb
      out = false;
    end comb
    transition to D when in;
    transition to A when ~in;
  end state C

  state D
    comb
      out = true;
    end comb
    transition to B when in;
    transition to C when ~in;
  end state D

end fsm TopModule
