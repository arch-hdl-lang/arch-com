// VerilogEval Prob120: 4-state Moore FSM, sync reset
domain SysDomain
end domain SysDomain

fsm TopModule
  port clk: in Clock<SysDomain>;
  port rst: in Reset<Sync>;
  port in_sig: in Bool;
  port out_sig: out Bool default false;

  state A, B, C, D;
  default state A;

  state A
    transition to B when in_sig;
  end state A

  state B
    transition to B when in_sig;
    transition to C when ~in_sig;
  end state B

  state C
    transition to D when in_sig;
    transition to A when ~in_sig;
  end state C

  state D
    comb
      out_sig = true;
    end comb
    transition to B when in_sig;
    transition to C when ~in_sig;
  end state D

end fsm TopModule
