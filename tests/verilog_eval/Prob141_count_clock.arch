// VerilogEval Prob141: 12-hour BCD clock
module TopModule
  port clk: in Clock<SysDomain>;
  port reset: in Reset<Sync>;
  port ena: in Bool;
  port pm: out Bool;
  port hh: out UInt<8>;
  port mm: out UInt<8>;
  port ss: out UInt<8>;

  default seq on clk rising;

  reg ss_lo: UInt<4> reset reset=>0;
  reg ss_hi: UInt<4> reset reset=>0;
  reg mm_lo: UInt<4> reset reset=>0;
  reg mm_hi: UInt<4> reset reset=>0;
  reg hh_lo: UInt<4> reset reset=>2;
  reg hh_hi: UInt<4> reset reset=>1;
  reg pm_reg: Bool reset reset=>0;

  comb
    ss = {ss_hi, ss_lo};
    mm = {mm_hi, mm_lo};
    hh = {hh_hi, hh_lo};
    pm = pm_reg;
  end comb

  seq
    if ena
      if ss_lo == 9
        ss_lo <= 0;
        if ss_hi == 5
          ss_hi <= 0;
          if mm_lo == 9
            mm_lo <= 0;
            if mm_hi == 5
              mm_hi <= 0;
              // Hour increment: 12->1, 11->12 (toggle pm), else increment
              if (hh_hi == 1) & (hh_lo == 2)
                // 12:59:59 -> 01:00:00
                hh_hi <= 0;
                hh_lo <= 1;
              elsif (hh_hi == 1) & (hh_lo == 1)
                // 11:59:59 -> 12:00:00, toggle PM
                hh_hi <= 1;
                hh_lo <= 2;
                pm_reg <= ~pm_reg;
              elsif hh_lo == 9
                hh_lo <= 0;
                hh_hi <= (hh_hi + 1).trunc<4>();
              else
                hh_lo <= (hh_lo + 1).trunc<4>();
              end if
            else
              mm_hi <= (mm_hi + 1).trunc<4>();
            end if
          else
            mm_lo <= (mm_lo + 1).trunc<4>();
          end if
        else
          ss_hi <= (ss_hi + 1).trunc<4>();
        end if
      else
        ss_lo <= (ss_lo + 1).trunc<4>();
      end if
    end if
  end seq
end module TopModule
