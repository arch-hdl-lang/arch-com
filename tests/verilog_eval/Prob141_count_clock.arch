// VerilogEval Prob141: 12-hour BCD clock
domain SysDomain
end domain SysDomain

module TopModule
  port clk: in Clock<SysDomain>;
  port reset: in Reset<Sync>;
  port ena: in Bool;
  port pm: out Bool;
  port hh: out UInt<8>;
  port mm: out UInt<8>;
  port ss: out UInt<8>;

  reg ss_lo: UInt<4> reset reset=0;
  reg ss_hi: UInt<4> reset reset=0;
  reg mm_lo: UInt<4> reset reset=0;
  reg mm_hi: UInt<4> reset reset=0;
  reg hh_lo: UInt<4> reset reset=2;
  reg hh_hi: UInt<4> reset reset=1;
  reg pm_reg: Bool reset reset=0;

  comb
    ss[0] = ss_lo[0];
    ss[1] = ss_lo[1];
    ss[2] = ss_lo[2];
    ss[3] = ss_lo[3];
    ss[4] = ss_hi[0];
    ss[5] = ss_hi[1];
    ss[6] = ss_hi[2];
    ss[7] = ss_hi[3];
    mm[0] = mm_lo[0];
    mm[1] = mm_lo[1];
    mm[2] = mm_lo[2];
    mm[3] = mm_lo[3];
    mm[4] = mm_hi[0];
    mm[5] = mm_hi[1];
    mm[6] = mm_hi[2];
    mm[7] = mm_hi[3];
    hh[0] = hh_lo[0];
    hh[1] = hh_lo[1];
    hh[2] = hh_lo[2];
    hh[3] = hh_lo[3];
    hh[4] = hh_hi[0];
    hh[5] = hh_hi[1];
    hh[6] = hh_hi[2];
    hh[7] = hh_hi[3];
    pm = pm_reg;
  end comb

  seq on clk rising
    if ena
      if ss_lo == 9
        ss_lo <= 0;
        if ss_hi == 5
          ss_hi <= 0;
          if mm_lo == 9
            mm_lo <= 0;
            if mm_hi == 5
              mm_hi <= 0;
              // Hour increment: 12->1, 11->12 (toggle pm), else increment
              if (hh_hi == 1) & (hh_lo == 2)
                // 12:59:59 -> 01:00:00
                hh_hi <= 0;
                hh_lo <= 1;
              elsif (hh_hi == 1) & (hh_lo == 1)
                // 11:59:59 -> 12:00:00, toggle PM
                hh_hi <= 1;
                hh_lo <= 2;
                pm_reg <= ~pm_reg;
              elsif hh_lo == 9
                hh_lo <= 0;
                hh_hi <= (hh_hi + 1).trunc<4>();
              else
                hh_lo <= (hh_lo + 1).trunc<4>();
              end if
            else
              mm_hi <= (mm_hi + 1).trunc<4>();
            end if
          else
            mm_lo <= (mm_lo + 1).trunc<4>();
          end if
        else
          ss_hi <= (ss_hi + 1).trunc<4>();
        end if
      else
        ss_lo <= (ss_lo + 1).trunc<4>();
      end if
    end if
  end seq
end module TopModule
