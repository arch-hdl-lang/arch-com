module TopModule
  port clk: in Clock<SysDomain>;
  port x: in Bool;
  port y: in UInt<3>;
  port Y0: out Bool;
  port z: out Bool;
  wire yx: UInt<4>;
  comb
    yx = (y.zext<4>() * 2 + x.zext<4>()).trunc<4>();
    if yx == 0
      Y0 = 0;
    elsif yx == 1
      Y0 = 1;
    elsif yx == 2
      Y0 = 1;
    elsif yx == 3
      Y0 = 0;
    elsif yx == 4
      Y0 = 0;
    elsif yx == 5
      Y0 = 1;
    elsif yx == 6
      Y0 = 1;
    elsif yx == 7
      Y0 = 0;
    elsif yx == 8
      Y0 = 1;
    else
      Y0 = 0;
    end if
    z = (y == 3) | (y == 4);
  end comb
end module TopModule
