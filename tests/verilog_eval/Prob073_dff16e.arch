// VerilogEval Prob073: 16 DFFs with byte enable, active-low sync reset
domain SysDomain
end domain SysDomain

module TopModule
  port clk: in Clock<SysDomain>;
  port resetn: in Reset<Sync, Low>;
  port byteena: in UInt<2>;
  port d: in UInt<16>;
  port reg q: out UInt<16> reset resetn=0;

  seq on clk rising
    if byteena[0]
      q[7:0] <= d[7:0];
    end if
    if byteena[1]
      q[15:8] <= d[15:8];
    end if
  end seq
end module TopModule
