// VerilogEval Prob151: Timer FSM (registered version) - detect 1101, shift 4, count, wait ack
domain SysDomain
end domain SysDomain

fsm TopModule
  port clk: in Clock<SysDomain>;
  port reset_sig: in Reset<Sync>;
  port data: in Bool;
  port done_counting: in Bool;
  port ack: in Bool;
  port shift_ena: out Bool default false;
  port counting: out Bool default false;
  port done: out Bool default false;

  state S, S1, S11, S110, B0, B1, B2, B3, Count, Wait;
  default state S;

  state S
    transition to S1 when data;
  end state S

  state S1
    transition to S11 when data;
    transition to S when ~data;
  end state S1

  state S11
    transition to S11 when data;
    transition to S110 when ~data;
  end state S11

  state S110
    transition to B0 when data;
    transition to S when ~data;
  end state S110

  state B0
    comb
      shift_ena = true;
    end comb
    transition to B1 when true;
  end state B0

  state B1
    comb
      shift_ena = true;
    end comb
    transition to B2 when true;
  end state B1

  state B2
    comb
      shift_ena = true;
    end comb
    transition to B3 when true;
  end state B2

  state B3
    comb
      shift_ena = true;
    end comb
    transition to Count when true;
  end state B3

  state Count
    comb
      counting = true;
    end comb
    transition to Wait when done_counting;
    transition to Count when ~done_counting;
  end state Count

  state Wait
    comb
      done = true;
    end comb
    transition to S when ack;
    transition to Wait when ~ack;
  end state Wait

end fsm TopModule
