// VerilogEval Prob151: Timer FSM (registered version) - detect 1101, shift 4, count, wait ack
fsm TopModule
  port clk: in Clock<SysDomain>;
  port reset: in Reset<Sync>;
  port data: in Bool;
  port done_counting: in Bool;
  port ack: in Bool;
  port shift_ena: out Bool;
  port counting: out Bool;
  port done: out Bool;

  state [S, S1, S11, S110, B0, B1, B2, B3, Count, Wait]
  default state S;
  default
    comb shift_ena = false;
    comb counting = false;
    comb done = false;
  end default

  state S -> S1 when data;

  state S1
    -> S11 when data;
    -> S when ~data;
  end state S1

  state S11
    -> S11 when data;
    -> S110 when ~data;
  end state S11

  state S110
    -> B0 when data;
    -> S when ~data;
  end state S110

  state B0
    comb shift_ena = true;
    -> B1 when true;
  end state B0

  state B1
    comb shift_ena = true;
    -> B2 when true;
  end state B1

  state B2
    comb shift_ena = true;
    -> B3 when true;
  end state B2

  state B3
    comb shift_ena = true;
    -> Count when true;
  end state B3

  state Count
    comb counting = true;
    -> Wait when done_counting;
    -> Count when ~done_counting;
  end state Count

  state Wait
    comb done = true;
    -> S when ack;
    -> Wait when ~ack;
  end state Wait

end fsm TopModule
