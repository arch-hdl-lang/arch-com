// VerilogEval Prob040: Decade counter (0-9), sync reset
module TopModule
  port clk: in Clock<SysDomain>;
  port reset: in Reset<Sync>;
  port q: out UInt<4>;

  default seq on clk rising;

  reg count_r: UInt<4> init 0 reset reset=>0;

  seq count_r <= count_r == 9 ? 0 : (count_r + 1).trunc<4>();

  comb
    q = count_r;
  end comb
end module TopModule
