domain SysDomain
end domain SysDomain

module TopModule
  port clk: in Clock<SysDomain>;
  port load: in Bool;
  port data: in UInt<512>;
  port reg q: out UInt<512>;

  wire q_next: UInt<512>;

  comb
    q_next[0] = q[1];
    for i in 1..510
      q_next[i] = q[i - 1] ^ q[i + 1];
    end for
    q_next[511] = q[510];
  end comb

  seq on clk rising
    if load
      q <= data;
    else
      q <= q_next;
    end if
  end seq
end module TopModule
