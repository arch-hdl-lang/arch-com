module TopModule
  port clk: in Clock<SysDomain>;
  port reset: in Reset<Sync>;
  port in: in UInt<32>;
  port out: out UInt<32>;

  default seq on clk rising;

  reg prev: UInt<32>;
  reg captured: UInt<32> reset reset=0;

  seq
    prev <= in;
    captured <= captured | (prev & ~in);
  end seq

  comb
    out = captured;
  end comb
end module TopModule
