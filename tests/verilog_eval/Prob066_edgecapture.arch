domain SysDomain
end domain SysDomain

module TopModule
  port clk: in Clock<SysDomain>;
  port reset_sig: in Reset<Sync>;
  port in_sig: in UInt<32>;
  port out_sig: out UInt<32>;

  reg prev: UInt<32>;
  reg captured: UInt<32> reset reset_sig=0;

  seq on clk rising
    prev <= in_sig;
    captured <= captured | (prev & ~in_sig);
  end seq

  comb
    out_sig = captured;
  end comb
end module TopModule
