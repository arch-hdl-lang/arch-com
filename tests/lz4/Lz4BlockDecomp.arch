// LZ4 block-format decompressor (byte-stream FSM).
//
// Accepts a raw LZ4 block byte-stream via AXI-S (in_valid/in_ready/
// in_data/in_last) and emits the decoded byte stream via AXI-S
// (out_valid/out_ready/out_data/out_last).  Caller must strip the
// 4-byte frame header before feeding this block.
//
// LZ4 sequence layout per token byte:
//   [7:4] = literal-length base  (if 0xF, read extension bytes until < 0xFF)
//   [3:0] = match-length-base-4  (if 0xF, read extension bytes until < 0xFF)
//   then: literal bytes (count = lit_len)
//   then: 2-byte LE match offset  (omitted for the LAST sequence)
//   then: match copy (count = match_len, minimum 4)
//
// History ring buffer is 65536 bytes (power-of-2 for free wrap-around).
// The design uses a phase register instead of nested do-while loops to
// comply with the ARCH thread constraint that do-until bodies must not
// contain wait-until or for-loop statements.

domain SysDomain
  freq_mhz: 100
end domain SysDomain

// Simple-dual-port, latency-0 (async read) history ring buffer.
ram HistBuf
  kind simple_dual;
  latency 0;
  port clk: in Clock<SysDomain>;
  store
    buf: Vec<UInt<8>, 65536>;
  end store
  ports wr_port
    en:   in Bool;
    addr: in UInt<16>;
    data: in UInt<8>;
  end ports wr_port
  ports rd_port
    addr: in UInt<16>;
    data: out UInt<8>;
  end ports rd_port
end ram HistBuf

// Decoder phase tags.  Each phase handles exactly one handshake event
// per thread iteration; the implicit thread loop drives the state machine.
enum LZ4Phase
  P_TOKEN,      // consume token byte, parse nibbles
  P_EXT_LIT,   // consume literal-length extension bytes (nibble was 0xF)
  P_COPY_LIT,  // consume + forward one literal byte
  P_OFF_LO,    // consume match-offset low byte
  P_OFF_HI,    // consume match-offset high byte; compute match base address
  P_EXT_MATCH, // consume match-length extension bytes (nibble was 0xF)
  P_MATCH_RD,  // set history read address (one-cycle address-setup bubble)
  P_MATCH_OUT  // emit one decoded match byte (back-pressure via do-until)
end enum LZ4Phase

module Lz4BlockDecomp
  port clk:       in Clock<SysDomain>;
  port rst:       in Reset<Sync>;
  port in_valid:  in Bool;
  port in_ready:  out Bool;
  port in_data:   in UInt<8>;
  port in_last:   in Bool;
  port out_valid: out Bool;
  port out_ready: in Bool;
  port out_data:  out UInt<8>;
  port out_last:  out Bool;

  // Decoder state registers
  reg phase_r:      LZ4Phase reset rst => LZ4Phase::P_TOKEN;
  reg lit_len_r:    UInt<16> reset rst => 0;
  reg lit_ctr_r:    UInt<16> reset rst => 0;
  reg match_len_r:  UInt<16> reset rst => 4;
  reg match_ctr_r:  UInt<16> reset rst => 0;
  reg match_off_r:  UInt<16> reset rst => 0;
  reg match_base_r: UInt<16> reset rst => 0;
  reg saw_last_r:   Bool     reset rst => false;
  reg wr_ptr_r:     UInt<16> reset rst => 0;
  reg hist_rd_addr_r: UInt<16> reset rst => 0;

  // History buffer wires — single-driver via thread default comb.
  wire hist_wr_en_w:   Bool;
  wire hist_wr_addr_w: UInt<16>;
  wire hist_wr_data_w: UInt<8>;
  wire hist_rd_data_w: UInt<8>;

  inst hist: HistBuf
    clk          <- clk;
    wr_port.en   <- hist_wr_en_w;
    wr_port.addr <- hist_wr_addr_w;
    wr_port.data <- hist_wr_data_w;
    rd_port.addr <- hist_rd_addr_r;
    rd_port.data -> hist_rd_data_w;
  end inst hist

  thread Decoder on clk rising, rst high
    default comb
      in_ready       = false;
      out_valid      = false;
      out_data       = 8'd0;
      out_last       = false;
      hist_wr_en_w   = false;
      hist_wr_addr_w = 16'd0;
      hist_wr_data_w = 8'd0;
    end default

    // ── P_TOKEN ──────────────────────────────────────────────────────────
    // Consume one token byte.  Parse high nibble → lit_len base,
    // low nibble → match_len base.  Advance phase based on nibble values.
    if phase_r == LZ4Phase::P_TOKEN
      wait until in_valid;
      in_ready    = true;
      lit_len_r   <= in_data[7:4].zext<16>();
      match_len_r <= (in_data[3:0].zext<16>()) +% 16'd4;
      lit_ctr_r   <= 16'd0;
      match_ctr_r <= 16'd0;
      saw_last_r  <= in_last;
      if in_data[7:4] == 4'hF
        phase_r <= LZ4Phase::P_EXT_LIT;
      elsif in_data[7:4] != 4'h0
        phase_r <= LZ4Phase::P_COPY_LIT;
      elsif not in_last
        phase_r <= LZ4Phase::P_OFF_LO;
      end if
      // in_data[7:4]==0 and in_last: last sequence with 0 literals and no
      // match → stay P_TOKEN, decompressor idles until next block.

    // ── P_EXT_LIT ────────────────────────────────────────────────────────
    // Each iteration consumes one extension byte, adding it to lit_len_r.
    // Stay until byte < 0xFF (LZ4 convention).
    elsif phase_r == LZ4Phase::P_EXT_LIT
      wait until in_valid;
      in_ready   = true;
      lit_len_r <= lit_len_r +% in_data.zext<16>();
      saw_last_r <= saw_last_r or in_last;
      if in_data < 8'hFF
        phase_r <= LZ4Phase::P_COPY_LIT;
      end if

    // ── P_COPY_LIT ───────────────────────────────────────────────────────
    // Pass one literal byte to output and write it to the history buffer.
    // Phase transitions: last literal + EOS → P_TOKEN;
    //                    last literal + !EOS → P_OFF_LO;
    //                    not last literal    → stay P_COPY_LIT.
    elsif phase_r == LZ4Phase::P_COPY_LIT
      wait until in_valid and out_ready;
      in_ready       = true;
      out_valid      = true;
      out_data       = in_data;
      out_last       = ((lit_ctr_r +% 16'd1) >= lit_len_r) and (saw_last_r or in_last);
      hist_wr_en_w   = true;
      hist_wr_addr_w = wr_ptr_r;
      hist_wr_data_w = in_data;
      wr_ptr_r      <= (wr_ptr_r +% 16'd1);
      lit_ctr_r     <= (lit_ctr_r +% 16'd1);
      saw_last_r    <= saw_last_r or in_last;
      if (lit_ctr_r +% 16'd1) >= lit_len_r
        if saw_last_r or in_last
          phase_r <= LZ4Phase::P_TOKEN;
        else
          phase_r <= LZ4Phase::P_OFF_LO;
        end if
      end if

    // ── P_OFF_LO ─────────────────────────────────────────────────────────
    elsif phase_r == LZ4Phase::P_OFF_LO
      wait until in_valid;
      in_ready    = true;
      match_off_r <= in_data.zext<16>();
      phase_r     <= LZ4Phase::P_OFF_HI;

    // ── P_OFF_HI ─────────────────────────────────────────────────────────
    // Complete the 16-bit little-endian match offset.  Pre-compute the
    // match base address (wr_ptr − full_offset) so P_MATCH_RD can use
    // match_base_r directly without a further pipeline bubble.
    elsif phase_r == LZ4Phase::P_OFF_HI
      wait until in_valid;
      in_ready     = true;
      match_off_r  <= (match_off_r | (in_data.zext<16>() << 8));
      match_base_r <= (wr_ptr_r -% (match_off_r | (in_data.zext<16>() << 8)));
      match_ctr_r  <= 16'd0;
      if match_len_r == 16'd19
        phase_r <= LZ4Phase::P_EXT_MATCH;
      else
        phase_r <= LZ4Phase::P_MATCH_RD;
      end if

    // ── P_EXT_MATCH ──────────────────────────────────────────────────────
    elsif phase_r == LZ4Phase::P_EXT_MATCH
      wait until in_valid;
      in_ready    = true;
      match_len_r <= match_len_r +% in_data.zext<16>();
      if in_data < 8'hFF
        phase_r <= LZ4Phase::P_MATCH_RD;
      end if

    // ── P_MATCH_RD ───────────────────────────────────────────────────────
    // One-cycle address-setup bubble: register hist_rd_addr_r so the
    // latency-0 async RAM read is valid in the following P_MATCH_OUT cycle.
    elsif phase_r == LZ4Phase::P_MATCH_RD
      hist_rd_addr_r <= (match_base_r +% match_ctr_r);
      phase_r        <= LZ4Phase::P_MATCH_OUT;

    // ── P_MATCH_OUT ──────────────────────────────────────────────────────
    // Emit one decoded match byte (from history) and append it to history.
    // Back-pressure: hold output valid until out_ready via do-until.
    elsif phase_r == LZ4Phase::P_MATCH_OUT
      do
        out_valid      = true;
        out_data       = hist_rd_data_w;
        hist_wr_en_w   = true;
        hist_wr_addr_w = wr_ptr_r;
        hist_wr_data_w = hist_rd_data_w;
      until out_ready;
      wr_ptr_r    <= (wr_ptr_r +% 16'd1);
      match_ctr_r <= (match_ctr_r +% 16'd1);
      if (match_ctr_r +% 16'd1) >= match_len_r
        phase_r <= LZ4Phase::P_TOKEN;
      else
        phase_r <= LZ4Phase::P_MATCH_RD;
      end if

    end if
  end thread Decoder
end module Lz4BlockDecomp
