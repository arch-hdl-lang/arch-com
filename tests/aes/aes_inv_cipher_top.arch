      0xe4 => 0xae, 0xe5 => 0x2a, 0xe6 => 0xf5, 0xe7 => 0xb0,
      0xe8 => 0xc8, 0xe9 => 0xeb, 0xea => 0xbb, 0xeb => 0x3c,
      0xec => 0x83, 0xed => 0x53, 0xee => 0x99, 0xef => 0x61,
