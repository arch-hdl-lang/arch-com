      0x38 => 0x76, 0x39 => 0x5b, 0x3a => 0xa2, 0x3b => 0x49,
      0x3c => 0x6d, 0x3d => 0x8b, 0x3e => 0xd1, 0x3f => 0x25,
      0x40 => 0x72, 0x41 => 0xf8, 0x42 => 0xf6, 0x43 => 0x64,
      0x44 => 0x86, 0x45 => 0x68, 0x46 => 0x98, 0x47 => 0x16,
