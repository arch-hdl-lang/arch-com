// AES-128 Encryption — function-based version
// Demonstrates: AesSbox and Xtime as pure combinational functions,
// eliminating 32 inst blocks from AesCipherTop and 4+1 inst blocks from AesKeyExpand128.

domain SysDomain
  freq_mhz: 100
end domain SysDomain

// ── Pure combinational functions ──────────────────────────────────────────────

function AesSbox(a: UInt<8>) -> UInt<8>
  return match a
    0x00 => 0x63, 0x01 => 0x7c, 0x02 => 0x77, 0x03 => 0x7b,
    0x04 => 0xf2, 0x05 => 0x6b, 0x06 => 0x6f, 0x07 => 0xc5,
    0x08 => 0x30, 0x09 => 0x01, 0x0a => 0x67, 0x0b => 0x2b,
    0x0c => 0xfe, 0x0d => 0xd7, 0x0e => 0xab, 0x0f => 0x76,
    0x10 => 0xca, 0x11 => 0x82, 0x12 => 0xc9, 0x13 => 0x7d,
    0x14 => 0xfa, 0x15 => 0x59, 0x16 => 0x47, 0x17 => 0xf0,
    0x18 => 0xad, 0x19 => 0xd4, 0x1a => 0xa2, 0x1b => 0xaf,
    0x1c => 0x9c, 0x1d => 0xa4, 0x1e => 0x72, 0x1f => 0xc0,
    0x20 => 0xb7, 0x21 => 0xfd, 0x22 => 0x93, 0x23 => 0x26,
    0x24 => 0x36, 0x25 => 0x3f, 0x26 => 0xf7, 0x27 => 0xcc,
    0x28 => 0x34, 0x29 => 0xa5, 0x2a => 0xe5, 0x2b => 0xf1,
    0x2c => 0x71, 0x2d => 0xd8, 0x2e => 0x31, 0x2f => 0x15,
    0x30 => 0x04, 0x31 => 0xc7, 0x32 => 0x23, 0x33 => 0xc3,
    0x34 => 0x18, 0x35 => 0x96, 0x36 => 0x05, 0x37 => 0x9a,
    0x38 => 0x07, 0x39 => 0x12, 0x3a => 0x80, 0x3b => 0xe2,
    0x3c => 0xeb, 0x3d => 0x27, 0x3e => 0xb2, 0x3f => 0x75,
    0x40 => 0x09, 0x41 => 0x83, 0x42 => 0x2c, 0x43 => 0x1a,
    0x44 => 0x1b, 0x45 => 0x6e, 0x46 => 0x5a, 0x47 => 0xa0,
    0x48 => 0x52, 0x49 => 0x3b, 0x4a => 0xd6, 0x4b => 0xb3,
    0x4c => 0x29, 0x4d => 0xe3, 0x4e => 0x2f, 0x4f => 0x84,
    0x50 => 0x53, 0x51 => 0xd1, 0x52 => 0x00, 0x53 => 0xed,
    0x54 => 0x20, 0x55 => 0xfc, 0x56 => 0xb1, 0x57 => 0x5b,
    0x58 => 0x6a, 0x59 => 0xcb, 0x5a => 0xbe, 0x5b => 0x39,
    0x5c => 0x4a, 0x5d => 0x4c, 0x5e => 0x58, 0x5f => 0xcf,
    0x60 => 0xd0, 0x61 => 0xef, 0x62 => 0xaa, 0x63 => 0xfb,
    0x64 => 0x43, 0x65 => 0x4d, 0x66 => 0x33, 0x67 => 0x85,
    0x68 => 0x45, 0x69 => 0xf9, 0x6a => 0x02, 0x6b => 0x7f,
    0x6c => 0x50, 0x6d => 0x3c, 0x6e => 0x9f, 0x6f => 0xa8,
    0x70 => 0x51, 0x71 => 0xa3, 0x72 => 0x40, 0x73 => 0x8f,
    0x74 => 0x92, 0x75 => 0x9d, 0x76 => 0x38, 0x77 => 0xf5,
    0x78 => 0xbc, 0x79 => 0xb6, 0x7a => 0xda, 0x7b => 0x21,
    0x7c => 0x10, 0x7d => 0xff, 0x7e => 0xf3, 0x7f => 0xd2,
    0x80 => 0xcd, 0x81 => 0x0c, 0x82 => 0x13, 0x83 => 0xec,
    0x84 => 0x5f, 0x85 => 0x97, 0x86 => 0x44, 0x87 => 0x17,
    0x88 => 0xc4, 0x89 => 0xa7, 0x8a => 0x7e, 0x8b => 0x3d,
    0x8c => 0x64, 0x8d => 0x5d, 0x8e => 0x19, 0x8f => 0x73,
    0x90 => 0x60, 0x91 => 0x81, 0x92 => 0x4f, 0x93 => 0xdc,
    0x94 => 0x22, 0x95 => 0x2a, 0x96 => 0x90, 0x97 => 0x88,
    0x98 => 0x46, 0x99 => 0xee, 0x9a => 0xb8, 0x9b => 0x14,
    0x9c => 0xde, 0x9d => 0x5e, 0x9e => 0x0b, 0x9f => 0xdb,
    0xa0 => 0xe0, 0xa1 => 0x32, 0xa2 => 0x3a, 0xa3 => 0x0a,
    0xa4 => 0x49, 0xa5 => 0x06, 0xa6 => 0x24, 0xa7 => 0x5c,
    0xa8 => 0xc2, 0xa9 => 0xd3, 0xaa => 0xac, 0xab => 0x62,
    0xac => 0x91, 0xad => 0x95, 0xae => 0xe4, 0xaf => 0x79,
    0xb0 => 0xe7, 0xb1 => 0xc8, 0xb2 => 0x37, 0xb3 => 0x6d,
    0xb4 => 0x8d, 0xb5 => 0xd5, 0xb6 => 0x4e, 0xb7 => 0xa9,
    0xb8 => 0x6c, 0xb9 => 0x56, 0xba => 0xf4, 0xbb => 0xea,
    0xbc => 0x65, 0xbd => 0x7a, 0xbe => 0xae, 0xbf => 0x08,
    0xc0 => 0xba, 0xc1 => 0x78, 0xc2 => 0x25, 0xc3 => 0x2e,
    0xc4 => 0x1c, 0xc5 => 0xa6, 0xc6 => 0xb4, 0xc7 => 0xc6,
    0xc8 => 0xe8, 0xc9 => 0xdd, 0xca => 0x74, 0xcb => 0x1f,
    0xcc => 0x4b, 0xcd => 0xbd, 0xce => 0x8b, 0xcf => 0x8a,
    0xd0 => 0x70, 0xd1 => 0x3e, 0xd2 => 0xb5, 0xd3 => 0x66,
    0xd4 => 0x48, 0xd5 => 0x03, 0xd6 => 0xf6, 0xd7 => 0x0e,
    0xd8 => 0x61, 0xd9 => 0x35, 0xda => 0x57, 0xdb => 0xb9,
    0xdc => 0x86, 0xdd => 0xc1, 0xde => 0x1d, 0xdf => 0x9e,
    0xe0 => 0xe1, 0xe1 => 0xf8, 0xe2 => 0x98, 0xe3 => 0x11,
    0xe4 => 0x69, 0xe5 => 0xd9, 0xe6 => 0x8e, 0xe7 => 0x94,
    0xe8 => 0x9b, 0xe9 => 0x1e, 0xea => 0x87, 0xeb => 0xe9,
    0xec => 0xce, 0xed => 0x55, 0xee => 0x28, 0xef => 0xdf,
    0xf0 => 0x8c, 0xf1 => 0xa1, 0xf2 => 0x89, 0xf3 => 0x0d,
    0xf4 => 0xbf, 0xf5 => 0xe6, 0xf6 => 0x42, 0xf7 => 0x68,
    0xf8 => 0x41, 0xf9 => 0x99, 0xfa => 0x2d, 0xfb => 0x0f,
    0xfc => 0xb0, 0xfd => 0x54, 0xfe => 0xbb, 0xff => 0x16,
    _ => 0x00,
  end match;
end function AesSbox

function Xtime(a: UInt<8>) -> UInt<8>
  let shifted: UInt<8> = (a << 1).trunc<8>();
  return match a & 0x80
    0x80 => shifted ^ 0x1b,
    _    => shifted,
  end match;
end function Xtime

// ── Key Expansion ─────────────────────────────────────────────────────────────
// AesSbox replaces 4 inst sbox blocks; AesRcon is inlined as a let/match.

module AesKeyExpand128
  port clk: in Clock<SysDomain>;
  port kld: in Bool;
  port key: in UInt<128>;
  port wo_0: out UInt<32>;
  port wo_1: out UInt<32>;
  port wo_2: out UInt<32>;
  port wo_3: out UInt<32>;

  reg w0: UInt<32> init 0 reset none;
  reg w1: UInt<32> init 0 reset none;
  reg w2: UInt<32> init 0 reset none;
  reg w3: UInt<32> init 0 reset none;
  reg rcnt: UInt<4> init 0 reset none;

  // SubWord: AesSbox on each byte of w3 (RotWord then SubBytes)
  let subword: UInt<32> = {
    AesSbox(w3.trunc<23,16>()),
    AesSbox(w3.trunc<15,8>()),
    AesSbox(w3.trunc<7,0>()),
    AesSbox(w3.trunc<31,24>())
  };

  // Round constant (was: inst rcon0: AesRcon)
  let rcon_val: UInt<32> = match rcnt
    0x0 => 0x01000000,
    0x1 => 0x02000000,
    0x2 => 0x04000000,
    0x3 => 0x08000000,
    0x4 => 0x10000000,
    0x5 => 0x20000000,
    0x6 => 0x40000000,
    0x7 => 0x80000000,
    0x8 => 0x1b000000,
    0x9 => 0x36000000,
    _ => 0x00000000,
  end match;

  let t: UInt<32> = subword ^ rcon_val;
  let nw0: UInt<32> = w0 ^ t;
  let nw1: UInt<32> = w1 ^ w0 ^ t;
  let nw2: UInt<32> = w2 ^ w1 ^ w0 ^ t;
  let nw3: UInt<32> = w3 ^ w2 ^ w1 ^ w0 ^ t;

  seq on clk rising
    if kld
      w0 <= key.trunc<127,96>();
      w1 <= key.trunc<95,64>();
      w2 <= key.trunc<63,32>();
      w3 <= key.trunc<31,0>();
      rcnt <= 0;
    else
      w0 <= nw0;
      w1 <= nw1;
      w2 <= nw2;
      w3 <= nw3;
      rcnt <= (rcnt + 1).trunc<4>();
    end if
  end seq

  comb
    wo_0 = w0;
    wo_1 = w1;
    wo_2 = w2;
    wo_3 = w3;
  end comb
end module AesKeyExpand128

// ── AES-128 Cipher Top ────────────────────────────────────────────────────────
// Replaces 16 AesSbox inst blocks + 16 Xtime inst blocks with inline calls.
// SubBytes + ShiftRows combined in the sa??_sr lets.
// MixColumns calls Xtime() inline.

module AesCipherTop
  port clk: in Clock<SysDomain>;
  port rst: in Reset<Sync>;
  port ld: in Bool;
  port done: out Bool;
  port key: in UInt<128>;
  port text_in: in UInt<128>;
  port text_out: out UInt<128>;

  // ── Control registers ──
  reg dcnt: UInt<4> init 0 reset rst=0;
  reg ld_r: Bool init false reset rst=false;
  reg done_r: Bool init false reset rst=false;

  // ── Input buffer ──
  reg text_in_r: UInt<128> init 0 reset rst=0;

  // ── State matrix: 16 individual 8-bit registers ──
  reg sa00: UInt<8> init 0 reset rst=0;
  reg sa01: UInt<8> init 0 reset rst=0;
  reg sa02: UInt<8> init 0 reset rst=0;
  reg sa03: UInt<8> init 0 reset rst=0;
  reg sa10: UInt<8> init 0 reset rst=0;
  reg sa11: UInt<8> init 0 reset rst=0;
  reg sa12: UInt<8> init 0 reset rst=0;
  reg sa13: UInt<8> init 0 reset rst=0;
  reg sa20: UInt<8> init 0 reset rst=0;
  reg sa21: UInt<8> init 0 reset rst=0;
  reg sa22: UInt<8> init 0 reset rst=0;
  reg sa23: UInt<8> init 0 reset rst=0;
  reg sa30: UInt<8> init 0 reset rst=0;
  reg sa31: UInt<8> init 0 reset rst=0;
  reg sa32: UInt<8> init 0 reset rst=0;
  reg sa33: UInt<8> init 0 reset rst=0;

  // ── Output register ──
  reg text_out_r: UInt<128> init 0 reset rst=0;

  // ── Key expansion instance ──
  inst key_exp: AesKeyExpand128
    connect clk <- clk;
    connect kld <- ld;
    connect key <- key;
    connect wo_0 -> w0;
    connect wo_1 -> w1;
    connect wo_2 -> w2;
    connect wo_3 -> w3;
  end inst key_exp

  // ── SubBytes + ShiftRows (was: 16 AesSbox inst + 16 let) ──
  // Row 0: no shift
  let sa00_sr: UInt<8> = AesSbox(sa00);
  let sa01_sr: UInt<8> = AesSbox(sa01);
  let sa02_sr: UInt<8> = AesSbox(sa02);
  let sa03_sr: UInt<8> = AesSbox(sa03);
  // Row 1: shift left 1
  let sa10_sr: UInt<8> = AesSbox(sa11);
  let sa11_sr: UInt<8> = AesSbox(sa12);
  let sa12_sr: UInt<8> = AesSbox(sa13);
  let sa13_sr: UInt<8> = AesSbox(sa10);
  // Row 2: shift left 2
  let sa20_sr: UInt<8> = AesSbox(sa22);
  let sa21_sr: UInt<8> = AesSbox(sa23);
  let sa22_sr: UInt<8> = AesSbox(sa20);
  let sa23_sr: UInt<8> = AesSbox(sa21);
  // Row 3: shift left 3
  let sa30_sr: UInt<8> = AesSbox(sa33);
  let sa31_sr: UInt<8> = AesSbox(sa30);
  let sa32_sr: UInt<8> = AesSbox(sa31);
  let sa33_sr: UInt<8> = AesSbox(sa32);

  // ── MixColumns (Xtime called inline — was: 16 Xtime inst) ──
  let sa00_mc: UInt<8> = Xtime(sa00_sr) ^ Xtime(sa10_sr) ^ sa10_sr ^ sa20_sr ^ sa30_sr;
  let sa10_mc: UInt<8> = sa00_sr ^ Xtime(sa10_sr) ^ Xtime(sa20_sr) ^ sa20_sr ^ sa30_sr;
  let sa20_mc: UInt<8> = sa00_sr ^ sa10_sr ^ Xtime(sa20_sr) ^ Xtime(sa30_sr) ^ sa30_sr;
  let sa30_mc: UInt<8> = Xtime(sa00_sr) ^ sa00_sr ^ sa10_sr ^ sa20_sr ^ Xtime(sa30_sr);
  let sa01_mc: UInt<8> = Xtime(sa01_sr) ^ Xtime(sa11_sr) ^ sa11_sr ^ sa21_sr ^ sa31_sr;
  let sa11_mc: UInt<8> = sa01_sr ^ Xtime(sa11_sr) ^ Xtime(sa21_sr) ^ sa21_sr ^ sa31_sr;
  let sa21_mc: UInt<8> = sa01_sr ^ sa11_sr ^ Xtime(sa21_sr) ^ Xtime(sa31_sr) ^ sa31_sr;
  let sa31_mc: UInt<8> = Xtime(sa01_sr) ^ sa01_sr ^ sa11_sr ^ sa21_sr ^ Xtime(sa31_sr);
  let sa02_mc: UInt<8> = Xtime(sa02_sr) ^ Xtime(sa12_sr) ^ sa12_sr ^ sa22_sr ^ sa32_sr;
  let sa12_mc: UInt<8> = sa02_sr ^ Xtime(sa12_sr) ^ Xtime(sa22_sr) ^ sa22_sr ^ sa32_sr;
  let sa22_mc: UInt<8> = sa02_sr ^ sa12_sr ^ Xtime(sa22_sr) ^ Xtime(sa32_sr) ^ sa32_sr;
  let sa32_mc: UInt<8> = Xtime(sa02_sr) ^ sa02_sr ^ sa12_sr ^ sa22_sr ^ Xtime(sa32_sr);
  let sa03_mc: UInt<8> = Xtime(sa03_sr) ^ Xtime(sa13_sr) ^ sa13_sr ^ sa23_sr ^ sa33_sr;
  let sa13_mc: UInt<8> = sa03_sr ^ Xtime(sa13_sr) ^ Xtime(sa23_sr) ^ sa23_sr ^ sa33_sr;
  let sa23_mc: UInt<8> = sa03_sr ^ sa13_sr ^ Xtime(sa23_sr) ^ Xtime(sa33_sr) ^ sa33_sr;
  let sa33_mc: UInt<8> = Xtime(sa03_sr) ^ sa03_sr ^ sa13_sr ^ sa23_sr ^ Xtime(sa33_sr);

  // ── AddRoundKey after MixColumns (rounds 1-9) ──
  let sa00_ark: UInt<8> = sa00_mc ^ w0.trunc<31,24>();
  let sa10_ark: UInt<8> = sa10_mc ^ w0.trunc<23,16>();
  let sa20_ark: UInt<8> = sa20_mc ^ w0.trunc<15,8>();
  let sa30_ark: UInt<8> = sa30_mc ^ w0.trunc<7,0>();
  let sa01_ark: UInt<8> = sa01_mc ^ w1.trunc<31,24>();
  let sa11_ark: UInt<8> = sa11_mc ^ w1.trunc<23,16>();
  let sa21_ark: UInt<8> = sa21_mc ^ w1.trunc<15,8>();
  let sa31_ark: UInt<8> = sa31_mc ^ w1.trunc<7,0>();
  let sa02_ark: UInt<8> = sa02_mc ^ w2.trunc<31,24>();
  let sa12_ark: UInt<8> = sa12_mc ^ w2.trunc<23,16>();
  let sa22_ark: UInt<8> = sa22_mc ^ w2.trunc<15,8>();
  let sa32_ark: UInt<8> = sa32_mc ^ w2.trunc<7,0>();
  let sa03_ark: UInt<8> = sa03_mc ^ w3.trunc<31,24>();
  let sa13_ark: UInt<8> = sa13_mc ^ w3.trunc<23,16>();
  let sa23_ark: UInt<8> = sa23_mc ^ w3.trunc<15,8>();
  let sa33_ark: UInt<8> = sa33_mc ^ w3.trunc<7,0>();

  // ── AddRoundKey after ShiftRows only (final round, no MixColumns) ──
  let sa00_fark: UInt<8> = sa00_sr ^ w0.trunc<31,24>();
  let sa10_fark: UInt<8> = sa10_sr ^ w0.trunc<23,16>();
  let sa20_fark: UInt<8> = sa20_sr ^ w0.trunc<15,8>();
  let sa30_fark: UInt<8> = sa30_sr ^ w0.trunc<7,0>();
  let sa01_fark: UInt<8> = sa01_sr ^ w1.trunc<31,24>();
  let sa11_fark: UInt<8> = sa11_sr ^ w1.trunc<23,16>();
  let sa21_fark: UInt<8> = sa21_sr ^ w1.trunc<15,8>();
  let sa31_fark: UInt<8> = sa31_sr ^ w1.trunc<7,0>();
  let sa02_fark: UInt<8> = sa02_sr ^ w2.trunc<31,24>();
  let sa12_fark: UInt<8> = sa12_sr ^ w2.trunc<23,16>();
  let sa22_fark: UInt<8> = sa22_sr ^ w2.trunc<15,8>();
  let sa32_fark: UInt<8> = sa32_sr ^ w2.trunc<7,0>();
  let sa03_fark: UInt<8> = sa03_sr ^ w3.trunc<31,24>();
  let sa13_fark: UInt<8> = sa13_sr ^ w3.trunc<23,16>();
  let sa23_fark: UInt<8> = sa23_sr ^ w3.trunc<15,8>();
  let sa33_fark: UInt<8> = sa33_sr ^ w3.trunc<7,0>();

  // ── FSM control + state matrix updates ──
  seq on clk rising
    ld_r <= ld;

    if ld
      dcnt <= 0xb;
    elsif dcnt != 0
      dcnt <= (dcnt - 1).trunc<4>();
    end if

    if ld_r
      sa00 <= text_in_r.trunc<127,120>() ^ w0.trunc<31,24>();
      sa10 <= text_in_r.trunc<119,112>() ^ w0.trunc<23,16>();
      sa20 <= text_in_r.trunc<111,104>() ^ w0.trunc<15,8>();
      sa30 <= text_in_r.trunc<103,96>()  ^ w0.trunc<7,0>();
      sa01 <= text_in_r.trunc<95,88>()   ^ w1.trunc<31,24>();
      sa11 <= text_in_r.trunc<87,80>()   ^ w1.trunc<23,16>();
      sa21 <= text_in_r.trunc<79,72>()   ^ w1.trunc<15,8>();
      sa31 <= text_in_r.trunc<71,64>()   ^ w1.trunc<7,0>();
      sa02 <= text_in_r.trunc<63,56>()   ^ w2.trunc<31,24>();
      sa12 <= text_in_r.trunc<55,48>()   ^ w2.trunc<23,16>();
      sa22 <= text_in_r.trunc<47,40>()   ^ w2.trunc<15,8>();
      sa32 <= text_in_r.trunc<39,32>()   ^ w2.trunc<7,0>();
      sa03 <= text_in_r.trunc<31,24>()   ^ w3.trunc<31,24>();
      sa13 <= text_in_r.trunc<23,16>()   ^ w3.trunc<23,16>();
      sa23 <= text_in_r.trunc<15,8>()    ^ w3.trunc<15,8>();
      sa33 <= text_in_r.trunc<7,0>()     ^ w3.trunc<7,0>();
    elsif dcnt > 1
      sa00 <= sa00_ark;  sa01 <= sa01_ark;  sa02 <= sa02_ark;  sa03 <= sa03_ark;
      sa10 <= sa10_ark;  sa11 <= sa11_ark;  sa12 <= sa12_ark;  sa13 <= sa13_ark;
      sa20 <= sa20_ark;  sa21 <= sa21_ark;  sa22 <= sa22_ark;  sa23 <= sa23_ark;
      sa30 <= sa30_ark;  sa31 <= sa31_ark;  sa32 <= sa32_ark;  sa33 <= sa33_ark;
    elsif dcnt == 1
      sa00 <= sa00_fark;  sa01 <= sa01_fark;  sa02 <= sa02_fark;  sa03 <= sa03_fark;
      sa10 <= sa10_fark;  sa11 <= sa11_fark;  sa12 <= sa12_fark;  sa13 <= sa13_fark;
      sa20 <= sa20_fark;  sa21 <= sa21_fark;  sa22 <= sa22_fark;  sa23 <= sa23_fark;
      sa30 <= sa30_fark;  sa31 <= sa31_fark;  sa32 <= sa32_fark;  sa33 <= sa33_fark;
    end if

    if ld
      text_in_r <= text_in;
    end if

    if ld
      done_r <= false;
    elsif dcnt == 1
      done_r <= true;
    end if

    if dcnt == 1
      text_out_r <= { sa00_fark, sa10_fark, sa20_fark, sa30_fark,
                      sa01_fark, sa11_fark, sa21_fark, sa31_fark,
                      sa02_fark, sa12_fark, sa22_fark, sa32_fark,
                      sa03_fark, sa13_fark, sa23_fark, sa33_fark };
    end if
  end seq

  comb
    done = done_r;
    text_out = text_out_r;
  end comb
end module AesCipherTop
