// AES-128 Encryption Top Module
// Iterative AES-128 encryption: 10 rounds, one per clock cycle.
// Depends on: AesSbox, AesRcon, AesKeyExpand128, Xtime

domain SysDomain
  freq_mhz: 100
end domain SysDomain

module AesCipherTop
  port clk: in Clock<SysDomain>;
  port rst: in Reset<Sync>;
  port ld: in Bool;
  port done: out Bool;
  port key: in UInt<128>;
  port text_in: in UInt<128>;
  port text_out: out UInt<128>;

  // ── Control registers ──
  reg dcnt: UInt<4> init 0 reset rst=0;
  reg ld_r: Bool init false reset rst=false;
  reg done_r: Bool init false reset rst=false;

  // ── Input buffer ──
  reg text_in_r: UInt<128> init 0 reset rst=0;

  // ── State matrix: 16 individual 8-bit registers ──
  reg sa00: UInt<8> init 0 reset rst=0;
  reg sa01: UInt<8> init 0 reset rst=0;
  reg sa02: UInt<8> init 0 reset rst=0;
  reg sa03: UInt<8> init 0 reset rst=0;
  reg sa10: UInt<8> init 0 reset rst=0;
  reg sa11: UInt<8> init 0 reset rst=0;
  reg sa12: UInt<8> init 0 reset rst=0;
  reg sa13: UInt<8> init 0 reset rst=0;
  reg sa20: UInt<8> init 0 reset rst=0;
  reg sa21: UInt<8> init 0 reset rst=0;
  reg sa22: UInt<8> init 0 reset rst=0;
  reg sa23: UInt<8> init 0 reset rst=0;
  reg sa30: UInt<8> init 0 reset rst=0;
  reg sa31: UInt<8> init 0 reset rst=0;
  reg sa32: UInt<8> init 0 reset rst=0;
  reg sa33: UInt<8> init 0 reset rst=0;

  // ── Output register ──
  reg text_out_r: UInt<128> init 0 reset rst=0;

  // ── Key expansion instance ──
  inst key_exp: AesKeyExpand128
    connect clk <- clk;
    connect kld <- ld;
    connect key <- key;
    connect wo_0 -> w0;
    connect wo_1 -> w1;
    connect wo_2 -> w2;
    connect wo_3 -> w3;
  end inst key_exp

  // ── 16 S-box instances: SubBytes on state matrix ──
  inst us00: AesSbox  connect a <- sa00; connect b -> sa00_sub; end inst us00
  inst us01: AesSbox  connect a <- sa01; connect b -> sa01_sub; end inst us01
  inst us02: AesSbox  connect a <- sa02; connect b -> sa02_sub; end inst us02
  inst us03: AesSbox  connect a <- sa03; connect b -> sa03_sub; end inst us03
  inst us10: AesSbox  connect a <- sa10; connect b -> sa10_sub; end inst us10
  inst us11: AesSbox  connect a <- sa11; connect b -> sa11_sub; end inst us11
  inst us12: AesSbox  connect a <- sa12; connect b -> sa12_sub; end inst us12
  inst us13: AesSbox  connect a <- sa13; connect b -> sa13_sub; end inst us13
  inst us20: AesSbox  connect a <- sa20; connect b -> sa20_sub; end inst us20
  inst us21: AesSbox  connect a <- sa21; connect b -> sa21_sub; end inst us21
  inst us22: AesSbox  connect a <- sa22; connect b -> sa22_sub; end inst us22
  inst us23: AesSbox  connect a <- sa23; connect b -> sa23_sub; end inst us23
  inst us30: AesSbox  connect a <- sa30; connect b -> sa30_sub; end inst us30
  inst us31: AesSbox  connect a <- sa31; connect b -> sa31_sub; end inst us31
  inst us32: AesSbox  connect a <- sa32; connect b -> sa32_sub; end inst us32
  inst us33: AesSbox  connect a <- sa33; connect b -> sa33_sub; end inst us33

  // ── ShiftRows ──
  let sa00_sr: UInt<8> = sa00_sub;
  let sa01_sr: UInt<8> = sa01_sub;
  let sa02_sr: UInt<8> = sa02_sub;
  let sa03_sr: UInt<8> = sa03_sub;
  let sa10_sr: UInt<8> = sa11_sub;
  let sa11_sr: UInt<8> = sa12_sub;
  let sa12_sr: UInt<8> = sa13_sub;
  let sa13_sr: UInt<8> = sa10_sub;
  let sa20_sr: UInt<8> = sa22_sub;
  let sa21_sr: UInt<8> = sa23_sub;
  let sa22_sr: UInt<8> = sa20_sub;
  let sa23_sr: UInt<8> = sa21_sub;
  let sa30_sr: UInt<8> = sa33_sub;
  let sa31_sr: UInt<8> = sa30_sub;
  let sa32_sr: UInt<8> = sa31_sub;
  let sa33_sr: UInt<8> = sa32_sub;

  // ── xtime instances for MixColumns ──
  inst xt00: Xtime  connect a <- sa00_sr; connect y -> xt00_y; end inst xt00
  inst xt01: Xtime  connect a <- sa01_sr; connect y -> xt01_y; end inst xt01
  inst xt02: Xtime  connect a <- sa02_sr; connect y -> xt02_y; end inst xt02
  inst xt03: Xtime  connect a <- sa03_sr; connect y -> xt03_y; end inst xt03
  inst xt10: Xtime  connect a <- sa10_sr; connect y -> xt10_y; end inst xt10
  inst xt11: Xtime  connect a <- sa11_sr; connect y -> xt11_y; end inst xt11
  inst xt12: Xtime  connect a <- sa12_sr; connect y -> xt12_y; end inst xt12
  inst xt13: Xtime  connect a <- sa13_sr; connect y -> xt13_y; end inst xt13
  inst xt20: Xtime  connect a <- sa20_sr; connect y -> xt20_y; end inst xt20
  inst xt21: Xtime  connect a <- sa21_sr; connect y -> xt21_y; end inst xt21
  inst xt22: Xtime  connect a <- sa22_sr; connect y -> xt22_y; end inst xt22
  inst xt23: Xtime  connect a <- sa23_sr; connect y -> xt23_y; end inst xt23
  inst xt30: Xtime  connect a <- sa30_sr; connect y -> xt30_y; end inst xt30
  inst xt31: Xtime  connect a <- sa31_sr; connect y -> xt31_y; end inst xt31
  inst xt32: Xtime  connect a <- sa32_sr; connect y -> xt32_y; end inst xt32
  inst xt33: Xtime  connect a <- sa33_sr; connect y -> xt33_y; end inst xt33

  // ── MixColumns ──
  let sa00_mc: UInt<8> = xt00_y ^ xt10_y ^ sa10_sr ^ sa20_sr ^ sa30_sr;
  let sa10_mc: UInt<8> = sa00_sr ^ xt10_y ^ xt20_y ^ sa20_sr ^ sa30_sr;
  let sa20_mc: UInt<8> = sa00_sr ^ sa10_sr ^ xt20_y ^ xt30_y ^ sa30_sr;
  let sa30_mc: UInt<8> = xt00_y ^ sa00_sr ^ sa10_sr ^ sa20_sr ^ xt30_y;
  let sa01_mc: UInt<8> = xt01_y ^ xt11_y ^ sa11_sr ^ sa21_sr ^ sa31_sr;
  let sa11_mc: UInt<8> = sa01_sr ^ xt11_y ^ xt21_y ^ sa21_sr ^ sa31_sr;
  let sa21_mc: UInt<8> = sa01_sr ^ sa11_sr ^ xt21_y ^ xt31_y ^ sa31_sr;
  let sa31_mc: UInt<8> = xt01_y ^ sa01_sr ^ sa11_sr ^ sa21_sr ^ xt31_y;
  let sa02_mc: UInt<8> = xt02_y ^ xt12_y ^ sa12_sr ^ sa22_sr ^ sa32_sr;
  let sa12_mc: UInt<8> = sa02_sr ^ xt12_y ^ xt22_y ^ sa22_sr ^ sa32_sr;
  let sa22_mc: UInt<8> = sa02_sr ^ sa12_sr ^ xt22_y ^ xt32_y ^ sa32_sr;
  let sa32_mc: UInt<8> = xt02_y ^ sa02_sr ^ sa12_sr ^ sa22_sr ^ xt32_y;
  let sa03_mc: UInt<8> = xt03_y ^ xt13_y ^ sa13_sr ^ sa23_sr ^ sa33_sr;
  let sa13_mc: UInt<8> = sa03_sr ^ xt13_y ^ xt23_y ^ sa23_sr ^ sa33_sr;
  let sa23_mc: UInt<8> = sa03_sr ^ sa13_sr ^ xt23_y ^ xt33_y ^ sa33_sr;
  let sa33_mc: UInt<8> = xt03_y ^ sa03_sr ^ sa13_sr ^ sa23_sr ^ xt33_y;

  // ── AddRoundKey after MixColumns (rounds 1-9) ──
  let sa00_ark: UInt<8> = sa00_mc ^ w0.trunc<31,24>();
  let sa10_ark: UInt<8> = sa10_mc ^ w0.trunc<23,16>();
  let sa20_ark: UInt<8> = sa20_mc ^ w0.trunc<15,8>();
  let sa30_ark: UInt<8> = sa30_mc ^ w0.trunc<7,0>();
  let sa01_ark: UInt<8> = sa01_mc ^ w1.trunc<31,24>();
  let sa11_ark: UInt<8> = sa11_mc ^ w1.trunc<23,16>();
  let sa21_ark: UInt<8> = sa21_mc ^ w1.trunc<15,8>();
  let sa31_ark: UInt<8> = sa31_mc ^ w1.trunc<7,0>();
  let sa02_ark: UInt<8> = sa02_mc ^ w2.trunc<31,24>();
  let sa12_ark: UInt<8> = sa12_mc ^ w2.trunc<23,16>();
  let sa22_ark: UInt<8> = sa22_mc ^ w2.trunc<15,8>();
  let sa32_ark: UInt<8> = sa32_mc ^ w2.trunc<7,0>();
  let sa03_ark: UInt<8> = sa03_mc ^ w3.trunc<31,24>();
  let sa13_ark: UInt<8> = sa13_mc ^ w3.trunc<23,16>();
  let sa23_ark: UInt<8> = sa23_mc ^ w3.trunc<15,8>();
  let sa33_ark: UInt<8> = sa33_mc ^ w3.trunc<7,0>();

  // ── AddRoundKey after ShiftRows only (final round) ──
  let sa00_fark: UInt<8> = sa00_sr ^ w0.trunc<31,24>();
  let sa10_fark: UInt<8> = sa10_sr ^ w0.trunc<23,16>();
  let sa20_fark: UInt<8> = sa20_sr ^ w0.trunc<15,8>();
  let sa30_fark: UInt<8> = sa30_sr ^ w0.trunc<7,0>();
  let sa01_fark: UInt<8> = sa01_sr ^ w1.trunc<31,24>();
  let sa11_fark: UInt<8> = sa11_sr ^ w1.trunc<23,16>();
  let sa21_fark: UInt<8> = sa21_sr ^ w1.trunc<15,8>();
  let sa31_fark: UInt<8> = sa31_sr ^ w1.trunc<7,0>();
  let sa02_fark: UInt<8> = sa02_sr ^ w2.trunc<31,24>();
  let sa12_fark: UInt<8> = sa12_sr ^ w2.trunc<23,16>();
  let sa22_fark: UInt<8> = sa22_sr ^ w2.trunc<15,8>();
  let sa32_fark: UInt<8> = sa32_sr ^ w2.trunc<7,0>();
  let sa03_fark: UInt<8> = sa03_sr ^ w3.trunc<31,24>();
  let sa13_fark: UInt<8> = sa13_sr ^ w3.trunc<23,16>();
  let sa23_fark: UInt<8> = sa23_sr ^ w3.trunc<15,8>();
  let sa33_fark: UInt<8> = sa33_sr ^ w3.trunc<7,0>();

  // ── FSM control + state matrix updates ──
  seq on clk rising
    ld_r <= ld;

    if ld
      dcnt <= 0xb;
    elsif dcnt != 0
      dcnt <= (dcnt - 1).trunc<4>();
    end if

    if ld_r
      sa00 <= text_in_r.trunc<127,120>() ^ w0.trunc<31,24>();
      sa10 <= text_in_r.trunc<119,112>() ^ w0.trunc<23,16>();
      sa20 <= text_in_r.trunc<111,104>() ^ w0.trunc<15,8>();
      sa30 <= text_in_r.trunc<103,96>()  ^ w0.trunc<7,0>();
      sa01 <= text_in_r.trunc<95,88>()   ^ w1.trunc<31,24>();
      sa11 <= text_in_r.trunc<87,80>()   ^ w1.trunc<23,16>();
      sa21 <= text_in_r.trunc<79,72>()   ^ w1.trunc<15,8>();
      sa31 <= text_in_r.trunc<71,64>()   ^ w1.trunc<7,0>();
      sa02 <= text_in_r.trunc<63,56>()   ^ w2.trunc<31,24>();
      sa12 <= text_in_r.trunc<55,48>()   ^ w2.trunc<23,16>();
      sa22 <= text_in_r.trunc<47,40>()   ^ w2.trunc<15,8>();
      sa32 <= text_in_r.trunc<39,32>()   ^ w2.trunc<7,0>();
      sa03 <= text_in_r.trunc<31,24>()   ^ w3.trunc<31,24>();
      sa13 <= text_in_r.trunc<23,16>()   ^ w3.trunc<23,16>();
      sa23 <= text_in_r.trunc<15,8>()    ^ w3.trunc<15,8>();
      sa33 <= text_in_r.trunc<7,0>()     ^ w3.trunc<7,0>();
    elsif dcnt > 1
      sa00 <= sa00_ark;  sa01 <= sa01_ark;  sa02 <= sa02_ark;  sa03 <= sa03_ark;
      sa10 <= sa10_ark;  sa11 <= sa11_ark;  sa12 <= sa12_ark;  sa13 <= sa13_ark;
      sa20 <= sa20_ark;  sa21 <= sa21_ark;  sa22 <= sa22_ark;  sa23 <= sa23_ark;
      sa30 <= sa30_ark;  sa31 <= sa31_ark;  sa32 <= sa32_ark;  sa33 <= sa33_ark;
    elsif dcnt == 1
      sa00 <= sa00_fark;  sa01 <= sa01_fark;  sa02 <= sa02_fark;  sa03 <= sa03_fark;
      sa10 <= sa10_fark;  sa11 <= sa11_fark;  sa12 <= sa12_fark;  sa13 <= sa13_fark;
      sa20 <= sa20_fark;  sa21 <= sa21_fark;  sa22 <= sa22_fark;  sa23 <= sa23_fark;
      sa30 <= sa30_fark;  sa31 <= sa31_fark;  sa32 <= sa32_fark;  sa33 <= sa33_fark;
    end if

    if ld
      text_in_r <= text_in;
    end if

    if ld
      done_r <= false;
    elsif dcnt == 1
      done_r <= true;
    end if

    if dcnt == 1
      text_out_r <= { sa00_fark, sa10_fark, sa20_fark, sa30_fark,
                      sa01_fark, sa11_fark, sa21_fark, sa31_fark,
                      sa02_fark, sa12_fark, sa22_fark, sa32_fark,
                      sa03_fark, sa13_fark, sa23_fark, sa33_fark };
    end if
  end seq

  comb
    done = done_r;
    text_out = text_out_r;
  end comb
end module AesCipherTop
