// AES Round Constant Generator
// Generates round constants for the AES key expansion process.
// Counter-based lookup: rcnt counts 0..9 on each clock when kld is low,
// resets to 0 when kld is high.

domain SysDomain
  freq_mhz: 100,
end domain SysDomain

module AesRcon
  port clk: in Clock<SysDomain>;
  port kld: in Bool;
  port out_rcon: out UInt<32>;

  reg rcnt: UInt<4> init 0 reset none;

  seq on clk rising
    if kld
      rcnt <= 0;
    else
      rcnt <= (rcnt + 1).trunc<4>();
    end if
  end seq

  comb
    out_rcon = match rcnt
      0x0 => 0x01000000,
      0x1 => 0x02000000,
      0x2 => 0x04000000,
      0x3 => 0x08000000,
      0x4 => 0x10000000,
      0x5 => 0x20000000,
      0x6 => 0x40000000,
      0x7 => 0x80000000,
      0x8 => 0x1b000000,
      0x9 => 0x36000000,
      _ => 0x00000000,
    end match;
  end comb
end module AesRcon
