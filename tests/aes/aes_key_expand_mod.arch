// AES 128-bit Key Expansion (standalone module, depends on AesSbox + AesRcon)
module AesKeyExpand128
  port clk: in Clock<SysDomain>;
  port kld: in Bool;
  port key: in UInt<128>;
  port wo_0: out UInt<32>;
  port wo_1: out UInt<32>;
  port wo_2: out UInt<32>;
  port wo_3: out UInt<32>;

  reg w0: UInt<32> init 0 reset none;
  reg w1: UInt<32> init 0 reset none;
  reg w2: UInt<32> init 0 reset none;
  reg w3: UInt<32> init 0 reset none;

  inst sbox0: AesSbox
    a <- w3[23:16];
    b -> subword0;
  end inst sbox0

  inst sbox1: AesSbox
    a <- w3[15:8];
    b -> subword1;
  end inst sbox1

  inst sbox2: AesSbox
    a <- w3[7:0];
    b -> subword2;
  end inst sbox2

  inst sbox3: AesSbox
    a <- w3[31:24];
    b -> subword3;
  end inst sbox3

  inst rcon0: AesRcon
    clk <- clk;
    kld <- kld;
    out_rcon -> rcon_val;
  end inst rcon0

  let t: UInt<32> = { subword0, subword1, subword2, subword3 } ^ rcon_val;
  let nw0: UInt<32> = w0 ^ t;
  let nw1: UInt<32> = w1 ^ w0 ^ t;
  let nw2: UInt<32> = w2 ^ w1 ^ w0 ^ t;
  let nw3: UInt<32> = w3 ^ w2 ^ w1 ^ w0 ^ t;

  seq on clk rising
    if kld
      w0 <= key[127:96];
      w1 <= key[95:64];
      w2 <= key[63:32];
      w3 <= key[31:0];
    else
      w0 <= nw0;
      w1 <= nw1;
      w2 <= nw2;
      w3 <= nw3;
    end if
  end seq

  comb
    wo_0 = w0;
    wo_1 = w1;
    wo_2 = w2;
    wo_3 = w3;
  end comb
end module AesKeyExpand128
