// =============================================================================
// BufMgr — 256-Queue Shared Buffer Manager
//
// 16K entries x 128-bit data pool, 256 dynamically-sharing queues.
// Singly-linked list per queue; all pointers + data in SRAM.
// Head/tail pointers in flops.  Simultaneous enqueue + dequeue every cycle.
//
// Sub-components (separate files):
//   DataMem       — 16K x 128b  simple_dual  sync_out (2-cycle read)
//   NextPtrMem    — 16K x 14b   simple_dual  sync_out (2-cycle read)
//   FreeListBank  — 8K x 14b    simple_dual  sync_out (2-cycle read) x 2
//
// Free-list uses 2-bank interleaving to hide 2-cycle read latency:
//   Bank0 holds even-index entries, Bank1 holds odd-index entries.
//   Alternating prefetch reads → 1 free slot per cycle once primed.
//   Results stored in a 4-entry flop FIFO for immediate access at EQ0.
//
// Enqueue pipeline: EQ0 → EQ1 → EQ2  (3 stages)
// Dequeue pipeline: DQ0 → DQ1 → DQ2  (3 stages)
// =============================================================================

module BufMgr
  param DEPTH:       const = 16384;
  param QUEUE_COUNT: const = 256;
  param DATA_WIDTH:  const = 128;
  param PTR_WIDTH:   const = 14;
  param QN_WIDTH:    const = 8;

  port clk: in Clock<SysDomain>;
  port rst: in Reset<Sync>;

  port enqueue_valid:        in Bool;
  port enqueue_queue_number: in UInt<8>;
  port enqueue_data:         in UInt<128>;

  port dequeue_valid:        in Bool;
  port dequeue_queue_number: in UInt<8>;
  port dequeue_resp_valid:   out Bool;
  port dequeue_data:         out UInt<128>;

  port free_count_out: out UInt<15>;
  port init_done:      out Bool;

  reg default: init 0 reset rst=>0;

  // ── Flop arrays (256 entries) ──
  reg head_arr:  Vec<UInt<14>, 256>;
  reg tail_arr:  Vec<UInt<14>, 256>;
  reg count_arr: Vec<UInt<15>, 256>;

  // ── Init FSM ──
  reg setup_done: Bool;
  reg setup_ctr:  UInt<14>;

  // ── Free-list state ──
  reg free_count:   UInt<15>;
  reg fl_wr_ptr:    UInt<14>;

  // Prefetch pipeline: tracks reads in-flight through sync_out latency
  reg fl_rd_ptr:       UInt<14>;
  reg fl_pipe_d1:      Bool;
  reg fl_pipe_d2:      Bool;
  reg fl_pipe_bank_d1: Bool;
  reg fl_pipe_bank_d2: Bool;

  // 4-entry flop FIFO for prefetched free slots (circular buffer)
  reg fl_buf0:      UInt<14>;
  reg fl_buf1:      UInt<14>;
  reg fl_buf2:      UInt<14>;
  reg fl_buf3:      UInt<14>;
  reg fl_buf_count: UInt<3>;
  reg fl_buf_wr:    UInt<2>;
  reg fl_buf_rd:    UInt<2>;

  // ── Enqueue pipeline registers ──
  reg eq1_valid:      Bool;
  reg eq1_qn:         UInt<8>;
  reg eq1_data:       UInt<128>;
  reg eq1_old_tail:   UInt<14>;
  reg eq1_was_empty:  Bool;
  reg eq1_alloc_slot: UInt<14>;

  reg eq2_valid:      Bool;
  reg eq2_qn:         UInt<8>;
  reg eq2_data:       UInt<128>;
  reg eq2_old_tail:   UInt<14>;
  reg eq2_was_empty:  Bool;
  reg eq2_alloc_slot: UInt<14>;

  // ── Dequeue pipeline registers ──
  reg dq1_valid:    Bool;
  reg dq1_qn:       UInt<8>;
  reg dq1_old_head: UInt<14>;

  reg dq2_valid:    Bool;
  reg dq2_qn:       UInt<8>;
  reg dq2_old_head: UInt<14>;

  // ── SRAM output wires (no reset — driven by SRAM outputs) ──
  reg fbank0_rd_data:  UInt<14> reset none;
  reg fbank1_rd_data:  UInt<14> reset none;
  reg data_rd_data:    UInt<128> reset none;
  reg next_ptr_rd_data: UInt<14> reset none;

  // ── Combinational: prefetch buffer output (4-entry mux) ──
  let alloc_slot: UInt<14> =
    fl_buf_rd == 2'h0 ? fl_buf0
    : fl_buf_rd == 2'h1 ? fl_buf1
    : fl_buf_rd == 2'h2 ? fl_buf2
    : fl_buf3;

  // ── Combinational: bypass logic ──
  let eq0_tail_bypassed: UInt<14> =
    eq1_valid and (eq1_qn == enqueue_queue_number) ? eq1_alloc_slot
    : eq2_valid and (eq2_qn == enqueue_queue_number) ? eq2_alloc_slot
    : tail_arr[enqueue_queue_number];

  let eq0_count_raw: UInt<15> = count_arr[enqueue_queue_number];
  let eq0_count_adj_eq2: UInt<15> =
    eq2_valid and (eq2_qn == enqueue_queue_number) ? (eq0_count_raw + 14'h1).trunc<15>()
    : eq0_count_raw;
  let eq0_count_adj_eq1: UInt<15> =
    eq1_valid and (eq1_qn == enqueue_queue_number) ? (eq0_count_adj_eq2 + 14'h1).trunc<15>()
    : eq0_count_adj_eq2;
  let eq0_was_empty: Bool = eq0_count_adj_eq1 == 15'h0;

  let dq0_head_bypassed: UInt<14> =
    dq2_valid and (dq2_qn == dequeue_queue_number) ? next_ptr_rd_data
    : head_arr[dequeue_queue_number];

  // ── Combinational: free-list bank address/select ──
  let fl_rd_bank: Bool = fl_rd_ptr.trunc<1>();
  let fl_rd_addr: UInt<13> = (fl_rd_ptr >> 1).trunc<13>();
  let fl_wr_bank: Bool = fl_wr_ptr.trunc<1>();
  let fl_wr_addr: UInt<13> = (fl_wr_ptr >> 1).trunc<13>();
  let setup_bank: Bool = setup_ctr.trunc<1>();
  let setup_addr: UInt<13> = (setup_ctr >> 1).trunc<13>();

  // Prefetch control: issue read if buffer + in-flight < 4
  let fl_inflight: UInt<3> = (fl_pipe_d1.zext<3>() + fl_pipe_d2.zext<3>()).trunc<3>();
  let fl_pending: UInt<3> = (fl_buf_count + fl_inflight).trunc<3>();
  let fl_do_prefetch: Bool = setup_done and (fl_pending != 3'h4);

  // Arriving data from whichever bank was read 2 cycles ago
  let fl_arriving_slot: UInt<14> = fl_pipe_bank_d2 ? fbank1_rd_data : fbank0_rd_data;

  // ── RAM Instances ──

  inst dmem: DataMem
    clk           <- clk;
    wr_port.en    <- eq2_valid;
    wr_port.addr  <- eq2_alloc_slot;
    wr_port.data  <- eq2_data;
    rd_port.en    <- dequeue_valid and setup_done;
    rd_port.addr  <- dq0_head_bypassed;
    rd_port.data  -> data_rd_data;
  end inst dmem

  inst nptr: NextPtrMem
    clk           <- clk;
    wr_port.en    <- eq2_valid and (not eq2_was_empty);
    wr_port.addr  <- eq2_old_tail;
    wr_port.data  <- eq2_alloc_slot;
    rd_port.en    <- dequeue_valid and setup_done;
    rd_port.addr  <- dq0_head_bypassed;
    rd_port.data  -> next_ptr_rd_data;
  end inst nptr

  inst fbank0: FreeListBank
    clk           <- clk;
    rd_port.en    <- fl_do_prefetch and (not fl_rd_bank);
    rd_port.addr  <- setup_done ? fl_rd_addr : setup_addr;
    wr_port.en    <- (not setup_done and not setup_bank) or (setup_done and dq2_valid and not fl_wr_bank);
    wr_port.addr  <- setup_done ? fl_wr_addr : setup_addr;
    wr_port.data  <- setup_done ? dq2_old_head : setup_ctr;
    rd_port.data  -> fbank0_rd_data;
  end inst fbank0

  inst fbank1: FreeListBank
    clk           <- clk;
    rd_port.en    <- fl_do_prefetch and fl_rd_bank;
    rd_port.addr  <- setup_done ? fl_rd_addr : setup_addr;
    wr_port.en    <- (not setup_done and setup_bank) or (setup_done and dq2_valid and fl_wr_bank);
    wr_port.addr  <- setup_done ? fl_wr_addr : setup_addr;
    wr_port.data  <- setup_done ? dq2_old_head : setup_ctr;
    rd_port.data  -> fbank1_rd_data;
  end inst fbank1

  // ══════════════════════════════════════════════════════════════════════════
  // Clocked logic
  // ══════════════════════════════════════════════════════════════════════════

  seq on clk rising

    // ── Init FSM: fill both free-list banks ──
    if not setup_done
      setup_ctr <= (setup_ctr + 14'h1).trunc<14>();
      if setup_ctr == 14'h3FFF
        setup_done <= 1'b1;
        free_count <= 15'h4000;
        fl_rd_ptr  <= 14'h0;
        fl_wr_ptr  <= 14'h0;
      end if
    end if

    // ── Prefetch pipeline shift ──
    fl_pipe_d2      <= fl_pipe_d1;
    fl_pipe_bank_d2 <= fl_pipe_bank_d1;

    // Issue prefetch read
    if fl_do_prefetch
      fl_pipe_d1      <= 1'b1;
      fl_pipe_bank_d1 <= fl_rd_bank;
      fl_rd_ptr       <= (fl_rd_ptr + 14'h1).trunc<14>();
    else
      fl_pipe_d1      <= 1'b0;
    end if

    // Capture arriving prefetch result into FIFO
    if fl_pipe_d2
      if fl_buf_wr == 2'h0
        fl_buf0 <= fl_arriving_slot;
      end if
      if fl_buf_wr == 2'h1
        fl_buf1 <= fl_arriving_slot;
      end if
      if fl_buf_wr == 2'h2
        fl_buf2 <= fl_arriving_slot;
      end if
      if fl_buf_wr == 2'h3
        fl_buf3 <= fl_arriving_slot;
      end if
      fl_buf_wr    <= (fl_buf_wr + 2'h1).trunc<2>();
      fl_buf_count <= (fl_buf_count + 3'h1).trunc<3>();
    end if

    // ── Enqueue Pipeline ──

    // EQ0: consume from prefetch buffer, capture inputs
    if enqueue_valid and setup_done
      eq1_valid      <= 1'b1;
      eq1_qn         <= enqueue_queue_number;
      eq1_data       <= enqueue_data;
      eq1_old_tail   <= eq0_tail_bypassed;
      eq1_was_empty  <= eq0_was_empty;
      eq1_alloc_slot <= alloc_slot;
      fl_buf_rd      <= (fl_buf_rd + 2'h1).trunc<2>();
      fl_buf_count   <= (fl_buf_count - 3'h1).trunc<3>();
      free_count     <= (free_count - 15'h1).trunc<15>();
    else
      eq1_valid      <= 1'b0;
    end if

    // Simultaneous prefetch arrive + enqueue consume: net zero on fl_buf_count
    if fl_pipe_d2 and enqueue_valid and setup_done
      fl_buf_count <= fl_buf_count;
    end if

    // EQ1 → EQ2
    eq2_valid      <= eq1_valid;
    eq2_qn         <= eq1_qn;
    eq2_data       <= eq1_data;
    eq2_old_tail   <= eq1_old_tail;
    eq2_was_empty  <= eq1_was_empty;
    eq2_alloc_slot <= eq1_alloc_slot;

    // EQ2 commit: update flop arrays
    if eq2_valid
      tail_arr[eq2_qn]  <= eq2_alloc_slot;
      count_arr[eq2_qn] <= (count_arr[eq2_qn] + 15'h1).trunc<15>();
      if eq2_was_empty
        head_arr[eq2_qn] <= eq2_alloc_slot;
      end if
    end if

    // ── Dequeue Pipeline ──

    // DQ0: issue SRAM reads
    if dequeue_valid and setup_done
      dq1_valid    <= 1'b1;
      dq1_qn       <= dequeue_queue_number;
      dq1_old_head <= dq0_head_bypassed;
    else
      dq1_valid    <= 1'b0;
    end if

    // DQ1 → DQ2
    dq2_valid    <= dq1_valid;
    dq2_qn       <= dq1_qn;
    dq2_old_head <= dq1_old_head;

    // DQ2 commit: return freed slot to free-list bank, update flop arrays
    if dq2_valid
      head_arr[dq2_qn]  <= next_ptr_rd_data;
      count_arr[dq2_qn] <= (count_arr[dq2_qn] - 15'h1).trunc<15>();
      fl_wr_ptr          <= (fl_wr_ptr + 14'h1).trunc<14>();
      free_count         <= (free_count + 15'h1).trunc<15>();
    end if

    // ── Simultaneous EQ2 + DQ2 same-queue count fix ──
    if eq2_valid and dq2_valid and (eq2_qn == dq2_qn)
      count_arr[eq2_qn] <= count_arr[eq2_qn];
    end if

    // Simultaneous alloc + free: net zero on free_count
    if (enqueue_valid and setup_done) and dq2_valid
      free_count <= free_count;
    end if

  end seq

  comb
    dequeue_resp_valid = dq2_valid;
    dequeue_data       = data_rd_data;
    free_count_out     = free_count;
    init_done          = setup_done and (fl_buf_count >= 3'h2);
  end comb

end module BufMgr
