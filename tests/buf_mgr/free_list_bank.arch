// Free-List Bank SRAM: 8K x 14b, simple_dual, sync_out (2-cycle read)
// Two instances used for 2-bank interleaving to hide read latency.

ram FreeListBank
  kind simple_dual;
  latency 2;
  param DEPTH: const = 8192;
  param T: type = UInt<14>;
  port clk: in Clock<SysDomain>;
  store
    slots: Vec<T, DEPTH>;
  end store
  ports rd_port
    en:   in Bool;
    addr: in UInt<13>;
    data: out T;
  end ports rd_port
  ports wr_port
    en:   in Bool;
    addr: in UInt<13>;
    data: in T;
  end ports wr_port
end ram FreeListBank
