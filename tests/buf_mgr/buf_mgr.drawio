<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net">
  <diagram name="BufMgr Architecture" id="buf_mgr_arch">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="&lt;b&gt;BufMgr — 256-Queue Shared Buffer Manager&lt;/b&gt;&lt;br&gt;16K entries x 128b, 2-port SRAMs, sync_out 2-cycle read latency&lt;br&gt;2-bank free-list interleaving with 4-entry prefetch FIFO" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="350" y="10" width="560" height="60" as="geometry"/>
        </mxCell>

        <!-- ══════════════════════════════════════════════ -->
        <!-- Primary Inputs (left side) -->
        <!-- ══════════════════════════════════════════════ -->
        <mxCell id="enq_in" value="&lt;b&gt;Enqueue Input&lt;/b&gt;&lt;br&gt;enqueue_valid&lt;br&gt;enqueue_queue_number[7:0]&lt;br&gt;enqueue_data[127:0]" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="20" y="200" width="220" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="deq_in" value="&lt;b&gt;Dequeue Input&lt;/b&gt;&lt;br&gt;dequeue_valid&lt;br&gt;dequeue_queue_number[7:0]" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="20" y="750" width="220" height="70" as="geometry"/>
        </mxCell>

        <!-- ══════════════════════════════════════════════ -->
        <!-- Enqueue Pipeline (top row) -->
        <!-- ══════════════════════════════════════════════ -->
        <mxCell id="eq0" value="&lt;b&gt;EQ0&lt;/b&gt;&lt;br&gt;Consume prefetch buf&lt;br&gt;Read tail[qn]&lt;br&gt;Read count[qn]&lt;br&gt;(+bypass from EQ1/EQ2)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="300" y="180" width="160" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="eq1" value="&lt;b&gt;EQ1&lt;/b&gt;&lt;br&gt;Pipeline reg&lt;br&gt;(alloc_slot captured)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="520" y="180" width="140" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="eq2" value="&lt;b&gt;EQ2&lt;/b&gt;&lt;br&gt;Write DataMem[slot]&lt;br&gt;Write NextPtrMem[old_tail]&lt;br&gt;Update tail[qn], count[qn]&lt;br&gt;Set head if was_empty" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="720" y="180" width="180" height="100" as="geometry"/>
        </mxCell>

        <!-- Enqueue pipeline arrows -->
        <mxCell id="e_in_eq0" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="enq_in" target="eq0" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_eq0_eq1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="eq0" target="eq1" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_eq1_eq2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="eq1" target="eq2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ══════════════════════════════════════════════ -->
        <!-- Dequeue Pipeline (bottom row) -->
        <!-- ══════════════════════════════════════════════ -->
        <mxCell id="dq0" value="&lt;b&gt;DQ0&lt;/b&gt;&lt;br&gt;Read head[qn]&lt;br&gt;Issue DataMem rd&lt;br&gt;Issue NextPtr rd&lt;br&gt;(+bypass from DQ2)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="300" y="730" width="160" height="110" as="geometry"/>
        </mxCell>

        <mxCell id="dq1" value="&lt;b&gt;DQ1&lt;/b&gt;&lt;br&gt;Pipeline reg&lt;br&gt;(SRAM cycle 2)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="520" y="730" width="140" height="110" as="geometry"/>
        </mxCell>

        <mxCell id="dq2" value="&lt;b&gt;DQ2&lt;/b&gt;&lt;br&gt;data + next_ptr ready&lt;br&gt;Output dequeue_data&lt;br&gt;Write FreeListBank&lt;br&gt;Update head[qn], count[qn]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="720" y="730" width="180" height="110" as="geometry"/>
        </mxCell>

        <!-- Dequeue pipeline arrows -->
        <mxCell id="e_in_dq0" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="deq_in" target="dq0" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_dq0_dq1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="dq0" target="dq1" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_dq1_dq2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="dq1" target="dq2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ══════════════════════════════════════════════ -->
        <!-- Primary Output (right side) -->
        <!-- ══════════════════════════════════════════════ -->
        <mxCell id="deq_out" value="&lt;b&gt;Dequeue Output&lt;/b&gt;&lt;br&gt;dequeue_resp_valid&lt;br&gt;dequeue_data[127:0]" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="980" y="750" width="220" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="status_out" value="&lt;b&gt;Status Output&lt;/b&gt;&lt;br&gt;free_count_out[14:0]&lt;br&gt;init_done" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="980" y="200" width="200" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="e_dq2_out" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="dq2" target="deq_out" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ══════════════════════════════════════════════ -->
        <!-- SRAMs (center) -->
        <!-- ══════════════════════════════════════════════ -->
        <mxCell id="data_mem" value="&lt;b&gt;DataMem&lt;/b&gt;&lt;br&gt;16K x 128b&lt;br&gt;simple_dual&lt;br&gt;sync_out (2-cyc)&lt;br&gt;&lt;hr&gt;WR ← EQ2&lt;br&gt;RD ← DQ0" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="550" y="400" width="150" height="130" as="geometry"/>
        </mxCell>

        <mxCell id="next_mem" value="&lt;b&gt;NextPtrMem&lt;/b&gt;&lt;br&gt;16K x 14b&lt;br&gt;simple_dual&lt;br&gt;sync_out (2-cyc)&lt;br&gt;&lt;hr&gt;WR ← EQ2&lt;br&gt;RD ← DQ0" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="750" y="400" width="150" height="130" as="geometry"/>
        </mxCell>

        <!-- 2-bank free list -->
        <mxCell id="fbank0" value="&lt;b&gt;FreeListBank0&lt;/b&gt;&lt;br&gt;8K x 14b (even)&lt;br&gt;simple_dual&lt;br&gt;sync_out (2-cyc)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="140" y="520" width="140" height="110" as="geometry"/>
        </mxCell>

        <mxCell id="fbank1" value="&lt;b&gt;FreeListBank1&lt;/b&gt;&lt;br&gt;8K x 14b (odd)&lt;br&gt;simple_dual&lt;br&gt;sync_out (2-cyc)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="310" y="520" width="140" height="110" as="geometry"/>
        </mxCell>

        <!-- Prefetch pipeline + buffer -->
        <mxCell id="prefetch" value="&lt;b&gt;Prefetch Pipeline&lt;/b&gt;&lt;br&gt;fl_pipe_d1 → fl_pipe_d2&lt;br&gt;(tracks bank + valid)&lt;br&gt;&lt;hr&gt;&lt;b&gt;4-Entry FIFO Buffer&lt;/b&gt;&lt;br&gt;fl_buf[0..3] (14b each)&lt;br&gt;fl_buf_wr / fl_buf_rd&lt;br&gt;fl_buf_count[2:0]&lt;br&gt;&lt;hr&gt;Refill: 1 slot/cyc once primed&lt;br&gt;Absorbs bursts of 4 enqueues" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="120" y="340" width="200" height="160" as="geometry"/>
        </mxCell>

        <!-- Prefetch connections -->
        <mxCell id="e_pfetch_fbank0" value="rd (even)" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#d79b00;" edge="1" source="prefetch" target="fbank0" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_pfetch_fbank1" value="rd (odd)" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#d79b00;" edge="1" source="prefetch" target="fbank1" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_pfetch_eq0" value="alloc_slot" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#d79b00;" edge="1" source="prefetch" target="eq0" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- SRAM connections from enqueue -->
        <mxCell id="e_eq2_data" value="wr data" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#d6b656;" edge="1" source="eq2" target="data_mem" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_eq2_next" value="wr next_ptr" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#d6b656;" edge="1" source="eq2" target="next_mem" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- SRAM connections from dequeue -->
        <mxCell id="e_dq0_data" value="rd" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#82b366;" edge="1" source="dq0" target="data_mem" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_dq0_next" value="rd" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#82b366;" edge="1" source="dq0" target="next_mem" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_dq2_fbank0" value="wr (free, even)" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#82b366;" edge="1" source="dq2" target="fbank0" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_dq2_fbank1" value="wr (free, odd)" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#82b366;" edge="1" source="dq2" target="fbank1" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ══════════════════════════════════════════════ -->
        <!-- Flop Arrays (right side, center) -->
        <!-- ══════════════════════════════════════════════ -->
        <mxCell id="head_arr" value="&lt;b&gt;head[256]&lt;/b&gt;&lt;br&gt;14b x 256 (flops)&lt;br&gt;RD: DQ0 (+bypass)&lt;br&gt;WR: EQ2 (was_empty), DQ2" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="980" y="400" width="170" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="tail_arr" value="&lt;b&gt;tail[256]&lt;/b&gt;&lt;br&gt;14b x 256 (flops)&lt;br&gt;RD: EQ0 (+bypass)&lt;br&gt;WR: EQ2" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="980" y="500" width="170" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="count_arr" value="&lt;b&gt;count[256]&lt;/b&gt;&lt;br&gt;15b x 256 (flops)&lt;br&gt;RD: EQ0 (+bypass), DQ0&lt;br&gt;WR: EQ2 (+1), DQ2 (-1)&lt;br&gt;Simul fix: net zero" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="1180" y="440" width="170" height="100" as="geometry"/>
        </mxCell>

        <!-- Flop array connections -->
        <mxCell id="e_eq0_tail" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#9673a6;" edge="1" source="eq0" target="tail_arr" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_dq0_head" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#9673a6;" edge="1" source="dq0" target="head_arr" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ══════════════════════════════════════════════ -->
        <!-- Bypass arrows -->
        <!-- ══════════════════════════════════════════════ -->
        <mxCell id="bypass_eq" value="bypass tail/count (EQ1→EQ0, EQ2→EQ0)" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#FF0000;curved=1;" edge="1" source="eq2" target="eq0" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="810" y="140"/>
              <mxPoint x="380" y="140"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="bypass_dq" value="bypass head (DQ2→DQ0)" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#FF0000;curved=1;" edge="1" source="dq2" target="dq0" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="810" y="890"/>
              <mxPoint x="380" y="890"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ══════════════════════════════════════════════ -->
        <!-- Free list flop state -->
        <!-- ══════════════════════════════════════════════ -->
        <mxCell id="free_ptrs" value="&lt;b&gt;Free-list state (flops)&lt;/b&gt;&lt;br&gt;fl_rd_ptr[13:0]&lt;br&gt;fl_wr_ptr[13:0]&lt;br&gt;free_count[14:0]&lt;br&gt;setup_done, setup_ctr" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="20" y="100" width="180" height="90" as="geometry"/>
        </mxCell>

        <!-- ══════════════════════════════════════════════ -->
        <!-- Legend -->
        <!-- ══════════════════════════════════════════════ -->
        <mxCell id="legend" value="&lt;b&gt;Legend&lt;/b&gt;&lt;br&gt;Yellow = Enqueue pipeline (EQ0→EQ1→EQ2)&lt;br&gt;Green = Dequeue pipeline (DQ0→DQ1→DQ2)&lt;br&gt;Orange = Prefetch pipeline + 4-entry FIFO&lt;br&gt;Red cylinder = SRAM (sync_out, 2-cycle read)&lt;br&gt;Purple = Flop arrays / state&lt;br&gt;Red dashed = Bypass/forwarding&lt;br&gt;&lt;hr&gt;Init: 16K cycles to fill FreeListBank0/1&lt;br&gt;Steady state: 1 alloc + 1 free per cycle" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="20" y="940" width="320" height="160" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
