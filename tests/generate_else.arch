// Integration test for generate if/else: when condition is false, else ports/insts are active.
module GenElseTest
  port clk: in Clock<SysDomain>;

  // false → else branch: main_out exists, debug_out does not
  generate if false
    port debug_out: out UInt<8>;
  generate else
    port main_out: out UInt<16>;
  end generate if

  // true → then branch: then_out exists, skip_out does not
  generate if true
    port then_out: out UInt<8>;
  generate else
    port skip_out: out UInt<8>;
  end generate if

  comb
    main_out = 16'hABCD;
    then_out = 8'h42;
  end comb
end module GenElseTest
