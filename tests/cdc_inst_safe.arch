domain DomainA
  freq_mhz: 100
end domain DomainA

domain DomainB
  freq_mhz: 200
end domain DomainB

module Producer
  port clk: in Clock<DomainA>;
  port rst: in Reset<Sync>;
  port data_out: out UInt<8>;

  reg cnt: UInt<8> init 0 reset rst=>0;

  seq on clk rising
    cnt <= (cnt + 1).trunc<8>();
  end seq

  let data_out = cnt;end module Producer

module Consumer
  port clk: in Clock<DomainB>;
  port rst: in Reset<Sync>;
  port data_in: in UInt<8>;
  port data_out: out UInt<8>;

  reg r: UInt<8> init 0 reset rst=>0;

  seq on clk rising
    r <= data_in;
  end seq

  let data_out = r;end module Consumer

module TopSafe
  port clk_a: in Clock<DomainA>;
  port clk_b: in Clock<DomainB>;
  port rst: in Reset<Sync>;
  port result: out UInt<8>;

  reg synced_data: UInt<8> init 0 reset rst=>0;

  inst prod: Producer
    clk <- clk_a;
    rst <- rst;
    data_out -> synced_data;
  end inst prod

  inst cons: Consumer
    clk <- clk_b;
    rst <- rst;
    data_in <- synced_data;
    data_out -> result;
  end inst cons
end module TopSafe
