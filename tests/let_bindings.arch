// Test: let bindings — typed and untyped
domain SysDomain
  freq_mhz: 100
end domain SysDomain

module LetDemo
  port a:      in UInt<8>;
  port b:      in UInt<8>;
  port masked: out UInt<8>;
  port equal:  out Bool;

  // Typed let binding: explicit type annotation
  let mask: UInt<8> = a & b;

  // Untyped let binding: type inferred from expression
  let same: Bool = a == b;

  comb
    masked = mask;
    equal  = same;
  end comb

end module LetDemo
