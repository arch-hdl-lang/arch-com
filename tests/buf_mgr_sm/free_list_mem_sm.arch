// Free-List SRAM: 16 x 4b, simple_dual, sync (1-cycle read)

ram FreeListMemSm
  kind simple_dual;
  latency 1;
  param DEPTH: const = 16;
  param T: type = UInt<4>;
  port clk: in Clock<SysDomain>;
  store
    slots: Vec<T, DEPTH>;
  end store
  ports rd_port
    en:   in Bool;
    addr: in UInt<4>;
    data: out T;
  end ports rd_port
  ports wr_port
    en:   in Bool;
    addr: in UInt<4>;
    data: in T;
  end ports wr_port
end ram FreeListMemSm
