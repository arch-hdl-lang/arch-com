// Next-Pointer SRAM: 16 x 4b, simple_dual, sync (1-cycle read)

ram NextPtrMemSm
  kind simple_dual;
  latency 1;
  param DEPTH: const = 16;
  param WIDTH: type = UInt<4>;
  port clk: in Clock<SysDomain>;
  store
    ptrs: Vec<WIDTH, DEPTH>;
  end store
  port rd_port
    en:   in Bool;
    addr: in UInt<4>;
    data: out WIDTH;
  end port rd_port
  port wr_port
    en:   in Bool;
    addr: in UInt<4>;
    data: in WIDTH;
  end port wr_port
end ram NextPtrMemSm
