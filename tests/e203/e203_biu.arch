// E203 HBirdv2 Bus Interface Unit (BIU)
// Routes memory transactions from LSU to ITCM, DTCM, or external bus
// based on address decoding.
//   ITCM: 0x80000000 - 0x8000FFFF (64KB)
//   DTCM: 0x90000000 - 0x9000FFFF (64KB)
// Pure combinational address decode + mux.

module Biu
  param ITCM_BASE: const = 0x80000000;
  param DTCM_BASE: const = 0x90000000;
  param TCM_SIZE:  const = 0x10000;

  // LSU interface (from core)
  port lsu_addr:    in  UInt<32>;
  port lsu_wdata:   in  UInt<32>;
  port lsu_wstrb:   in  UInt<4>;
  port lsu_wen:     in  Bool;
  port lsu_ren:     in  Bool;
  port lsu_rdata:   out UInt<32>;

  // ITCM interface
  port itcm_rd_en:   out Bool;
  port itcm_rd_addr: out UInt<14>;
  port itcm_rd_data: in  UInt<32>;
  port itcm_wr_en:   out Bool;
  port itcm_wr_addr: out UInt<14>;
  port itcm_wr_data: out UInt<32>;

  // DTCM interface
  port dtcm_rd_en:   out Bool;
  port dtcm_rd_addr: out UInt<14>;
  port dtcm_rd_data: in  UInt<32>;
  port dtcm_wr_en:   out Bool;
  port dtcm_wr_addr: out UInt<14>;
  port dtcm_wr_data: out UInt<32>;
  port dtcm_wr_be:   out UInt<4>;

  // Address decode
  let addr_top: UInt<16> = lsu_addr.trunc<31,16>();
  let is_itcm: Bool = (addr_top == ITCM_BASE.trunc<31,16>());
  let is_dtcm: Bool = (addr_top == DTCM_BASE.trunc<31,16>());
  let word_addr: UInt<14> = lsu_addr.trunc<15,2>();

  comb
    // ITCM: read-only from BIU perspective (writes go through IFU path)
    // But allow store to ITCM for self-modifying code / boot loading
    itcm_rd_en   = is_itcm & lsu_ren;
    itcm_rd_addr = word_addr;
    itcm_wr_en   = is_itcm & lsu_wen;
    itcm_wr_addr = word_addr;
    itcm_wr_data = lsu_wdata;

    // DTCM: primary data memory
    dtcm_rd_en   = is_dtcm & lsu_ren;
    dtcm_rd_addr = word_addr;
    dtcm_wr_en   = is_dtcm & lsu_wen;
    dtcm_wr_addr = word_addr;
    dtcm_wr_data = lsu_wdata;
    dtcm_wr_be   = lsu_wstrb;

    // Read data mux
    if is_itcm
      lsu_rdata = itcm_rd_data;
    elsif is_dtcm
      lsu_rdata = dtcm_rd_data;
    else
      lsu_rdata = 0;
    end if
  end comb

end module Biu
