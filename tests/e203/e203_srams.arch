// E203 SRAM Container
// Instantiates ITCM RAM and DTCM RAM, forwarding all ports.

module e203_srams

  port test_mode: in Bool;

  // ITCM RAM interface
  port clk_itcm_ram: in Clock<SysDomain>;
  port rst_itcm:     in Reset<Async, Low>;
  port itcm_ram_sd:   in Bool;
  port itcm_ram_ds:   in Bool;
  port itcm_ram_ls:   in Bool;
  port itcm_ram_cs:   in Bool;
  port itcm_ram_we:   in Bool;
  port itcm_ram_addr: in UInt<13>;
  port itcm_ram_wem:  in UInt<8>;
  port itcm_ram_din:  in UInt<64>;
  port itcm_ram_dout: out UInt<64>;

  // DTCM RAM interface
  port clk_dtcm_ram: in Clock<SysDomain>;
  port rst_dtcm:     in Reset<Async, Low>;
  port dtcm_ram_sd:   in Bool;
  port dtcm_ram_ds:   in Bool;
  port dtcm_ram_ls:   in Bool;
  port dtcm_ram_cs:   in Bool;
  port dtcm_ram_we:   in Bool;
  port dtcm_ram_addr: in UInt<14>;
  port dtcm_ram_wem:  in UInt<4>;
  port dtcm_ram_din:  in UInt<32>;
  port dtcm_ram_dout: out UInt<32>;

  // ITCM RAM instance
  inst u_itcm_ram: e203_itcm_ram
    clk   <- clk_itcm_ram;
    rst_n <- rst_itcm;
    sd    <- itcm_ram_sd;
    ds    <- itcm_ram_ds;
    ls    <- itcm_ram_ls;
    cs    <- itcm_ram_cs;
    we    <- itcm_ram_we;
    addr  <- itcm_ram_addr;
    wem   <- itcm_ram_wem;
    din   <- itcm_ram_din;
    dout  -> itcm_ram_dout_w;
  end inst u_itcm_ram

  // DTCM RAM instance
  inst u_dtcm_ram: e203_dtcm_ram
    clk   <- clk_dtcm_ram;
    rst_n <- rst_dtcm;
    sd    <- dtcm_ram_sd;
    ds    <- dtcm_ram_ds;
    ls    <- dtcm_ram_ls;
    cs    <- dtcm_ram_cs;
    we    <- dtcm_ram_we;
    addr  <- dtcm_ram_addr;
    wem   <- dtcm_ram_wem;
    din   <- dtcm_ram_din;
    dout  -> dtcm_ram_dout_w;
  end inst u_dtcm_ram

  comb
    itcm_ram_dout = itcm_ram_dout_w;
    dtcm_ram_dout = dtcm_ram_dout_w;
  end comb
end module e203_srams
