// E203 ITCM Controller
// Arbitrates IFU (64-bit) and LSU (32-bit, width-converted) access to ITCM SRAM.
// IFU has lower priority (blocked when LSU active).
// 1-cycle SRAM latency, response tagged with requester ID.

module e203_itcm_ctrl

  port clk:   in Clock<SysDomain>;
  port rst_n: in Reset<Async, Low>;
  port test_mode: in Bool;
  port tcm_cgstop: in Bool;

  port itcm_active: out Bool;

  // IFU ICB (64-bit)
  port ifu2itcm_icb_cmd_valid: in Bool;
  port ifu2itcm_icb_cmd_ready: out Bool;
  port ifu2itcm_icb_cmd_addr:  in UInt<16>;
  port ifu2itcm_icb_cmd_read:  in Bool;
  port ifu2itcm_icb_cmd_wdata: in UInt<64>;
  port ifu2itcm_icb_cmd_wmask: in UInt<8>;
  port ifu2itcm_icb_rsp_valid: out Bool;
  port ifu2itcm_icb_rsp_ready: in Bool;
  port ifu2itcm_icb_rsp_err:   out Bool;
  port ifu2itcm_icb_rsp_rdata: out UInt<64>;
  port ifu2itcm_holdup:        out Bool;

  // LSU ICB (32-bit)
  port lsu2itcm_icb_cmd_valid: in Bool;
  port lsu2itcm_icb_cmd_ready: out Bool;
  port lsu2itcm_icb_cmd_addr:  in UInt<16>;
  port lsu2itcm_icb_cmd_read:  in Bool;
  port lsu2itcm_icb_cmd_wdata: in UInt<32>;
  port lsu2itcm_icb_cmd_wmask: in UInt<4>;
  port lsu2itcm_icb_rsp_valid: out Bool;
  port lsu2itcm_icb_rsp_ready: in Bool;
  port lsu2itcm_icb_rsp_err:   out Bool;
  port lsu2itcm_icb_rsp_rdata: out UInt<32>;

  // External debug ICB command
  port ext2itcm_icb_cmd_valid: in Bool;
  port ext2itcm_icb_cmd_ready: out Bool;
  port ext2itcm_icb_cmd_addr:  in UInt<16>;
  port ext2itcm_icb_cmd_read:  in Bool;
  port ext2itcm_icb_cmd_wdata: in UInt<32>;
  port ext2itcm_icb_cmd_wmask: in UInt<4>;

  // External debug ICB response
  port ext2itcm_icb_rsp_valid: out Bool;
  port ext2itcm_icb_rsp_ready: in Bool;
  port ext2itcm_icb_rsp_err:   out Bool;
  port ext2itcm_icb_rsp_rdata: out UInt<32>;

  // SRAM interface (64-bit)
  port itcm_ram_cs:   out Bool;
  port itcm_ram_we:   out Bool;
  port itcm_ram_addr: out UInt<13>;
  port itcm_ram_wem:  out UInt<8>;
  port itcm_ram_din:  out UInt<64>;
  port itcm_ram_dout: in UInt<64>;
  port clk_itcm_ram:  out Bool;

  // Response pipeline: track which requester (IFU vs LSU) and address for LSU 32->64
  reg rsp_valid_r: Bool reset rst_n => false;
  reg rsp_ifu_r:   Bool reset rst_n => false;
  reg rsp_read_r:  Bool reset rst_n => false;
  reg rsp_lsu_lo_r: Bool reset rst_n => false;  // LSU accessed low word

  // IFU holdup tracking
  reg ifu_holdup_r: Bool reset rst_n => false;

  // LSU width conversion: expand 32-bit cmd to 64-bit SRAM
  let lsu_addr_lo: Bool = ~lsu2itcm_icb_cmd_addr[2:2];  // Low word if addr[2]=0
  let lsu_wdata_64: UInt<64> = lsu_addr_lo ? {32'b0, lsu2itcm_icb_cmd_wdata}
                              : {lsu2itcm_icb_cmd_wdata, 32'b0};
  let lsu_wmask_8: UInt<8> = lsu_addr_lo ? {4'b0, lsu2itcm_icb_cmd_wmask}
                            : {lsu2itcm_icb_cmd_wmask, 4'b0};

  // Arbitration: LSU has priority over IFU
  let sram_sel_lsu: Bool = lsu2itcm_icb_cmd_valid;
  let sram_sel_ifu: Bool = ifu2itcm_icb_cmd_valid & (~lsu2itcm_icb_cmd_valid);
  let sram_cmd_valid: Bool = sram_sel_lsu | sram_sel_ifu;
  let sram_ready: Bool = ~rsp_valid_r | (rsp_ifu_r ? ifu2itcm_icb_rsp_ready : lsu2itcm_icb_rsp_ready);

  default seq on clk rising;

  seq
    if sram_cmd_valid & sram_ready
      rsp_valid_r <= true;
      rsp_ifu_r   <= sram_sel_ifu;
      rsp_read_r  <= sram_sel_lsu ? lsu2itcm_icb_cmd_read : ifu2itcm_icb_cmd_read;
      rsp_lsu_lo_r <= lsu_addr_lo;
    elsif rsp_valid_r & (rsp_ifu_r ? ifu2itcm_icb_rsp_ready : lsu2itcm_icb_rsp_ready)
      rsp_valid_r <= false;
    end if

    // IFU holdup: set when IFU accessed SRAM, cleared when non-IFU accesses
    if sram_cmd_valid & sram_ready
      ifu_holdup_r <= sram_sel_ifu;
    end if
  end seq

  comb
    // SRAM command
    itcm_ram_cs = sram_cmd_valid & sram_ready;
    clk_itcm_ram = clk;

    if sram_sel_lsu
      itcm_ram_addr = lsu2itcm_icb_cmd_addr[15:3];
      itcm_ram_we   = ~lsu2itcm_icb_cmd_read;
      itcm_ram_din  = lsu_wdata_64;
      itcm_ram_wem  = lsu_wmask_8;
    else
      itcm_ram_addr = ifu2itcm_icb_cmd_addr[15:3];
      itcm_ram_we   = ~ifu2itcm_icb_cmd_read;
      itcm_ram_din  = ifu2itcm_icb_cmd_wdata;
      itcm_ram_wem  = ifu2itcm_icb_cmd_wmask;
    end if

    // Handshake
    lsu2itcm_icb_cmd_ready = sram_ready;
    ifu2itcm_icb_cmd_ready = sram_ready & (~lsu2itcm_icb_cmd_valid);

    // Response demux
    ifu2itcm_icb_rsp_valid = rsp_valid_r & rsp_ifu_r;
    ifu2itcm_icb_rsp_err   = false;
    ifu2itcm_icb_rsp_rdata = itcm_ram_dout;

    lsu2itcm_icb_rsp_valid = rsp_valid_r & (~rsp_ifu_r);
    lsu2itcm_icb_rsp_err   = false;
    lsu2itcm_icb_rsp_rdata = rsp_lsu_lo_r ? itcm_ram_dout[31:0] : itcm_ram_dout[63:32];

    // IFU holdup
    ifu2itcm_holdup = ifu_holdup_r;

    // External debug interface: lowest priority
    ext2itcm_icb_cmd_ready = (~ifu2itcm_icb_cmd_valid) & (~lsu2itcm_icb_cmd_valid) & sram_ready;
    ext2itcm_icb_rsp_valid = false;
    ext2itcm_icb_rsp_err   = false;
    ext2itcm_icb_rsp_rdata = itcm_ram_dout[31:0];

    // Active
    itcm_active = ifu2itcm_icb_cmd_valid | lsu2itcm_icb_cmd_valid | ext2itcm_icb_cmd_valid | rsp_valid_r;
  end comb
end module e203_itcm_ctrl
