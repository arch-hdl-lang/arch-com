// E203 ICB Bus Arbiter (2-master)
// Round-robin arbitration between two ICB masters.
// Internal Command Bus (ICB) is E203's on-chip bus protocol:
//   cmd: valid/ready + addr + wdata + wmask + read
//   rsp: valid/ready + rdata + err

module IcbArbt

  port clk:   in Clock<SysDomain>;
  port rst_n: in Reset<Async, Low>;

  // Master 0 (higher default priority)
  port m0_cmd_valid: in  Bool;
  port m0_cmd_ready: out Bool;
  port m0_cmd_addr:  in  UInt<32>;
  port m0_cmd_wdata: in  UInt<32>;
  port m0_cmd_wmask: in  UInt<4>;
  port m0_cmd_read:  in  Bool;
  port m0_rsp_valid: out Bool;
  port m0_rsp_ready: in  Bool;
  port m0_rsp_rdata: out UInt<32>;
  port m0_rsp_err:   out Bool;

  // Master 1
  port m1_cmd_valid: in  Bool;
  port m1_cmd_ready: out Bool;
  port m1_cmd_addr:  in  UInt<32>;
  port m1_cmd_wdata: in  UInt<32>;
  port m1_cmd_wmask: in  UInt<4>;
  port m1_cmd_read:  in  Bool;
  port m1_rsp_valid: out Bool;
  port m1_rsp_ready: in  Bool;
  port m1_rsp_rdata: out UInt<32>;
  port m1_rsp_err:   out Bool;

  // Slave port
  port s_cmd_valid: out Bool;
  port s_cmd_ready: in  Bool;
  port s_cmd_addr:  out UInt<32>;
  port s_cmd_wdata: out UInt<32>;
  port s_cmd_wmask: out UInt<4>;
  port s_cmd_read:  out Bool;
  port s_rsp_valid: in  Bool;
  port s_rsp_ready: out Bool;
  port s_rsp_rdata: in  UInt<32>;
  port s_rsp_err:   in  Bool;

  // ── Round-robin state ──────────────────────────────────────────
  reg last_grant: Bool init false reset rst_n=false;  // false=m0, true=m1

  // ── Arbitration logic ──────────────────────────────────────────
  // If both request, alternate; otherwise grant whoever requests
  let both_req: Bool = m0_cmd_valid & m1_cmd_valid;
  let grant_m0: Bool = m0_cmd_valid & (~both_req | last_grant);
  let grant_m1: Bool = m1_cmd_valid & ~grant_m0;

  // Track which master owns the current outstanding transaction
  reg rsp_owner: Bool init false reset rst_n=false;  // false=m0, true=m1

  seq on clk rising
    // Update last_grant on successful cmd handshake
    if s_cmd_valid & s_cmd_ready
      last_grant <= grant_m1;
      rsp_owner  <= grant_m1;
    end if
  end seq

  comb
    // Command mux
    s_cmd_valid = m0_cmd_valid | m1_cmd_valid;
    if grant_m0
      s_cmd_addr  = m0_cmd_addr;
      s_cmd_wdata = m0_cmd_wdata;
      s_cmd_wmask = m0_cmd_wmask;
      s_cmd_read  = m0_cmd_read;
    else
      s_cmd_addr  = m1_cmd_addr;
      s_cmd_wdata = m1_cmd_wdata;
      s_cmd_wmask = m1_cmd_wmask;
      s_cmd_read  = m1_cmd_read;
    end if

    // Command ready: only the granted master gets ready
    m0_cmd_ready = grant_m0 & s_cmd_ready;
    m1_cmd_ready = grant_m1 & s_cmd_ready;

    // Response demux: route to whichever master owns the txn
    m0_rsp_valid = s_rsp_valid & ~rsp_owner;
    m1_rsp_valid = s_rsp_valid &  rsp_owner;
    m0_rsp_rdata = s_rsp_rdata;
    m1_rsp_rdata = s_rsp_rdata;
    m0_rsp_err   = s_rsp_err;
    m1_rsp_err   = s_rsp_err;

    // Response ready
    s_rsp_ready = rsp_owner ? m1_rsp_ready : m0_rsp_ready;
  end comb

end module IcbArbt
