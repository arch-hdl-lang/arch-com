domain SysDomain
  freq_mhz: 100
end domain SysDomain

ram ItcmSram
  kind simple_dual;
  latency 1;
  param DEPTH: const = 16384;
  param WIDTH: type = UInt<32>;
  port clk: in Clock<SysDomain>;
  store
    buf: Vec<WIDTH, DEPTH>;
  end store
  port rd_port
    en:   in Bool;
    addr: in UInt<14>;
    data: out WIDTH;
  end port rd_port
  port wr_port
    en:   in Bool;
    addr: in UInt<14>;
    data: in WIDTH;
  end port wr_port
end ram ItcmSram

module e203_itcm
  port clk:      in Clock<SysDomain>;
  port rst_n:    in Reset<Async, Low>;
  port rd_en:    in Bool;
  port rd_addr:  in UInt<14>;
  port rd_data:  out UInt<32>;
  port wr_en:    in Bool;
  port wr_addr:  in UInt<14>;
  port wr_data:  in UInt<32>;

  inst mem: ItcmSram
    clk          <- clk;
    rd_port.en   <- rd_en;
    rd_port.addr <- rd_addr;
    rd_port.data -> rd_data;
    wr_port.en   <- wr_en;
    wr_port.addr <- wr_addr;
    wr_port.data <- wr_data;
  end inst mem

end module e203_itcm
