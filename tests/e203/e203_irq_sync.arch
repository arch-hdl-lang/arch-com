// E203 IRQ Synchronizer
// 2-stage FF synchronizer for async interrupt inputs.
// MASTER=1: synchronize through 2-FF chain; MASTER=0: pass-through.

module e203_irq_sync
  param MASTER: const = 1;

  port clk:   in Clock<SysDomain>;
  port rst_n: in Reset<Async, Low>;

  port ext_irq_a: in Bool;
  port sft_irq_a: in Bool;
  port tmr_irq_a: in Bool;
  port dbg_irq_a: in Bool;

  port ext_irq_r: out Bool;
  port sft_irq_r: out Bool;
  port tmr_irq_r: out Bool;
  port dbg_irq_r: out Bool;

  // 2-stage synchronizer registers (stage 0 samples input, stage 1 = output)
  reg ext_s0: Bool reset rst_n => false;
  reg ext_s1: Bool reset rst_n => false;
  reg sft_s0: Bool reset rst_n => false;
  reg sft_s1: Bool reset rst_n => false;
  reg tmr_s0: Bool reset rst_n => false;
  reg tmr_s1: Bool reset rst_n => false;
  reg dbg_s0: Bool reset rst_n => false;
  reg dbg_s1: Bool reset rst_n => false;

  default seq on clk rising;

  seq
    ext_s0 <= ext_irq_a;
    ext_s1 <= ext_s0;
    sft_s0 <= sft_irq_a;
    sft_s1 <= sft_s0;
    tmr_s0 <= tmr_irq_a;
    tmr_s1 <= tmr_s0;
    dbg_s0 <= dbg_irq_a;
    dbg_s1 <= dbg_s0;
  end seq

  comb
    ext_irq_r = ext_s1;
    sft_irq_r = sft_s1;
    tmr_irq_r = tmr_s1;
    dbg_irq_r = dbg_s1;
  end comb
end module e203_irq_sync
