// E203 HBirdv2 integer register file
// 32 × 32-bit, 2 async read ports, 1 sync write port.
// x0 hardwired to 0 via init[0]=0 and write guard in the pipeline.
// No reset on data entries (matches E203 spec).

regfile ExuRegfile
  param XLEN:   const = 32;
  param NREGS:  const = 32;
  param NREAD:  const = 2;
  param NWRITE: const = 1;

  port clk:    in Clock<SysDomain>;
  port rst_n:  in Reset<Async, Low>;
  port test_mode: in Bool;

  ports[NREAD] read
    addr: in  UInt<5>;
    data: out UInt<32>;
  end ports read

  ports[NWRITE] write
    en:   in Bool;
    addr: in UInt<5>;
    data: in UInt<32>;
  end ports write

  init [0] = 0;                    // x0 hardwired to 0
  forward write_before_read: false; // no bypass — hazards resolved by pipeline

end regfile ExuRegfile
