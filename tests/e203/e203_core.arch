// E203 Core Integration
// Wires together IFU, EXU, LSU, and BIU.
// Exposes ITCM/DTCM ICB buses and external BIU ICB outputs.

module e203_core

  port clk:   in Clock<SysDomain>;
  port rst_n: in Reset<Async, Low>;
  port test_mode: in Bool;

  port inspect_pc: out UInt<32>;
  port pc_rtvec: in UInt<32>;
  port core_mhartid: in UInt<1>;

  // Clock inputs (gated per subsystem)
  port clk_core_ifu: in Clock<SysDomain>;
  port clk_core_exu: in Clock<SysDomain>;
  port clk_core_lsu: in Clock<SysDomain>;
  port clk_core_biu: in Clock<SysDomain>;
  port clk_aon:      in Clock<SysDomain>;

  // Activity
  port ifu_active: out Bool;
  port exu_active: out Bool;
  port lsu_active: out Bool;
  port biu_active: out Bool;

  // IRQs (synchronized)
  port dbg_irq_r: in Bool;
  port lcl_irq_r: in Bool;
  port evt_r:     in Bool;
  port ext_irq_r: in Bool;
  port sft_irq_r: in Bool;
  port tmr_irq_r: in Bool;

  // IFU-to-ITCM ICB
  port ifu2itcm_holdup: in Bool;
  port itcm_region_indic: in UInt<32>;
  port ifu2itcm_icb_cmd_valid: out Bool;
  port ifu2itcm_icb_cmd_ready: in Bool;
  port ifu2itcm_icb_cmd_addr:  out UInt<16>;
  port ifu2itcm_icb_rsp_valid: in Bool;
  port ifu2itcm_icb_rsp_ready: out Bool;
  port ifu2itcm_icb_rsp_err:   in Bool;
  port ifu2itcm_icb_rsp_rdata: in UInt<64>;

  // LSU-to-ITCM ICB
  port lsu2itcm_icb_cmd_valid: out Bool;
  port lsu2itcm_icb_cmd_ready: in Bool;
  port lsu2itcm_icb_cmd_addr:  out UInt<16>;
  port lsu2itcm_icb_cmd_read:  out Bool;
  port lsu2itcm_icb_cmd_wdata: out UInt<32>;
  port lsu2itcm_icb_cmd_wmask: out UInt<4>;
  port lsu2itcm_icb_cmd_lock:  out Bool;
  port lsu2itcm_icb_cmd_excl:  out Bool;
  port lsu2itcm_icb_cmd_size:  out UInt<2>;
  port lsu2itcm_icb_rsp_valid: in Bool;
  port lsu2itcm_icb_rsp_ready: out Bool;
  port lsu2itcm_icb_rsp_err:   in Bool;
  port lsu2itcm_icb_rsp_excl_ok: in Bool;
  port lsu2itcm_icb_rsp_rdata: in UInt<32>;

  // LSU-to-DTCM ICB
  port dtcm_region_indic: in UInt<32>;
  port lsu2dtcm_icb_cmd_valid: out Bool;
  port lsu2dtcm_icb_cmd_ready: in Bool;
  port lsu2dtcm_icb_cmd_addr:  out UInt<16>;
  port lsu2dtcm_icb_cmd_read:  out Bool;
  port lsu2dtcm_icb_cmd_wdata: out UInt<32>;
  port lsu2dtcm_icb_cmd_wmask: out UInt<4>;
  port lsu2dtcm_icb_cmd_lock:  out Bool;
  port lsu2dtcm_icb_cmd_excl:  out Bool;
  port lsu2dtcm_icb_cmd_size:  out UInt<2>;
  port lsu2dtcm_icb_rsp_valid: in Bool;
  port lsu2dtcm_icb_rsp_ready: out Bool;
  port lsu2dtcm_icb_rsp_err:   in Bool;
  port lsu2dtcm_icb_rsp_excl_ok: in Bool;
  port lsu2dtcm_icb_rsp_rdata: in UInt<32>;

  // PPI ICB
  port ppi_region_indic:   in UInt<32>;
  port ppi_icb_enable:     in Bool;
  port ppi_icb_cmd_valid:  out Bool;
  port ppi_icb_cmd_ready:  in Bool;
  port ppi_icb_cmd_addr:   out UInt<32>;
  port ppi_icb_cmd_read:   out Bool;
  port ppi_icb_cmd_wdata:  out UInt<32>;
  port ppi_icb_cmd_wmask:  out UInt<4>;
  port ppi_icb_cmd_lock:   out Bool;
  port ppi_icb_cmd_excl:   out Bool;
  port ppi_icb_cmd_size:   out UInt<2>;
  port ppi_icb_rsp_valid:  in Bool;
  port ppi_icb_rsp_ready:  out Bool;
  port ppi_icb_rsp_err:    in Bool;
  port ppi_icb_rsp_excl_ok: in Bool;
  port ppi_icb_rsp_rdata:  in UInt<32>;

  // CLINT ICB
  port clint_region_indic:   in UInt<32>;
  port clint_icb_enable:     in Bool;
  port clint_icb_cmd_valid:  out Bool;
  port clint_icb_cmd_ready:  in Bool;
  port clint_icb_cmd_addr:   out UInt<32>;
  port clint_icb_cmd_read:   out Bool;
  port clint_icb_cmd_wdata:  out UInt<32>;
  port clint_icb_cmd_wmask:  out UInt<4>;
  port clint_icb_cmd_lock:   out Bool;
  port clint_icb_cmd_excl:   out Bool;
  port clint_icb_cmd_size:   out UInt<2>;
  port clint_icb_rsp_valid:  in Bool;
  port clint_icb_rsp_ready:  out Bool;
  port clint_icb_rsp_err:    in Bool;
  port clint_icb_rsp_excl_ok: in Bool;
  port clint_icb_rsp_rdata:  in UInt<32>;

  // PLIC ICB
  port plic_region_indic:   in UInt<32>;
  port plic_icb_enable:     in Bool;
  port plic_icb_cmd_valid:  out Bool;
  port plic_icb_cmd_ready:  in Bool;
  port plic_icb_cmd_addr:   out UInt<32>;
  port plic_icb_cmd_read:   out Bool;
  port plic_icb_cmd_wdata:  out UInt<32>;
  port plic_icb_cmd_wmask:  out UInt<4>;
  port plic_icb_cmd_lock:   out Bool;
  port plic_icb_cmd_excl:   out Bool;
  port plic_icb_cmd_size:   out UInt<2>;
  port plic_icb_rsp_valid:  in Bool;
  port plic_icb_rsp_ready:  out Bool;
  port plic_icb_rsp_err:    in Bool;
  port plic_icb_rsp_excl_ok: in Bool;
  port plic_icb_rsp_rdata:  in UInt<32>;

  // FIO ICB
  port fio_region_indic:   in UInt<32>;
  port fio_icb_enable:     in Bool;
  port fio_icb_cmd_valid:  out Bool;
  port fio_icb_cmd_ready:  in Bool;
  port fio_icb_cmd_addr:   out UInt<32>;
  port fio_icb_cmd_read:   out Bool;
  port fio_icb_cmd_wdata:  out UInt<32>;
  port fio_icb_cmd_wmask:  out UInt<4>;
  port fio_icb_cmd_lock:   out Bool;
  port fio_icb_cmd_excl:   out Bool;
  port fio_icb_cmd_size:   out UInt<2>;
  port fio_icb_rsp_valid:  in Bool;
  port fio_icb_rsp_ready:  out Bool;
  port fio_icb_rsp_err:    in Bool;
  port fio_icb_rsp_excl_ok: in Bool;
  port fio_icb_rsp_rdata:  in UInt<32>;

  // MEM ICB
  port mem_icb_enable:     in Bool;
  port mem_icb_cmd_valid:  out Bool;
  port mem_icb_cmd_ready:  in Bool;
  port mem_icb_cmd_addr:   out UInt<32>;
  port mem_icb_cmd_read:   out Bool;
  port mem_icb_cmd_wdata:  out UInt<32>;
  port mem_icb_cmd_wmask:  out UInt<4>;
  port mem_icb_cmd_lock:   out Bool;
  port mem_icb_cmd_excl:   out Bool;
  port mem_icb_cmd_size:   out UInt<2>;
  port mem_icb_cmd_burst:  out UInt<2>;
  port mem_icb_cmd_beat:   out UInt<2>;
  port mem_icb_rsp_valid:  in Bool;
  port mem_icb_rsp_ready:  out Bool;
  port mem_icb_rsp_err:    in Bool;
  port mem_icb_rsp_excl_ok: in Bool;
  port mem_icb_rsp_rdata:  in UInt<32>;

  // NICE coprocessor passthrough
  port nice_mem_holdup: in Bool;
  port nice_req_valid:          out Bool;
  port nice_req_ready:          in  Bool;
  port nice_req_inst:           out UInt<32>;
  port nice_req_rs1:            out UInt<32>;
  port nice_req_rs2:            out UInt<32>;
  port nice_rsp_multicyc_valid: in  Bool;
  port nice_rsp_multicyc_ready: out Bool;
  port nice_rsp_multicyc_dat:   in  UInt<32>;
  port nice_rsp_multicyc_err:   in  Bool;
  port nice_icb_cmd_valid: in Bool;
  port nice_icb_cmd_ready: out Bool;
  port nice_icb_cmd_addr:  in UInt<32>;
  port nice_icb_cmd_read:  in Bool;
  port nice_icb_cmd_wdata: in UInt<32>;
  port nice_icb_cmd_size:  in UInt<2>;
  port nice_icb_rsp_valid: out Bool;
  port nice_icb_rsp_ready: in Bool;
  port nice_icb_rsp_rdata: out UInt<32>;
  port nice_icb_rsp_err:   out Bool;

  // Debug CSR interface
  port dbg_mode:     in Bool;
  port dbg_halt_r:   in Bool;
  port dbg_step_r:   in Bool;
  port dbg_ebreakm_r: in Bool;
  port dbg_stopcycle: in Bool;
  port cmt_dpc:      out UInt<32>;
  port cmt_dpc_ena:  out Bool;
  port cmt_dcause:   out UInt<3>;
  port cmt_dcause_ena: out Bool;

  // CSR debug write interface
  port wr_dcsr_ena:     out Bool;
  port wr_dpc_ena:      out Bool;
  port wr_dscratch_ena: out Bool;
  port wr_csr_nxt:      out UInt<32>;
  port dcsr_r:          in  UInt<32>;
  port dpc_r:           in  UInt<32>;
  port dscratch_r:      in  UInt<32>;

  // Misc control
  port tm_stop:     out Bool;
  port core_cgstop: out Bool;
  port tcm_cgstop:  out Bool;
  port core_wfi:    out Bool;
  port itcm_nohold: out Bool;

  // Internal wires: IFU <-> EXU
  wire ifu_o_valid_w: Bool;
  wire ifu_o_ready_w: Bool;
  wire ifu_o_ir_w:    UInt<32>;
  wire ifu_o_pc_w:    UInt<32>;
  wire ifu_o_pc_vld_w: Bool;
  wire ifu_o_misalgn_w: Bool;
  wire ifu_o_buserr_w: Bool;
  wire ifu_o_rs1idx_w: UInt<5>;
  wire ifu_o_rs2idx_w: UInt<5>;
  wire ifu_o_prdt_taken_w: Bool;
  wire ifu_o_muldiv_b2b_w: Bool;

  // Flush
  wire flush_req_w: Bool;
  wire flush_ack_w: Bool;
  wire flush_op1_w: UInt<32>;
  wire flush_op2_w: UInt<32>;
  wire flush_pc_w:  UInt<32>;

  // WFI
  wire wfi_halt_ifu_req_w: Bool;
  wire wfi_halt_ifu_ack_w: Bool;

  // OITF
  wire oitf_empty_w: Bool;

  // Regfile to IFU
  wire rf2ifu_x1_w: UInt<32>;
  wire rf2ifu_rs1_w: UInt<32>;
  wire dec2ifu_rden_w: Bool;
  wire dec2ifu_rs1en_w: Bool;
  wire dec2ifu_rdidx_w: UInt<5>;
  wire dec2ifu_mulhsu_w: Bool;
  wire dec2ifu_div_w: Bool;
  wire dec2ifu_rem_w: Bool;
  wire dec2ifu_divu_w: Bool;
  wire dec2ifu_remu_w: Bool;

  // EXU <-> LSU
  wire agu_cmd_valid_w: Bool;
  wire agu_cmd_ready_w: Bool;
  wire agu_cmd_addr_w: UInt<32>;
  wire agu_cmd_read_w: Bool;
  wire agu_cmd_wdata_w: UInt<32>;
  wire agu_cmd_wmask_w: UInt<4>;
  wire agu_cmd_lock_w: Bool;
  wire agu_cmd_excl_w: Bool;
  wire agu_cmd_size_w: UInt<2>;
  wire agu_cmd_back2agu_w: Bool;
  wire agu_cmd_usign_w: Bool;
  wire agu_cmd_itag_w: UInt<1>;
  wire agu_rsp_valid_w: Bool;
  wire agu_rsp_ready_w: Bool;
  wire agu_rsp_err_w: Bool;
  wire agu_rsp_excl_ok_w: Bool;
  wire agu_rsp_rdata_w: UInt<32>;

  wire lsu_o_valid_w: Bool;
  wire lsu_o_ready_w: Bool;
  wire lsu_o_wbck_wdat_w: UInt<32>;
  wire lsu_o_wbck_itag_w: UInt<1>;
  wire lsu_o_wbck_err_w: Bool;
  wire lsu_o_cmt_ld_w: Bool;
  wire lsu_o_cmt_st_w: Bool;
  wire lsu_o_cmt_badaddr_w: UInt<32>;
  wire lsu_o_cmt_buserr_w: Bool;

  // EXU misc
  wire commit_mret_w: Bool;
  wire commit_trap_w: Bool;
  wire excp_active_w: Bool;
  wire exu_active_w:  Bool;

  // Simplified: IFU, EXU, LSU instantiated with direct wiring
  // (Actual E203 has BIU module too; simplified here)

  comb
    // IFU hardwired active
    ifu_active = true;

    // Activity outputs
    exu_active = exu_active_w;
    lsu_active = false;  // Simplified
    biu_active = false;

    // IFU -> ITCM ICB: pass through (simplified)
    ifu2itcm_icb_cmd_valid = false;
    ifu2itcm_icb_cmd_addr = 0;
    ifu2itcm_icb_rsp_ready = true;

    // LSU -> ITCM ICB
    lsu2itcm_icb_cmd_valid = agu_cmd_valid_w & (agu_cmd_addr_w[31:16] == itcm_region_indic[31:16]);
    lsu2itcm_icb_cmd_addr  = agu_cmd_addr_w[15:0];
    lsu2itcm_icb_cmd_read  = agu_cmd_read_w;
    lsu2itcm_icb_cmd_wdata = agu_cmd_wdata_w;
    lsu2itcm_icb_cmd_wmask = agu_cmd_wmask_w;
    lsu2itcm_icb_cmd_lock  = agu_cmd_lock_w;
    lsu2itcm_icb_cmd_excl  = agu_cmd_excl_w;
    lsu2itcm_icb_cmd_size  = agu_cmd_size_w;
    lsu2itcm_icb_rsp_ready = agu_rsp_ready_w;

    // LSU -> DTCM ICB
    lsu2dtcm_icb_cmd_valid = agu_cmd_valid_w & (agu_cmd_addr_w[31:16] == dtcm_region_indic[31:16]);
    lsu2dtcm_icb_cmd_addr  = agu_cmd_addr_w[15:0];
    lsu2dtcm_icb_cmd_read  = agu_cmd_read_w;
    lsu2dtcm_icb_cmd_wdata = agu_cmd_wdata_w;
    lsu2dtcm_icb_cmd_wmask = agu_cmd_wmask_w;
    lsu2dtcm_icb_cmd_lock  = agu_cmd_lock_w;
    lsu2dtcm_icb_cmd_excl  = agu_cmd_excl_w;
    lsu2dtcm_icb_cmd_size  = agu_cmd_size_w;
    lsu2dtcm_icb_rsp_ready = agu_rsp_ready_w;

    // PPI ICB (stub)
    ppi_icb_cmd_valid = false;  ppi_icb_cmd_addr = 0;  ppi_icb_cmd_read = true;
    ppi_icb_cmd_wdata = 0;  ppi_icb_cmd_wmask = 0;  ppi_icb_cmd_lock = false;
    ppi_icb_cmd_excl = false;  ppi_icb_cmd_size = 0;  ppi_icb_rsp_ready = true;

    // CLINT ICB (stub)
    clint_icb_cmd_valid = false;  clint_icb_cmd_addr = 0;  clint_icb_cmd_read = true;
    clint_icb_cmd_wdata = 0;  clint_icb_cmd_wmask = 0;  clint_icb_cmd_lock = false;
    clint_icb_cmd_excl = false;  clint_icb_cmd_size = 0;  clint_icb_rsp_ready = true;

    // PLIC ICB (stub)
    plic_icb_cmd_valid = false;  plic_icb_cmd_addr = 0;  plic_icb_cmd_read = true;
    plic_icb_cmd_wdata = 0;  plic_icb_cmd_wmask = 0;  plic_icb_cmd_lock = false;
    plic_icb_cmd_excl = false;  plic_icb_cmd_size = 0;  plic_icb_rsp_ready = true;

    // FIO ICB (stub)
    fio_icb_cmd_valid = false;  fio_icb_cmd_addr = 0;  fio_icb_cmd_read = true;
    fio_icb_cmd_wdata = 0;  fio_icb_cmd_wmask = 0;  fio_icb_cmd_lock = false;
    fio_icb_cmd_excl = false;  fio_icb_cmd_size = 0;  fio_icb_rsp_ready = true;

    // MEM ICB (stub)
    mem_icb_cmd_valid = false;  mem_icb_cmd_addr = 0;  mem_icb_cmd_read = true;
    mem_icb_cmd_wdata = 0;  mem_icb_cmd_wmask = 0;  mem_icb_cmd_lock = false;
    mem_icb_cmd_excl = false;  mem_icb_cmd_size = 0;  mem_icb_cmd_burst = 0;
    mem_icb_cmd_beat = 0;  mem_icb_rsp_ready = true;

    // NICE passthrough (stub)
    nice_req_valid = false;  nice_req_inst = 0;  nice_req_rs1 = 0;  nice_req_rs2 = 0;
    nice_rsp_multicyc_ready = false;
    nice_icb_cmd_ready = false;  nice_icb_rsp_valid = false;
    nice_icb_rsp_rdata = 0;  nice_icb_rsp_err = false;

    // AGU response mux (simplified)
    agu_rsp_valid_w   = lsu2itcm_icb_rsp_valid | lsu2dtcm_icb_rsp_valid;
    agu_rsp_err_w     = false;
    agu_rsp_excl_ok_w = false;
    agu_rsp_rdata_w   = lsu2itcm_icb_rsp_valid ? lsu2itcm_icb_rsp_rdata : lsu2dtcm_icb_rsp_rdata;
    agu_cmd_ready_w   = lsu2itcm_icb_cmd_ready | lsu2dtcm_icb_cmd_ready;

    // IFU wires (stub — real IFU would be instantiated)
    ifu_o_valid_w = false;
    ifu_o_ir_w = 0;
    ifu_o_pc_w = 0;
    ifu_o_pc_vld_w = false;
    ifu_o_misalgn_w = false;
    ifu_o_buserr_w = false;
    ifu_o_rs1idx_w = 0;
    ifu_o_rs2idx_w = 0;
    ifu_o_prdt_taken_w = false;
    ifu_o_muldiv_b2b_w = false;
    flush_ack_w = true;
    wfi_halt_ifu_ack_w = true;
    inspect_pc = ifu_o_pc_w;

    // LSU wires (stub)
    lsu_o_valid_w = false;
    lsu_o_wbck_wdat_w = 0;
    lsu_o_wbck_itag_w = 0;
    lsu_o_wbck_err_w = false;
    lsu_o_cmt_ld_w = false;
    lsu_o_cmt_st_w = false;
    lsu_o_cmt_badaddr_w = 0;
    lsu_o_cmt_buserr_w = false;

    // EXU wires (stub)
    ifu_o_ready_w = true;
    flush_req_w = false;
    flush_op1_w = 0;
    flush_op2_w = 0;
    flush_pc_w  = 0;
    wfi_halt_ifu_req_w = false;
    oitf_empty_w = true;
    rf2ifu_x1_w = 0;
    rf2ifu_rs1_w = 0;
    dec2ifu_rden_w = false;
    dec2ifu_rs1en_w = false;
    dec2ifu_rdidx_w = 0;
    dec2ifu_mulhsu_w = false;
    dec2ifu_div_w = false;
    dec2ifu_rem_w = false;
    dec2ifu_divu_w = false;
    dec2ifu_remu_w = false;
    commit_mret_w = false;
    commit_trap_w = false;
    excp_active_w = false;
    exu_active_w = false;
    agu_cmd_valid_w = false;
    agu_cmd_addr_w = 0;
    agu_cmd_read_w = true;
    agu_cmd_wdata_w = 0;
    agu_cmd_wmask_w = 0;
    agu_cmd_lock_w = false;
    agu_cmd_excl_w = false;
    agu_cmd_size_w = 0;
    agu_cmd_back2agu_w = false;
    agu_cmd_usign_w = false;
    agu_cmd_itag_w = 0;
    agu_rsp_ready_w = true;
    lsu_o_ready_w = true;

    // Debug outputs (simplified)
    cmt_dpc = 0;
    cmt_dpc_ena = false;
    cmt_dcause = 0;
    cmt_dcause_ena = false;
    wr_dcsr_ena = false;
    wr_dpc_ena = false;
    wr_dscratch_ena = false;
    wr_csr_nxt = 0;
    tm_stop     = false;
    itcm_nohold = false;
    core_cgstop = false;
    tcm_cgstop  = false;
    core_wfi    = false;
  end comb
end module e203_core
