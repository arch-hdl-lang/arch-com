// E203 HBirdv2 Execution Dispatch Unit
// Routes decoded instructions to ALU pipeline, checks OITF hazards,
// manages WFI halt handshake. Matches RealBench port interface.

module e203_exu_disp

  port clk:   in Clock<SysDomain>;
  port rst_n: in Reset<Async, Low>;

  // ── WFI halt interface ────────────────────────────────────────────
  port wfi_halt_exu_req: in  Bool;
  port wfi_halt_exu_ack: out Bool;

  // ── OITF status ───────────────────────────────────────────────────
  port oitf_empty: in Bool;
  port amo_wait:   in Bool;

  // ── Dispatch input (from decode) ──────────────────────────────────
  port disp_i_valid:   in  Bool;
  port disp_i_ready:   out Bool;
  port disp_i_rs1x0:   in  Bool;
  port disp_i_rs2x0:   in  Bool;
  port disp_i_rs1en:   in  Bool;
  port disp_i_rs2en:   in  Bool;
  port disp_i_rs1idx:  in  UInt<5>;
  port disp_i_rs2idx:  in  UInt<5>;
  port disp_i_rs1:     in  UInt<32>;
  port disp_i_rs2:     in  UInt<32>;
  port disp_i_rdwen:   in  Bool;
  port disp_i_rdidx:   in  UInt<5>;
  port disp_i_info:    in  UInt<32>;
  port disp_i_imm:     in  UInt<32>;
  port disp_i_pc:      in  UInt<32>;
  port disp_i_misalgn: in  Bool;
  port disp_i_buserr:  in  Bool;
  port disp_i_ilegl:   in  Bool;

  // ── ALU dispatch output ───────────────────────────────────────────
  port disp_o_alu_valid:    out Bool;
  port disp_o_alu_ready:    in  Bool;
  port disp_o_alu_longpipe: in  Bool;
  port disp_o_alu_rs1:      out UInt<32>;
  port disp_o_alu_rs2:      out UInt<32>;
  port disp_o_alu_rdwen:    out Bool;
  port disp_o_alu_rdidx:    out UInt<5>;
  port disp_o_alu_info:     out UInt<32>;
  port disp_o_alu_imm:      out UInt<32>;
  port disp_o_alu_pc:       out UInt<32>;
  port disp_o_alu_itag:     out UInt<1>;
  port disp_o_alu_misalgn:  out Bool;
  port disp_o_alu_buserr:   out Bool;
  port disp_o_alu_ilegl:    out Bool;

  // ── OITF hazard check inputs ──────────────────────────────────────
  port oitfrd_match_disprs1: in Bool;
  port oitfrd_match_disprs2: in Bool;
  port oitfrd_match_disprs3: in Bool;
  port oitfrd_match_disprd:  in Bool;

  // ── OITF dispatch interface ───────────────────────────────────────
  port disp_oitf_ptr:    in  UInt<1>;
  port disp_oitf_ena:    out Bool;
  port disp_oitf_ready:  in  Bool;
  port disp_oitf_rs1fpu: out Bool;
  port disp_oitf_rs2fpu: out Bool;
  port disp_oitf_rs3fpu: out Bool;
  port disp_oitf_rdfpu:  out Bool;
  port disp_oitf_rs1en:  out Bool;
  port disp_oitf_rs2en:  out Bool;
  port disp_oitf_rs3en:  out Bool;
  port disp_oitf_rdwen:  out Bool;
  port disp_oitf_rs1idx: out UInt<5>;
  port disp_oitf_rs2idx: out UInt<5>;
  port disp_oitf_rs3idx: out UInt<5>;
  port disp_oitf_rdidx:  out UInt<5>;
  port disp_oitf_pc:     out UInt<32>;

  // ── Hazard detection ──────────────────────────────────────────────
  // Reference does NOT gate on rs1en/rs2en — matches any rs-field hit
  let raw_dep: Bool = oitfrd_match_disprs1 |
                       oitfrd_match_disprs2 |
                       oitfrd_match_disprs3;
  // Reference matches any rd-field hit regardless of rdwen
  let waw_dep: Bool = oitfrd_match_disprd;
  let dep: Bool = raw_dep | waw_dep;

  // Instruction group from info bus (bits [2:0])
  let disp_i_info_grp: UInt<3> = disp_i_info[2:0];

  // CSR group = 3; FENCE/FENCEI in BJP group (2) with specific bits
  let disp_csr: Bool = disp_i_info_grp == 3;
  let disp_fence_fencei: Bool = (disp_i_info_grp == 2) &
                                  (disp_i_info[14:14] | disp_i_info[15:15]);

  // Long-pipe prediction: AGU group (1)
  let disp_alu_longp_prdt: Bool = disp_i_info_grp == 1;

  // Dispatch condition matches reference exactly
  let disp_condition: Bool =
      (disp_csr ? oitf_empty : true)
    & (disp_fence_fencei ? oitf_empty : true)
    & ~wfi_halt_exu_req
    & ~dep
    & (disp_alu_longp_prdt ? disp_oitf_ready : true);

  comb
    // Dispatch handshake
    disp_o_alu_valid = disp_i_valid & disp_condition;
    disp_i_ready     = disp_o_alu_ready & disp_condition;

    // Pass-through to ALU (x0 hardwired to 0)
    disp_o_alu_rs1     = disp_i_rs1x0 ? 0 : disp_i_rs1;
    disp_o_alu_rs2     = disp_i_rs2x0 ? 0 : disp_i_rs2;
    disp_o_alu_rdwen   = disp_i_rdwen;
    disp_o_alu_rdidx   = disp_i_rdidx;
    disp_o_alu_info    = disp_i_info;
    disp_o_alu_imm     = disp_i_imm;
    disp_o_alu_pc      = disp_i_pc;
    disp_o_alu_itag    = disp_oitf_ptr;
    disp_o_alu_misalgn = disp_i_misalgn;
    disp_o_alu_buserr  = disp_i_buserr;
    disp_o_alu_ilegl   = disp_i_ilegl;

    // OITF dispatch: allocate entry for long-pipe instructions
    disp_oitf_ena    = disp_i_valid & disp_i_ready & disp_o_alu_longpipe;
    disp_oitf_rs1en  = disp_i_rs1en;
    disp_oitf_rs2en  = disp_i_rs2en;
    disp_oitf_rs3en  = false;
    disp_oitf_rdwen  = disp_i_rdwen;
    disp_oitf_rs1idx = disp_i_rs1idx;
    disp_oitf_rs2idx = disp_i_rs2idx;
    disp_oitf_rs3idx = 0;
    disp_oitf_rdidx  = disp_i_rdidx;
    disp_oitf_pc     = disp_i_pc;

    // No FPU in E203
    disp_oitf_rs1fpu = false;
    disp_oitf_rs2fpu = false;
    disp_oitf_rs3fpu = false;
    disp_oitf_rdfpu  = false;

    // WFI halt ack: EXU ready to halt when OITF is empty and no AMO
    wfi_halt_exu_ack = oitf_empty & ~amo_wait;
  end comb

end module e203_exu_disp
