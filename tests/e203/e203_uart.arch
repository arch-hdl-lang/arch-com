// E203 UART Peripheral (simplified)
// APB-accessible UART with TX/RX, configurable baud divisor.
// Registers: txdata(0x00), rxdata(0x04), txctrl(0x08), rxctrl(0x0C),
//            div(0x10), status(0x14)
// TX: write to txdata starts transmission.
// RX: read from rxdata returns received byte.
// Uses shift-register based serial TX/RX.

domain SysDomain
  freq_mhz: 100
end domain SysDomain

module Uart

  port clk:   in Clock<SysDomain>;
  port rst_n: in Reset<Async, Low>;

  // APB slave interface
  port psel:    in  Bool;
  port penable: in  Bool;
  port paddr:   in  UInt<32>;
  port pwdata:  in  UInt<32>;
  port pwrite:  in  Bool;
  port prdata:  out UInt<32>;
  port pready:  out Bool;

  // UART pins
  port uart_tx: out Bool;
  port uart_rx: in  Bool;

  // Interrupt
  port uart_irq: out Bool;

  // ── Baud rate divider ──────────────────────────────────────────
  reg baud_div_r: UInt<16> init 1 reset rst_n=1;  // configurable; default=1 for sim
  reg baud_cnt_r: UInt<16> init 0 reset rst_n=0;
  let baud_tick: Bool = (baud_cnt_r == 0);

  // ── TX state ───────────────────────────────────────────────────
  reg tx_shift_r: UInt<10> init 0x3FF reset rst_n=0x3FF;  // idle=all 1s: {stop, data[7:0], start}
  reg tx_cnt_r:   UInt<4>  init 0 reset rst_n=0;      // bit counter (0=idle)
  reg tx_busy_r:  Bool     init false reset rst_n=false;

  // ── RX state ───────────────────────────────────────────────────
  reg rx_shift_r: UInt<8>  init 0 reset rst_n=0;
  reg rx_cnt_r:   UInt<4>  init 0 reset rst_n=0;
  reg rx_valid_r: Bool     init false reset rst_n=false;
  reg rx_data_r:  UInt<8>  init 0 reset rst_n=0;
  reg rx_prev_r:  Bool     init true reset rst_n=true;   // previous rx pin

  // ── TX/RX enable ───────────────────────────────────────────────
  reg txen_r: Bool init false reset rst_n=false;
  reg rxen_r: Bool init false reset rst_n=false;

  // APB decode
  let reg_off: UInt<8> = paddr.trunc<7,0>();
  let apb_wr: Bool = psel & penable & pwrite;

  seq on clk rising
    // Baud counter
    if baud_cnt_r == 0
      baud_cnt_r <= baud_div_r;
    else
      baud_cnt_r <= (baud_cnt_r - 1).trunc<16>();
    end if

    // ── TX logic ─────────────────────────────────────────────────
    if apb_wr & (reg_off == 0x00) & ~tx_busy_r
      // Load TX shift register: {1(stop), data[7:0], 0(start)}
      tx_shift_r <= {true, pwdata.trunc<7,0>(), false};
      tx_cnt_r   <= 10;
      tx_busy_r  <= true;
    elsif tx_busy_r & baud_tick
      // Shift out LSB first
      tx_shift_r <= {true, tx_shift_r.trunc<9,1>()};
      tx_cnt_r   <= (tx_cnt_r - 1).trunc<4>();
      if tx_cnt_r == 1
        tx_busy_r <= false;
      end if
    end if

    // ── RX logic ─────────────────────────────────────────────────
    rx_prev_r <= uart_rx;

    if rxen_r
      if rx_cnt_r == 0
        // Wait for start bit (falling edge)
        if rx_prev_r & ~uart_rx
          rx_cnt_r <= 9;  // 1 start + 8 data
        end if
      elsif baud_tick
        if rx_cnt_r > 1
          // Sample data bits
          rx_shift_r <= {uart_rx, rx_shift_r.trunc<7,1>()};
        end if
        rx_cnt_r <= (rx_cnt_r - 1).trunc<4>();
        if rx_cnt_r == 1
          rx_data_r  <= {uart_rx, rx_shift_r.trunc<7,1>()};
          rx_valid_r <= true;
        end if
      end if
    end if

    // Clear rx_valid on read
    if psel & penable & ~pwrite & (reg_off == 0x04)
      rx_valid_r <= false;
    end if

    // Register writes
    if apb_wr
      if reg_off == 0x08
        txen_r <= pwdata.trunc<0,0>() != 0;
      elsif reg_off == 0x0C
        rxen_r <= pwdata.trunc<0,0>() != 0;
      elsif reg_off == 0x10
        baud_div_r <= pwdata.trunc<15,0>();
      end if
    end if
  end seq

  comb
    // TX pin
    if tx_busy_r
      uart_tx = tx_shift_r.trunc<0,0>() != 0;
    else
      uart_tx = true;  // idle high
    end if

    // APB read
    if reg_off == 0x00
      prdata = {tx_busy_r, {31{false}}};  // bit 31 = tx_busy (full)
    elsif reg_off == 0x04
      prdata = {~rx_valid_r, {23{false}}, rx_data_r};  // bit 31 = empty
    elsif reg_off == 0x08
      prdata = txen_r.zext<32>();
    elsif reg_off == 0x0C
      prdata = rxen_r.zext<32>();
    elsif reg_off == 0x10
      prdata = baud_div_r.zext<32>();
    elsif reg_off == 0x14
      // Status: bit 0 = tx_busy, bit 1 = rx_valid
      prdata = {tx_busy_r, rx_valid_r}.zext<32>();
    else
      prdata = 0;
    end if

    pready   = true;
    uart_irq = rx_valid_r;
  end comb

end module Uart
