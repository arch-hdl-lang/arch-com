// E203 HBirdv2 ALU shared datapath
// Handles ALU, BJP (branch/jump), and AGU (address gen) operation requests.
// Pure combinational except for two shared-buffer registers (no reset).

module AluDpath
  param XLEN: const = 32;

  port clk:   in Clock<SysDomain>;
  port rst_n: in Reset<Async, Low>;

  // ── Regular ALU requests ───────────────────────────────────────────────
  port alu_req_alu:      in Bool;
  port alu_req_alu_add:  in Bool;
  port alu_req_alu_sub:  in Bool;
  port alu_req_alu_xor:  in Bool;
  port alu_req_alu_sll:  in Bool;
  port alu_req_alu_srl:  in Bool;
  port alu_req_alu_sra:  in Bool;
  port alu_req_alu_or:   in Bool;
  port alu_req_alu_and:  in Bool;
  port alu_req_alu_slt:  in Bool;
  port alu_req_alu_sltu: in Bool;
  port alu_req_alu_lui:  in Bool;
  port alu_req_alu_op1:  in UInt<32>;
  port alu_req_alu_op2:  in UInt<32>;
  port alu_req_alu_res:  out UInt<32>;

  // ── Branch/Jump unit requests ──────────────────────────────────────────
  port bjp_req_alu:         in Bool;
  port bjp_req_alu_op1:     in UInt<32>;
  port bjp_req_alu_op2:     in UInt<32>;
  port bjp_req_alu_cmp_eq:  in Bool;
  port bjp_req_alu_cmp_ne:  in Bool;
  port bjp_req_alu_cmp_lt:  in Bool;
  port bjp_req_alu_cmp_gt:  in Bool;
  port bjp_req_alu_cmp_ltu: in Bool;
  port bjp_req_alu_cmp_gtu: in Bool;
  port bjp_req_alu_add:     in Bool;
  port bjp_req_alu_add_res: out UInt<32>;
  port bjp_req_alu_cmp_res: out Bool;

  // ── AGU requests (AMO + address calc) ─────────────────────────────────
  port agu_req_alu:      in Bool;
  port agu_req_alu_op1:  in UInt<32>;
  port agu_req_alu_op2:  in UInt<32>;
  port agu_req_alu_swap: in Bool;
  port agu_req_alu_add:  in Bool;
  port agu_req_alu_and:  in Bool;
  port agu_req_alu_or:   in Bool;
  port agu_req_alu_xor:  in Bool;
  port agu_req_alu_max:  in Bool;
  port agu_req_alu_min:  in Bool;
  port agu_req_alu_maxu: in Bool;
  port agu_req_alu_minu: in Bool;
  port agu_req_alu_res:  out UInt<32>;

  // ── Shared-buffer load enables (AGU multi-cycle AMO) ──────────────────
  port agu_sbf_0_ena: in Bool;
  port agu_sbf_0_nxt: in UInt<32>;
  port agu_sbf_1_ena: in Bool;
  port agu_sbf_1_nxt: in UInt<32>;

  // ── Shared buffer registers (no reset — hold AMO operands) ────────────
  reg sbf_0_r: UInt<32> init 0 reset none;
  reg sbf_1_r: UInt<32> init 0 reset none;

  always on clk rising
    if agu_sbf_0_ena
      sbf_0_r <= agu_sbf_0_nxt;
    end if
    if agu_sbf_1_ena
      sbf_1_r <= agu_sbf_1_nxt;
    end if
  end always

  // ── Shared operand mux: BJP > AGU > ALU ───────────────────────────────
  let req_op1: UInt<32> = bjp_req_alu ? bjp_req_alu_op1 :
                agu_req_alu ? agu_req_alu_op1 :
                              alu_req_alu_op1;

  let req_op2: UInt<32> = bjp_req_alu ? bjp_req_alu_op2 :
                agu_req_alu ? agu_req_alu_op2 :
                              alu_req_alu_op2;

  // ── Shared adder (add/sub — BJP add, ALU add/sub, AGU add) ────────────
  // Subtraction: op1 + ~op2 + 1 (two's complement); captured in 33 bits
  let adder_op2_inv: UInt<32> = ~req_op2;
  let do_sub: Bool = alu_req_alu_sub | alu_req_alu_slt | alu_req_alu_sltu |
               bjp_req_alu_cmp_eq | bjp_req_alu_cmp_ne |
               bjp_req_alu_cmp_lt | bjp_req_alu_cmp_gt |
               bjp_req_alu_cmp_ltu | bjp_req_alu_cmp_gtu |
               agu_req_alu_max | agu_req_alu_min |
               agu_req_alu_maxu | agu_req_alu_minu;

  let adder_op2_sel: UInt<32> = do_sub ? adder_op2_inv : req_op2;

  // 33-bit result: bit 32 = carry-out (unsigned) or sign (signed sext)
  let adder_res: UInt<33> = (req_op1.zext<33>() + adder_op2_sel.zext<33>() +
                              do_sub.zext<33>()).trunc<33>();
  let adder_res32: UInt<32> = adder_res.trunc<32>();

  // Unsigned carry-out: bit 32 = 1 → no borrow → op1 >= op2
  let adder_carry: Bool = (adder_res >> 32) != 0;

  // ── Signed comparison via SInt cast ───────────────────────────────────
  let signed_lt: Bool = (req_op1 as SInt<32>) < (req_op2 as SInt<32>);

  // ── Shift amount: lower 5 bits of op2 ─────────────────────────────────
  let shamt: UInt<5> = alu_req_alu_op2.trunc<4,0>();

  // ── XOR (also used for EQ/NE comparison) ──────────────────────────────
  let xor_res: UInt<32> = req_op1 ^ req_op2;
  let xor_all_zero: Bool = xor_res == 0;

  // ── Combinational outputs ──────────────────────────────────────────────
  comb
    // ── ALU result ──────────────────────────────────────────────────────
    if alu_req_alu_add
      alu_req_alu_res = adder_res32;
    else if alu_req_alu_sub
      alu_req_alu_res = adder_res32;
    else if alu_req_alu_xor
      alu_req_alu_res = xor_res;
    else if alu_req_alu_or
      alu_req_alu_res = alu_req_alu_op1 | alu_req_alu_op2;
    else if alu_req_alu_and
      alu_req_alu_res = alu_req_alu_op1 & alu_req_alu_op2;
    else if alu_req_alu_sll
      alu_req_alu_res = (alu_req_alu_op1 << shamt).trunc<32>();
    else if alu_req_alu_srl
      alu_req_alu_res = alu_req_alu_op1 >> shamt;
    else if alu_req_alu_sra
      alu_req_alu_res = ((alu_req_alu_op1 as SInt<32>) >> shamt) as UInt<32>;
    else if alu_req_alu_slt
      alu_req_alu_res = signed_lt.zext<32>();
    else if alu_req_alu_sltu
      alu_req_alu_res = (~adder_carry).zext<32>();
    else if alu_req_alu_lui
      alu_req_alu_res = alu_req_alu_op2;
    else
      alu_req_alu_res = 0;
    end if

    // ── BJP addition result (JAL/JALR return address = PC + 4/2) ────────
    bjp_req_alu_add_res = adder_res32;

    // ── BJP comparison result ────────────────────────────────────────────
    if bjp_req_alu_cmp_eq
      bjp_req_alu_cmp_res = xor_all_zero;
    else if bjp_req_alu_cmp_ne
      bjp_req_alu_cmp_res = ~xor_all_zero;
    else if bjp_req_alu_cmp_lt
      bjp_req_alu_cmp_res = signed_lt;
    else if bjp_req_alu_cmp_gt
      bjp_req_alu_cmp_res = ~signed_lt & ~xor_all_zero;
    else if bjp_req_alu_cmp_ltu
      bjp_req_alu_cmp_res = ~adder_carry;
    else if bjp_req_alu_cmp_gtu
      bjp_req_alu_cmp_res = adder_carry & ~xor_all_zero;
    else
      bjp_req_alu_cmp_res = false;
    end if

    // ── AGU result ───────────────────────────────────────────────────────
    if agu_req_alu_add
      agu_req_alu_res = adder_res32;
    else if agu_req_alu_and
      agu_req_alu_res = agu_req_alu_op1 & agu_req_alu_op2;
    else if agu_req_alu_or
      agu_req_alu_res = agu_req_alu_op1 | agu_req_alu_op2;
    else if agu_req_alu_xor
      agu_req_alu_res = agu_req_alu_op1 ^ agu_req_alu_op2;
    else if agu_req_alu_swap
      // SWAP: write mem value (op2) to rd; op1 is the address
      agu_req_alu_res = agu_req_alu_op2;
    else if agu_req_alu_max
      agu_req_alu_res = signed_lt ? agu_req_alu_op2 : agu_req_alu_op1;
    else if agu_req_alu_min
      agu_req_alu_res = signed_lt ? agu_req_alu_op1 : agu_req_alu_op2;
    else if agu_req_alu_maxu
      agu_req_alu_res = (~adder_carry) ? agu_req_alu_op2 : agu_req_alu_op1;
    else if agu_req_alu_minu
      agu_req_alu_res = (~adder_carry) ? agu_req_alu_op1 : agu_req_alu_op2;
    else
      agu_req_alu_res = 0;
    end if
  end comb

end module AluDpath
