// E203 Clock Control
// Generates gated clocks for core subsystems and TCMs.
// Port list matches RealBench testbench.

module e203_clk_ctrl

  port clk:         in Clock<SysDomain>;
  port rst_n:       in Reset<Async, Low>;
  port test_mode:   in Bool;
  port core_cgstop: in Bool;

  // Subsystem active flags (inputs — used for clock gating decisions)
  port core_ifu_active: in Bool;
  port core_exu_active: in Bool;
  port core_lsu_active: in Bool;
  port core_biu_active: in Bool;
  port itcm_active:     in Bool;
  port dtcm_active:     in Bool;
  port core_wfi:        in Bool;

  // Gated clocks out
  port clk_core_ifu: out Clock<SysDomain>;
  port clk_core_exu: out Clock<SysDomain>;
  port clk_core_lsu: out Clock<SysDomain>;
  port clk_core_biu: out Clock<SysDomain>;
  port clk_itcm:     out Clock<SysDomain>;
  port clk_dtcm:     out Clock<SysDomain>;
  port clk_aon:      out Clock<SysDomain>;

  // TCM light-sleep outputs
  port itcm_ls: out Bool;
  port dtcm_ls: out Bool;

  // Gate enable: active & not stopped
  let ifu_gate_en: Bool = core_ifu_active & (~core_cgstop);
  let exu_gate_en: Bool = core_exu_active & (~core_cgstop);
  let lsu_gate_en: Bool = core_lsu_active & (~core_cgstop);
  let biu_gate_en: Bool = core_biu_active & (~core_cgstop);
  let itcm_gate_en: Bool = itcm_active & (~core_cgstop);
  let dtcm_gate_en: Bool = dtcm_active & (~core_cgstop);

  // ICG instances
  inst icg_ifu: e203_clkgate
    clk_in    <- clk;
    clock_en  <- ifu_gate_en;
    test_mode <- test_mode;
    clk_out   -> clk_ifu_w;
  end inst icg_ifu

  inst icg_exu: e203_clkgate
    clk_in    <- clk;
    clock_en  <- exu_gate_en;
    test_mode <- test_mode;
    clk_out   -> clk_exu_w;
  end inst icg_exu

  inst icg_lsu: e203_clkgate
    clk_in    <- clk;
    clock_en  <- lsu_gate_en;
    test_mode <- test_mode;
    clk_out   -> clk_lsu_w;
  end inst icg_lsu

  inst icg_biu: e203_clkgate
    clk_in    <- clk;
    clock_en  <- biu_gate_en;
    test_mode <- test_mode;
    clk_out   -> clk_biu_w;
  end inst icg_biu

  inst icg_itcm: e203_clkgate
    clk_in    <- clk;
    clock_en  <- itcm_gate_en;
    test_mode <- test_mode;
    clk_out   -> clk_itcm_w;
  end inst icg_itcm

  inst icg_dtcm: e203_clkgate
    clk_in    <- clk;
    clock_en  <- dtcm_gate_en;
    test_mode <- test_mode;
    clk_out   -> clk_dtcm_w;
  end inst icg_dtcm

  comb
    clk_core_ifu = clk_ifu_w;
    clk_core_exu = clk_exu_w;
    clk_core_lsu = clk_lsu_w;
    clk_core_biu = clk_biu_w;
    clk_itcm = clk_itcm_w;
    clk_dtcm = clk_dtcm_w;
    clk_aon  = clk;  // Always-on = ungated

    // TCM light-sleep: enter when inactive and WFI
    itcm_ls = (~itcm_active) & core_wfi;
    dtcm_ls = (~dtcm_active) & core_wfi;
  end comb

end module e203_clk_ctrl
