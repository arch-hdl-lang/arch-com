module instruction_cache_controller
  param TAG_BITS: const = 8;
  param ADR_BITS: const = 9;

  port clk:  in Clock<SysDomain>;
  port rst:  in Reset<Async>;

  port io_mem_valid: out Bool;
  port io_mem_ready: in  Bool;
  port io_mem_addr:  out UInt<17>;

  port l1b_wait: out Bool;
  port l1b_data: out UInt<32>;
  port l1b_addr: in  UInt<18>;

  port ram256_t0_we:   out Bool;
  port ram256_t0_addr: out UInt<8>;
  port ram256_t0_data: in  UInt<8>;

  port ram256_t1_we:   out Bool;
  port ram256_t1_addr: out UInt<8>;
  port ram256_t1_data: in  UInt<8>;

  port ram512_d0_we:   out Bool;
  port ram512_d0_addr: out UInt<9>;
  port ram512_d0_data: in  UInt<16>;

  port ram512_d1_we:   out Bool;
  port ram512_d1_addr: out UInt<9>;
  port ram512_d1_data: in  UInt<16>;

  // Unaligned data handling
  wire data_0: UInt<16>;
  wire data_1: UInt<16>;

  comb
    if l1b_addr[0]
      data_0 = ram512_d1_data;
      data_1 = ram512_d0_data;
    else
      data_0 = ram512_d0_data;
      data_1 = ram512_d1_data;
    end if
    l1b_data = {data_1, data_0};
  end comb

  // FSM states: IDLE=0, READMEM0=1, READMEM1=2, READCACHE=3
  reg state_r:    UInt<3> reset rst=>0;
  reg addr_0_r:   UInt<9> reset rst=>0;
  reg addr_1_r:   UInt<9> reset rst=>0;
  reg write_en_r: Bool    reset rst=>false;

  let data_addr_0: UInt<9> = (l1b_addr[17:9] + {8'd0, l1b_addr[0]}).trunc<9>();
  let data_addr_1: UInt<9> = l1b_addr[17:9];

  // Tag controller outputs
  wire valid_0: Bool;
  wire tag_0:   UInt<8>;
  wire valid_1: Bool;
  wire tag_1:   UInt<8>;

  wire tc_data_out_0: UInt<9>;
  wire tc_data_out_1: UInt<9>;

  comb
    valid_0 = tc_data_out_0[8];
    tag_0   = tc_data_out_0[7:0];
    valid_1 = tc_data_out_1[8];
    tag_1   = tc_data_out_1[7:0];
  end comb

  let data_0_ready: Bool = (l1b_addr[17:9] == tag_0.zext<9>()) & valid_0;
  let data_1_ready: Bool = (l1b_addr[17:9] == tag_1.zext<9>()) & valid_1;

  // Next state + output logic (all wires)
  wire next_state: UInt<3>;
  wire mem_valid_w: Bool;
  wire mem_addr_w:  UInt<17>;
  wire wait_w:      Bool;
  wire d0_we_w: Bool;
  wire d1_we_w: Bool;

  comb
    next_state  = 0;
    mem_valid_w = false;
    mem_addr_w  = 0;
    wait_w      = false;
    d0_we_w     = false;
    d1_we_w     = false;

    if state_r == 0
      // IDLE
      if data_0_ready & data_1_ready
        wait_w = false;
        next_state = 0;
      else
        wait_w = true;
        next_state = 1;
        mem_valid_w = true;
        mem_addr_w = {1'd0, l1b_addr[17:9], 7'd0};
      end if
    elsif state_r == 1
      // READMEM0
      wait_w = true;
      mem_valid_w = true;
      mem_addr_w = {1'd0, addr_1_r, 7'd0};
      if io_mem_ready
        d0_we_w = true;
        next_state = 2;
      else
        next_state = 1;
      end if
    elsif state_r == 2
      // READMEM1
      wait_w = true;
      mem_valid_w = true;
      mem_addr_w = {1'd0, addr_0_r, 7'd0};
      if io_mem_ready
        d1_we_w = true;
        next_state = 3;
      else
        next_state = 2;
      end if
    elsif state_r == 3
      // READCACHE
      wait_w = false;
      next_state = 0;
    else
      next_state = 0;
    end if

    io_mem_valid = mem_valid_w;
    io_mem_addr  = mem_addr_w;
    l1b_wait     = wait_w;
    ram512_d0_we = d0_we_w;
    ram512_d1_we = d1_we_w;
    ram512_d0_addr = addr_0_r;
    ram512_d1_addr = addr_1_r;
  end comb

  // Sequential logic
  seq on clk rising
    if (state_r == 1) | (state_r == 2)
      if io_mem_ready
        write_en_r <= true;
      else
        write_en_r <= false;
      end if
    else
      write_en_r <= false;
    end if
    state_r  <= next_state;
    addr_0_r <= data_addr_0;
    addr_1_r <= data_addr_1;
  end seq

  // Tag controller instance
  inst tag_ctrl: tag_controller
    connect clk          <- clk;
    connect rst          <- rst;
    connect write_enable <- write_en_r;
    connect write_addr   <- io_mem_addr[8:0];
    connect read_addr_0  <- data_addr_0[7:0];
    connect read_addr_1  <- data_addr_1[7:0];
    connect data_in_0    <- ram256_t0_data;
    connect data_in_1    <- ram256_t1_data;
    connect data_out_0   -> tc_data_out_0;
    connect data_out_1   -> tc_data_out_1;
    connect write_enable_0 -> ram256_t0_we;
    connect write_enable_1 -> ram256_t1_we;
    connect addr_out_0   -> ram256_t0_addr;
    connect addr_out_1   -> ram256_t1_addr;
  end inst tag_ctrl
end module instruction_cache_controller
