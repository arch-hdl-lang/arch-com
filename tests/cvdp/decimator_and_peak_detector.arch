module advanced_decimator_with_adaptive_peak_detection
  param N: const = 8;
  param DATA_WIDTH: const = 16;
  param DEC_FACTOR: const = 4;
  param NUM_DEC: const = N / DEC_FACTOR;

  port clk: in Clock<SysDomain>;
  port reset: in Reset<Async>;
  port valid_in: in Bool;
  port data_in: in UInt<DATA_WIDTH * N>;
  port valid_out: out pipe_reg<Bool, 1> reset reset=>false;
  port data_out: out pipe_reg<UInt<DATA_WIDTH * NUM_DEC>, 1> reset reset=>0;
  port peak_value: out pipe_reg<SInt<DATA_WIDTH>, 1> reset reset=>0;

  default seq on clk rising;

  // Decimation: select every DEC_FACTOR-th sample and pack output
  wire dec_packed: UInt<DATA_WIDTH * NUM_DEC>;
  comb
    for i in 0..NUM_DEC - 1
      dec_packed[i * DATA_WIDTH + DATA_WIDTH - 1 : i * DATA_WIDTH] = data_in[i * DEC_FACTOR * DATA_WIDTH + DATA_WIDTH - 1 : i * DEC_FACTOR * DATA_WIDTH];
    end for
  end comb

  // Peak detection: find max among decimated samples (signed comparison)
  wire peak: SInt<DATA_WIDTH>;
  comb
    peak = data_in[DATA_WIDTH - 1 : 0] as SInt<DATA_WIDTH>;
    for i in 0..NUM_DEC - 1
      if (dec_packed[i * DATA_WIDTH + DATA_WIDTH - 1 : i * DATA_WIDTH] as SInt<DATA_WIDTH>) > peak
        peak = dec_packed[i * DATA_WIDTH + DATA_WIDTH - 1 : i * DATA_WIDTH] as SInt<DATA_WIDTH>;
      end if
    end for
  end comb

  // Register outputs (1-cycle latency)
  seq
    valid_out <= valid_in;
    data_out <= dec_packed;
    peak_value <= peak;
  end seq

end module advanced_decimator_with_adaptive_peak_detection
