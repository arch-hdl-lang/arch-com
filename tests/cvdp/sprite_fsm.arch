fsm sprite_controller_fsm
  param MEM_ADDR_WIDTH: const = 16;
  param PIXEL_WIDTH: const = 24;
  param SPRITE_WIDTH: const = 16;
  param SPRITE_HEIGHT: const = 16;
  param WAIT_WIDTH: const = 4;
  param N_ROM: const = 256;

  port clk: in Clock<SysDomain>;
  port rst_n: in Reset<Sync, Low>;
  port i_wait: in UInt<WAIT_WIDTH>;
  port reg rw: out Bool reset rst_n=>false;
  port reg write_addr: out UInt<MEM_ADDR_WIDTH> reset rst_n=>0;
  port reg write_data: out UInt<PIXEL_WIDTH> reset rst_n=>0;
  port reg x_pos: out UInt<SPRITE_WIDTH> reset rst_n=>0;
  port reg y_pos: out UInt<SPRITE_HEIGHT> reset rst_n=>0;
  port pixel_out: in UInt<PIXEL_WIDTH>;
  port reg done: out Bool reset rst_n=>false;

  reg addr_cnt: UInt<MEM_ADDR_WIDTH> reset rst_n=>0;
  reg data_cnt: UInt<PIXEL_WIDTH> reset rst_n=>0;
  reg wait_cnt: UInt<WAIT_WIDTH> reset rst_n=>0;

  state [IDLE, INIT_WRITE, WRITE, INIT_READ, READ, WAIT, DONE]
  default state IDLE;
  default seq on clk rising;

  state IDLE
    seq
      rw <= false;
      addr_cnt <= 0;
      data_cnt <= 0;
      done <= false;
    end seq
    -> INIT_WRITE;
  end state IDLE

  state INIT_WRITE
    seq
      rw <= true;
      write_data <= 24'hFF0000;
      write_addr <= addr_cnt;
    end seq
    -> WRITE;
  end state INIT_WRITE

  state WRITE
    seq
      write_addr <= addr_cnt;
      write_data <= data_cnt;
      addr_cnt <= (addr_cnt + 1).trunc<MEM_ADDR_WIDTH>();
      data_cnt <= (data_cnt + 1).trunc<PIXEL_WIDTH>();
    end seq
    -> INIT_READ when addr_cnt.zext<32>() == (N_ROM - 1);
  end state WRITE

  state INIT_READ
    seq
      rw <= false;
      addr_cnt <= 0;
    end seq
    -> READ;
  end state INIT_READ

  state READ
    seq
      x_pos <= (addr_cnt.zext<32>() % SPRITE_WIDTH).trunc<SPRITE_WIDTH>();
      y_pos <= (addr_cnt.zext<32>() / SPRITE_WIDTH).trunc<SPRITE_HEIGHT>();
      addr_cnt <= (addr_cnt + 1).trunc<MEM_ADDR_WIDTH>();
    end seq
    -> WAIT when addr_cnt.zext<32>() == (SPRITE_WIDTH * SPRITE_HEIGHT - 1);
  end state READ

  state WAIT
    seq
      wait_cnt <= (wait_cnt + 1).trunc<WAIT_WIDTH>();
    end seq
    -> DONE when wait_cnt == i_wait;
  end state WAIT

  state DONE
    seq
      done <= true;
    end seq
    -> IDLE;
  end state DONE

end fsm sprite_controller_fsm
