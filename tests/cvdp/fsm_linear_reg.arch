module fsm_linear_reg
  param DATA_WIDTH: const = 16;
  port clk:     in Clock<SysDomain>;
  port reset:   in Reset<Async, High>;
  port start:   in Bool;
  port x_in:    in SInt<DATA_WIDTH>;
  port w_in:    in SInt<DATA_WIDTH>;
  port b_in:    in SInt<DATA_WIDTH>;
  port reg result1: out SInt<DATA_WIDTH * 2> reset reset=>0;
  port reg result2: out SInt<DATA_WIDTH + 1> reset reset=>0;
  port reg done:    out Bool reset reset=>0;

  reg state: UInt<2> reset reset=>0;
  reg buf_result1: SInt<DATA_WIDTH * 2> reset reset=>0;
  reg buf_result2: SInt<DATA_WIDTH + 1> reset reset=>0;
  reg buf_done: Bool reset reset=>0;

  let x_shifted: SInt<DATA_WIDTH> = x_in >> 2;
  let product: SInt<DATA_WIDTH * 2> = (w_in.sext<DATA_WIDTH * 2>() * x_in.sext<DATA_WIDTH * 2>()).trunc<DATA_WIDTH * 2>();

  seq on clk rising
    result1 <= buf_result1;
    result2 <= buf_result2;
    done    <= buf_done;

    if state == 0
      if start
        state <= 1;
      end if
      buf_result1 <= 0;
      buf_result2 <= 0;
      buf_done    <= false;
    elsif state == 1
      buf_result1 <= (product >> 1).trunc<DATA_WIDTH * 2>();
      buf_result2 <= (b_in.sext<DATA_WIDTH + 1>() + x_shifted.sext<DATA_WIDTH + 1>()).trunc<DATA_WIDTH + 1>();
      buf_done    <= false;
      state       <= 2;
    elsif state == 2
      buf_done <= true;
      state    <= 0;
    else
      state       <= 0;
      buf_result1 <= 0;
      buf_result2 <= 0;
      buf_done    <= false;
    end if
  end seq
end module fsm_linear_reg
