module secure_variable_timer
  port i_clk: in Clock<SysDomain>;
  port i_rst_n: in Reset<Sync, Low>;
  port i_data_in: in Bool;
  port o_time_left: out pipe_reg<UInt<4>, 1> reset i_rst_n=>0;
  port o_processing: out pipe_reg<Bool, 1> reset i_rst_n=>false;
  port o_completed: out pipe_reg<Bool, 1> reset i_rst_n=>false;
  port i_ack: in Bool;

  default seq on i_clk rising;

  // State encoding: 0=IDLE, 1=CONFIG, 2=COUNT, 3=DONE
  reg st: UInt<2> reset i_rst_n=>0;
  reg shift_reg: UInt<4> reset i_rst_n=>0;
  reg bit_cnt: UInt<3> reset i_rst_n=>0;
  reg delay_val: UInt<4> reset i_rst_n=>0;
  reg cycle_cnt: UInt<10> reset i_rst_n=>0;

  // Pattern detection: track last 4 bits for 1101
  reg pat: UInt<4> reset i_rst_n=>0;

  seq
    if st == 0
      // IDLE: detect 1101 pattern
      pat <= {pat[2:0], i_data_in};
      if pat == 4'b1101
        st <= 1;
        shift_reg <= {3'b000, i_data_in};
        bit_cnt <= 1;
        pat <= 0;
      end if
    elsif st == 1
      // CONFIG: shift in 4 bits MSB first
      shift_reg <= {shift_reg[2:0], i_data_in};
      bit_cnt <= (bit_cnt + 1).trunc<3>();
      if bit_cnt == 3
        st <= 2;
        delay_val <= {shift_reg[2:0], i_data_in};
        o_time_left <= {shift_reg[2:0], i_data_in};
        o_processing <= true;
        cycle_cnt <= 0;
      end if
    elsif st == 2
      // COUNT
      if cycle_cnt == 999
        cycle_cnt <= 0;
        if o_time_left == 0
          st <= 3;
          o_processing <= false;
          o_completed <= true;
        else
          o_time_left <= (o_time_left - 1).trunc<4>();
        end if
      else
        cycle_cnt <= (cycle_cnt + 1).trunc<10>();
      end if
    else
      // DONE: wait for ack
      if i_ack
        st <= 0;
        o_completed <= false;
        o_processing <= false;
        o_time_left <= 0;
        pat <= 0;
      end if
    end if
  end seq
end module secure_variable_timer
