fsm apb_dsp_unit
  port pclk:    in Clock<SysDomain>;
  port presetn: in Reset<Async, Low>;
  port paddr:   in UInt<10>;
  port pselx:   in Bool;
  port penable: in Bool;
  port pwrite:  in Bool;
  port pwdata:  in UInt<8>;
  port sram_valid: in Clock<SysDomain>;
  port reg pready:  out Bool reset presetn => false;
  port reg prdata:  out UInt<8> reset presetn => 0;
  port reg pslverr: out Bool reset presetn => false;

  state [Idle, WriteAccess, ReadAccess]
  default state Idle;

  // Config registers
  reg r_operand_1: UInt<10> reset presetn => 0;
  reg r_operand_2: UInt<10> reset presetn => 0;
  reg r_Enable: UInt<8> reset presetn => 0;
  reg r_write_address: UInt<10> reset presetn => 0;
  reg r_write_data: UInt<8> reset presetn => 0;

  // SRAM 1KB - init only
  reg mem: Vec<UInt<8>, 1024> init 0;

  // Result register at address 0x5
  reg r_result: UInt<8> reset presetn => 0;

  default
    // SRAM write on posedge sram_valid
    seq on sram_valid rising
      mem[r_write_address] <= r_write_data;
    end seq

    // DSP computation runs every cycle
    seq on pclk rising
      if r_Enable == 1
        r_result <= (mem[r_operand_1] + mem[r_operand_2]).trunc<8>();
      elsif r_Enable == 2
        r_result <= (mem[r_operand_1] * mem[r_operand_2]).trunc<8>();
      end if
    end seq
  end default

  state Idle
    seq on pclk rising
      pready <= false;
      pslverr <= false;
      if pselx & ~penable
        if ~pwrite
          if paddr == 0
            prdata <= r_operand_1.trunc<8>();
          elsif paddr == 1
            prdata <= r_operand_2.trunc<8>();
          elsif paddr == 2
            prdata <= r_Enable;
          elsif paddr == 3
            prdata <= r_write_address.trunc<8>();
          elsif paddr == 4
            prdata <= r_write_data;
          elsif paddr == 5
            prdata <= r_result;
          else
            prdata <= mem[paddr];
          end if
        end if
      end if
    end seq
    -> WriteAccess when pselx & ~penable & pwrite;
    -> ReadAccess  when pselx & ~penable & ~pwrite;
  end state Idle

  state WriteAccess
    seq on pclk rising
      pready <= true;
      if paddr == 0
        r_operand_1 <= pwdata.zext<10>();
      elsif paddr == 1
        r_operand_2 <= pwdata.zext<10>();
      elsif paddr == 2
        r_Enable <= pwdata;
      elsif paddr == 3
        r_write_address <= pwdata.zext<10>();
      elsif paddr == 4
        r_write_data <= pwdata;
      else
        pslverr <= true;
      end if
    end seq
    -> Idle;
  end state WriteAccess

  state ReadAccess
    seq on pclk rising
      pready <= true;
    end seq
    -> Idle;
  end state ReadAccess
end fsm apb_dsp_unit
