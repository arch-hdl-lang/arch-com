module Data_Reduction
  param REDUCTION_OP:      const = 0;
  param DATA_WIDTH:        const = 4;
  param DATA_COUNT:        const = 4;
  param TOTAL_INPUT_WIDTH: const = DATA_WIDTH * DATA_COUNT;

  port data_in:          in  UInt<TOTAL_INPUT_WIDTH>;
  port reduced_data_out: out UInt<DATA_WIDTH>;

  // One word per input element, extracted from flat data_in
  wire words: Vec<UInt<DATA_WIDTH>, DATA_COUNT>;

  // Running reductions across all DATA_COUNT words
  wire and_result: UInt<DATA_WIDTH>;
  wire or_result:  UInt<DATA_WIDTH>;
  wire xor_result: UInt<DATA_WIDTH>;

  // Unpack flat input into word array
  comb
    for i in 0..DATA_COUNT-1
      words[i] = data_in[i*DATA_WIDTH + DATA_WIDTH - 1 : i*DATA_WIDTH];
    end for
  end comb

  // Fold words[0..DATA_COUNT-1] with AND, OR, and XOR simultaneously
  comb
    and_result = words[0];
    or_result  = words[0];
    xor_result = words[0];
    for i in 1..DATA_COUNT-1
      and_result = and_result & words[i];
      or_result  = or_result  | words[i];
      xor_result = xor_result ^ words[i];
    end for
  end comb

  // Select output based on REDUCTION_OP parameter
  //   0=AND  1=OR  2=XOR  3=NAND  4=NOR  5=XNOR  6/7=AND (default)
  comb
    if REDUCTION_OP == 1
      reduced_data_out = or_result;
    elsif REDUCTION_OP == 2
      reduced_data_out = xor_result;
    elsif REDUCTION_OP == 3
      reduced_data_out = ~and_result;
    elsif REDUCTION_OP == 4
      reduced_data_out = ~or_result;
    elsif REDUCTION_OP == 5
      reduced_data_out = ~xor_result;
    else
      reduced_data_out = and_result;
    end if
  end comb

end module Data_Reduction
