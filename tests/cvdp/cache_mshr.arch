// Address-CAM helper used by cache_mshr to find the tail of the chain
// for a given line address. Maintains (valid, addr) per slot; the cam's
// dual-write port commits allocate (port 2, wins on conflict) and
// finalize (port 1) on the same edge.
cam Mshr_Addr_Cam
  param DEPTH: const = 32;
  param KEY_W: const = 10;

  port clk: in Clock<SysDomain>;
  port rst: in Reset<Sync, High>;

  // Port 1: finalize (clear by id)
  port write_valid: in Bool;
  port write_idx:   in UInt<5>;
  port write_key:   in UInt<10>;
  port write_set:   in Bool;

  // Port 2: allocate (insert at alloc_idx with allocate_addr) — wins on same-idx conflict
  port write2_valid: in Bool;
  port write2_idx:   in UInt<5>;
  port write2_key:   in UInt<10>;
  port write2_set:   in Bool;

  port search_key:   in  UInt<10>;
  port search_mask:  out UInt<32>;
  port search_any:   out Bool;
  port search_first: out UInt<5>;
end cam Mshr_Addr_Cam

module cache_mshr
  param MSHR_SIZE: const = 32;
  param CS_LINE_ADDR_WIDTH: const = 10;
  param WORD_SEL_WIDTH: const = 4;
  param WORD_SIZE: const = 4;
  local param MSHR_ADDR_WIDTH: const = $clog2(MSHR_SIZE);
  local param TAG_WIDTH: const = 32 - CS_LINE_ADDR_WIDTH - $clog2(WORD_SIZE) - WORD_SEL_WIDTH;
  local param CS_WORD_WIDTH: const = WORD_SIZE * 8;
  local param DATA_WIDTH: const = WORD_SEL_WIDTH + WORD_SIZE + CS_WORD_WIDTH + TAG_WIDTH;

  port clk:   in Clock<SysDomain>;
  port reset: in Reset<Sync, High>;

  // Memory fill interface
  port fill_valid: in Bool;
  port fill_id:    in UInt<MSHR_ADDR_WIDTH>;
  port fill_addr:  out UInt<CS_LINE_ADDR_WIDTH>;

  // Dequeue interface
  port dequeue_valid: out Bool;
  port dequeue_addr:  out UInt<CS_LINE_ADDR_WIDTH>;
  port dequeue_rw:    out Bool;
  port dequeue_data:  out UInt<DATA_WIDTH>;
  port dequeue_id:    out UInt<MSHR_ADDR_WIDTH>;
  port dequeue_ready: in Bool;

  // Allocate interface
  port allocate_valid:   in Bool;
  port allocate_addr:    in UInt<CS_LINE_ADDR_WIDTH>;
  port allocate_rw:      in Bool;
  port allocate_data:    in UInt<DATA_WIDTH>;
  port allocate_id:      out UInt<MSHR_ADDR_WIDTH>;
  port allocate_pending: out Bool;
  port allocate_previd:  out UInt<MSHR_ADDR_WIDTH>;
  port allocate_ready:   out Bool;

  // Finalize interface
  port finalize_valid: in Bool;
  port finalize_id:    in UInt<MSHR_ADDR_WIDTH>;

  default seq on clk rising;
  reg default: reset reset => 0;

  // Entry metadata registers
  reg entry_valid:    Vec<Bool, MSHR_SIZE>;
  reg entry_addr:     Vec<UInt<CS_LINE_ADDR_WIDTH>, MSHR_SIZE>;
  reg entry_write:    Vec<Bool, MSHR_SIZE>;
  reg entry_has_next: Vec<Bool, MSHR_SIZE>;
  reg entry_next_idx: Vec<UInt<MSHR_ADDR_WIDTH>, MSHR_SIZE>;

  // Data RAM
  reg data_mem: Vec<UInt<DATA_WIDTH>, MSHR_SIZE>;

  // Registered outputs for allocate
  reg allocate_id_r:      UInt<MSHR_ADDR_WIDTH>;
  reg allocate_pending_r: Bool;
  reg allocate_previd_r:  UInt<MSHR_ADDR_WIDTH>;

  // Dequeue state registers
  reg dq_valid_r:   Bool;
  reg dq_idx_r:     UInt<MSHR_ADDR_WIDTH>;

  // Wires for the free-slot priority encoder
  wire alloc_idx:      UInt<MSHR_ADDR_WIDTH>;
  wire full_flag:      Bool;

  // Wires for the address-CAM lookup chain
  wire addr_search_mask:  UInt<MSHR_SIZE>;
  wire addr_search_any:   Bool;                       // unused; required to bind cam port
  wire addr_search_first: UInt<MSHR_ADDR_WIDTH>;      // unused; required to bind cam port
  wire has_next_mask:     UInt<MSHR_SIZE>;
  wire tail_mask:         UInt<MSHR_SIZE>;
  wire prev_idx:          UInt<MSHR_ADDR_WIDTH>;
  wire prev_all_zeros:    Bool;

  // Address CAM: maintains (valid, addr) per slot. Port 1 = finalize,
  // port 2 = allocate (wins on same-idx conflict, matching the original
  // last-assignment-wins seq semantics).
  inst addr_cam: Mshr_Addr_Cam
    param DEPTH = MSHR_SIZE;
    param KEY_W = CS_LINE_ADDR_WIDTH;

    clk           <- clk;
    rst           <- reset;
    write_valid   <- finalize_valid;
    write_idx     <- finalize_id;
    write_key     <- 0.zext<CS_LINE_ADDR_WIDTH>();  // ignored on clear; explicit width to silence iverilog literal-prune warning
    write_set     <- false;
    write2_valid  <- allocate_valid & ~full_flag;
    write2_idx    <- alloc_idx;
    write2_key    <- allocate_addr;
    write2_set    <- true;
    search_key    <- allocate_addr;
    search_mask   -> addr_search_mask;
    search_any    -> addr_search_any;
    search_first  -> addr_search_first;
  end inst addr_cam

  // Free-slot priority encoder: find first ~entry_valid (LSB-first).
  // Not a CAM lookup (no key matching), so still hand-rolled.
  comb
    alloc_idx = 0;
    full_flag = true;
    for i in 0..MSHR_SIZE-1
      if ~full_flag == false
        if ~entry_valid[i]
          alloc_idx = i.trunc<MSHR_ADDR_WIDTH>();
          full_flag = false;
        end if
      end if
    end for
  end comb

  // Pack entry_has_next into a UInt mask so we can AND it with the
  // CAM's search_mask. The tail of a chain is an entry that matches
  // the address AND has no next pointer.
  comb
    has_next_mask = 0;
    for i in 0..MSHR_SIZE-1
      if entry_has_next[i]
        has_next_mask = has_next_mask | ((1.zext<MSHR_SIZE>()) << i);
      end if
    end for
  end comb

  let tail_mask_w: UInt<MSHR_SIZE> = addr_search_mask & ~has_next_mask;
  let tail_mask = tail_mask_w;

  // Priority-encode tail_mask to get prev_idx (LSB-first).
  comb
    prev_idx = 0;
    prev_all_zeros = true;
    for i in 0..MSHR_SIZE-1
      if ~prev_all_zeros == false
        if (tail_mask >> i) & 1
          prev_idx = i.trunc<MSHR_ADDR_WIDTH>();
          prev_all_zeros = false;
        end if
      end if
    end for
  end comb

  // allocate_ready is combinational: not full
  let allocate_ready = ~full_flag;

  // Pending detection
  let has_pending: Bool = ~prev_all_zeros;

  // Register outputs and update state
  seq
    // Register the combinational outputs
    allocate_id_r <= alloc_idx;
    allocate_pending_r <= has_pending;
    allocate_previd_r <= prev_idx;

    // Dequeue FSM: fill_valid starts traversal, then walk linked list
    if fill_valid
      dq_valid_r <= true;
      dq_idx_r <= fill_id;
    elsif dq_valid_r & dequeue_ready
      if entry_has_next[dq_idx_r]
        dq_idx_r <= entry_next_idx[dq_idx_r];
      else
        dq_valid_r <= false;
      end if
    end if

    // Finalize: invalidate entry (placed before allocate so allocate wins on conflict)
    if finalize_valid
      entry_valid[finalize_id] <= false;
      entry_has_next[finalize_id] <= false;
    end if

    // Allocate: mark entry valid, store metadata
    if allocate_valid & ~full_flag
      entry_valid[alloc_idx] <= true;
      entry_addr[alloc_idx] <= allocate_addr;
      entry_write[alloc_idx] <= allocate_rw;
      entry_has_next[alloc_idx] <= false;
      entry_next_idx[alloc_idx] <= 0;
      data_mem[alloc_idx] <= allocate_data;

      // If pending, update previous entry's next pointer
      if has_pending
        entry_has_next[prev_idx] <= true;
        entry_next_idx[prev_idx] <= alloc_idx;
      end if
    end if
  end seq

  // Output assignments
  let allocate_id = allocate_id_r;
  let allocate_pending = allocate_pending_r;
  let allocate_previd = allocate_previd_r;

  // Fill address output
  let fill_addr = entry_addr[fill_id];

  // Dequeue outputs: driven from registered index
  let dequeue_valid = dq_valid_r;
  let dequeue_addr = entry_addr[dq_idx_r];
  let dequeue_rw = entry_write[dq_idx_r];
  let dequeue_data = data_mem[dq_idx_r];
  let dequeue_id = dq_idx_r;
end module cache_mshr
