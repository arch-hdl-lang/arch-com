module copilot_rs_232
  param CLOCK_FREQ: const = 100000000;
  param BAUD_RATE: const = 115200;
  param BAUD_ACC_WIDTH: const = 16;
  param REG_INPUT: const = 1;
  port clock:     in Clock<SysDomain>;
  port reset_neg: in Reset<Async, Low>;
  port tx_datain_ready: in Bool;
  port Present_Processing_Completed: in Bool;
  port tx_datain: in UInt<8>;
  port tx_transmitter: out Bool;
  port tx_transmitter_valid: out Bool;

  default seq on clock rising;

  // Shift register: {stop, data[7:0], start} = {1, D7..D0, 0}
  reg tx_shift: UInt<10> reset reset_neg => 0b1111111111;
  reg bit_cnt: UInt<4> reset reset_neg => 0;
  wire baud_pulse_w: Bool;
  wire active: Bool;

  comb
    active = (bit_cnt != 0);
  end comb

  inst baud_gen: baud_rate_generator
    param BAUD_ACC_WIDTH = BAUD_ACC_WIDTH;
    param CLOCK_FREQ = CLOCK_FREQ;
    param BAUD_RATE = BAUD_RATE;
    clock <- clock;
    reset_neg <- reset_neg;
    enable <- active;
    baud_pulse -> baud_pulse_w;
  end inst baud_gen

  // Registered valid output
  reg valid_r: Bool reset reset_neg => false;
  seq
    valid_r <= active;
  end seq
  let tx_transmitter_valid = valid_r;

  // Load shift register and start transmission
  seq
    if ~reset_neg
      tx_shift <= 0b1111111111;
      bit_cnt <= 0;
    elsif Present_Processing_Completed
      tx_shift <= 0b1111111111;
      bit_cnt <= 0;
    elsif (bit_cnt == 0) & tx_datain_ready
      tx_shift <= {true, tx_datain, false};
      bit_cnt <= 10;
    elsif baud_pulse_w & (bit_cnt != 0)
      tx_shift <= {true, tx_shift[9:1]};
      bit_cnt <= (bit_cnt - 1).trunc<4>();
    end if
  end seq

  // Output is LSB of shift register
  let tx_transmitter = tx_shift[0];
end module copilot_rs_232
