module priority_encoder
  param N: const = 8;
  param M: const = 3;
  port input_signal: in UInt<N>;
  port out: out UInt<M>;

  wire result: UInt<M>;

  comb
    result = 0;
    for i in 0..N-1
      if input_signal[i:i]
        result = i[M-1:0];
      end if
    end for
  end comb

  comb out = result;
end module priority_encoder
