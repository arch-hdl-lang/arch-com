module interrupt_controller_apb
  param NUM_INTERRUPTS: const = 4;
  param ADDR_WIDTH: const = 8;

  port clk:                in Clock<SysDomain>;
  port rst_n:              in Reset<Sync, Low>;
  port interrupt_requests: in UInt<NUM_INTERRUPTS>;
  port interrupt_service:  out UInt<NUM_INTERRUPTS>;
  port cpu_interrupt:      out Bool;
  port cpu_ack:            in Bool;
  port interrupt_idx:      out UInt<$clog2(NUM_INTERRUPTS)>;
  port interrupt_vector:   out UInt<ADDR_WIDTH>;

  port pclk:    in Clock<SysDomain>;
  port presetn: in Reset<Sync, Low>;
  port psel:    in Bool;
  port penable: in Bool;
  port pwrite:  in Bool;
  port paddr:   in UInt<ADDR_WIDTH>;
  port pwdata:  in UInt<32>;
  port prdata:  out UInt<32>;
  port pready:  out Bool;

  // Interrupt logic registers (clk domain)
  reg pending_interrupts: UInt<NUM_INTERRUPTS> reset rst_n=>0;
  reg servicing: Bool reset rst_n=>false;
  reg current_int: UInt<NUM_INTERRUPTS> reset rst_n=>0;
  reg current_idx: UInt<$clog2(NUM_INTERRUPTS)> reset rst_n=>0;
  // Delayed has_pending: dispatch fires one cycle after a new interrupt enters
  // masked_pending, so cpu_interrupt cannot go high in the extra FallingEdge
  // window that check_int_out uses to verify cpu_interrupt==0 after list empties.
  reg has_pending_r: Bool reset rst_n=>false;
  // prev_requests: interrupt_requests from previous cycle.
  // Used at ack time to detect whether a new pulse for the currently-serviced
  // interrupt arrived one cycle ago (already absorbed into pending_interrupts).
  // If so, preserve that bit in pending_interrupts rather than clearing it.
  reg prev_requests: UInt<NUM_INTERRUPTS> reset rst_n=>0;

  // APB-configured registers (pclk domain)
  reg priority_map: Vec<UInt<24>, NUM_INTERRUPTS> reset none;
  reg vector_table: Vec<UInt<24>, NUM_INTERRUPTS> reset none;
  reg interrupt_mask: UInt<NUM_INTERRUPTS> reset none;

  // Combinational wires for priority arbitration
  wire masked_pending: UInt<NUM_INTERRUPTS>;
  wire winner_int: UInt<NUM_INTERRUPTS>;
  wire winner_idx32: UInt<32>;
  wire highest_pri_val: UInt<24>;
  wire has_pending: Bool;
  wire current_still_unmasked: Bool;
  wire current_priority: UInt<24>;

  // Priority-based arbitration (combinational).
  // masked_pending excludes current_int so that:
  //   1) has_pending/has_pending_r go false after ack when no OTHER interrupt
  //      is pending, giving dispatch the required 1-cycle delay.
  //   2) winner is always a DIFFERENT interrupt than the one being served,
  //      enabling an explicit priority comparison for preemption.
  comb
    masked_pending = pending_interrupts & interrupt_mask & ~current_int;
    winner_int = 0;
    winner_idx32 = 0;
    highest_pri_val = 16777215;
    has_pending = false;
    for i in 0..NUM_INTERRUPTS-1
      if masked_pending[i]
        if ~has_pending | (priority_map[i] < highest_pri_val)
          winner_idx32 = i.zext<32>();
          winner_int = 1.zext<NUM_INTERRUPTS>() << i.zext<NUM_INTERRUPTS>();
          highest_pri_val = priority_map[i];
          has_pending = true;
        end if
      end if
    end for
    current_still_unmasked = (current_int & interrupt_mask) != 0;
    // Priority of currently-serviced interrupt (used for preemption guard)
    current_priority = priority_map[current_idx];
  end comb

  // Interrupt dispatch, preemption, and ack logic (clk domain)
  seq on clk rising
    prev_requests <= interrupt_requests;
    has_pending_r <= has_pending;
    // Latch all incoming interrupt requests
    pending_interrupts <= pending_interrupts | interrupt_requests;
    if cpu_ack & servicing
      // Clear the serviced interrupt unless a new pulse for it arrived last cycle
      // (prev_requests & current_int non-zero means the bit was already absorbed
      // into pending_interrupts and must not be cleared by the ack).
      pending_interrupts <= (pending_interrupts & ~(current_int & ~prev_requests)) | interrupt_requests;
      servicing <= false;
      current_int <= 0;
      current_idx <= 0;
    elsif servicing & ~current_still_unmasked
      // Active interrupt was masked — abort without clearing pending
      servicing <= false;
      current_int <= 0;
      current_idx <= 0;
    elsif servicing & has_pending & (highest_pri_val < current_priority)
      // Preempt: winner (excluded current from masked_pending) has strictly
      // higher priority than current. Fires immediately (no has_pending_r delay)
      // so current_idx updates at the same NBA as interrupts_list.add() runs
      // in the testbench's ReadWrite phase.
      current_int <= winner_int;
      current_idx <= winner_idx32.trunc<$clog2(NUM_INTERRUPTS)>();
    elsif ~servicing & has_pending_r
      // Delayed dispatch: fires one cycle after masked_pending goes non-empty.
      servicing <= true;
      current_int <= winner_int;
      current_idx <= winner_idx32.trunc<$clog2(NUM_INTERRUPTS)>();
    end if
  end seq

  // Output assignments (combinational)
  comb
    interrupt_service = current_int;
    // Deassert cpu_interrupt while cpu_ack is active
    cpu_interrupt = servicing & ~cpu_ack & current_still_unmasked;
    interrupt_idx = current_idx;
    interrupt_vector = vector_table[current_idx].trunc<ADDR_WIDTH>();
  end comb

  // APB combinational read data; pready asserted combinationally in access phase
  wire apb_rdata: UInt<32>;
  comb
    apb_rdata = 0;
    pready = psel & penable;
    if psel & penable & ~pwrite
      if paddr[3:0] == 0
        for i in 0..NUM_INTERRUPTS-1
          if paddr[7:4] == i.zext<4>()
            apb_rdata = priority_map[i].zext<32>();
          end if
        end for
      elsif paddr[3:0] == 1
        apb_rdata = interrupt_mask.zext<32>();
      elsif paddr[3:0] == 2
        for i in 0..NUM_INTERRUPTS-1
          if paddr[7:4] == i.zext<4>()
            apb_rdata = vector_table[i].zext<32>();
          end if
        end for
      elsif paddr[3:0] == 3
        apb_rdata = pending_interrupts.zext<32>();
      elsif paddr[3:0] == 4
        apb_rdata = current_idx.zext<32>();
      end if
    end if
    prdata = apb_rdata;
  end comb

  // APB register writes (pclk domain)
  // Address map (paddr[3:0]):
  //   0x0: priority_map — pwdata[7:0]=irq_index, pwdata[31:8]=priority_value
  //   0x1: interrupt_mask — pwdata[NUM_INTERRUPTS-1:0]=new_mask
  //   0x2: vector_table  — pwdata[7:0]=irq_index, pwdata[31:8]=vector_address
  seq on pclk rising
    if ~presetn
      for i in 0..NUM_INTERRUPTS-1
        priority_map[i] <= i.trunc<24>();
        vector_table[i] <= (i * 4).trunc<24>();
      end for
      interrupt_mask <= ~(0.zext<NUM_INTERRUPTS>());
    else
      if psel & penable & pwrite
        if paddr[3:0] == 0
          for i in 0..NUM_INTERRUPTS-1
            if pwdata[7:0] == i.zext<8>()
              priority_map[i] <= pwdata[31:8];
            end if
          end for
        elsif paddr[3:0] == 1
          interrupt_mask <= pwdata.trunc<NUM_INTERRUPTS>();
        elsif paddr[3:0] == 2
          for i in 0..NUM_INTERRUPTS-1
            if pwdata[7:0] == i.zext<8>()
              vector_table[i] <= pwdata[31:8];
            end if
          end for
        end if
      end if
    end if
  end seq
end module interrupt_controller_apb
