module interrupt_controller_apb
  param NUM_INTERRUPTS: const = 4;
  param ADDR_WIDTH: const = 8;
  param IDX_WIDTH: const = $clog2(NUM_INTERRUPTS) > 0 ? $clog2(NUM_INTERRUPTS) : 1;

  port clk:                in Clock<SysDomain>;
  port rst_n:              in Reset<Sync, Low>;
  port interrupt_requests: in UInt<NUM_INTERRUPTS>;
  port interrupt_service:  out UInt<NUM_INTERRUPTS>;
  port cpu_interrupt:      out Bool;
  port cpu_ack:            in Bool;
  port interrupt_idx:      out UInt<IDX_WIDTH>;
  port interrupt_vector:   out UInt<ADDR_WIDTH>;

  port pclk:    in Clock<SysDomain>;
  port presetn: in Reset<Sync, Low>;
  port psel:    in Bool;
  port penable: in Bool;
  port pwrite:  in Bool;
  port paddr:   in UInt<ADDR_WIDTH>;
  port pwdata:  in UInt<32>;
  port prdata:  out UInt<32>;
  port pready:  out Bool;

  // Interrupt logic registers (clk domain)
  reg pending_interrupts: UInt<NUM_INTERRUPTS> reset rst_n => 0;
  reg servicing: Bool reset rst_n => false;
  reg current_int: UInt<NUM_INTERRUPTS> reset rst_n => 0;
  reg current_idx: UInt<IDX_WIDTH> reset rst_n => 0;
  reg has_pending_r: Bool reset rst_n => false;

  // APB-configured registers (pclk domain)
  reg priority_map: Vec<UInt<24>, NUM_INTERRUPTS> reset none;
  reg vector_table: Vec<UInt<24>, NUM_INTERRUPTS> reset none;
  reg interrupt_mask: UInt<NUM_INTERRUPTS> reset none;

  // Combinational wires for priority arbitration
  wire effective_pending: UInt<NUM_INTERRUPTS>;
  wire masked_pending: UInt<NUM_INTERRUPTS>;
  wire winner_int: UInt<NUM_INTERRUPTS>;
  wire winner_idx32: UInt<32>;
  wire highest_pri_val: UInt<24>;
  wire has_pending: Bool;
  wire current_still_unmasked: Bool;

  // Priority-based arbitration (combinational).
  // Winner uses effective_pending (pending | requests) for same-cycle visibility.
  // has_pending uses only pending_interrupts for dispatch timing.
  comb
    effective_pending = pending_interrupts | interrupt_requests;
    masked_pending = effective_pending & interrupt_mask;
    winner_int = 0;
    winner_idx32 = 0;
    highest_pri_val = 16777215;
    for i in 0..NUM_INTERRUPTS-1
      if masked_pending[i]
        if (priority_map[i] < highest_pri_val)
          winner_idx32 = i.zext<32>();
          winner_int = 1.zext<NUM_INTERRUPTS>() << i.zext<NUM_INTERRUPTS>();
          highest_pri_val = priority_map[i];
        end if
      end if
    end for
    has_pending = (pending_interrupts & interrupt_mask) != 0;
    current_still_unmasked = (current_int & interrupt_mask) != 0;
  end comb

  // Interrupt dispatch and ack logic (clk domain)
  seq on clk rising
    // Always update the delayed dispatch enable
    has_pending_r <= has_pending;
    // Latch all incoming interrupt requests
    pending_interrupts <= pending_interrupts | interrupt_requests;
    if cpu_ack & servicing
      // Clear the serviced interrupt's pending bit
      pending_interrupts <= (pending_interrupts & ~current_int) | interrupt_requests;
      servicing <= false;
      current_int <= 0;
      current_idx <= 0;
    elsif servicing & (~current_still_unmasked)
      servicing <= false;
      current_int <= 0;
      current_idx <= 0;
    elsif (~servicing) & has_pending_r & has_pending
      // Dispatch: requires both delayed AND current has_pending
      servicing <= true;
      current_int <= winner_int;
      current_idx <= winner_idx32.trunc<IDX_WIDTH>();
    end if
  end seq

  // Output assignments (combinational)
  comb
    interrupt_service = current_int;
    cpu_interrupt = servicing & (~cpu_ack) & current_still_unmasked;
    interrupt_idx = current_idx;
    interrupt_vector = vector_table[current_idx].trunc<ADDR_WIDTH>();
  end comb

  // APB combinational read data
  wire apb_rdata: UInt<32>;
  comb
    apb_rdata = 0;
    pready = psel & penable;
    if psel & penable & (~pwrite)
      if paddr[3:0] == 0
        for i in 0..NUM_INTERRUPTS-1
          if paddr[7:4] == i.zext<4>()
            apb_rdata = priority_map[i].zext<32>();
          end if
        end for
      elsif paddr[3:0] == 1
        apb_rdata = interrupt_mask.zext<32>();
      elsif paddr[3:0] == 2
        for i in 0..NUM_INTERRUPTS-1
          if paddr[7:4] == i.zext<4>()
            apb_rdata = vector_table[i].zext<32>();
          end if
        end for
      elsif paddr[3:0] == 3
        apb_rdata = pending_interrupts.zext<32>();
      elsif paddr[3:0] == 4
        apb_rdata = current_idx.zext<32>();
      end if
    end if
    prdata = apb_rdata;
  end comb

  // APB register writes (pclk domain)
  seq on pclk rising
    if ~presetn
      for i in 0..NUM_INTERRUPTS-1
        priority_map[i] <= i.trunc<24>();
        vector_table[i] <= (i * 4).trunc<24>();
      end for
      interrupt_mask <= ~(0.zext<NUM_INTERRUPTS>());
    else
      if psel & penable & pwrite
        if paddr[3:0] == 0
          for i in 0..NUM_INTERRUPTS-1
            if pwdata[7:0] == i.zext<8>()
              priority_map[i] <= pwdata[31:8];
            end if
          end for
        elsif paddr[3:0] == 1
          interrupt_mask <= pwdata.trunc<NUM_INTERRUPTS>();
        elsif paddr[3:0] == 2
          for i in 0..NUM_INTERRUPTS-1
            if pwdata[7:0] == i.zext<8>()
              vector_table[i] <= pwdata[31:8];
            end if
          end for
        end if
      end if
    end if
  end seq
end module interrupt_controller_apb
