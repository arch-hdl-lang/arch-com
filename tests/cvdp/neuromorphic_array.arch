module neuromorphic_array
  param NEURONS: const = 8;
  param INPUTS: const = 8;
  param OUTPUTS: const = 8;
  port ui_in:  in UInt<8>;
  port uio_in: in UInt<8>;
  port uo_out: out UInt<8>;
  port clk:    in Clock<SysDomain>;
  port rst_n:  in Reset<Sync, Low>;

  wire neuron_outputs: Vec<UInt<8>, NEURONS>;

  generate for i in 0..NEURONS-1
    inst neuron_i: single_neuron_dut
      connect clk    <- clk;
      connect rst_n  <- rst_n;
      connect ctrl   <- ui_in[0];
      connect seq_in <- uio_in;
      connect seq_out -> neuron_outputs[i];
    end inst neuron_i
  end generate for i

  comb uo_out = neuron_outputs[NEURONS - 1];
end module neuromorphic_array
