module interrupt_controller
  param STARVATION_THRESHOLD: const = 5;
  port clk:                  in Clock<SysDomain>;
  port rst_n:                in Reset<Async, Low>;
  port reset_interrupts:     in Bool;
  port interrupt_requests:   in UInt<10>;
  port interrupt_ack:        in Bool;
  port interrupt_trig:       in Bool;
  port interrupt_mask:       in UInt<10>;
  port priority_override:    in UInt<4>;
  port override_interrupt_id: in UInt<4>;
  port priority_override_en: in Bool;
  port interrupt_id:         out UInt<4>;
  port interrupt_valid:      out Bool;
  port interrupt_status:     out UInt<10>;
  port missed_interrupts:    out UInt<10>;
  port starvation_detected:  out Bool;

  // FSM states
  // 0=IDLE, 1=PRIORITY_CALC, 2=SERVICE_PREP, 3=SERVICING, 4=COMPLETION, 7=ERROR
  reg current_state: UInt<3> reset rst_n=>0;

  reg pending_interrupts: UInt<10> reset rst_n=>0;
  reg r_interrupt_status: UInt<10> reset rst_n=>0;
  reg r_missed_interrupts: UInt<10> reset rst_n=>0;
  reg r_interrupt_id: UInt<4> reset rst_n=>0;
  reg r_interrupt_valid: Bool reset rst_n=>false;
  reg r_starvation_detected: Bool reset rst_n=>false;

  // Wait counters for each interrupt (4 bits each)
  reg wait_cnt_0: UInt<4> reset rst_n=>0;
  reg wait_cnt_1: UInt<4> reset rst_n=>0;
  reg wait_cnt_2: UInt<4> reset rst_n=>0;
  reg wait_cnt_3: UInt<4> reset rst_n=>0;
  reg wait_cnt_4: UInt<4> reset rst_n=>0;
  reg wait_cnt_5: UInt<4> reset rst_n=>0;
  reg wait_cnt_6: UInt<4> reset rst_n=>0;
  reg wait_cnt_7: UInt<4> reset rst_n=>0;
  reg wait_cnt_8: UInt<4> reset rst_n=>0;
  reg wait_cnt_9: UInt<4> reset rst_n=>0;

  // Effective priority for each interrupt (5 bits each)
  reg eff_pri_0: UInt<5> reset rst_n=>0;
  reg eff_pri_1: UInt<5> reset rst_n=>0;
  reg eff_pri_2: UInt<5> reset rst_n=>0;
  reg eff_pri_3: UInt<5> reset rst_n=>0;
  reg eff_pri_4: UInt<5> reset rst_n=>0;
  reg eff_pri_5: UInt<5> reset rst_n=>0;
  reg eff_pri_6: UInt<5> reset rst_n=>0;
  reg eff_pri_7: UInt<5> reset rst_n=>0;
  reg eff_pri_8: UInt<5> reset rst_n=>0;
  reg eff_pri_9: UInt<5> reset rst_n=>0;

  reg service_timer: UInt<4> reset rst_n=>0;
  reg timeout_error: Bool reset rst_n=>false;
  reg next_interrupt_id: UInt<4> reset rst_n=>0;
  reg max_priority: UInt<5> reset rst_n=>0;

  // Active mask
  reg active_mask: UInt<10> reset rst_n=>0;

  // Wires for combinational priority calculation
  wire w_eff_pri_0: UInt<5>;
  wire w_eff_pri_1: UInt<5>;
  wire w_eff_pri_2: UInt<5>;
  wire w_eff_pri_3: UInt<5>;
  wire w_eff_pri_4: UInt<5>;
  wire w_eff_pri_5: UInt<5>;
  wire w_eff_pri_6: UInt<5>;
  wire w_eff_pri_7: UInt<5>;
  wire w_eff_pri_8: UInt<5>;
  wire w_eff_pri_9: UInt<5>;
  wire w_max_pri: UInt<5>;
  wire w_max_id: UInt<4>;
  wire mask_inv: UInt<10>;
  wire any_starvation: Bool;

  // Inverted mask
  let mask_inv = ~interrupt_mask;

  // Compute effective priorities combinationally
  comb
    // Base priorities: (10-i), override if enabled
    if priority_override_en & (override_interrupt_id == 0)
      w_eff_pri_0 = priority_override.zext<5>();
    else
      w_eff_pri_0 = 10;
    end if
    if priority_override_en & (override_interrupt_id == 1)
      w_eff_pri_1 = priority_override.zext<5>();
    else
      w_eff_pri_1 = 9;
    end if
    if priority_override_en & (override_interrupt_id == 2)
      w_eff_pri_2 = priority_override.zext<5>();
    else
      w_eff_pri_2 = 8;
    end if
    if priority_override_en & (override_interrupt_id == 3)
      w_eff_pri_3 = priority_override.zext<5>();
    else
      w_eff_pri_3 = 7;
    end if
    if priority_override_en & (override_interrupt_id == 4)
      w_eff_pri_4 = priority_override.zext<5>();
    else
      w_eff_pri_4 = 6;
    end if
    if priority_override_en & (override_interrupt_id == 5)
      w_eff_pri_5 = priority_override.zext<5>();
    else
      w_eff_pri_5 = 5;
    end if
    if priority_override_en & (override_interrupt_id == 6)
      w_eff_pri_6 = priority_override.zext<5>();
    else
      w_eff_pri_6 = 4;
    end if
    if priority_override_en & (override_interrupt_id == 7)
      w_eff_pri_7 = priority_override.zext<5>();
    else
      w_eff_pri_7 = 3;
    end if
    if priority_override_en & (override_interrupt_id == 8)
      w_eff_pri_8 = priority_override.zext<5>();
    else
      w_eff_pri_8 = 2;
    end if
    if priority_override_en & (override_interrupt_id == 9)
      w_eff_pri_9 = priority_override.zext<5>();
    else
      w_eff_pri_9 = 1;
    end if
  end comb

  // Find max priority pending interrupt (>=, so highest index wins on tie)
  comb
    w_max_pri = 0;
    w_max_id = 0;
    if pending_interrupts[0:0] == 1
      if eff_pri_0 >= w_max_pri
        w_max_pri = eff_pri_0;
        w_max_id = 0;
      end if
    end if
    if pending_interrupts[1:1] == 1
      if eff_pri_1 >= w_max_pri
        w_max_pri = eff_pri_1;
        w_max_id = 1;
      end if
    end if
    if pending_interrupts[2:2] == 1
      if eff_pri_2 >= w_max_pri
        w_max_pri = eff_pri_2;
        w_max_id = 2;
      end if
    end if
    if pending_interrupts[3:3] == 1
      if eff_pri_3 >= w_max_pri
        w_max_pri = eff_pri_3;
        w_max_id = 3;
      end if
    end if
    if pending_interrupts[4:4] == 1
      if eff_pri_4 >= w_max_pri
        w_max_pri = eff_pri_4;
        w_max_id = 4;
      end if
    end if
    if pending_interrupts[5:5] == 1
      if eff_pri_5 >= w_max_pri
        w_max_pri = eff_pri_5;
        w_max_id = 5;
      end if
    end if
    if pending_interrupts[6:6] == 1
      if eff_pri_6 >= w_max_pri
        w_max_pri = eff_pri_6;
        w_max_id = 6;
      end if
    end if
    if pending_interrupts[7:7] == 1
      if eff_pri_7 >= w_max_pri
        w_max_pri = eff_pri_7;
        w_max_id = 7;
      end if
    end if
    if pending_interrupts[8:8] == 1
      if eff_pri_8 >= w_max_pri
        w_max_pri = eff_pri_8;
        w_max_id = 8;
      end if
    end if
    if pending_interrupts[9:9] == 1
      if eff_pri_9 >= w_max_pri
        w_max_pri = eff_pri_9;
        w_max_id = 9;
      end if
    end if
  end comb

  // Starvation detection
  comb
    any_starvation = (wait_cnt_0 >= STARVATION_THRESHOLD) | (wait_cnt_1 >= STARVATION_THRESHOLD)
      | (wait_cnt_2 >= STARVATION_THRESHOLD) | (wait_cnt_3 >= STARVATION_THRESHOLD)
      | (wait_cnt_4 >= STARVATION_THRESHOLD) | (wait_cnt_5 >= STARVATION_THRESHOLD)
      | (wait_cnt_6 >= STARVATION_THRESHOLD) | (wait_cnt_7 >= STARVATION_THRESHOLD)
      | (wait_cnt_8 >= STARVATION_THRESHOLD) | (wait_cnt_9 >= STARVATION_THRESHOLD);
  end comb

  // Main FSM
  seq on clk rising
    if reset_interrupts
      current_state <= 0;
      pending_interrupts <= 0;
      r_interrupt_status <= 0;
      r_missed_interrupts <= 0;
      r_interrupt_valid <= false;
      r_interrupt_id <= 0;
      r_starvation_detected <= false;
      wait_cnt_0 <= 0; wait_cnt_1 <= 0; wait_cnt_2 <= 0; wait_cnt_3 <= 0; wait_cnt_4 <= 0;
      wait_cnt_5 <= 0; wait_cnt_6 <= 0; wait_cnt_7 <= 0; wait_cnt_8 <= 0; wait_cnt_9 <= 0;
      eff_pri_0 <= 0; eff_pri_1 <= 0; eff_pri_2 <= 0; eff_pri_3 <= 0; eff_pri_4 <= 0;
      eff_pri_5 <= 0; eff_pri_6 <= 0; eff_pri_7 <= 0; eff_pri_8 <= 0; eff_pri_9 <= 0;
      service_timer <= 0;
      timeout_error <= false;
      next_interrupt_id <= 0;
      max_priority <= 0;
      active_mask <= 0;
    else
      // Capture new interrupts on trig
      if interrupt_trig
        pending_interrupts <= pending_interrupts | (interrupt_requests & mask_inv);
        // Track missed (masked) interrupts
        r_missed_interrupts <= r_missed_interrupts | (interrupt_requests & interrupt_mask);
      end if

      // State machine
      if current_state == 0
        // IDLE
        r_interrupt_valid <= false;
        service_timer <= 0;
        timeout_error <= false;
        if (pending_interrupts != 0) | interrupt_trig
          current_state <= 1;
          // Compute effective priorities with starvation boost
          eff_pri_0 <= w_eff_pri_0; eff_pri_1 <= w_eff_pri_1;
          eff_pri_2 <= w_eff_pri_2; eff_pri_3 <= w_eff_pri_3;
          eff_pri_4 <= w_eff_pri_4; eff_pri_5 <= w_eff_pri_5;
          eff_pri_6 <= w_eff_pri_6; eff_pri_7 <= w_eff_pri_7;
          eff_pri_8 <= w_eff_pri_8; eff_pri_9 <= w_eff_pri_9;

          // Update wait counters for pending interrupts
          if (pending_interrupts[0:0] == 1) | (interrupt_trig & (interrupt_requests[0:0] == 1))
            wait_cnt_0 <= (wait_cnt_0 + 1).trunc<4>();
          else
            wait_cnt_0 <= 0;
          end if
          if (pending_interrupts[1:1] == 1) | (interrupt_trig & (interrupt_requests[1:1] == 1))
            wait_cnt_1 <= (wait_cnt_1 + 1).trunc<4>();
          else
            wait_cnt_1 <= 0;
          end if
          if (pending_interrupts[2:2] == 1) | (interrupt_trig & (interrupt_requests[2:2] == 1))
            wait_cnt_2 <= (wait_cnt_2 + 1).trunc<4>();
          else
            wait_cnt_2 <= 0;
          end if
          if (pending_interrupts[3:3] == 1) | (interrupt_trig & (interrupt_requests[3:3] == 1))
            wait_cnt_3 <= (wait_cnt_3 + 1).trunc<4>();
          else
            wait_cnt_3 <= 0;
          end if
          if (pending_interrupts[4:4] == 1) | (interrupt_trig & (interrupt_requests[4:4] == 1))
            wait_cnt_4 <= (wait_cnt_4 + 1).trunc<4>();
          else
            wait_cnt_4 <= 0;
          end if
          if (pending_interrupts[5:5] == 1) | (interrupt_trig & (interrupt_requests[5:5] == 1))
            wait_cnt_5 <= (wait_cnt_5 + 1).trunc<4>();
          else
            wait_cnt_5 <= 0;
          end if
          if (pending_interrupts[6:6] == 1) | (interrupt_trig & (interrupt_requests[6:6] == 1))
            wait_cnt_6 <= (wait_cnt_6 + 1).trunc<4>();
          else
            wait_cnt_6 <= 0;
          end if
          if (pending_interrupts[7:7] == 1) | (interrupt_trig & (interrupt_requests[7:7] == 1))
            wait_cnt_7 <= (wait_cnt_7 + 1).trunc<4>();
          else
            wait_cnt_7 <= 0;
          end if
          if (pending_interrupts[8:8] == 1) | (interrupt_trig & (interrupt_requests[8:8] == 1))
            wait_cnt_8 <= (wait_cnt_8 + 1).trunc<4>();
          else
            wait_cnt_8 <= 0;
          end if
          if (pending_interrupts[9:9] == 1) | (interrupt_trig & (interrupt_requests[9:9] == 1))
            wait_cnt_9 <= (wait_cnt_9 + 1).trunc<4>();
          else
            wait_cnt_9 <= 0;
          end if
        end if
      elsif current_state == 1
        // PRIORITY_CALC - compute next interrupt id
        next_interrupt_id <= w_max_id;
        max_priority <= w_max_pri;
        current_state <= 2;
      elsif current_state == 2
        // SERVICE_PREP
        r_interrupt_id <= next_interrupt_id;
        r_interrupt_valid <= true;
        r_interrupt_status <= pending_interrupts;
        r_starvation_detected <= any_starvation;
        current_state <= 3;
        service_timer <= 0;
      elsif current_state == 3
        // SERVICING
        if interrupt_ack
          current_state <= 4;
        elsif service_timer == 15
          timeout_error <= true;
          current_state <= 5;
        else
          service_timer <= (service_timer + 1).trunc<4>();
        end if
      elsif current_state == 4
        // COMPLETION
        pending_interrupts <= pending_interrupts & ~(1.zext<10>() << r_interrupt_id);
        r_interrupt_valid <= false;
        r_interrupt_status <= 0;
        current_state <= 0;
      else
        // ERROR (state 5/7)
        r_interrupt_valid <= false;
        r_interrupt_status <= 0;
        current_state <= 0;
      end if
    end if
  end seq

  // Output assignments
  comb
    interrupt_id = r_interrupt_id;
    interrupt_valid = r_interrupt_valid;
    interrupt_status = r_interrupt_status;
    missed_interrupts = r_missed_interrupts;
    starvation_detected = r_starvation_detected;
  end comb
end module interrupt_controller
