module digital_dice_roller
  param DICE_MAX: const = 6;

  port clk: in Clock<SysDomain>;
  port reset: in Reset<Async, Low>;
  port button: in Bool;
  port reg dice_value: out UInt<3> reset reset=>1;

  seq on clk rising
    if button
      if dice_value >= DICE_MAX
        dice_value <= 3'd1;
      else
        dice_value <= (dice_value + 3'd1).trunc<3>();
      end if
    end if
  end seq
end module digital_dice_roller
