module hamming_rx
  // Parameterized Hamming receiver
  // Default: DATA_WIDTH=4, PARITY_BIT=3 => ENCODED_DATA=8, ENCODED_DATA_BIT=3
  param DATA_WIDTH:       const = 4;
  param PARITY_BIT:       const = 3;
  param ENCODED_DATA:     const = DATA_WIDTH + PARITY_BIT + 1;
  param ENCODED_DATA_BIT: const = 3;

  port data_in:  in  UInt<ENCODED_DATA>;
  port data_out: out UInt<DATA_WIDTH>;

  // Compute PARITY_BIT syndrome bits using even-parity XOR
  // parity[n] = XOR of data_in[i] for all i where bit n of i is 1
  // For default case: PARITY_BIT=3, ENCODED_DATA=8
  // parity[0]: positions where bit0=1 => 1,3,5,7
  // parity[1]: positions where bit1=1 => 2,3,6,7
  // parity[2]: positions where bit2=1 => 4,5,6,7
  let p0: UInt<1> = (data_in[1:1] ^ data_in[3:3] ^ data_in[5:5] ^ data_in[7:7]).trunc<1>();
  let p1: UInt<1> = (data_in[2:2] ^ data_in[3:3] ^ data_in[6:6] ^ data_in[7:7]).trunc<1>();
  let p2: UInt<1> = (data_in[4:4] ^ data_in[5:5] ^ data_in[6:6] ^ data_in[7:7]).trunc<1>();

  let syndrome: UInt<3> = {p2, p1, p0};

  wire corrected: UInt<ENCODED_DATA>;

  comb
    if syndrome == 0
      corrected = data_in;
    elsif syndrome == 1
      corrected = data_in ^ 8'd2;
    elsif syndrome == 2
      corrected = data_in ^ 8'd4;
    elsif syndrome == 3
      corrected = data_in ^ 8'd8;
    elsif syndrome == 4
      corrected = data_in ^ 8'd16;
    elsif syndrome == 5
      corrected = data_in ^ 8'd32;
    elsif syndrome == 6
      corrected = data_in ^ 8'd64;
    else
      corrected = data_in ^ 8'd128;
    end if
  end comb

  // Extract data bits at non-power-of-2 positions (skip 0,1,2,4): 3,5,6,7
  // d0=corrected[3], d1=corrected[5], d2=corrected[6], d3=corrected[7]
  comb
    data_out[0:0] = corrected[3:3];
    data_out[1:1] = corrected[5:5];
    data_out[2:2] = corrected[6:6];
    data_out[3:3] = corrected[7:7];
  end comb
end module hamming_rx
