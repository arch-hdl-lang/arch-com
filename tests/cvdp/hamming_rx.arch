module hamming_rx
  param DATA_WIDTH: const = 8;
  param PARITY_BIT: const = 4;
  param ENCODED_DATA: const = DATA_WIDTH + PARITY_BIT + 1;
  param ENCODED_DATA_BIT: const = $clog2(ENCODED_DATA);

  port data_in:  in  UInt<ENCODED_DATA>;
  port data_out: out UInt<DATA_WIDTH>;

  wire parity: Vec<UInt<1>, ENCODED_DATA_BIT>;
  wire syndrome: UInt<ENCODED_DATA_BIT>;
  wire corrected: UInt<ENCODED_DATA>;
  wire data_idx: UInt<$clog2(DATA_WIDTH)>;

  comb
    // Compute parity check bits over received codeword.
    for j in 0..ENCODED_DATA_BIT-1
      parity[j] = 0;
      for k in 0..ENCODED_DATA-1
        if ((k >> j) & 1) == 1
          parity[j] = parity[j] ^ data_in[k:k];
        end if
      end for
    end for

    // Syndrome is parity vector interpreted as a bit index.
    syndrome = 0;
    for j in 0..ENCODED_DATA_BIT-1
      syndrome[j:j] = parity[j];
    end for

    // Correct single-bit error at syndrome index.
    for i in 0..ENCODED_DATA-1
      corrected[i:i] = data_in[i:i];
      if (syndrome != 0) & (syndrome == i)
        corrected[i:i] = ~data_in[i:i];
      end if
    end for

    // Extract data bits from non-parity positions.
    data_out = 0;
    data_idx = 0;
    for i in 0..ENCODED_DATA-1
      if (i != 0) & ((i & (i - 1)) != 0)
        data_out[data_idx:data_idx] = corrected[i:i];
        if data_idx == DATA_WIDTH - 1
          data_idx = 0;
        else
          data_idx = (data_idx + 1).trunc<$clog2(DATA_WIDTH)>();
        end if
      end if
    end for
  end comb
end module hamming_rx
