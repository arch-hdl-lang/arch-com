module binary_to_bcd
  port binary_in: in UInt<8>;
  port bcd_out: out UInt<12>;

  // Double Dabble: 8 steps, each step: add-3 to nibbles >= 5, then shift left 1
  // 20-bit register: [19:16]=hundreds, [15:12]=tens, [11:8]=ones, [7:0]=binary shift-in

  wire s0: UInt<20>;
  wire s1: UInt<20>;
  wire s2: UInt<20>;
  wire s3: UInt<20>;
  wire s4: UInt<20>;
  wire s5: UInt<20>;
  wire s6: UInt<20>;
  wire s7: UInt<20>;
  wire s8: UInt<20>;

  wire a0: UInt<20>;
  wire a1: UInt<20>;
  wire a2: UInt<20>;
  wire a3: UInt<20>;
  wire a4: UInt<20>;
  wire a5: UInt<20>;
  wire a6: UInt<20>;
  wire a7: UInt<20>;

  // shifted versions (21-bit to avoid losing the top bit in shift expr)
  wire sh0: UInt<21>;
  wire sh1: UInt<21>;
  wire sh2: UInt<21>;
  wire sh3: UInt<21>;
  wire sh4: UInt<21>;
  wire sh5: UInt<21>;
  wire sh6: UInt<21>;
  wire sh7: UInt<21>;

  let s0 = binary_in.zext<20>();

  // Step 1 adjust: check nibbles >= 5, add 3 if so
  let a0 = ((s0[19:16] >= 5 ? (s0[19:16] + 3).trunc<4>() : s0[19:16]).zext<20>() << 16) |
           ((s0[15:12] >= 5 ? (s0[15:12] + 3).trunc<4>() : s0[15:12]).zext<20>() << 12) |
           ((s0[11:8]  >= 5 ? (s0[11:8]  + 3).trunc<4>() : s0[11:8] ).zext<20>() << 8)  |
           s0[7:0].zext<20>();
  let sh0 = a0.zext<21>() << 1;
  let s1 = sh0[19:0];

  // Step 2 adjust
  let a1 = ((s1[19:16] >= 5 ? (s1[19:16] + 3).trunc<4>() : s1[19:16]).zext<20>() << 16) |
           ((s1[15:12] >= 5 ? (s1[15:12] + 3).trunc<4>() : s1[15:12]).zext<20>() << 12) |
           ((s1[11:8]  >= 5 ? (s1[11:8]  + 3).trunc<4>() : s1[11:8] ).zext<20>() << 8)  |
           s1[7:0].zext<20>();
  let sh1 = a1.zext<21>() << 1;
  let s2 = sh1[19:0];

  // Step 3 adjust
  let a2 = ((s2[19:16] >= 5 ? (s2[19:16] + 3).trunc<4>() : s2[19:16]).zext<20>() << 16) |
           ((s2[15:12] >= 5 ? (s2[15:12] + 3).trunc<4>() : s2[15:12]).zext<20>() << 12) |
           ((s2[11:8]  >= 5 ? (s2[11:8]  + 3).trunc<4>() : s2[11:8] ).zext<20>() << 8)  |
           s2[7:0].zext<20>();
  let sh2 = a2.zext<21>() << 1;
  let s3 = sh2[19:0];

  // Step 4 adjust
  let a3 = ((s3[19:16] >= 5 ? (s3[19:16] + 3).trunc<4>() : s3[19:16]).zext<20>() << 16) |
           ((s3[15:12] >= 5 ? (s3[15:12] + 3).trunc<4>() : s3[15:12]).zext<20>() << 12) |
           ((s3[11:8]  >= 5 ? (s3[11:8]  + 3).trunc<4>() : s3[11:8] ).zext<20>() << 8)  |
           s3[7:0].zext<20>();
  let sh3 = a3.zext<21>() << 1;
  let s4 = sh3[19:0];

  // Step 5 adjust
  let a4 = ((s4[19:16] >= 5 ? (s4[19:16] + 3).trunc<4>() : s4[19:16]).zext<20>() << 16) |
           ((s4[15:12] >= 5 ? (s4[15:12] + 3).trunc<4>() : s4[15:12]).zext<20>() << 12) |
           ((s4[11:8]  >= 5 ? (s4[11:8]  + 3).trunc<4>() : s4[11:8] ).zext<20>() << 8)  |
           s4[7:0].zext<20>();
  let sh4 = a4.zext<21>() << 1;
  let s5 = sh4[19:0];

  // Step 6 adjust
  let a5 = ((s5[19:16] >= 5 ? (s5[19:16] + 3).trunc<4>() : s5[19:16]).zext<20>() << 16) |
           ((s5[15:12] >= 5 ? (s5[15:12] + 3).trunc<4>() : s5[15:12]).zext<20>() << 12) |
           ((s5[11:8]  >= 5 ? (s5[11:8]  + 3).trunc<4>() : s5[11:8] ).zext<20>() << 8)  |
           s5[7:0].zext<20>();
  let sh5 = a5.zext<21>() << 1;
  let s6 = sh5[19:0];

  // Step 7 adjust
  let a6 = ((s6[19:16] >= 5 ? (s6[19:16] + 3).trunc<4>() : s6[19:16]).zext<20>() << 16) |
           ((s6[15:12] >= 5 ? (s6[15:12] + 3).trunc<4>() : s6[15:12]).zext<20>() << 12) |
           ((s6[11:8]  >= 5 ? (s6[11:8]  + 3).trunc<4>() : s6[11:8] ).zext<20>() << 8)  |
           s6[7:0].zext<20>();
  let sh6 = a6.zext<21>() << 1;
  let s7 = sh6[19:0];

  // Step 8 adjust
  let a7 = ((s7[19:16] >= 5 ? (s7[19:16] + 3).trunc<4>() : s7[19:16]).zext<20>() << 16) |
           ((s7[15:12] >= 5 ? (s7[15:12] + 3).trunc<4>() : s7[15:12]).zext<20>() << 12) |
           ((s7[11:8]  >= 5 ? (s7[11:8]  + 3).trunc<4>() : s7[11:8] ).zext<20>() << 8)  |
           s7[7:0].zext<20>();
  let sh7 = a7.zext<21>() << 1;
  let s8 = sh7[19:0];

  let bcd_out = s8[19:8];
end module binary_to_bcd
