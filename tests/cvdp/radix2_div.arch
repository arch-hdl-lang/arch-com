module radix2_div
  port clk:       in  Clock<SysDomain>;
  port rst_n:     in  Reset<Async, Low>;
  port start:     in  Bool;
  port dividend:  in  UInt<8>;
  port divisor:   in  UInt<8>;
  port quotient:  out UInt<8>;
  port remainder: out UInt<8>;
  port done:      out Bool;

  default seq on clk rising;
  reg default: reset rst_n => 0;

  reg dvd:      UInt<8>;
  reg dvs:      UInt<8>;
  reg quot:     UInt<8>;
  reg acc:      UInt<8>;
  reg count:    UInt<4>;
  reg active:   Bool;
  reg done_r:   Bool;

  // trial: shift acc left 1, bring in MSB of dvd
  wire trial: UInt<9>;
  let trial = {acc, dvd[7:7]};

  wire sub_result: UInt<9>;
  let sub_result = (trial - dvs.zext<9>()).trunc<9>();

  wire fits: Bool;
  let fits = ~sub_result[8:8];

  let quotient  = quot;
  let remainder = acc;
  let done      = done_r;

  seq
    done_r <= false;
    if start
      if divisor == 0
        quot     <= 8'hFF;
        acc      <= 8'hFF;
        active   <= false;
        done_r   <= true;
        dvd      <= 0.zext<8>();
        dvs      <= 0.zext<8>();
        count    <= 0.zext<4>();
      else
        dvd      <= {dividend[6:0], 1'b0};
        dvs      <= divisor;
        count    <= 1.zext<4>();
        active   <= true;
        // first iteration: trial = {0, dividend[7]}
        if dividend[7:7].zext<9>() >= divisor.zext<9>()
          acc  <= (dividend[7:7].zext<9>() - divisor.zext<9>()).trunc<8>();
          quot <= 8'h01;
        else
          acc  <= dividend[7:7].zext<8>();
          quot <= 0.zext<8>();
        end if
      end if
    elsif active
      if fits
        acc  <= sub_result.trunc<8>();
        quot <= {quot[6:0], 1'b1};
      else
        acc  <= trial.trunc<8>();
        quot <= {quot[6:0], 1'b0};
      end if
      dvd <= {dvd[6:0], 1'b0};
      if count == 7
        active <= false;
        done_r <= true;
      else
        count <= (count + 1).trunc<4>();
      end if
    end if
  end seq
end module radix2_div
