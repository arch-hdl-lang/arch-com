module signed_unsigned_comparator
  param WIDTH: const = 5;

  port i_A: in UInt<WIDTH>;
  port i_B: in UInt<WIDTH>;
  port i_enable: in Bool;
  port i_mode: in Bool;
  port o_greater: out Bool;
  port o_less: out Bool;
  port o_equal: out Bool;

  comb
    if not i_enable
      o_greater = false;
      o_less    = false;
      o_equal   = false;
    elsif not i_mode
      o_greater = i_A > i_B;
      o_less    = i_A < i_B;
      o_equal   = i_A == i_B;
    else
      o_greater = signed(i_A) > signed(i_B);
      o_less    = signed(i_A) < signed(i_B);
      o_equal   = signed(i_A) == signed(i_B);
    end if
  end comb
end module signed_unsigned_comparator
