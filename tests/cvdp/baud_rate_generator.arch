module baud_rate_generator
  param CLOCK_FREQ: const = 100000000;
  param BAUD_RATE: const = 115200;
  param BAUD_ACC_WIDTH: const = 16;
  port clock:     in Clock<SysDomain>;
  port reset_neg: in Reset<Async, Low>;
  port enable:    in Bool;
  port baud_pulse: out Bool;

  default seq on clock rising;

  // Exact baud timing via up-counter
  param BAUD_TICKS: const = CLOCK_FREQ / BAUD_RATE;

  reg cnt: UInt<32> reset reset_neg => 0;

  wire pulse_w: Bool;
  comb
    pulse_w = enable & (cnt == (BAUD_TICKS - 1).zext<32>());
  end comb

  seq
    if ~reset_neg
      cnt <= 0;
    elsif ~enable
      cnt <= 0;
    elsif cnt == (BAUD_TICKS - 1).zext<32>()
      cnt <= 0;
    else
      cnt <= (cnt + 1).trunc<32>();
    end if
  end seq

  let baud_pulse = pulse_w;
end module baud_rate_generator
