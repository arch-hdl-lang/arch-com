module qam16_demapper_interpolated
  param N: const = 4;
  param OUT_WIDTH: const = 4;
  param IN_WIDTH: const = 3;
  param ERROR_THRESHOLD: const = 1;
  param TOTAL_SAMPLES: const = N + N / 2;
  param TOTAL_I_WIDTH: const = TOTAL_SAMPLES * IN_WIDTH;
  param TOTAL_OUT_WIDTH: const = N * OUT_WIDTH;
  param NUM_GROUPS: const = N / 2;

  port I: in UInt<TOTAL_I_WIDTH>;
  port Q: in UInt<TOTAL_I_WIDTH>;
  port bits: out UInt<TOTAL_OUT_WIDTH>;
  port error_flag: out UInt<1>;

  // Extract all samples: MSB-first, each IN_WIDTH bits, signed
  wire si_val: Vec<SInt<IN_WIDTH>, TOTAL_SAMPLES>;
  wire sq_val: Vec<SInt<IN_WIDTH>, TOTAL_SAMPLES>;

  // Mapped values per symbol
  wire mi: Vec<SInt<IN_WIDTH>, N>;
  wire mq: Vec<SInt<IN_WIDTH>, N>;

  // Per-group wider values (avoid let inside loop)
  wire g_interp_i: Vec<SInt<IN_WIDTH+2>, NUM_GROUPS>;
  wire g_interp_q: Vec<SInt<IN_WIDTH+2>, NUM_GROUPS>;
  wire g_sum_i:    Vec<SInt<IN_WIDTH+2>, NUM_GROUPS>;
  wire g_sum_q:    Vec<SInt<IN_WIDTH+2>, NUM_GROUPS>;
  wire g_diff_i:   Vec<SInt<IN_WIDTH+2>, NUM_GROUPS>;
  wire g_diff_q:   Vec<SInt<IN_WIDTH+2>, NUM_GROUPS>;
  wire grp_err:    Vec<UInt<1>, NUM_GROUPS>;
  wire err_flag_acc: Vec<UInt<1>, NUM_GROUPS + 1>;

  // Encoded 2-bit values per mapped symbol
  wire i_enc: Vec<UInt<2>, N>;
  wire q_enc: Vec<UInt<2>, N>;
  wire bits_acc: Vec<UInt<TOTAL_OUT_WIDTH>, N + 1>;

  // Extract samples: MSB-first, sign-extend
  comb
    for k in 0..TOTAL_SAMPLES-1
      si_val[k] = (I >> ((TOTAL_SAMPLES - 1 - k) * IN_WIDTH)).trunc<IN_WIDTH>() as SInt<IN_WIDTH>;
      sq_val[k] = (Q >> ((TOTAL_SAMPLES - 1 - k) * IN_WIDTH)).trunc<IN_WIDTH>() as SInt<IN_WIDTH>;
    end for
  end comb

  // Extract mapped values (symbol si comes from group si/2)
  comb
    for si in 0..N-1
      if si % 2 == 0
        mi[si] = si_val[3 * (si / 2)];
        mq[si] = sq_val[3 * (si / 2)];
      else
        mi[si] = si_val[3 * (si / 2) + 2];
        mq[si] = sq_val[3 * (si / 2) + 2];
      end if
    end for
  end comb

  // Compute 2*interp and sum(m0,m1) for each group
  comb
    for gi in 0..NUM_GROUPS-1
      g_interp_i[gi] = si_val[3 * gi + 1].sext<IN_WIDTH+2>() + si_val[3 * gi + 1].sext<IN_WIDTH+2>();
      g_interp_q[gi] = sq_val[3 * gi + 1].sext<IN_WIDTH+2>() + sq_val[3 * gi + 1].sext<IN_WIDTH+2>();
      g_sum_i[gi] = si_val[3 * gi].sext<IN_WIDTH+2>() + si_val[3 * gi + 2].sext<IN_WIDTH+2>();
      g_sum_q[gi] = sq_val[3 * gi].sext<IN_WIDTH+2>() + sq_val[3 * gi + 2].sext<IN_WIDTH+2>();
      g_diff_i[gi] = g_interp_i[gi] - g_sum_i[gi];
      g_diff_q[gi] = g_interp_q[gi] - g_sum_q[gi];
    end for
  end comb

  // Per-group error detection (sext diff to 32-bit for comparison with int const)
  comb
    for gi in 0..NUM_GROUPS-1
      if g_diff_i[gi].sext<32>() > (2 * ERROR_THRESHOLD)
        grp_err[gi] = 1;
      elsif g_diff_i[gi].sext<32>() < (-(2 * ERROR_THRESHOLD))
        grp_err[gi] = 1;
      elsif g_diff_q[gi].sext<32>() > (2 * ERROR_THRESHOLD)
        grp_err[gi] = 1;
      elsif g_diff_q[gi].sext<32>() < (-(2 * ERROR_THRESHOLD))
        grp_err[gi] = 1;
      else
        grp_err[gi] = 0;
      end if
    end for
  end comb

  // Error flag accumulation
  comb
    err_flag_acc[0] = 0;
    for gi in 0..NUM_GROUPS-1
      err_flag_acc[gi + 1] = err_flag_acc[gi] | grp_err[gi];
    end for
  end comb

  // Bit encoding: -3→00, -1→01, 1→10, 3→11
  comb
    for si in 0..N-1
      if mi[si] < -2
        i_enc[si] = 0;
      elsif mi[si] < 0
        i_enc[si] = 1;
      elsif mi[si] < 2
        i_enc[si] = 2;
      else
        i_enc[si] = 3;
      end if
      if mq[si] < -2
        q_enc[si] = 0;
      elsif mq[si] < 0
        q_enc[si] = 1;
      elsif mq[si] < 2
        q_enc[si] = 2;
      else
        q_enc[si] = 3;
      end if
    end for
  end comb

  // Pack output bits: symbol 0 at MSB
  comb
    bits_acc[0] = 0;
    for si in 0..N-1
      bits_acc[si + 1] = bits_acc[si] | ({i_enc[si], q_enc[si]}.zext<TOTAL_OUT_WIDTH>() << ((N - 1 - si) * OUT_WIDTH));
    end for
  end comb

  let bits = bits_acc[N];
  let error_flag = err_flag_acc[NUM_GROUPS];
end module qam16_demapper_interpolated
