module GP
  port i_A: in Bool;
  port i_B: in Bool;
  port i_Cin: in Bool;
  port o_generate: out Bool;
  port o_propagate: out Bool;
  port o_Cout: out Bool;

  wire gen: Bool;
  wire prop: Bool;

  comb
    gen  = i_A & i_B;
    prop = i_A | i_B;
    o_generate  = gen;
    o_propagate = prop;
    o_Cout      = gen | (prop & i_Cin);
  end comb
end module GP
