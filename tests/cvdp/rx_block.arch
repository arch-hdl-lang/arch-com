module rx_block
  port clk:         in Clock<SysDomain>;
  port reset_n:     in Reset<Async, Low>;
  port data_in:     in Bool;
  port sel:         in UInt<3>;
  port serial_clk:  in Bool;
  port reg data_out: out UInt<64> reset reset_n=>0;
  port reg done:     out Bool reset reset_n=>false;

  reg shift_reg: UInt<64> reset reset_n=>0;
  reg bit_cnt:   UInt<7> reset reset_n=>0;
  reg active:    Bool reset reset_n=>false;

  default seq on clk rising;

  seq
    if active
      if serial_clk
        shift_reg <= {data_in, shift_reg[63:1]};
        bit_cnt <= (bit_cnt - 1).trunc<7>();
        if bit_cnt == 0
          active <= false;
          done <= true;
          if sel == 1
            data_out <= {56'h0, data_in, shift_reg[63:57]};
          elsif sel == 2
            data_out <= {48'h0, data_in, shift_reg[63:49]};
          elsif sel == 3
            data_out <= {32'h0, data_in, shift_reg[63:33]};
          elsif sel == 4
            data_out <= {data_in, shift_reg[63:1]};
          else
            data_out <= 0;
          end if
        end if
      end if
    else
      done <= false;
      if serial_clk
        if sel == 1
          shift_reg <= {data_in, shift_reg[63:1]};
          bit_cnt <= 6;
          active <= true;
        elsif sel == 2
          shift_reg <= {data_in, shift_reg[63:1]};
          bit_cnt <= 14;
          active <= true;
        elsif sel == 3
          shift_reg <= {data_in, shift_reg[63:1]};
          bit_cnt <= 30;
          active <= true;
        elsif sel == 4
          shift_reg <= {data_in, shift_reg[63:1]};
          bit_cnt <= 62;
          active <= true;
        end if
      end if
    end if
  end seq
end module rx_block
