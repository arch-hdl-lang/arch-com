module clock_divider
  port clk: in Clock<SysDomain>;
  port rst_n: in Reset<Async, Low>;
  port sel: in UInt<2>;
  port clk_out: out pipe_reg<Bool, 1> reset rst_n=>0;

  reg cnt: UInt<3> reset rst_n=>0;

  seq on clk rising
    if sel == 2'd0
      // Divide by 2: toggle every cycle
      clk_out <= ~clk_out;
      cnt <= 3'd0;
    elsif sel == 2'd1
      // Divide by 4: toggle every 2 cycles
      if cnt == 3'd1
        clk_out <= ~clk_out;
        cnt <= 3'd0;
      else
        cnt <= (cnt + 3'd1).trunc<3>();
      end if
    elsif sel == 2'd2
      // Divide by 8: toggle every 4 cycles
      if cnt == 3'd3
        clk_out <= ~clk_out;
        cnt <= 3'd0;
      else
        cnt <= (cnt + 3'd1).trunc<3>();
      end if
    else
      clk_out <= 1'd0;
      cnt <= 3'd0;
    end if
  end seq
end module clock_divider
