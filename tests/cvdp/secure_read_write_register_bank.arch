use SecureRegBankPkg;

fsm secure_read_write_register_bank
  param P_ADDRESS_WIDTH: const = 8;
  param P_DATA_WIDTH: const = 8;
  param P_UNLOCK_CODE_0: const = 171;
  param P_UNLOCK_CODE_1: const = 205;

  port i_capture_pulse: in Clock<SysDomain>;
  port i_rst_n: in Reset<Async, Low>;
  port i_addr: in UInt<P_ADDRESS_WIDTH>;
  port i_data_in: in UInt<P_DATA_WIDTH>;
  port i_read_write_enable: in Bit;
  port reg o_data_out: out UInt<P_DATA_WIDTH> reset i_rst_n=>0;

  reg mem: Vec<UInt<P_DATA_WIDTH>, 256> reset i_rst_n=>0;

  let is_write: Bool = i_read_write_enable == 0;
  let code0_match: Bool = i_data_in == P_UNLOCK_CODE_0.trunc<P_DATA_WIDTH>();
  let code1_match: Bool = i_data_in == P_UNLOCK_CODE_1.trunc<P_DATA_WIDTH>();

  state LOCKED, GOT_CODE0, UNLOCKED;
  default state LOCKED;
  default seq on i_capture_pulse rising;

  state LOCKED
    seq
      o_data_out <= 0;
      if is_write
        if i_addr == 0
          mem[0] <= i_data_in;
        elsif i_addr == 1
          mem[1] <= i_data_in;
        end if
      end if
    end seq
    transition to GOT_CODE0 when is_write & (i_addr == 0) & code0_match;
  end state LOCKED

  state GOT_CODE0
    seq
      o_data_out <= 0;
      if is_write
        if i_addr == 0
          mem[0] <= i_data_in;
        elsif i_addr == 1
          mem[1] <= i_data_in;
        end if
      end if
    end seq
    transition to UNLOCKED when is_write & (i_addr == 1) & code1_match;
    transition to LOCKED   when is_write & (i_addr == 1) & ~code1_match;
    transition to LOCKED   when is_write & (i_addr != 0) & (i_addr != 1);
    transition to LOCKED   when ~is_write;
  end state GOT_CODE0

  state UNLOCKED
    seq
      if is_write
        if i_addr == 0
          mem[0] <= i_data_in;
          o_data_out <= 0;
        elsif i_addr == 1
          mem[1] <= i_data_in;
          o_data_out <= 0;
        else
          mem[i_addr] <= i_data_in;
          o_data_out <= 0;
        end if
      else
        if (i_addr == 0) | (i_addr == 1)
          o_data_out <= 0;
        else
          o_data_out <= mem[i_addr];
        end if
      end if
    end seq
    transition to UNLOCKED;
  end state UNLOCKED

end fsm secure_read_write_register_bank
