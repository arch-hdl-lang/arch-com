fsm secure_read_write_register_bank
  param p_address_width: const = 8;
  param p_data_width:    const = 8;
  param p_unlock_code_0: const = 0xAB;
  param p_unlock_code_1: const = 0xCD;
  param MEM_DEPTH:       const = 1 << p_address_width;

  port i_capture_pulse:    in Clock<SysDomain>;
  port i_rst_n:            in Reset<Async, Low>;
  port i_addr:             in UInt<p_address_width>;
  port i_data_in:          in UInt<p_data_width>;
  port i_read_write_enable: in Bool;
  port o_data_out:         out UInt<p_data_width>;

  state [Locked, Code0Written, Unlocked]
  default state Locked;

  reg mem:       Vec<UInt<p_data_width>, MEM_DEPTH> reset i_rst_n => 0;
  reg data_out_r: UInt<p_data_width> reset i_rst_n => 0;

  let is_write:     Bool = ~i_read_write_enable;
  let addr_is_0:    Bool = i_addr == 0;
  let addr_is_1:    Bool = i_addr == 1;
  let addr_is_other: Bool = ~addr_is_0 & ~addr_is_1;
  let match_code0:  Bool = i_data_in == p_unlock_code_0.trunc<p_data_width>();
  let match_code1:  Bool = i_data_in == p_unlock_code_1.trunc<p_data_width>();

  default
    comb
      o_data_out = data_out_r;
    end comb
  end default

  state Locked
    seq on i_capture_pulse rising
      data_out_r <= 0;
    end seq
    -> Code0Written when is_write & addr_is_0 & match_code0;
  end state Locked

  state Code0Written
    seq on i_capture_pulse rising
      data_out_r <= 0;
    end seq
    -> Unlocked when is_write & addr_is_1 & match_code1;
    -> Locked   when ~(is_write & addr_is_1 & match_code1);
  end state Code0Written

  state Unlocked
    seq on i_capture_pulse rising
      if is_write
        if addr_is_other
          mem[i_addr] <= i_data_in;
        end if
        data_out_r <= 0;
      elsif addr_is_other
        data_out_r <= mem[i_addr];
      else
        data_out_r <= 0;
      end if
    end seq
    -> Code0Written when is_write & addr_is_0 & match_code0;
    -> Locked       when is_write & addr_is_0 & ~match_code0;
    -> Locked       when is_write & addr_is_1;
  end state Unlocked

end fsm secure_read_write_register_bank
