function xtime(a: UInt<8>) -> UInt<8>
  let shifted: UInt<8> = a << 1;
  return (a[7:7] == 1) ? (shifted ^ 8'h1B) : shifted;
end function xtime

function gf_mul8(x: UInt<8>, y: UInt<8>) -> UInt<8>
  let mut_a0: UInt<8> = x;
  let mut_a1: UInt<8> = xtime(mut_a0);
  let mut_a2: UInt<8> = xtime(mut_a1);
  let mut_a3: UInt<8> = xtime(mut_a2);
  let mut_a4: UInt<8> = xtime(mut_a3);
  let mut_a5: UInt<8> = xtime(mut_a4);
  let mut_a6: UInt<8> = xtime(mut_a5);
  let mut_a7: UInt<8> = xtime(mut_a6);
  let part0: UInt<8> = (y[0:0] == 1) ? mut_a0 : 0;
  let part1: UInt<8> = (y[1:1] == 1) ? mut_a1 : 0;
  let part2: UInt<8> = (y[2:2] == 1) ? mut_a2 : 0;
  let part3: UInt<8> = (y[3:3] == 1) ? mut_a3 : 0;
  let part4: UInt<8> = (y[4:4] == 1) ? mut_a4 : 0;
  let part5: UInt<8> = (y[5:5] == 1) ? mut_a5 : 0;
  let part6: UInt<8> = (y[6:6] == 1) ? mut_a6 : 0;
  let part7: UInt<8> = (y[7:7] == 1) ? mut_a7 : 0;
  return part0 ^ part1 ^ part2 ^ part3 ^ part4 ^ part5 ^ part6 ^ part7;
end function gf_mul8

module gf_mac
  param WIDTH: const = 8;
  local param SEGMENTS: const = WIDTH / 8;
  local param WIDTH_VALID: const = (WIDTH > 0) and ((WIDTH % 8) == 0);

  port a:      in UInt<WIDTH>;
  port b:      in UInt<WIDTH>;
  port result: out UInt<8>;
  port error_flag: out Bool;
  port valid_result: out Bool;

  comb
    result = 0;
    error_flag = ~WIDTH_VALID;
    valid_result = WIDTH_VALID;
    if WIDTH_VALID
      for i in 0..SEGMENTS-1
        result = result ^ gf_mul8(a[i * 8 + 7 : i * 8], b[i * 8 + 7 : i * 8]);
      end for
    end if
  end comb
end module gf_mac
