module dig_stopwatch
  param CLK_FREQ: const = 50000000;
  port clk: in Clock<SysDomain>;
  port reset: in Reset<Async, High>;
  port start_stop: in Bool;
  port seconds: out UInt<6>;
  port minutes: out UInt<6>;
  port hour: out UInt<8>;
  port one_sec_pulse: out Bool;

  reg default: reset reset => 0;

  reg clk_cnt: UInt<32>;
  reg secs: UInt<6>;
  reg mins: UInt<6>;
  reg hrs: UInt<8>;
  reg pulse: Bool;

  // cnt_wrap: combinational — fires when counter is at max and running
  wire cnt_wrap: Bool;
  comb
    cnt_wrap = start_stop & (clk_cnt == (CLK_FREQ - 1).zext<32>());
    seconds = secs;
    minutes = mins;
    hour = hrs;
    one_sec_pulse = pulse;
  end comb

  seq on clk rising
    // pulse is registered copy of cnt_wrap; one_sec_pulse goes high cycle AFTER wrap
    pulse <= cnt_wrap;
    if start_stop
      if cnt_wrap
        clk_cnt <= 0;
      else
        clk_cnt <= (clk_cnt + 1).trunc<32>();
      end if
    end if
    // Increment counters cycle AFTER pulse fires.
    // Gate with start_stop so a pending pulse is discarded if stopped.
    if pulse & start_stop
      if secs == 59
        secs <= 0;
        if mins == 59
          mins <= 0;
          hrs <= (hrs + 1).trunc<8>();
        else
          mins <= (mins + 1).trunc<6>();
        end if
      else
        secs <= (secs + 1).trunc<6>();
      end if
    end if
  end seq
end module dig_stopwatch
