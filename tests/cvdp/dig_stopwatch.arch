module dig_stopwatch
  param CLK_FREQ: const = 50000000;

  port clk:        in Clock<SysDomain>;
  port reset:      in Reset<Async, High>;
  port start_stop: in Bool;
  port seconds:    out UInt<6>;
  port minutes:    out UInt<6>;
  port hour:       out UInt<1>;

  reg clk_cnt: UInt<32> reset reset=>0;
  reg one_sec_pulse: Bool reset reset=>false;
  reg prev_start: Bool reset reset=>false;
  reg r_seconds: UInt<6> reset reset=>0;
  reg r_minutes: UInt<6> reset reset=>0;
  reg r_hour:    UInt<1> reset reset=>0;

  seq on clk rising
    one_sec_pulse <= false;
    prev_start <= start_stop;

    // Clock divider: advance counter while running.
    if start_stop
      if clk_cnt == (CLK_FREQ - 1).zext<32>()
        clk_cnt <= 0;
        one_sec_pulse <= true;
      else
        clk_cnt <= clk_cnt +% 1;
      end if
    end if

    // Counter updates: use (start_stop | prev_start) so that a pending
    // pulse from the clock when start_stop dropped still counts.
    if one_sec_pulse & (start_stop | prev_start) & ~r_hour
      if r_seconds == 59
        r_seconds <= 0;
        if r_minutes == 59
          r_minutes <= 0;
          r_hour <= 1;
        else
          r_minutes <= r_minutes +% 1;
        end if
      else
        r_seconds <= r_seconds +% 1;
      end if
    end if
  end seq

  // Combinational outputs: lookahead when pulse is active and running
  // (or was running one cycle ago via prev_start).
  comb
    if one_sec_pulse & (start_stop | prev_start) & ~r_hour
      if r_seconds == 59
        seconds = 0;
        if r_minutes == 59
          minutes = 0;
          hour    = 1;
        else
          minutes = r_minutes +% 1;
          hour    = r_hour;
        end if
      else
        seconds = r_seconds +% 1;
        minutes = r_minutes;
        hour    = r_hour;
      end if
    else
      seconds = r_seconds;
      minutes = r_minutes;
      hour    = r_hour;
    end if
  end comb
end module dig_stopwatch
