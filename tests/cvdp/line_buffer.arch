module line_buffer
  param NBW_DATA:  const = 8;
  param NS_ROW:    const = 10;
  param NS_COLUMN: const = 8;
  param NS_R_OUT:  const = 4;
  param NS_C_OUT:  const = 3;
  param CONSTANT:  const = 255;
  param NBW_ROW:   const = 4;
  param NBW_COL:   const = 3;
  param NBW_MODE:  const = 3;

  local param WIN_PIXELS: const = NS_R_OUT * NS_C_OUT;
  local param OUT_BITS:   const = WIN_PIXELS * NBW_DATA;

  port clk:               in Clock<SysDomain>;
  port rst_async_n:       in Reset<Async, Low>;
  port i_mode:            in UInt<NBW_MODE>;
  port i_valid:           in Bool;
  port i_update_window:   in Bool;
  port i_row_image:       in UInt<NS_COLUMN * NBW_DATA>;
  port i_image_row_start: in UInt<NBW_ROW>;
  port i_image_col_start: in UInt<NBW_COL>;
  port o_image_window:    out UInt<OUT_BITS>;

  default seq on clk rising;

  // Line buffer: pix_rows[0] = newest row, pix_rows[NS_ROW-1] = oldest
  reg pix_rows: Vec<UInt<NS_COLUMN * NBW_DATA>, NS_ROW> reset rst_async_n => 0;

  // Last registered window pixels (updated when i_update_window=1)
  reg last_win: Vec<UInt<NBW_DATA>, WIN_PIXELS> reset rst_async_n => 0;

  // Compute current window combinatorially from current inputs + pix_rows
  wire comb_win: UInt<OUT_BITS>;

  comb
    for wr in 0..NS_R_OUT-1
      for wc in 0..NS_C_OUT-1
        if i_mode == 0
          if ((i_image_row_start.zext<8>() + wr.zext<8>()) < NS_ROW.zext<8>()) & ((i_image_col_start.zext<8>() + wc.zext<8>()) < NS_COLUMN.zext<8>())
            comb_win[(wr * NS_C_OUT + wc) * NBW_DATA + NBW_DATA - 1 : (wr * NS_C_OUT + wc) * NBW_DATA] =
              (pix_rows[(i_image_row_start.zext<8>() + wr.zext<8>()).trunc<4>()] >>
               ((NS_COLUMN.zext<8>() - 1 - (i_image_col_start.zext<8>() + wc.zext<8>())) * NBW_DATA.zext<8>())).trunc<NBW_DATA>();
          else
            comb_win[(wr * NS_C_OUT + wc) * NBW_DATA + NBW_DATA - 1 : (wr * NS_C_OUT + wc) * NBW_DATA] = 0.zext<NBW_DATA>();
          end if
        elsif i_mode == 1
          if ((i_image_row_start.zext<8>() + wr.zext<8>()) < NS_ROW.zext<8>()) & ((i_image_col_start.zext<8>() + wc.zext<8>()) < NS_COLUMN.zext<8>())
            comb_win[(wr * NS_C_OUT + wc) * NBW_DATA + NBW_DATA - 1 : (wr * NS_C_OUT + wc) * NBW_DATA] =
              (pix_rows[(i_image_row_start.zext<8>() + wr.zext<8>()).trunc<4>()] >>
               ((NS_COLUMN.zext<8>() - 1 - (i_image_col_start.zext<8>() + wc.zext<8>())) * NBW_DATA.zext<8>())).trunc<NBW_DATA>();
          else
            comb_win[(wr * NS_C_OUT + wc) * NBW_DATA + NBW_DATA - 1 : (wr * NS_C_OUT + wc) * NBW_DATA] = CONSTANT.zext<NBW_DATA+1>().trunc<NBW_DATA>();
          end if
        elsif i_mode == 2
          comb_win[(wr * NS_C_OUT + wc) * NBW_DATA + NBW_DATA - 1 : (wr * NS_C_OUT + wc) * NBW_DATA] =
            (pix_rows[((i_image_row_start.zext<8>() + wr.zext<8>()) < NS_ROW.zext<8>() ? (i_image_row_start.zext<8>() + wr.zext<8>()) : (NS_ROW - 1).zext<8>()).trunc<4>()] >>
             ((NS_COLUMN.zext<8>() - 1 - ((i_image_col_start.zext<8>() + wc.zext<8>()) < NS_COLUMN.zext<8>() ? (i_image_col_start.zext<8>() + wc.zext<8>()) : (NS_COLUMN - 1).zext<8>())) * NBW_DATA.zext<8>())).trunc<NBW_DATA>();
        elsif i_mode == 3
          comb_win[(wr * NS_C_OUT + wc) * NBW_DATA + NBW_DATA - 1 : (wr * NS_C_OUT + wc) * NBW_DATA] =
            (pix_rows[((i_image_row_start.zext<8>() + wr.zext<8>()) < NS_ROW.zext<8>() ? (i_image_row_start.zext<8>() + wr.zext<8>()) : ((2 * NS_ROW - 1).zext<8>() - (i_image_row_start.zext<8>() + wr.zext<8>()))).trunc<4>()] >>
             ((NS_COLUMN.zext<8>() - 1 - ((i_image_col_start.zext<8>() + wc.zext<8>()) < NS_COLUMN.zext<8>() ? (i_image_col_start.zext<8>() + wc.zext<8>()) : ((2 * NS_COLUMN - 1).zext<8>() - (i_image_col_start.zext<8>() + wc.zext<8>())))) * NBW_DATA.zext<8>())).trunc<NBW_DATA>();
        elsif i_mode == 4
          comb_win[(wr * NS_C_OUT + wc) * NBW_DATA + NBW_DATA - 1 : (wr * NS_C_OUT + wc) * NBW_DATA] =
            (pix_rows[((i_image_row_start.zext<8>() + wr.zext<8>()) % NS_ROW.zext<8>()).trunc<4>()] >>
             ((NS_COLUMN.zext<8>() - 1 - ((i_image_col_start.zext<8>() + wc.zext<8>()) % NS_COLUMN.zext<8>())) * NBW_DATA.zext<8>())).trunc<NBW_DATA>();
        else
          comb_win[(wr * NS_C_OUT + wc) * NBW_DATA + NBW_DATA - 1 : (wr * NS_C_OUT + wc) * NBW_DATA] = 0.zext<NBW_DATA>();
        end if
      end for
    end for
  end comb

  // Output: if update_window, show comb result; else show last registered window
  comb
    for wr in 0..NS_R_OUT-1
      for wc in 0..NS_C_OUT-1
        o_image_window[(wr * NS_C_OUT + wc) * NBW_DATA + NBW_DATA - 1 : (wr * NS_C_OUT + wc) * NBW_DATA] =
          i_update_window ? comb_win[(wr * NS_C_OUT + wc) * NBW_DATA + NBW_DATA - 1 : (wr * NS_C_OUT + wc) * NBW_DATA] : last_win[wr * NS_C_OUT + wc];
      end for
    end for
  end comb

  seq
    // Shift buffer: insert new row at index 0 on valid
    if i_valid
      for sr in 1..NS_ROW-1
        pix_rows[sr] <= pix_rows[sr - 1];
      end for
      pix_rows[0] <= i_row_image;
    end if
    // Register window when update_window=1
    if i_update_window
      for wr in 0..NS_R_OUT-1
        for wc in 0..NS_C_OUT-1
          last_win[wr * NS_C_OUT + wc] <=
            comb_win[(wr * NS_C_OUT + wc) * NBW_DATA + NBW_DATA - 1 : (wr * NS_C_OUT + wc) * NBW_DATA];
        end for
      end for
    end if
  end seq

end module line_buffer
