module async_filo
  pragma cdc_safe;
  param DATA_WIDTH: const = 16;
  param DEPTH[3:0]:    const = 8;   // max 15; width matches ADDR_WIDTH+1
  param ADDR_WIDTH: const = 3;      // must equal log2(DEPTH)

  port w_clk:   in Clock<WDomain>;
  port w_rst:   in Reset<Async>;
  port push:    in Bool;
  port r_rst:   in Reset<Async>;
  port r_clk:   in Clock<RDomain>;
  port pop:     in Bool;
  port w_data:  in UInt<DATA_WIDTH>;
  port r_data:  out UInt<DATA_WIDTH>;
  port r_empty: out Bool;
  port w_full:  out Bool;

  // Memory array
  reg mem: Vec<UInt<DATA_WIDTH>, DEPTH> init 0;

  // Write domain: monotonically increasing push count (ADDR_WIDTH+1 bits)
  reg w_ptr: UInt<ADDR_WIDTH+1> reset w_rst=0;

  // Read domain: monotonically increasing pop count
  reg r_pop_cnt: UInt<ADDR_WIDTH+1> reset r_rst=0;

  // Gray-code CDC: w_ptr (WDomain) → RDomain
  wire rq2_wptr: UInt<ADDR_WIDTH+1>;
  inst wptr_sync: WToRGraySync
    param WIDTH = ADDR_WIDTH+1;
    connect src_clk  <- w_clk;
    connect dst_clk  <- r_clk;
    connect rst      <- r_rst;
    connect data_in  <- w_ptr;
    connect data_out -> rq2_wptr;
  end inst wptr_sync

  // Gray-code CDC: r_pop_cnt (RDomain) → WDomain
  wire wq2_rcnt: UInt<ADDR_WIDTH+1>;
  inst rptr_sync: RToWGraySync
    param WIDTH = ADDR_WIDTH+1;
    connect src_clk  <- r_clk;
    connect dst_clk  <- w_clk;
    connect rst      <- w_rst;
    connect data_in  <- r_pop_cnt;
    connect data_out -> wq2_rcnt;
  end inst rptr_sync

  // Stack pointer and empty-edge detection (read domain only — no CDC needed)
  reg r_ptr:    UInt<ADDR_WIDTH+1> reset r_rst=0;
  reg was_empty: Bool reset r_rst=1;

  wire full_i:  Bool;
  wire empty_i: Bool;
  comb full_i  = (w_ptr - wq2_rcnt) == DEPTH;
  comb empty_i = (rq2_wptr == r_pop_cnt);

  comb r_data  = mem[r_ptr[ADDR_WIDTH-1:0]];
  comb r_empty = empty_i;
  comb w_full  = full_i;

  // Write domain: push data
  seq on w_clk rising
    if push & ~full_i
      mem[w_ptr[ADDR_WIDTH-1:0]] <= w_data;
      w_ptr <= (w_ptr + 1).trunc<ADDR_WIDTH+1>();
    end if
  end seq

  // Read domain: manage stack pointer
  seq on r_clk rising
    was_empty <= empty_i;
    if was_empty & ~empty_i
      r_ptr <= (rq2_wptr - 1).trunc<ADDR_WIDTH+1>();
    elsif pop & ~empty_i
      r_pop_cnt <= (r_pop_cnt + 1).trunc<ADDR_WIDTH+1>();
      r_ptr <= (r_ptr - 1).trunc<ADDR_WIDTH+1>();
    end if
  end seq

end module async_filo
