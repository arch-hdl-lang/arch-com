// Simple floor number to 7-segment display decoder
// Maps floor number 0-9 to 7-segment patterns
module floor_to_seven_segment
  port floor_in:    in  UInt<4>;
  port seven_seg:   out UInt<7>;

  comb
    if floor_in == 0
      seven_seg = 7'b1111110;
    elsif floor_in == 1
      seven_seg = 7'b0110000;
    elsif floor_in == 2
      seven_seg = 7'b1101101;
    elsif floor_in == 3
      seven_seg = 7'b1111001;
    elsif floor_in == 4
      seven_seg = 7'b0110011;
    elsif floor_in == 5
      seven_seg = 7'b1011011;
    elsif floor_in == 6
      seven_seg = 7'b1011111;
    elsif floor_in == 7
      seven_seg = 7'b1110000;
    elsif floor_in == 8
      seven_seg = 7'b1111111;
    elsif floor_in == 9
      seven_seg = 7'b1111011;
    else
      seven_seg = 7'b0000000;
    end if
  end comb
end module floor_to_seven_segment
