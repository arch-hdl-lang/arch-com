module cvdp_copilot_perf_counters
  port clk: in Clock<SysDomain>;
  port reset: in Reset<Sync, High>;
  port cpu_trig_i: in Bool;
  port sw_req_i: in Bool;
  port p_count_o: out UInt<8>;

  reg cnt: UInt<8> reset reset => 0;

  seq on clk rising
    if sw_req_i
      cnt <= cpu_trig_i.zext<8>();
    elsif cpu_trig_i
      cnt <= (cnt + 8'd1).trunc<8>();
    end if
  end seq

  wire p_count_comb: UInt<8>;

  comb
    if sw_req_i
      p_count_comb = cnt;
    else
      p_count_comb = 0;
    end if
  end comb

  let p_count_o = p_count_comb;
end module cvdp_copilot_perf_counters
