module image_stego
  param row: const = 2;
  param col: const = 2;

  port bpp:     in  UInt<2>;
  port img_in:  in  UInt<row*col*8>;
  port data_in: in  UInt<row*col*4>;
  port img_out: out UInt<row*col*8>;

  wire out_val: UInt<row*col*8>;

  comb
    out_val = img_in;
    for i in 0..row*col-1
      out_val[8*i+7:8*i] = match bpp
        0 => {img_in[8*i+7:8*i+1], data_in[i:i]},
        1 => {img_in[8*i+7:8*i+2], data_in[2*i+1:2*i]},
        2 => {img_in[8*i+7:8*i+3], data_in[3*i+2:3*i]},
        _ => {img_in[8*i+7:8*i+4], data_in[4*i+3:4*i]},
      end match;
    end for
    img_out = out_val;
  end comb
end module image_stego
