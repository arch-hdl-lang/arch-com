module sync_serial_communication_tx_rx
  port clk:       in Clock<SysDomain>;
  port reset_n:   in Reset<Async, Low>;
  port data_in:   in UInt<64>;
  port sel:       in UInt<3>;
  port data_out:  out UInt<64>;
  port done:      out Bool;

  wire serial_out_w: Bool;
  wire tx_done_w:    Bool;
  wire serial_clk_w: Bool;

  inst tx: tx_block
    clk        <- clk;
    reset_n    <- reset_n;
    data_in    <- data_in;
    sel        <- sel;
    serial_out -> serial_out_w;
    done       -> tx_done_w;
    serial_clk -> serial_clk_w;
  end inst tx

  inst rx: rx_block
    clk        <- clk;
    reset_n    <- reset_n;
    data_in    <- serial_out_w;
    sel        <- sel;
    serial_clk <- serial_clk_w;
    data_out   -> data_out;
    done       -> done;
  end inst rx

end module sync_serial_communication_tx_rx
