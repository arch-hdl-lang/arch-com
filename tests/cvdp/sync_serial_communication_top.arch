module sync_serial_communication_tx_rx
  port clk:      in Clock<SysDomain>;
  port reset_n:  in Reset<Async, Low>;
  port sel:      in UInt<3>;
  port data_in:  in UInt<64>;
  port data_out: out UInt<64>;
  port done:     out Bool;

  wire tx_serial_out: Bool;
  wire tx_done:       Bool;
  wire tx_serial_clk: Bool;

  inst tx: tx_block
    clk        <- clk;
    reset_n    <- reset_n;
    data_in    <- data_in;
    sel        <- sel;
    serial_out -> tx_serial_out;
    done       -> tx_done;
    serial_clk -> tx_serial_clk;
  end inst tx

  wire rx_data_out: UInt<64>;
  wire rx_done:     Bool;

  inst rx: rx_block
    clk        <- clk;
    reset_n    <- reset_n;
    serial_clk <- tx_serial_clk;
    sel        <- sel;
    data_in    <- tx_serial_out;
    data_out   -> rx_data_out;
    done       -> rx_done;
  end inst rx

  let data_out = rx_data_out;
  let done = rx_done;end module sync_serial_communication_tx_rx
