module qam16_mapper_interpolated
  param N: const = 4;
  param IN_WIDTH: const = 4;
  param OUT_WIDTH: const = 3;
  param OUTW: const = (N + N/2) * OUT_WIDTH;
  param NPAIRS: const = N / 2;

  port bits: in UInt<N*IN_WIDTH>;
  port I: out UInt<OUTW>;
  port Q: out UInt<OUTW>;

  // Per-symbol mapped values
  wire mi: Vec<UInt<OUT_WIDTH>, N>;
  wire mq: Vec<UInt<OUT_WIDTH>, N>;

  // Interpolated values per pair
  wire itp_i: Vec<UInt<OUT_WIDTH>, NPAIRS>;
  wire itp_q: Vec<UInt<OUT_WIDTH>, NPAIRS>;

  // Output slots: N + N/2 = 3*NPAIRS total
  wire out_i: Vec<UInt<OUT_WIDTH>, N + N/2>;
  wire out_q: Vec<UInt<OUT_WIDTH>, N + N/2>;

  // Accumulator for packing output
  wire acc_i: Vec<UInt<OUTW>, N + N/2 + 1>;
  wire acc_q: Vec<UInt<OUTW>, N + N/2 + 1>;

  // Map each symbol: MSBs[3:2] -> I, LSBs[1:0] -> Q
  // Formula: (2*x + 5) mod 8: 00->5(101), 01->7(111), 10->1(001), 11->3(011)
  comb
    for i in 0..N-1
      mi[i] = (bits[i*IN_WIDTH + IN_WIDTH - 1 : i*IN_WIDTH + IN_WIDTH - 2] * 2 + 5).trunc<OUT_WIDTH>();
      mq[i] = (bits[i*IN_WIDTH + 1 : i*IN_WIDTH] * 2 + 5).trunc<OUT_WIDTH>();
    end for
  end comb

  // Compute interpolated values per pair using signed arithmetic (avoids $bits chain-index)
  comb
    for j in 0..NPAIRS-1
      itp_i[j] = unsigned((signed(mi[2*j]) + signed(mi[2*j+1])) >> 1).trunc<OUT_WIDTH>();
      itp_q[j] = unsigned((signed(mq[2*j]) + signed(mq[2*j+1])) >> 1).trunc<OUT_WIDTH>();
    end for
  end comb

  // Build output slots: for each pair j, three slots at 3*j, 3*j+1, 3*j+2
  comb
    for j in 0..NPAIRS-1
      out_i[3*j]   = mi[2*j];
      out_i[3*j+1] = itp_i[j];
      out_i[3*j+2] = mi[2*j+1];
      out_q[3*j]   = mq[2*j];
      out_q[3*j+1] = itp_q[j];
      out_q[3*j+2] = mq[2*j+1];
    end for
  end comb

  // Pack output accumulator
  comb
    acc_i[0] = 0;
    acc_q[0] = 0;
    for k in 0..N+N/2-1
      acc_i[k+1] = acc_i[k] | (out_i[k].zext<OUTW>() << (k * OUT_WIDTH));
      acc_q[k+1] = acc_q[k] | (out_q[k].zext<OUTW>() << (k * OUT_WIDTH));
    end for
    I = acc_i[N + N/2];
    Q = acc_q[N + N/2];
  end comb
end module qam16_mapper_interpolated
