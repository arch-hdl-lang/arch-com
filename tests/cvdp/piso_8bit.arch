module piso_8bit
  port clk: in Clock<SysDomain>;
  port rst: in Reset<Async, Low>;
  port reg serial_out: out Bool reset rst=0;

  reg tmp: UInt<8> reset rst=1;
  reg bit_cnt: UInt<3> reset rst=0;

  seq on clk rising
    // Output MSB-first: bit (7 - bit_cnt)
    serial_out <= tmp[7 - bit_cnt];

    if bit_cnt == 3'd7
      bit_cnt <= 3'd0;
      tmp <= (tmp + 8'd1).trunc<8>();
    else
      bit_cnt <= (bit_cnt + 3'd1).trunc<3>();
    end if
  end seq
end module piso_8bit
