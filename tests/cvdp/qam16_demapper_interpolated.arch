module qam16_demapper_interpolated
  param N: const = 4;
  param OUT_WIDTH: const = 4;
  param IN_WIDTH: const = 3;
  param ERROR_THRESHOLD: const = 1;
  param TOTAL_SAMPLES: const = N + N / 2;
  param TOTAL_I_WIDTH: const = TOTAL_SAMPLES * IN_WIDTH;
  param TOTAL_OUT_WIDTH: const = N * OUT_WIDTH;
  param NUM_GROUPS: const = N / 2;

  port I: in UInt<TOTAL_I_WIDTH>;
  port Q: in UInt<TOTAL_I_WIDTH>;
  port bits: out UInt<TOTAL_OUT_WIDTH>;
  port error_flag: out UInt<1>;

  // Scalar wires avoid packed-2D-array issues with iverilog loop indexing
  wire bits_out: UInt<TOTAL_OUT_WIDTH>;
  wire err_out: UInt<1>;
  // Per-symbol encode temporaries (scalar, not Vec)
  wire i_enc: UInt<2>;
  wire q_enc: UInt<2>;

  // Bit encoding and output packing in one comb block
  // pack_signal: values[0] at MSB → sample k at shift=(TOTAL_SAMPLES-1-k)*IN_WIDTH
  // Even symbol si uses sample 3*(si/2), odd uses 3*(si/2)+2
  comb
    bits_out = 0;
    i_enc = 0;
    q_enc = 0;
    for si in 0..N-1
      if si % 2 == 0
        if (I >> ((TOTAL_SAMPLES - 1 - 3 * (si / 2)) * IN_WIDTH)).trunc<IN_WIDTH>() as SInt<IN_WIDTH> < (-2)
          i_enc = 0;
        elsif (I >> ((TOTAL_SAMPLES - 1 - 3 * (si / 2)) * IN_WIDTH)).trunc<IN_WIDTH>() as SInt<IN_WIDTH> < 0
          i_enc = 1;
        elsif (I >> ((TOTAL_SAMPLES - 1 - 3 * (si / 2)) * IN_WIDTH)).trunc<IN_WIDTH>() as SInt<IN_WIDTH> < 2
          i_enc = 2;
        else
          i_enc = 3;
        end if
        if (Q >> ((TOTAL_SAMPLES - 1 - 3 * (si / 2)) * IN_WIDTH)).trunc<IN_WIDTH>() as SInt<IN_WIDTH> < (-2)
          q_enc = 0;
        elsif (Q >> ((TOTAL_SAMPLES - 1 - 3 * (si / 2)) * IN_WIDTH)).trunc<IN_WIDTH>() as SInt<IN_WIDTH> < 0
          q_enc = 1;
        elsif (Q >> ((TOTAL_SAMPLES - 1 - 3 * (si / 2)) * IN_WIDTH)).trunc<IN_WIDTH>() as SInt<IN_WIDTH> < 2
          q_enc = 2;
        else
          q_enc = 3;
        end if
      else
        if (I >> ((TOTAL_SAMPLES - 3 - 3 * (si / 2)) * IN_WIDTH)).trunc<IN_WIDTH>() as SInt<IN_WIDTH> < (-2)
          i_enc = 0;
        elsif (I >> ((TOTAL_SAMPLES - 3 - 3 * (si / 2)) * IN_WIDTH)).trunc<IN_WIDTH>() as SInt<IN_WIDTH> < 0
          i_enc = 1;
        elsif (I >> ((TOTAL_SAMPLES - 3 - 3 * (si / 2)) * IN_WIDTH)).trunc<IN_WIDTH>() as SInt<IN_WIDTH> < 2
          i_enc = 2;
        else
          i_enc = 3;
        end if
        if (Q >> ((TOTAL_SAMPLES - 3 - 3 * (si / 2)) * IN_WIDTH)).trunc<IN_WIDTH>() as SInt<IN_WIDTH> < (-2)
          q_enc = 0;
        elsif (Q >> ((TOTAL_SAMPLES - 3 - 3 * (si / 2)) * IN_WIDTH)).trunc<IN_WIDTH>() as SInt<IN_WIDTH> < 0
          q_enc = 1;
        elsif (Q >> ((TOTAL_SAMPLES - 3 - 3 * (si / 2)) * IN_WIDTH)).trunc<IN_WIDTH>() as SInt<IN_WIDTH> < 2
          q_enc = 2;
        else
          q_enc = 3;
        end if
      end if
      bits_out = bits_out | ({i_enc, q_enc}.zext<TOTAL_OUT_WIDTH>() << ((N - 1 - si) * OUT_WIDTH));
    end for
  end comb

  // Error detection: group gi, samples at 3*gi (map0), 3*gi+1 (interp), 3*gi+2 (map1)
  // Auto-widening: SInt<IN_WIDTH>+SInt<IN_WIDTH> = SInt<IN_WIDTH+1>
  // (two_interp) - (sum_maps) = SInt<IN_WIDTH+2>
  // Compare with 2*ERROR_THRESHOLD (no sext needed - comparison auto-promotes)
  comb
    err_out = 0;
    for gi in 0..NUM_GROUPS-1
      if ((I >> ((TOTAL_SAMPLES - 2 - 3 * gi) * IN_WIDTH)).trunc<IN_WIDTH>() as SInt<IN_WIDTH> +
          (I >> ((TOTAL_SAMPLES - 2 - 3 * gi) * IN_WIDTH)).trunc<IN_WIDTH>() as SInt<IN_WIDTH>) -
         ((I >> ((TOTAL_SAMPLES - 1 - 3 * gi) * IN_WIDTH)).trunc<IN_WIDTH>() as SInt<IN_WIDTH> +
          (I >> ((TOTAL_SAMPLES - 3 - 3 * gi) * IN_WIDTH)).trunc<IN_WIDTH>() as SInt<IN_WIDTH>) > (2 * ERROR_THRESHOLD)
        err_out = 1;
      elsif ((I >> ((TOTAL_SAMPLES - 2 - 3 * gi) * IN_WIDTH)).trunc<IN_WIDTH>() as SInt<IN_WIDTH> +
             (I >> ((TOTAL_SAMPLES - 2 - 3 * gi) * IN_WIDTH)).trunc<IN_WIDTH>() as SInt<IN_WIDTH>) -
            ((I >> ((TOTAL_SAMPLES - 1 - 3 * gi) * IN_WIDTH)).trunc<IN_WIDTH>() as SInt<IN_WIDTH> +
             (I >> ((TOTAL_SAMPLES - 3 - 3 * gi) * IN_WIDTH)).trunc<IN_WIDTH>() as SInt<IN_WIDTH>) < (-(2 * ERROR_THRESHOLD))
        err_out = 1;
      elsif ((Q >> ((TOTAL_SAMPLES - 2 - 3 * gi) * IN_WIDTH)).trunc<IN_WIDTH>() as SInt<IN_WIDTH> +
             (Q >> ((TOTAL_SAMPLES - 2 - 3 * gi) * IN_WIDTH)).trunc<IN_WIDTH>() as SInt<IN_WIDTH>) -
            ((Q >> ((TOTAL_SAMPLES - 1 - 3 * gi) * IN_WIDTH)).trunc<IN_WIDTH>() as SInt<IN_WIDTH> +
             (Q >> ((TOTAL_SAMPLES - 3 - 3 * gi) * IN_WIDTH)).trunc<IN_WIDTH>() as SInt<IN_WIDTH>) > (2 * ERROR_THRESHOLD)
        err_out = 1;
      elsif ((Q >> ((TOTAL_SAMPLES - 2 - 3 * gi) * IN_WIDTH)).trunc<IN_WIDTH>() as SInt<IN_WIDTH> +
             (Q >> ((TOTAL_SAMPLES - 2 - 3 * gi) * IN_WIDTH)).trunc<IN_WIDTH>() as SInt<IN_WIDTH>) -
            ((Q >> ((TOTAL_SAMPLES - 1 - 3 * gi) * IN_WIDTH)).trunc<IN_WIDTH>() as SInt<IN_WIDTH> +
             (Q >> ((TOTAL_SAMPLES - 3 - 3 * gi) * IN_WIDTH)).trunc<IN_WIDTH>() as SInt<IN_WIDTH>) < (-(2 * ERROR_THRESHOLD))
        err_out = 1;
      end if
    end for
  end comb

  let bits = bits_out;
  let error_flag = err_out;
end module qam16_demapper_interpolated
