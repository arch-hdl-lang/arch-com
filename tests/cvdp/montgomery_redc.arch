// Montgomery reduction: result = T * R^{-1} mod N
// Combinational implementation
module montgomery_redc
  param N:        const = 7;
  param R:        const = 8;
  param R_INVERSE: const = 1;
  local param NWIDTH: const = $clog2(N + 1);
  local param TWIDTH: const = $clog2(N * R);

  port T:      in  UInt<TWIDTH>;
  port result: out UInt<NWIDTH>;

  // N_PRIME = (R * R_INVERSE - 1) / N
  let n_prime_wide: UInt<32> = ((R.zext<32>() * R_INVERSE.zext<32>()) - 1.zext<32>()).trunc<32>() / N.zext<32>();

  // T_mod_R = T & (R-1) since R is a power of 2
  let r_mask:     UInt<32> = (R.zext<32>() - 1.zext<32>()).trunc<32>();
  let t_mod_r:    UInt<32> = T.zext<32>() & r_mask;

  // m = (T_mod_R * N_PRIME) mod R
  let t_x_np:     UInt<32> = (t_mod_r * n_prime_wide).trunc<32>();
  let m_wide:     UInt<32> = t_x_np & r_mask;

  // t_redc = (T + m * N) / R
  let m_x_n:      UInt<32> = (m_wide * N.zext<32>()).trunc<32>();
  let t_plus_mn:  UInt<32> = (T.zext<32>() + m_x_n).trunc<32>();

  // Divide by R (right shift by log2(R))
  let r_log2: UInt<5> =
    R == 4    ? 2 :
    R == 8    ? 3 :
    R == 16   ? 4 :
    R == 32   ? 5 :
    R == 64   ? 6 :
    R == 128  ? 7 :
    R == 256  ? 8 :
    R == 512  ? 9 :
    R == 1024 ? 10 :
              3;

  let t_redc_wide: UInt<32> = t_plus_mn >> r_log2;

  // Final reduction: if t_redc >= N, subtract N
  comb
    if t_redc_wide >= N.zext<32>()
      result = (t_redc_wide - N.zext<32>()).trunc<NWIDTH>();
    else
      result = t_redc_wide.trunc<NWIDTH>();
    end if
  end comb
end module montgomery_redc
