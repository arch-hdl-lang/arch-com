module halfband_fir
  param IW:    const = 16;
  param OW:    const = 32;
  param TW:    const = 12;
  param NTAPS: const = 7;

  port i_clk:    in Clock<SysDomain>;
  port i_reset:  in Reset<Sync, High>;
  port i_tap_wr: in Bool;
  port i_tap:    in UInt<12>;
  port i_ce:     in Bool;
  port i_sample: in SInt<16>;
  port o_ce:     out Bool;
  port o_result: out SInt<32>;

  default seq on i_clk rising;

  // Tap storage — write pointer increments on i_tap_wr
  reg tap0: SInt<12> reset i_reset=>0;
  reg tap1: SInt<12> reset i_reset=>0;
  reg tap2: SInt<12> reset i_reset=>0;
  reg tap3: SInt<12> reset i_reset=>0;
  reg tap4: SInt<12> reset i_reset=>0;
  reg tap5: SInt<12> reset i_reset=>0;
  reg tap6: SInt<12> reset i_reset=>0;
  reg tap_ptr: UInt<3> reset i_reset=>0;

  // Sample shift register
  reg sr0: SInt<16> reset i_reset=>0;
  reg sr1: SInt<16> reset i_reset=>0;
  reg sr2: SInt<16> reset i_reset=>0;
  reg sr3: SInt<16> reset i_reset=>0;
  reg sr4: SInt<16> reset i_reset=>0;
  reg sr5: SInt<16> reset i_reset=>0;
  reg sr6: SInt<16> reset i_reset=>0;

  reg result_r: SInt<32> reset i_reset=>0;
  reg ce_r:     Bool     reset i_reset=>false;

  // Extend both operands to 32 bits before multiply -> 64-bit product, trunc to 32
  let p0: SInt<32> = (tap0.sext<32>() * sr0.sext<32>()).trunc<32>();
  let p1: SInt<32> = (tap1.sext<32>() * sr1.sext<32>()).trunc<32>();
  let p2: SInt<32> = (tap2.sext<32>() * sr2.sext<32>()).trunc<32>();
  let p3: SInt<32> = (tap3.sext<32>() * sr3.sext<32>()).trunc<32>();
  let p4: SInt<32> = (tap4.sext<32>() * sr4.sext<32>()).trunc<32>();
  let p5: SInt<32> = (tap5.sext<32>() * sr5.sext<32>()).trunc<32>();
  let p6: SInt<32> = (tap6.sext<32>() * sr6.sext<32>()).trunc<32>();

  let sum01: SInt<32> = (p0 + p1).trunc<32>();
  let sum23: SInt<32> = (p2 + p3).trunc<32>();
  let sum45: SInt<32> = (p4 + p5).trunc<32>();
  let acc:   SInt<32> = ((sum01 + sum23).trunc<32>() + (sum45 + p6).trunc<32>()).trunc<32>();

  comb
    o_result = result_r;
    o_ce     = ce_r;
  end comb

  seq
    ce_r <= i_ce;
    if i_tap_wr
      if tap_ptr == 0
        tap0 <= i_tap as SInt<12>;
      elsif tap_ptr == 1
        tap1 <= i_tap as SInt<12>;
      elsif tap_ptr == 2
        tap2 <= i_tap as SInt<12>;
      elsif tap_ptr == 3
        tap3 <= i_tap as SInt<12>;
      elsif tap_ptr == 4
        tap4 <= i_tap as SInt<12>;
      elsif tap_ptr == 5
        tap5 <= i_tap as SInt<12>;
      else
        tap6 <= i_tap as SInt<12>;
      end if
      tap_ptr <= (tap_ptr + 1).trunc<3>();
    end if
    if i_ce
      sr0 <= i_sample;
      sr1 <= sr0;
      sr2 <= sr1;
      sr3 <= sr2;
      sr4 <= sr3;
      sr5 <= sr4;
      sr6 <= sr5;
      result_r <= acc;
    end if
  end seq
end module halfband_fir
