module password_generator
  param WIDTH: const = 4;
  port clk: in Clock<SysDomain>;
  port reset: in Reset<Async>;
  port password: out pipe_reg<UInt<WIDTH * 8>, 1> reset reset=>0;

  default seq on clk rising;

  reg cnt: UInt<8> reset reset=>0;
  reg char_array: Vec<UInt<8>, WIDTH> reset reset=>0;

  seq
    cnt <= (cnt + 1).trunc<8>();
  end seq

  seq
    for i in 0..WIDTH-1
      if i % 4 == 0
        char_array[i] <= ((cnt.zext<32>() + char_array[(i + 1) % WIDTH].zext<32>()) % 26 + 97).trunc<8>();
        password[i * 8 + 7 : i * 8] <= ((cnt.zext<32>() + char_array[(i + 1) % WIDTH].zext<32>()) % 26 + 97).trunc<8>();
      elsif i % 4 == 1
        char_array[i] <= ((cnt.zext<32>() + i) % 26 + 65).trunc<8>();
        password[i * 8 + 7 : i * 8] <= ((cnt.zext<32>() + i) % 26 + 65).trunc<8>();
      elsif i % 4 == 2
        char_array[i] <= ((cnt.zext<32>() + char_array[(i + WIDTH - 1) % WIDTH].zext<32>()) % 14 + 33).trunc<8>();
        password[i * 8 + 7 : i * 8] <= ((cnt.zext<32>() + char_array[(i + WIDTH - 1) % WIDTH].zext<32>()) % 14 + 33).trunc<8>();
      else
        char_array[i] <= ((cnt.zext<32>() + i) % 10 + 48).trunc<8>();
        password[i * 8 + 7 : i * 8] <= ((cnt.zext<32>() + i) % 10 + 48).trunc<8>();
      end if
    end for
  end seq
end module password_generator
