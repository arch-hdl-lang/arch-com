module gcd_top
  param WIDTH: const = 4;
  port clk:  in Clock<SysDomain>;
  port rst:  in Reset<Sync>;
  port A:    in UInt<WIDTH>;
  port B:    in UInt<WIDTH>;
  port go:   in Bool;
  port OUT:  out UInt<WIDTH>;
  port done: out Bool;

  wire cp_state: UInt<2>;
  wire eq: Bool;
  wire gt: Bool;

  inst u_ctrl: gcd_controlpath
    param WIDTH = WIDTH;
    clk <- clk;
    rst <- rst;
    go <- go;
    equal <- eq;
    greater_than <- gt;
    controlpath_state -> cp_state;
    done -> done;
  end inst u_ctrl

  inst u_dp: gcd_datapath
    param WIDTH = WIDTH;
    clk <- clk;
    rst <- rst;
    A <- A;
    B <- B;
    controlpath_state <- cp_state;
    OUT -> OUT;
    equal -> eq;
    greater_than -> gt;
  end inst u_dp
end module gcd_top
