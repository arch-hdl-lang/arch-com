module SR_flipflop
  port i_clk: in Clock<SysDomain>;
  port i_rst_b: in Reset<Async, Low>;
  port i_S: in Bool;
  port i_R: in Bool;
  port o_Q: out Bool;
  port o_Q_b: out Bool;

  reg q: Bool reset i_rst_b => 0;
  reg q_b: Bool reset i_rst_b => 1;

  let o_Q = q;
  let o_Q_b = q_b;

  seq on i_clk rising
    if i_S & i_R
      q <= 0;
      q_b <= 0;
    elsif i_S
      q <= 1;
      q_b <= 0;
    elsif i_R
      q <= 0;
      q_b <= 1;
    end if
  end seq
end module SR_flipflop
