module pseudo_lru_nmru_policy
  param NWAYS: const = 4;
  param NINDEXES: const = 32;

  port clock:      in Clock<SysDomain>;
  port reset:      in Reset<Async>;
  port index:      in UInt<$clog2(NINDEXES)>;
  port way_select: in UInt<$clog2(NWAYS)>;
  port access:     in Bool;
  port hit:        in Bool;
  port way_replace: out UInt<$clog2(NWAYS)>;

  default seq on clock rising;

  reg recency: Vec<UInt<NWAYS>, NINDEXES> reset reset=>0;

  wire replace_way: UInt<$clog2(NWAYS)>;
  wire only_one_zero: Bool;
  wire cur_recency: UInt<NWAYS>;
  wire zero_count: UInt<$clog2(NWAYS)+1>;

  let idx: UInt<$clog2(NINDEXES)> = index;

  comb
    cur_recency = recency[idx];

    // Count zeros
    zero_count = 0;
    for i in 0..NWAYS-1
      if ~cur_recency[i]
        zero_count = (zero_count + 1).trunc<$clog2(NWAYS)+1>();
      end if
    end for

    only_one_zero = (zero_count == 1);

    // Find lowest-index zero bit (iterate from high to low, last write wins = lowest)
    replace_way = 0;
    for i in 0..NWAYS-1
      if ~cur_recency[NWAYS - 1 - i]
        replace_way = (NWAYS - 1 - i).trunc<$clog2(NWAYS)>();
      end if
    end for
  end comb

  comb way_replace = replace_way;

  seq
    if access & hit
      // On a hit: set the way_select recency bit
      if only_one_zero
        // LRU case: set way_select bit, clear all others
        recency[idx] <= (1.zext<NWAYS>() << way_select);
      else
        recency[idx] <= recency[idx] | (1.zext<NWAYS>() << way_select);
      end if
    elsif access & ~hit
      // On a miss: set the replace_way recency bit (replacement happened)
      if only_one_zero
        recency[idx] <= (1.zext<NWAYS>() << replace_way);
      else
        recency[idx] <= recency[idx] | (1.zext<NWAYS>() << replace_way);
      end if
    end if
  end seq

end module pseudo_lru_nmru_policy
