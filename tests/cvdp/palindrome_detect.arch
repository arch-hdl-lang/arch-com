module palindrome_detect
  param N: const = 3;
  port clk: in Clock<SysDomain>;
  port reset: in Reset<Sync, High>;
  port bit_stream: in Bool;
  port palindrome_detected: out Bool;

  reg sr: UInt<3> reset reset => 0;

  wire sr_next: UInt<3>;

  comb
    sr_next = (sr[1:0] << 1) | bit_stream.zext<3>();
  end comb

  seq on clk rising
    sr <= sr_next;
  end seq

  let palindrome_detected = sr[2:2] == sr[0:0];
end module palindrome_detect
