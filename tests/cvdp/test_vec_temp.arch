module test_vec_temp
  param IN_WIDTH: const = 3;
  param T: const = 1;
  param NG: const = 4;

  port x: in UInt<NG * IN_WIDTH>;
  port y: out UInt<1>;

  wire a: Vec<SInt<IN_WIDTH+1>, NG>;
  wire b: Vec<SInt<IN_WIDTH+2>, NG>;
  wire result: Vec<UInt<1>, NG>;

  comb
    for i in 0..NG-1
      a[i] = 0;
      b[i] = 0;
    end for
    for i in 0..NG-1
      if (a[i] - b[i]) > (2 * T)
        result[i] = 1;
      elsif (a[i] - b[i]) < (-(2 * T))
        result[i] = 1;
      else
        result[i] = 0;
      end if
    end for
    y = result[0];
  end comb
end module test_vec_temp
