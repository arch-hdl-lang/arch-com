module adc_data_rotate
  param DATA_WIDTH: const = 8;
  port i_clk: in Clock<SysDomain>;
  port i_rst_n: in Reset<Async, Low>;
  port i_adc_data_in: in UInt<DATA_WIDTH>;
  port i_shift_count: in UInt<4>;
  port i_shift_direction: in Bool;
  port o_processed_data: out pipe_reg<UInt<DATA_WIDTH>, 1> reset i_rst_n=>0;
  port o_operation_status: out pipe_reg<Bool, 1> reset i_rst_n=>false;

  default seq on i_clk rising;

  // Modulo DATA_WIDTH for shift amount
  let mod_shift: UInt<4> = (i_shift_count.zext<32>() % DATA_WIDTH).trunc<4>();
  let rev_shift: UInt<4> = (DATA_WIDTH - mod_shift.zext<32>()).trunc<4>();

  seq
    o_operation_status <= true;
    if i_shift_direction
      // Right rotate
      o_processed_data <= (i_adc_data_in >> mod_shift) | (i_adc_data_in << rev_shift);
    else
      // Left rotate
      o_processed_data <= (i_adc_data_in << mod_shift) | (i_adc_data_in >> rev_shift);
    end if
  end seq
end module adc_data_rotate
