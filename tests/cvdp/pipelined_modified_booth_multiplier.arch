module pipelined_modified_booth_multiplier
  port clk:    in Clock<SysDomain>;
  port rst:    in Reset<Async, High>;
  port start:  in Bool;
  port X:      in SInt<16>;
  port Y:      in SInt<16>;
  port result: out SInt<32>;
  port done:   out Bool;

  default seq on clk rising;
  reg default: reset rst => 0;

  // Stage 1: latch inputs
  reg s1_x: SInt<16>;
  reg s1_y: SInt<16>;
  reg s1_v: Bool;

  // Stage 2: compute product
  reg s2_prod: SInt<32>;
  reg s2_v:    Bool;

  // Stage 3: pass through
  reg s3_prod: SInt<32>;
  reg s3_v:    Bool;

  // Stage 4: pass through
  reg s4_prod: SInt<32>;
  reg s4_v:    Bool;

  // Stage 5: output
  reg s5_prod: SInt<32>;
  reg s5_v:    Bool;

  // Multiply in combinational logic from stage 1 regs
  let prod: SInt<32> = s1_x * s1_y;

  comb
    result = s5_prod;
    done   = s5_v;
  end comb

  seq
    // Stage 1: latch inputs
    s1_x <= X;
    s1_y <= Y;
    s1_v <= start;

    // Stage 2: multiply
    s2_prod <= prod;
    s2_v    <= s1_v;

    // Stage 3: pass
    s3_prod <= s2_prod;
    s3_v    <= s2_v;

    // Stage 4: pass
    s4_prod <= s3_prod;
    s4_v    <= s3_v;

    // Stage 5: pass
    s5_prod <= s4_prod;
    s5_v    <= s4_v;
  end seq
end module pipelined_modified_booth_multiplier
