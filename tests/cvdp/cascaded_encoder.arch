module cascaded_encoder
  param N: const = 8;
  param M: const = 3;
  param HALF: const = N / 2;
  port input_signal: in UInt<N>;
  port out: out UInt<M>;
  port out_upper_half: out UInt<M-1>;
  port out_lower_half: out UInt<M-1>;

  wire upper_out: UInt<M-1>;
  wire lower_out: UInt<M-1>;
  wire upper_active: Bool;

  inst upper_enc: priority_encoder
    param N = HALF;
    param M = M - 1;
    input_signal <- input_signal[N-1:HALF];
    out -> upper_out;
  end inst upper_enc

  inst lower_enc: priority_encoder
    param N = HALF;
    param M = M - 1;
    input_signal <- input_signal[HALF-1:0];
    out -> lower_out;
  end inst lower_enc

  let out_upper_half = upper_out;
  let out_lower_half = lower_out;

  let upper_active = input_signal[N-1:HALF] != 0;

  comb
    if upper_active
      out = {true, upper_out};
    else
      out = {false, lower_out};
    end if
  end comb
end module cascaded_encoder
