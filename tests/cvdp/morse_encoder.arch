module morse_encoder
  port ascii_in: in UInt<8>;
  port morse_out: out UInt<10>;
  port morse_length: out UInt<4>;

  wire code: UInt<10>;
  wire len: UInt<4>;

  comb
    if ascii_in == 65
      code = 0b01;
      len = 2;
    elsif ascii_in == 66
      code = 0b1000;
      len = 4;
    elsif ascii_in == 67
      code = 0b1010;
      len = 4;
    elsif ascii_in == 68
      code = 0b100;
      len = 3;
    elsif ascii_in == 69
      code = 0b0;
      len = 1;
    elsif ascii_in == 70
      code = 0b0010;
      len = 4;
    elsif ascii_in == 71
      code = 0b110;
      len = 3;
    elsif ascii_in == 72
      code = 0b0000;
      len = 4;
    elsif ascii_in == 73
      code = 0b00;
      len = 2;
    elsif ascii_in == 74
      code = 0b0111;
      len = 4;
    elsif ascii_in == 75
      code = 0b101;
      len = 3;
    elsif ascii_in == 76
      code = 0b0100;
      len = 4;
    elsif ascii_in == 77
      code = 0b11;
      len = 2;
    elsif ascii_in == 78
      code = 0b10;
      len = 2;
    elsif ascii_in == 79
      code = 0b111;
      len = 3;
    elsif ascii_in == 80
      code = 0b0110;
      len = 4;
    elsif ascii_in == 81
      code = 0b1101;
      len = 4;
    elsif ascii_in == 82
      code = 0b010;
      len = 3;
    elsif ascii_in == 83
      code = 0b000;
      len = 3;
    elsif ascii_in == 84
      code = 0b1;
      len = 1;
    elsif ascii_in == 85
      code = 0b001;
      len = 3;
    elsif ascii_in == 86
      code = 0b0001;
      len = 4;
    elsif ascii_in == 87
      code = 0b011;
      len = 3;
    elsif ascii_in == 88
      code = 0b1001;
      len = 4;
    elsif ascii_in == 89
      code = 0b1011;
      len = 4;
    elsif ascii_in == 90
      code = 0b1100;
      len = 4;
    elsif ascii_in == 48
      code = 0b11111;
      len = 5;
    elsif ascii_in == 49
      code = 0b01111;
      len = 5;
    elsif ascii_in == 50
      code = 0b00111;
      len = 5;
    elsif ascii_in == 51
      code = 0b00011;
      len = 5;
    elsif ascii_in == 52
      code = 0b00001;
      len = 5;
    elsif ascii_in == 53
      code = 0b00000;
      len = 5;
    elsif ascii_in == 54
      code = 0b10000;
      len = 5;
    elsif ascii_in == 55
      code = 0b11000;
      len = 5;
    elsif ascii_in == 56
      code = 0b11100;
      len = 5;
    elsif ascii_in == 57
      code = 0b11110;
      len = 5;
    else
      code = 0;
      len = 0;
    end if
    morse_out = code;
    morse_length = len;
  end comb
end module morse_encoder
