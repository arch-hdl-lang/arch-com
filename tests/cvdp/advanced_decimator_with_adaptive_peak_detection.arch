module advanced_decimator_with_adaptive_peak_detection
  param N: const = 8;
  param DATA_WIDTH: const = 16;
  param DEC_FACTOR: const = 4;
  local param NUM_OUT: const = N / DEC_FACTOR;

  port clk: in Clock<SysDomain>;
  port reset: in Reset<Async, High>;
  port valid_in: in UInt<1>;
  port data_in: in UInt<N * DATA_WIDTH>;
  port valid_out: out UInt<1>;
  port data_out: out UInt<NUM_OUT * DATA_WIDTH>;
  port peak_value: out SInt<DATA_WIDTH>;

  // Registered inputs
  reg data_in_reg: UInt<N * DATA_WIDTH> reset reset => 0;
  reg valid_in_reg: UInt<1> reset reset => 0;

  // data_vec_in as Vec for debug access (dut.data_vec_in[i])
  // MSB-first: element i at shift (N-1-i)*DATA_WIDTH
  wire data_vec_in: Vec<SInt<DATA_WIDTH>, N>;

  // Scalar accumulators to avoid packed-2D-array iverilog bugs
  // data_out_acc: running packed output accumulator
  // peak_acc: running max value (signed)
  wire data_out_acc: UInt<NUM_OUT * DATA_WIDTH>;
  wire peak_cur: SInt<DATA_WIDTH>;

  default seq on clk rising;

  seq on clk rising
    data_in_reg <= data_in;
    valid_in_reg <= valid_in;
  end seq

  // Unpack registered data MSB-first: element i at shift (N-1-i)*DATA_WIDTH
  // pack_signal packs values[0] at MSB: values[i] at shift (N-1-i)*DATA_WIDTH
  comb
    for i in 0..N-1
      data_vec_in[i] = (data_in_reg >> ((N - 1 - i) * DATA_WIDTH)).trunc<DATA_WIDTH>() as SInt<DATA_WIDTH>;
    end for
  end comb

  // Decimate and pack output (MSB-first) and compute peak - scalar accumulators
  // dec_vec[j] = data_vec_in[DEC_FACTOR-1 + j*DEC_FACTOR] = sample at index DEC_FACTOR-1+j*DEC_FACTOR
  // = (data_in_reg >> ((N - 1 - (DEC_FACTOR-1 + j*DEC_FACTOR)) * DATA_WIDTH)).trunc...
  // = (data_in_reg >> ((N - DEC_FACTOR - j*DEC_FACTOR) * DATA_WIDTH)).trunc...
  // Output packing MSB-first: dec_vec[0] at bits[(NUM_OUT-1)*DW +: DW], dec_vec[j] at (NUM_OUT-1-j)*DW
  comb
    data_out_acc = 0;
    peak_cur = (data_in_reg >> ((N - DEC_FACTOR) * DATA_WIDTH)).trunc<DATA_WIDTH>() as SInt<DATA_WIDTH>;
    for j in 0..NUM_OUT-1
      data_out_acc = data_out_acc | ((data_in_reg >> ((N - DEC_FACTOR - j * DEC_FACTOR) * DATA_WIDTH)).trunc<DATA_WIDTH>().zext<NUM_OUT * DATA_WIDTH>() << ((NUM_OUT - 1 - j) * DATA_WIDTH));
      if (data_in_reg >> ((N - DEC_FACTOR - j * DEC_FACTOR) * DATA_WIDTH)).trunc<DATA_WIDTH>() as SInt<DATA_WIDTH> > peak_cur
        peak_cur = (data_in_reg >> ((N - DEC_FACTOR - j * DEC_FACTOR) * DATA_WIDTH)).trunc<DATA_WIDTH>() as SInt<DATA_WIDTH>;
      end if
    end for
  end comb

  let valid_out = valid_in_reg;
  let data_out = data_out_acc;
  let peak_value = peak_cur;
end module advanced_decimator_with_adaptive_peak_detection
