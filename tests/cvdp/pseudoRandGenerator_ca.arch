module pseudoRandGenerator_ca
  port clock: in Clock<SysDomain>;
  port reset: in Reset<Sync, High>;
  port CA_seed: in UInt<16>;
  port CA_out: out UInt<16>;

  // state has no auto-reset; we handle reset manually in seq
  reg state: UInt<16> reset none;

  // Rule 90: next[i] = state[i-1] ^ state[i+1]
  // Rule 150: next[i] = state[i-1] ^ state[i] ^ state[i+1]
  // rule_mask bit i=1 means Rule 150, bit i=0 means Rule 90
  // Using alternating pattern for good randomness
  let rule_mask: UInt<16> = 0xAAAA;

  wire next_state: UInt<16>;
  wire left_shifted: UInt<16>;
  wire right_shifted: UInt<16>;
  wire r90: UInt<16>;
  wire state_shifted_left: UInt<17>;

  comb
    // left_shifted[i] = state[i-1], with wrap: state[-1] = state[15]
    left_shifted = (state >> 1) | state[15:15].zext<16>() << 15;
    // right_shifted[i] = state[i+1], with wrap: state[16] = state[0]
    state_shifted_left = state.zext<17>() << 1;
    right_shifted = state_shifted_left[15:0] | state[0:0].zext<16>();
    // Rule 90 base: left XOR right
    r90 = left_shifted ^ right_shifted;
    // Apply Rule 150 where rule_mask bit is 1: XOR in current state bit
    next_state = r90 ^ (state & rule_mask);
    CA_out = state;
  end comb

  seq on clock rising
    if reset
      state <= CA_seed;
    else
      state <= next_state;
    end if
  end seq
end module pseudoRandGenerator_ca
