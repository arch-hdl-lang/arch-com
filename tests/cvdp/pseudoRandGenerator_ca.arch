module pseudoRandGenerator_ca
  port clock: in Clock<SysDomain>;
  port reset: in Reset<Sync>;
  port CA_seed: in UInt<16>;
  port reg CA_out: out UInt<16> reset reset=>0;

  default seq on clock rising;

  // Rule pattern: R90-R90-R150-R90-R150-R90-R150-R90-R150-R90-R150-R90-R150-R90-R150-R90
  // Bit 15: R90, Bit 14: R90, Bit 13: R150, Bit 12: R90, ...
  // R90:  next[i] = left ^ right
  // R150: next[i] = left ^ self ^ right
  // Boundary: neighbors outside 0..15 treated as 0

  wire next_ca: UInt<16>;
  comb
    // Bit 15 (R90): left=0, right=CA_out[14]
    next_ca[15:15] = CA_out[14:14];
    // Bit 14 (R90): left=CA_out[15], right=CA_out[13]
    next_ca[14:14] = CA_out[15:15] ^ CA_out[13:13];
    // Bit 13 (R150): left=CA_out[14], self=CA_out[13], right=CA_out[12]
    next_ca[13:13] = CA_out[14:14] ^ CA_out[13:13] ^ CA_out[12:12];
    // Bit 12 (R90)
    next_ca[12:12] = CA_out[13:13] ^ CA_out[11:11];
    // Bit 11 (R150)
    next_ca[11:11] = CA_out[12:12] ^ CA_out[11:11] ^ CA_out[10:10];
    // Bit 10 (R90)
    next_ca[10:10] = CA_out[11:11] ^ CA_out[9:9];
    // Bit 9 (R150)
    next_ca[9:9] = CA_out[10:10] ^ CA_out[9:9] ^ CA_out[8:8];
    // Bit 8 (R90)
    next_ca[8:8] = CA_out[9:9] ^ CA_out[7:7];
    // Bit 7 (R150)
    next_ca[7:7] = CA_out[8:8] ^ CA_out[7:7] ^ CA_out[6:6];
    // Bit 6 (R90)
    next_ca[6:6] = CA_out[7:7] ^ CA_out[5:5];
    // Bit 5 (R150)
    next_ca[5:5] = CA_out[6:6] ^ CA_out[5:5] ^ CA_out[4:4];
    // Bit 4 (R90)
    next_ca[4:4] = CA_out[5:5] ^ CA_out[3:3];
    // Bit 3 (R150)
    next_ca[3:3] = CA_out[4:4] ^ CA_out[3:3] ^ CA_out[2:2];
    // Bit 2 (R90)
    next_ca[2:2] = CA_out[3:3] ^ CA_out[1:1];
    // Bit 1 (R150)
    next_ca[1:1] = CA_out[2:2] ^ CA_out[1:1] ^ CA_out[0:0];
    // Bit 0 (R90): left=CA_out[1], right=0
    next_ca[0:0] = CA_out[1:1];
  end comb

  seq
    CA_out <= next_ca;
  end seq
end module pseudoRandGenerator_ca
