module FILO_RTL
  param DATA_WIDTH: const = 8;
  param FILO_DEPTH: const = 16;

  port clk:   in Clock<SysDomain>;
  port reset: in Reset<Async>;
  port push:  in Bool;
  port pop:   in Bool;
  port data_in: in UInt<DATA_WIDTH>;
  port reg data_out: out UInt<DATA_WIDTH> reset reset=>0;
  port reg full:     out Bool reset reset=>0;
  port reg empty:    out Bool reset reset=>1;

  default seq on clk rising;

  reg top: UInt<32> reset reset=>0;
  reg buffer: Vec<UInt<DATA_WIDTH>, FILO_DEPTH> reset reset=>0;

  seq
    if push & ~pop & ~full
      buffer[top] <= data_in;
      top <= (top + 1).trunc<32>();
      empty <= false;
      if (top + 1).trunc<32>() == FILO_DEPTH.trunc<32>()
        full <= true;
      end if
    elsif pop & ~push & ~empty
      top <= (top - 1).trunc<32>();
      data_out <= buffer[(top - 1).trunc<32>()];
      full <= false;
      if (top - 1).trunc<32>() == 0
        empty <= true;
      end if
    elsif push & pop & empty
      data_out <= data_in;
    end if
  end seq

end module FILO_RTL
