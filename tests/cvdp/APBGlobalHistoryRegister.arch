module APBGlobalHistoryRegister
  port pclk:    in Clock<SysDomain>;
  port presetn: in Reset<Async, Low>;
  port paddr:   in UInt<10>;
  port pselx:   in Bool;
  port penable: in Bool;
  port pwrite:  in Bool;
  port pwdata:  in UInt<8>;
  port reg pready:  out Bool reset presetn=>false;
  port reg prdata:  out UInt<8> reset presetn=>0;
  port reg pslverr: out Bool reset presetn=>false;
  port history_shift_valid: in Bool;
  port clk_gate_en: in Bool;
  port history_full:    out Bool;
  port history_empty:   out Bool;
  port error_flag:      out Bool;
  port interrupt_full:  out Bool;
  port interrupt_error: out Bool;

  // Internal clock gating latch
  reg clk_gate_latch: Bool init false;
  wire pclk_gated_en: Bool;

  seq on pclk falling
    clk_gate_latch <= clk_gate_en;
  end seq

  let pclk_gated_en = ~clk_gate_latch;

  // CSR registers
  reg control_reg: UInt<8> reset presetn=>0;
  reg train_hist:  UInt<8> reset presetn=>0;
  reg predict_hist: UInt<8> reset presetn=>0;

  // APB interface - pready always high (no wait states)
  seq on pclk rising
    if pclk_gated_en
      pready <= true;
      if pselx & penable
        if paddr == 0
          if pwrite
            control_reg <= pwdata;
          end if
          prdata <= control_reg;
          pslverr <= false;
        elsif paddr == 1
          if pwrite
            train_hist <= {1'b0, pwdata[6:0]};
          end if
          prdata <= train_hist;
          pslverr <= false;
        elsif paddr == 2
          prdata <= predict_hist;
          pslverr <= false;
        else
          pslverr <= true;
          prdata <= 0;
        end if
      end if
    end if
  end seq

  // Decode control register fields
  wire ctrl_predict_valid: Bool;
  wire ctrl_predict_taken: Bool;
  wire ctrl_train_mispredicted: Bool;
  wire ctrl_train_taken: Bool;

  comb
    ctrl_predict_valid = (control_reg[0:0] == 1);
    ctrl_predict_taken = (control_reg[1:1] == 1);
    ctrl_train_mispredicted = (control_reg[2:2] == 1);
    ctrl_train_taken = (control_reg[3:3] == 1);
  end comb

  // Predict history update on rising edge of history_shift_valid
  seq on history_shift_valid rising
    if ctrl_train_mispredicted
      predict_hist <= {train_hist[6:0], ctrl_train_taken};
    elsif ctrl_predict_valid
      predict_hist <= {predict_hist[6:0], ctrl_predict_taken};
    end if
  end seq

  // Status outputs
  comb
    history_full  = (predict_hist == 8'hFF);
    history_empty = (predict_hist == 0);
    error_flag    = pslverr;
    interrupt_full  = (predict_hist == 8'hFF);
    interrupt_error = pslverr;
  end comb

end module APBGlobalHistoryRegister
