module data_bus_controller
  param AFINITY: const = 0;

  port clk:   in Clock<SysDomain>;
  port rst_n:  in Reset<Async, Low>;

  port m0_ready: out Bool;
  port m0_valid: in Bool;
  port m0_data:  in UInt<32>;

  port m1_ready: out Bool;
  port m1_valid: in Bool;
  port m1_data:  in UInt<32>;

  port s_ready:  in Bool;
  port s_valid: out pipe_reg<Bool, 1> reset rst_n=>false;
  port s_data: out pipe_reg<UInt<32>, 1> reset rst_n=>0;

  default seq on clk rising;

  comb
    m0_ready = s_ready;
    m1_ready = s_ready;
  end comb

  seq
    if m0_valid & m1_valid
      if AFINITY == 0
        s_valid <= true;
        s_data  <= m0_data;
      else
        s_valid <= true;
        s_data  <= m1_data;
      end if
    elsif m0_valid
      s_valid <= true;
      s_data  <= m0_data;
    elsif m1_valid
      s_valid <= true;
      s_data  <= m1_data;
    else
      s_valid <= false;
    end if
  end seq
end module data_bus_controller
