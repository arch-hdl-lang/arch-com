module nff
  port d_in:    in Bit;
  port dst_clk: in Clock<SysDomain>;
  port rst:     in Reset<Async, Low>;
  port syncd: out pipe_reg<Bit, 1> reset rst=>0;

  reg ff1: Bit reset rst=>0;

  default seq on dst_clk rising;

  seq
    ff1 <= d_in;
  end seq

  seq
    syncd <= ff1;
  end seq
end module nff
