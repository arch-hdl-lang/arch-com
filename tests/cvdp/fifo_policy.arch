module fifo_policy
  param NWAYS: const = 4;
  param NINDEXES: const = 32;
  param WAY_W: const = $clog2(NWAYS);

  port clock: in Clock<SysDomain>;
  port reset: in Reset<Async, High>;
  port index: in UInt<$clog2(NINDEXES)>;
  port way_select: in UInt<WAY_W>;
  port access: in Bool;
  port hit: in Bool;
  port way_replace: out UInt<WAY_W>;

  default seq on clock rising;

  reg fifo_array: Vec<UInt<WAY_W>, NINDEXES> reset reset => 0;

  wire cur_val: UInt<WAY_W>;
  wire next_val: UInt<WAY_W>;

  let idx: UInt<$clog2(NINDEXES)> = index;

  comb
    cur_val = fifo_array[idx];
    way_replace = cur_val;
    if cur_val == (NWAYS - 1).trunc<WAY_W>()
      next_val = 0;
    else
      next_val = (cur_val + 1).trunc<WAY_W>();
    end if
  end comb

  seq
    if access & ~hit
      fifo_array[idx] <= next_val;
    end if
  end seq
end module fifo_policy
