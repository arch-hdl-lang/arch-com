fsm fsm_seq_detector
  port clk_in: in Clock<SysDomain>;
  port rst_in: in Reset<Async, High>;
  port seq_in: in Bool;
  port seq_detected: out Bool;

  state [S0, S1, S2, S3, S4, S5, S6, S7, S8]
  default state S0;
  default
    let seq_detected = false;
  end default

  state S0
    -> S1 when seq_in;
  end state S0

  state S1
    -> S2 when ~seq_in;
    -> S1 when seq_in;
  end state S1

  state S2
    -> S3 when seq_in;
    -> S0 when ~seq_in;
  end state S2

  state S3
    -> S4 when seq_in;
    -> S2 when ~seq_in;
  end state S3

  state S4
    -> S5 when ~seq_in;
    -> S1 when seq_in;
  end state S4

  state S5
    -> S3 when seq_in;
    -> S6 when ~seq_in;
  end state S5

  state S6
    -> S1 when seq_in;
    -> S7 when ~seq_in;
  end state S6

  state S7
    -> S8 when seq_in;
    -> S0 when ~seq_in;
  end state S7

  state S8
    let seq_detected = true;
    -> S1 when seq_in;
    -> S2 when ~seq_in;
  end state S8

end fsm fsm_seq_detector
