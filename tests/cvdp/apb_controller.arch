fsm apb_controller
  port clk:          in Clock<SysDomain>;
  port reset_n:      in Reset<Async, Low>;
  port select_a_i:   in Bool;
  port select_b_i:   in Bool;
  port select_c_i:   in Bool;
  port addr_a_i:     in UInt<32>;
  port data_a_i:     in UInt<32>;
  port addr_b_i:     in UInt<32>;
  port data_b_i:     in UInt<32>;
  port addr_c_i:     in UInt<32>;
  port data_c_i:     in UInt<32>;
  port apb_pready_i: in Bool;
  port apb_psel_o:    out Bool;
  port apb_penable_o: out Bool;
  port apb_pwrite_o:  out Bool;
  port apb_paddr_o:   out UInt<32>;
  port apb_pwdata_o:  out UInt<32>;

  state [Idle, Setup, Access]
  default state Idle;

  reg r_psel:    Bool reset reset_n => false;
  reg r_penable: Bool reset reset_n => false;
  reg r_pwrite:  Bool reset reset_n => false;
  reg r_paddr:   UInt<32> reset reset_n => 0;
  reg r_pwdata:  UInt<32> reset reset_n => 0;
  reg timeout_cnt: UInt<4> reset reset_n => 0;

  default
    comb
      apb_psel_o    = r_psel;
      apb_penable_o = r_penable;
      apb_pwrite_o  = r_pwrite;
      apb_paddr_o   = r_paddr;
      apb_pwdata_o  = r_pwdata;
    end comb
  end default

  state Idle
    seq on clk rising
      if select_a_i
        r_psel   <= true;
        r_pwrite <= true;
        r_paddr  <= addr_a_i;
        r_pwdata <= data_a_i;
        r_penable <= false;
      elsif select_b_i
        r_psel   <= true;
        r_pwrite <= true;
        r_paddr  <= addr_b_i;
        r_pwdata <= data_b_i;
        r_penable <= false;
      elsif select_c_i
        r_psel   <= true;
        r_pwrite <= true;
        r_paddr  <= addr_c_i;
        r_pwdata <= data_c_i;
        r_penable <= false;
      else
        r_psel    <= false;
        r_penable <= false;
        r_pwrite  <= false;
        r_paddr   <= 0;
        r_pwdata  <= 0;
      end if
      timeout_cnt <= 0;
    end seq
    -> Setup when select_a_i | select_b_i | select_c_i;
  end state Idle

  state Setup
    seq on clk rising
      r_penable <= true;
    end seq
    -> Access;
  end state Setup

  state Access
    seq on clk rising
      if apb_pready_i
        r_psel    <= false;
        r_penable <= false;
        r_pwrite  <= false;
        r_paddr   <= 0;
        r_pwdata  <= 0;
        timeout_cnt <= 0;
      elsif timeout_cnt == 15
        r_psel    <= false;
        r_penable <= false;
        r_pwrite  <= false;
        r_paddr   <= 0;
        r_pwdata  <= 0;
        timeout_cnt <= 0;
      else
        timeout_cnt <= (timeout_cnt + 1).trunc<4>();
      end if
    end seq
    -> Idle when apb_pready_i | (timeout_cnt == 15);
  end state Access
end fsm apb_controller
