module axi_tap
  param ADDR_WIDTH: const = 32;
  param DATA_WIDTH: const = 32;

  // Global ports
  port clk_i: in Clock<SysDomain>;
  port rst_i: in Reset<Sync>;

  // Master inport - Write Address Channel (AW)
  port inport_awvalid_i: in Bool;
  port inport_awaddr_i:  in UInt<ADDR_WIDTH>;
  port inport_awready_o: out Bool;

  // Master inport - Write Data Channel (W)
  port inport_wvalid_i: in Bool;
  port inport_wdata_i:  in UInt<DATA_WIDTH>;
  port inport_wstrb_i:  in UInt<4>;
  port inport_wready_o: out Bool;

  // Master inport - Write Response Channel (B)
  port inport_bready_i: in Bool;
  port inport_bvalid_o: out Bool;
  port inport_bresp_o:  out UInt<2>;

  // Master inport - Read Address Channel (AR)
  port inport_arvalid_i: in Bool;
  port inport_araddr_i:  in UInt<ADDR_WIDTH>;
  port inport_arready_o: out Bool;

  // Master inport - Read Data Channel (R)
  port inport_rready_i: in Bool;
  port inport_rvalid_o: out Bool;
  port inport_rdata_o:  out UInt<DATA_WIDTH>;
  port inport_rresp_o:  out UInt<2>;

  // Default outport - Write Address Channel (AW)
  port outport_awready_i: in Bool;
  port outport_awvalid_o: out Bool;
  port outport_awaddr_o:  out UInt<ADDR_WIDTH>;

  // Default outport - Write Data Channel (W)
  port outport_wready_i: in Bool;
  port outport_wvalid_o: out Bool;
  port outport_wdata_o:  out UInt<DATA_WIDTH>;
  port outport_wstrb_o:  out UInt<4>;

  // Default outport - Write Response Channel (B)
  port outport_bvalid_i: in Bool;
  port outport_bresp_i:  in UInt<2>;
  port outport_bready_o: out Bool;

  // Default outport - Read Address Channel (AR)
  port outport_arready_i: in Bool;
  port outport_arvalid_o: out Bool;
  port outport_araddr_o:  out UInt<ADDR_WIDTH>;

  // Default outport - Read Data Channel (R)
  port outport_rvalid_i: in Bool;
  port outport_rdata_i:  in UInt<DATA_WIDTH>;
  port outport_rresp_i:  in UInt<2>;
  port outport_rready_o: out Bool;

  // Peripheral0 outport - Write Address Channel (AW)
  port outport_peripheral0_awready_i: in Bool;
  port outport_peripheral0_awvalid_o: out Bool;
  port outport_peripheral0_awaddr_o:  out UInt<ADDR_WIDTH>;

  // Peripheral0 outport - Write Data Channel (W)
  port outport_peripheral0_wready_i: in Bool;
  port outport_peripheral0_wvalid_o: out Bool;
  port outport_peripheral0_wdata_o:  out UInt<DATA_WIDTH>;
  port outport_peripheral0_wstrb_o:  out UInt<4>;

  // Peripheral0 outport - Write Response Channel (B)
  port outport_peripheral0_bresp_i:  in UInt<2>;
  port outport_peripheral0_bvalid_i: in Bool;
  port outport_peripheral0_bready_o: out Bool;

  // Peripheral0 outport - Read Address Channel (AR)
  port outport_peripheral0_arready_i: in Bool;
  port outport_peripheral0_arvalid_o: out Bool;
  port outport_peripheral0_araddr_o:  out UInt<ADDR_WIDTH>;

  // Peripheral0 outport - Read Data Channel (R)
  port outport_peripheral0_rresp_i:  in UInt<2>;
  port outport_peripheral0_rvalid_i: in Bool;
  port outport_peripheral0_rdata_i:  in UInt<DATA_WIDTH>;
  port outport_peripheral0_rready_o: out Bool;

  // Read tracking registers
  reg read_pending_q: UInt<4> reset rst_i=>0;
  reg read_port_q: UInt<1> reset rst_i=>0;

  // Write tracking registers
  reg write_pending_q: UInt<4> reset rst_i=>0;
  reg write_port_q: UInt<1> reset rst_i=>0;
  reg awvalid_q: Bool reset rst_i=>false;
  reg wvalid_q: Bool reset rst_i=>false;

  // Combinational wires
  wire read_port_r: UInt<1>;
  wire read_pending_r: UInt<4>;
  wire write_port_r: UInt<1>;
  wire write_pending_r: UInt<4>;

  wire read_accept_w: Bool;
  wire write_accept_w: Bool;

  wire wr_cmd_accepted_w: Bool;
  wire wr_data_accepted_w: Bool;

  wire outport_rvalid_r: Bool;
  wire outport_rdata_r: UInt<DATA_WIDTH>;
  wire outport_rresp_r: UInt<2>;

  wire outport_bvalid_r: Bool;
  wire outport_bresp_r: UInt<2>;

  wire inport_arready_r: Bool;
  wire inport_awready_r: Bool;
  wire inport_wready_r: Bool;

  default seq on clk_i rising;

  //---------------------------------------------------------------
  // Read port selection: address decode
  //---------------------------------------------------------------
  comb
    if (inport_araddr_i & 32'h80000000) == 32'h80000000
      read_port_r = 1;
    else
      read_port_r = 0;
    end if
  end comb

  //---------------------------------------------------------------
  // Read pending counter
  //---------------------------------------------------------------
  comb
    read_pending_r = read_pending_q;

    if (inport_arvalid_i & inport_arready_o) & ~(inport_rvalid_o & inport_rready_i)
      read_pending_r = (read_pending_q + 1).trunc<4>();
    elsif ~(inport_arvalid_i & inport_arready_o) & (inport_rvalid_o & inport_rready_i)
      read_pending_r = (read_pending_q - 1).trunc<4>();
    end if
  end comb

  //---------------------------------------------------------------
  // Read registers
  //---------------------------------------------------------------
  seq
    read_pending_q <= read_pending_r;
    if inport_arvalid_i & inport_arready_o
      read_port_q <= read_port_r;
    end if
  end seq

  //---------------------------------------------------------------
  // Read accept
  //---------------------------------------------------------------
  comb read_accept_w = ((read_port_q == read_port_r) & (read_pending_q != 4'hF)) | (read_pending_q == 0);

  //---------------------------------------------------------------
  // Read channel: outport default
  //---------------------------------------------------------------
  comb outport_arvalid_o = inport_arvalid_i & read_accept_w & (read_port_r == 0);
  comb outport_araddr_o = inport_araddr_i;
  comb outport_rready_o = inport_rready_i;

  //---------------------------------------------------------------
  // Read channel: peripheral0
  //---------------------------------------------------------------
  comb outport_peripheral0_arvalid_o = inport_arvalid_i & read_accept_w & (read_port_r == 1);
  comb outport_peripheral0_araddr_o = inport_araddr_i;
  comb outport_peripheral0_rready_o = inport_rready_i;

  //---------------------------------------------------------------
  // Read response mux
  //---------------------------------------------------------------
  comb
    if read_port_q == 1
      outport_rvalid_r = outport_peripheral0_rvalid_i;
      outport_rdata_r  = outport_peripheral0_rdata_i;
      outport_rresp_r  = outport_peripheral0_rresp_i;
    else
      outport_rvalid_r = outport_rvalid_i;
      outport_rdata_r  = outport_rdata_i;
      outport_rresp_r  = outport_rresp_i;
    end if
  end comb

  comb inport_rvalid_o = outport_rvalid_r;
  comb inport_rdata_o  = outport_rdata_r;
  comb inport_rresp_o  = outport_rresp_r;

  //---------------------------------------------------------------
  // Read arready mux
  //---------------------------------------------------------------
  comb
    if read_port_r == 1
      inport_arready_r = outport_peripheral0_arready_i;
    else
      inport_arready_r = outport_arready_i;
    end if
  end comb

  comb inport_arready_o = read_accept_w & inport_arready_r;

  //---------------------------------------------------------------
  // Write command/data tracking
  //---------------------------------------------------------------
  comb wr_cmd_accepted_w  = (inport_awvalid_i & inport_awready_o) | awvalid_q;
  comb wr_data_accepted_w = (inport_wvalid_i & inport_wready_o) | wvalid_q;

  seq
    if inport_awvalid_i & inport_awready_o & ~wr_data_accepted_w
      awvalid_q <= true;
    elsif wr_data_accepted_w
      awvalid_q <= false;
    end if
  end seq

  seq
    if inport_wvalid_i & inport_wready_o & ~wr_cmd_accepted_w
      wvalid_q <= true;
    elsif wr_cmd_accepted_w
      wvalid_q <= false;
    end if
  end seq

  //---------------------------------------------------------------
  // Write port selection: address decode
  //---------------------------------------------------------------
  comb
    if (inport_awaddr_i & 32'h80000000) == 32'h80000000
      write_port_r = 1;
    else
      write_port_r = 0;
    end if
  end comb

  //---------------------------------------------------------------
  // Write pending counter
  //---------------------------------------------------------------
  comb
    write_pending_r = write_pending_q;

    if (wr_cmd_accepted_w & wr_data_accepted_w) & ~(inport_bvalid_o & inport_bready_i)
      write_pending_r = (write_pending_q + 1).trunc<4>();
    elsif ~(wr_cmd_accepted_w & wr_data_accepted_w) & (inport_bvalid_o & inport_bready_i)
      write_pending_r = (write_pending_q - 1).trunc<4>();
    end if
  end comb

  //---------------------------------------------------------------
  // Write registers
  //---------------------------------------------------------------
  seq
    write_pending_q <= write_pending_r;
    if inport_awvalid_i & inport_awready_o
      write_port_q <= write_port_r;
    end if
  end seq

  //---------------------------------------------------------------
  // Write accept
  //---------------------------------------------------------------
  comb write_accept_w = ((write_port_q == write_port_r) & (write_pending_q != 4'hF)) | (write_pending_q == 0);

  //---------------------------------------------------------------
  // Write channel: outport default
  //---------------------------------------------------------------
  comb outport_awvalid_o = inport_awvalid_i & ~awvalid_q & write_accept_w & (write_port_r == 0);
  comb outport_awaddr_o  = inport_awaddr_i;
  comb outport_wvalid_o  = inport_wvalid_i & ~wvalid_q & (inport_awvalid_i | awvalid_q) & (write_port_r == 0);
  comb outport_wdata_o   = inport_wdata_i;
  comb outport_wstrb_o   = inport_wstrb_i;
  comb outport_bready_o  = inport_bready_i;

  //---------------------------------------------------------------
  // Write channel: peripheral0
  //---------------------------------------------------------------
  comb outport_peripheral0_awvalid_o = inport_awvalid_i & ~awvalid_q & write_accept_w & (write_port_r == 1);
  comb outport_peripheral0_awaddr_o  = inport_awaddr_i;
  comb outport_peripheral0_wvalid_o  = inport_wvalid_i & ~wvalid_q & ((inport_awvalid_i & write_accept_w) | awvalid_q) & (write_port_r == 1);
  comb outport_peripheral0_wdata_o   = inport_wdata_i;
  comb outport_peripheral0_wstrb_o   = inport_wstrb_i;
  comb outport_peripheral0_bready_o  = inport_bready_i;

  //---------------------------------------------------------------
  // Write response mux
  //---------------------------------------------------------------
  comb
    if write_port_q == 1
      outport_bvalid_r = outport_peripheral0_bvalid_i;
      outport_bresp_r  = outport_peripheral0_bresp_i;
    else
      outport_bvalid_r = outport_bvalid_i;
      outport_bresp_r  = outport_bresp_i;
    end if
  end comb

  comb inport_bvalid_o = outport_bvalid_r;
  comb inport_bresp_o  = outport_bresp_r;

  //---------------------------------------------------------------
  // Write awready/wready mux
  //---------------------------------------------------------------
  comb
    if write_port_r == 1
      inport_awready_r = outport_peripheral0_awready_i;
      inport_wready_r  = outport_peripheral0_wready_i;
    else
      inport_awready_r = outport_awready_i;
      inport_wready_r  = outport_wready_i;
    end if
  end comb

  comb inport_awready_o = write_accept_w & ~awvalid_q & inport_awready_r;
  comb inport_wready_o  = write_accept_w & ~wvalid_q & inport_wready_r;

end module axi_tap
