// CDC Pulse Synchronizer: toggle-FF synchronizer
// Supports NUM_CHANNELS channels
// Also provides rst_src_sync and rst_des_sync for reset synchronization
module cdc_pulse_synchronizer
  param NUM_CHANNELS: const = 1;

  port src_clock:    in  Clock<SrcDomain>;
  port des_clock:    in  Clock<DesDomain>;
  port rst_in:       in  Reset<Async, High>;
  port src_pulse:    in  UInt<NUM_CHANNELS>;
  port des_pulse:    out UInt<NUM_CHANNELS>;
  port rst_src_sync: out Bool;
  port rst_des_sync: out Bool;

  // Toggle registers in src domain (one per channel)
  reg toggle_r: UInt<NUM_CHANNELS> reset rst_in=>0;

  seq on src_clock rising
    for i in 0..NUM_CHANNELS-1
      if src_pulse[i:i]
        toggle_r[i:i] <= ~toggle_r[i:i];
      end if
    end for
  end seq

  // 2-FF synchronizers for each channel (des_clock domain)
  reg sync1_r: UInt<NUM_CHANNELS> reset rst_in=>0;
  reg sync2_r: UInt<NUM_CHANNELS> reset rst_in=>0;
  reg prev_r:  UInt<NUM_CHANNELS> reset rst_in=>0;

  seq on des_clock rising
    sync1_r <= toggle_r;
    sync2_r <= sync1_r;
    prev_r  <= sync2_r;
  end seq

  let des_pulse = sync2_r ^ prev_r;

  // Reset synchronizers: 2FF sync of rst_in into each clock domain
  reg rst_src1: Bool reset rst_in=>true;
  reg rst_src2: Bool reset rst_in=>true;
  seq on src_clock rising
    rst_src1 <= false;
    rst_src2 <= rst_src1;
  end seq
  let rst_src_sync = rst_src2;

  reg rst_des1: Bool reset rst_in=>true;
  reg rst_des2: Bool reset rst_in=>true;
  seq on des_clock rising
    rst_des1 <= false;
    rst_des2 <= rst_des1;
  end seq
  let rst_des_sync = rst_des2;
end module cdc_pulse_synchronizer
