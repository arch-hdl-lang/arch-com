module Attenuator
  port clk:      in Clock<SysDomain>;
  port reset:    in Reset<Async>;
  port data:     in UInt<5>;
  port ATTN_CLK: out UInt<1>;
  port ATTN_DATA: out UInt<1>;
  port ATTN_LE:  out UInt<1>;

  default seq on clk rising;

  reg clk_div2:    UInt<1> reset reset=>0;
  reg shift_reg:   UInt<5> reset reset=>0;
  reg bit_cnt:     UInt<3> reset reset=>0;
  reg old_data:    UInt<5> reset reset=>0;
  reg attn_clk_r:  UInt<1> reset reset=>0;
  reg attn_data_r: UInt<1> reset reset=>0;
  reg attn_le_r:   UInt<1> reset reset=>0;
  reg cur_state:   UInt<2> reset reset=>0;

  let IDLE:  UInt<2> = 0;
  let LOAD:  UInt<2> = 1;
  let SHIFT: UInt<2> = 2;
  let LATCH: UInt<2> = 3;

  let zero1: UInt<1> = 0;

  comb
    ATTN_CLK  = attn_clk_r;
    ATTN_DATA = attn_data_r;
    ATTN_LE   = attn_le_r;
  end comb

  seq
    clk_div2 <= ~clk_div2;

    if cur_state == IDLE
      attn_clk_r  <= 0;
      attn_data_r <= 0;
      attn_le_r   <= 0;
      if data != old_data
        cur_state <= LOAD;
        old_data  <= data;
      end if

    elsif cur_state == LOAD
      shift_reg <= data;
      bit_cnt   <= 0;
      attn_clk_r  <= 0;
      attn_data_r <= 0;
      attn_le_r   <= 0;
      cur_state <= SHIFT;

    elsif cur_state == SHIFT
      if clk_div2 == 1
        attn_data_r <= shift_reg[4:4];
        attn_clk_r  <= 1;
        shift_reg   <= {shift_reg[3:0], zero1};
        if bit_cnt == 4
          cur_state <= LATCH;
          bit_cnt   <= 0;
        else
          bit_cnt <= (bit_cnt + 1).trunc<3>();
        end if
      else
        attn_clk_r <= 0;
      end if

    elsif cur_state == LATCH
      attn_clk_r  <= 0;
      attn_data_r <= 0;
      attn_le_r   <= 1;
      cur_state   <= IDLE;

    end if
  end seq
end module Attenuator
