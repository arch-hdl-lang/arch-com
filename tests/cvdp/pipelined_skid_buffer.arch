module pipelined_skid_buffer
  port clock:   in Clock<SysDomain>;
  port rst:     in Reset<Sync>;
  port i_data:  in UInt<4>;
  port i_valid: in Bool;
  port ready_i: in Bool;
  port data_o:  out UInt<4>;
  port valid_o: out Bool;
  port ready_o: out Bool;

  wire s0_data:  UInt<4>;
  wire s0_valid: Bool;
  wire s0_ready: Bool;

  wire r1_data:  UInt<4>;
  wire r1_valid: Bool;
  wire r1_ready: Bool;

  wire s2_data:  UInt<4>;
  wire s2_valid: Bool;
  wire s2_ready: Bool;

  wire r3_data:  UInt<4>;
  wire r3_valid: Bool;
  wire r3_ready: Bool;

  inst skid_0: skid_buffer
    clk     <- clock;
    rst     <- rst;
    i_data  <- i_data;
    i_valid <- i_valid;
    i_ready <- r1_ready;
    o_data  -> s0_data;
    o_valid -> s0_valid;
    o_ready -> s0_ready;
  end inst skid_0

  inst reg1: register
    clk       <- clock;
    rst       <- rst;
    data_in   <- s0_data;
    valid_in  <- s0_valid;
    ready_in  <- s2_ready;
    data_out  -> r1_data;
    valid_out -> r1_valid;
    ready_out -> r1_ready;
  end inst reg1

  inst skid_2: skid_buffer
    clk     <- clock;
    rst     <- rst;
    i_data  <- r1_data;
    i_valid <- r1_valid;
    i_ready <- r3_ready;
    o_data  -> s2_data;
    o_valid -> s2_valid;
    o_ready -> s2_ready;
  end inst skid_2

  inst reg3: register
    clk       <- clock;
    rst       <- rst;
    data_in   <- s2_data;
    valid_in  <- s2_valid;
    ready_in  <- ready_i;
    data_out  -> r3_data;
    valid_out -> r3_valid;
    ready_out -> r3_ready;
  end inst reg3

  comb data_o = r3_data;
  comb valid_o = r3_valid;
  comb ready_o = s0_ready;
end module pipelined_skid_buffer
