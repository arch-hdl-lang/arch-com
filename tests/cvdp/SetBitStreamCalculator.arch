module SetBitStreamCalculator
  param p_max_set_bit_count_width: const = 8;
  port i_clk: in Clock<SysDomain>;
  port i_rst_n: in Reset<Async, Low>;
  port i_ready: in Bool;
  port i_bit_in: in Bool;
  port o_set_bit_count: out UInt<p_max_set_bit_count_width>;

  reg count: UInt<p_max_set_bit_count_width> reset i_rst_n => 0;
  reg prev_ready: Bool reset i_rst_n => 0;

  wire sum_wide: UInt<9>;
  wire next_count: UInt<p_max_set_bit_count_width>;

  comb
    sum_wide = (count.zext<9>() + i_bit_in.zext<9>()).trunc<9>();
    if sum_wide[8:8]
      next_count = 8'hFF;
    else
      next_count = sum_wide.trunc<p_max_set_bit_count_width>();
    end if
  end comb

  seq on i_clk rising
    prev_ready <= i_ready;
    if i_ready & ~prev_ready
      count <= 0;
    elsif i_ready
      count <= next_count;
    end if
  end seq

  let o_set_bit_count = count;
end module SetBitStreamCalculator
