module signed_sequential_booth_multiplier
  param WIDTH: const = 8;

  port clk:    in Clock<SysDomain>;
  port rst:    in Reset<Async, High>;
  port start:  in Bool;
  port A:      in SInt<WIDTH>;
  port B:      in SInt<WIDTH>;
  port result: out SInt<2*WIDTH>;
  port done:   out Bool;

  default seq on clk rising;
  reg default: reset rst => 0;

  local param HALF: const = WIDTH / 2;
  local param DW: const = 2 * WIDTH;

  // State encoding: 0=IDLE, 1=COMPUTE, 2=DONE
  reg st: UInt<2>;

  // Datapath registers
  reg accum_r:  SInt<DW>;
  reg mcand_r:  SInt<DW>;
  reg mplier_r: UInt<WIDTH+1>;
  reg step_r:   UInt<8>;
  reg done_r:   Bool;

  // Current 3-bit Booth group from bottom of mplier_r
  let grp: UInt<3> = mplier_r[2:0];

  // Booth partial product selection
  let m_pos:  SInt<DW+1> = mcand_r.sext<DW+1>();
  let m2_pos: SInt<DW+1> = mcand_r.sext<DW+1>() << 1;
  let m_neg:  SInt<DW+1> = (0 - mcand_r.sext<DW+1>()).trunc<DW+1>();
  let m2_neg: SInt<DW+1> = (0 - m2_pos).trunc<DW+1>();

  wire pp_val: SInt<DW+1>;

  let accum_ext: SInt<DW+1> = accum_r.sext<DW+1>();
  let sum: SInt<DW+1> = (accum_ext + pp_val).trunc<DW+1>();

  // Step thresholds
  let last_step_v: UInt<8> = (HALF + 2).zext<8>();
  let half_val_v:  UInt<8> = HALF.zext<8>();

  comb
    result = accum_r;
    done   = done_r;
    pp_val =
      (grp == 1) | (grp == 2) ? m_pos  :
      (grp == 3)              ? m2_pos :
      (grp == 4)              ? m2_neg :
      (grp == 5) | (grp == 6) ? m_neg  :
                                 m_pos ^ m_pos;
  end comb

  seq
    if st == 0
      // IDLE
      done_r <= false;
      if start
        accum_r  <= 0;
        mcand_r  <= A.sext<DW>();
        mplier_r <= {unsigned(B), 1'b0};
        step_r   <= 0;
        st       <= 1;
      end if
    elsif st == 1
      // COMPUTE
      if step_r < half_val_v
        accum_r  <= sum.trunc<DW>();
        mplier_r <= mplier_r >> 2;
        mcand_r  <= mcand_r << 2;
      end if
      step_r <= (step_r + 1).trunc<8>();
      if step_r == last_step_v
        st     <= 2;
        done_r <= true;
      end if
    else
      // DONE
      done_r <= false;
      st     <= 0;
    end if
  end seq
end module signed_sequential_booth_multiplier
