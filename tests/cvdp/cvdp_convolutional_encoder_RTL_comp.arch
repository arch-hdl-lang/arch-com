module convolutional_encoder
  port clk: in Clock<SysDomain>;
  port rst: in Reset<Sync>;
  port data_in: in Bit;
  port reg encoded_bit1: out Bit reset rst = 0;
  port reg encoded_bit2: out Bit reset rst = 0;

  default seq on clk rising;

  reg sr: UInt<2> reset rst = 0;

  seq
    if rst
      sr <= 0;
      encoded_bit1 <= 0;
      encoded_bit2 <= 0;
    else
      sr <= {data_in, sr[1]};
      encoded_bit1 <= data_in ^ sr[1] ^ sr[0];
      encoded_bit2 <= data_in ^ sr[0];
    end if
  end seq
end module convolutional_encoder
