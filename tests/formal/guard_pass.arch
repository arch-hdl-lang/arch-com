module GuardPass
  port clk: in Clock<SysDomain>;
  port rst: in Reset<Sync>;
  port en:  in Bool;
  port din: in UInt<8>;

  reg data:    UInt<8> reset rst => 0;
  reg valid_r: Bool    reset rst => false;
  reg written: Bool    reset rst => false;

  seq on clk rising
    if en
      data    <= din;
      valid_r <= true;
      written <= true;
    end if
  end seq

  assert valid_implies_written: valid_r implies written;
end module GuardPass
