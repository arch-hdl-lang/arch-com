// arch formal Phase 2: past(_, N) and a |=> b cycle-shift encoding
module SvaTemporalProves
  port clk: in Clock<SysDomain>;
  port rst: in Reset<Sync>;
  port req: in Bool;

  reg gnt_r: Bool reset rst => false;

  seq on clk rising
    gnt_r <= req;
  end seq

  // gnt_r equals past(req, 1) — when reset wasn't active at the past cycle either.
  assert gnt_follows_req: (not rst) and (not past(rst, 1)) implies (gnt_r == past(req, 1));
  // Top-level |=>: req at t (no reset) implies gnt_r at t+1.
  assert req_implies_next_gnt: ((not rst) and req) |=> gnt_r;
  // Cover: witness exists.
  cover saw_req_then_gnt: past(req, 1) and gnt_r;
end module SvaTemporalProves
