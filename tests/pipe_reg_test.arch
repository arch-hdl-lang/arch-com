domain SysDomain
  freq_mhz: 100
end domain SysDomain

module PipeRegTest
  port clk: in Clock<SysDomain>;
  port rst: in Reset<Sync>;
  port data_in: in UInt<8>;
  port data_out: out UInt<8>;

  reg default: init 0 reset rst=0;

  let w: UInt<8> = data_in ^ 8'hFF;

  pipe_reg delayed: w stages 3;

  comb
    data_out = delayed;
  end comb
end module PipeRegTest
