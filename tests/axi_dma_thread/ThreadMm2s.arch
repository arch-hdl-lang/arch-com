// Thread-based multi-outstanding MM2S read engine.
//
// Architecture: single ArIssuer thread + 4 RCollect threads.
//   - ArIssuer: single state machine drives all AR outputs — no 4-way mux needed.
//     Address maintained in next_ar_addr_r (increment-only, no multiply).
//   - RCollect_i: each thread collects R beats for its assigned ID.
//     Only drives 1-bit r_ready/push_valid — narrow mux overhead.
//   - push_data = r_data unconditionally (all threads push same source).
//
// Work assignment: xfer k → AR ID k%4, handled by RCollect_{k%4}.
// Done when sum of thread_complete[i] == total_xfers.

module ThreadMm2s
  param NUM_OUTSTANDING: const = 4;

  port clk:  in Clock<SysDomain>;
  port rst:  in Reset<Sync>;

  port start:       in Bool;
  port total_xfers: in UInt<16>;
  port base_addr:   in UInt<32>;
  port burst_len:   in UInt<8>;

  port done:     out Bool;
  port halted:   out Bool;
  port idle_out: out Bool;

  port ar_valid: out Bool;
  port ar_ready: in Bool;
  port ar_addr:  out UInt<32>;
  port ar_id:    out UInt<2>;
  port ar_len:   out UInt<8>;
  port ar_size:  out UInt<3>;
  port ar_burst: out UInt<2>;

  port r_valid:  in Bool;
  port r_ready:  out Bool shared(or);
  port r_data:   in UInt<32>;
  port r_id:     in UInt<2>;
  port r_last:   in Bool;

  port push_valid: out Bool shared(or);
  port push_ready: in Bool;
  port push_data:  out UInt<32>;

  // Control latches
  reg total_xfers_r: UInt<16> reset rst => 0;
  reg burst_len_r:   UInt<8>  reset rst => 0;
  reg active_r:      Bool     reset rst => false;

  // AR issuer state: xfer_ctr_r counts issued ARs; next_ar_addr_r is current address.
  // Incremental update — no multiply in comb path.
  reg xfer_ctr_r:     UInt<16> reset rst => 0;
  reg next_ar_addr_r: UInt<32> reset rst => 0;

  // Per-thread completion counts (one per R collector thread)
  reg thread_complete: Vec<UInt<16>, 4> reset rst => 0;

  // Done when all responses received
  let tc01: UInt<17> = thread_complete[0] + thread_complete[1];
  let tc23: UInt<17> = thread_complete[2] + thread_complete[3];
  let total_complete: UInt<18> = tc01 + tc23;
  let all_done: Bool = active_r and (total_xfers_r != 0)
      and (total_complete == total_xfers_r.zext<18>());

  // Zero-latency active signal
  let active: Bool = active_r or (start and not active_r);

  comb
    halted    = false;
    idle_out  = not active;
    done      = all_done;
    // push_data is always r_data — single driver, no per-thread mux needed
    push_data = r_data;
  end comb

  // Controller: latch config on start, clear on done
  seq on clk rising
    if start and not active_r
      total_xfers_r  <= total_xfers;
      burst_len_r    <= burst_len;
      active_r       <= true;
      xfer_ctr_r     <= 0;
      next_ar_addr_r <= base_addr;
      thread_complete[0] <= 0; thread_complete[1] <= 0;
      thread_complete[2] <= 0; thread_complete[3] <= 0;
    end if
    if all_done
      active_r <= false;
    end if
  end seq

  // ── AR issuer ─────────────────────────────────────────────────────────────
  // Single thread drives all AR outputs — no resource lock, no 4-way mux.
  // Issues one AR per beat, round-robin IDs 0..3.
  thread ArIssuer on clk rising, rst high
    wait until active and xfer_ctr_r < total_xfers_r;
    do
      ar_valid = 1;
      ar_addr  = next_ar_addr_r;
      ar_id    = xfer_ctr_r[1:0];
      ar_len   = (burst_len_r - 1).trunc<8>();
      ar_size  = 3'd2;
      ar_burst = 2'd1;
    until ar_ready;
    xfer_ctr_r     <= (xfer_ctr_r + 1).trunc<16>();
    next_ar_addr_r <= (next_ar_addr_r + (burst_len_r.zext<32>() << 2)).trunc<32>();
  end thread ArIssuer

  // ── R collectors ─────────────────────────────────────────────────────────
  // Each thread handles R beats for one ID. Wakes when AR has been issued for
  // that ID (xfer_ctr_r > completed*4 + i). Only drives 1-bit signals —
  // narrow mux overhead compared to driving 32-bit ar_addr.
  generate_for i in 0..3
    thread RCollect_i on clk rising, rst high
      // Wait until an AR with this ID has been issued but not yet responded
      wait until active and ((thread_complete[i] << 2) + i < xfer_ctr_r);
      // Collect burst beats for this ID
      for b in 0..burst_len_r-1
        do
          r_ready    = 1;
          push_valid = r_valid and (r_id == i);
        until r_valid and r_id == i and push_ready;
      end for
      thread_complete[i] <= (thread_complete[i] + 1).trunc<16>();
    end thread RCollect_i
  end generate_for
end module ThreadMm2s
