// Thread-based multi-outstanding MM2S read engine.
// Each thread index = AXI ID. Thread i issues burst i.
// No seq blocks — all state managed by threads.

module ThreadMm2s
  param NUM_OUTSTANDING: const = 4;

  port clk:  in Clock<SysDomain>;
  port rst:  in Reset<Sync>;

  port start:       in Bool;
  port total_xfers: in UInt<16>;
  port base_addr:   in UInt<32>;
  port burst_len:   in UInt<8>;

  port done:     out Bool;
  port halted:   out Bool;
  port idle_out: out Bool;

  port ar_valid: out Bool;
  port ar_ready: in Bool;
  port ar_addr:  out UInt<32>;
  port ar_id:    out UInt<2>;
  port ar_len:   out UInt<8>;
  port ar_size:  out UInt<3>;
  port ar_burst: out UInt<2>;

  port r_valid:  in Bool;
  port r_ready:  out Bool shared(or);
  port r_data:   in UInt<32>;
  port r_id:     in UInt<2>;
  port r_last:   in Bool;

  port push_valid: out Bool shared(or);
  port push_ready: in Bool;
  port push_data:  out UInt<32>;

  // All state driven by threads only
  reg active_r:      Bool     reset rst => false;
  reg total_xfers_r: UInt<16> reset rst => 0;
  reg base_addr_r:   UInt<32> reset rst => 0;
  reg burst_len_r:   UInt<8>  reset rst => 0;
  reg done_0: Bool reset rst => true;
  reg done_1: Bool reset rst => true;
  reg done_2: Bool reset rst => true;
  reg done_3: Bool reset rst => true;

  comb
    halted   = false;
    idle_out = not active_r;
    done     = active_r and done_0 and done_1 and done_2 and done_3;
  end comb

  resource ar_ch : mutex<round_robin>;

  // Controller thread: latches start, clears done flags
  thread Controller on clk rising, rst high
    wait until start;
    total_xfers_r <= total_xfers;
    base_addr_r   <= base_addr;
    burst_len_r   <= burst_len;
    active_r      <= true;
    done_0 <= (total_xfers == 0);
    done_1 <= (total_xfers < 2);
    done_2 <= (total_xfers < 3);
    done_3 <= (total_xfers < 4);
    // Wait for all threads to complete
    wait until done_0 and done_1 and done_2 and done_3;
    active_r <= false;
    wait 1 cycle;
  end thread Controller

  // Read thread 0
  thread ReadReq_0 on clk rising, rst high
    wait until active_r and (not done_0);
    lock ar_ch
      ar_valid = 1; ar_addr = base_addr_r; ar_id = 0;
      ar_len = (burst_len_r - 1).trunc<8>(); ar_size = 3'd2; ar_burst = 2'd1;
      wait until ar_ready; ar_valid = 0;
    end lock ar_ch
    for b in 0..burst_len_r-1
      r_ready = 1; push_valid = r_valid and (r_id == 0); push_data = r_data;
      wait until r_valid and r_id == 0;
    end for
    r_ready = 0;
    done_0 <= true; wait 1 cycle;
  end thread ReadReq_0

  // Read thread 1
  thread ReadReq_1 on clk rising, rst high
    wait until active_r and (not done_1);
    lock ar_ch
      ar_valid = 1; ar_addr = base_addr_r + (burst_len_r.zext<32>() << 2); ar_id = 1;
      ar_len = (burst_len_r - 1).trunc<8>(); ar_size = 3'd2; ar_burst = 2'd1;
      wait until ar_ready; ar_valid = 0;
    end lock ar_ch
    for b in 0..burst_len_r-1
      r_ready = 1; push_valid = r_valid and (r_id == 1); push_data = r_data;
      wait until r_valid and r_id == 1;
    end for
    r_ready = 0;
    done_1 <= true; wait 1 cycle;
  end thread ReadReq_1

  // Read thread 2
  thread ReadReq_2 on clk rising, rst high
    wait until active_r and (not done_2);
    lock ar_ch
      ar_valid = 1; ar_addr = base_addr_r + (2 * (burst_len_r.zext<32>() << 2)); ar_id = 2;
      ar_len = (burst_len_r - 1).trunc<8>(); ar_size = 3'd2; ar_burst = 2'd1;
      wait until ar_ready; ar_valid = 0;
    end lock ar_ch
    for b in 0..burst_len_r-1
      r_ready = 1; push_valid = r_valid and (r_id == 2); push_data = r_data;
      wait until r_valid and r_id == 2;
    end for
    r_ready = 0;
    done_2 <= true; wait 1 cycle;
  end thread ReadReq_2

  // Read thread 3
  thread ReadReq_3 on clk rising, rst high
    wait until active_r and (not done_3);
    lock ar_ch
      ar_valid = 1; ar_addr = base_addr_r + (3 * (burst_len_r.zext<32>() << 2)); ar_id = 3;
      ar_len = (burst_len_r - 1).trunc<8>(); ar_size = 3'd2; ar_burst = 2'd1;
      wait until ar_ready; ar_valid = 0;
    end lock ar_ch
    for b in 0..burst_len_r-1
      r_ready = 1; push_valid = r_valid and (r_id == 3); push_data = r_data;
      wait until r_valid and r_id == 3;
    end for
    r_ready = 0;
    done_3 <= true; wait 1 cycle;
  end thread ReadReq_3
end module ThreadMm2s
