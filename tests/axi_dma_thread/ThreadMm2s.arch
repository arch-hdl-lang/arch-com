// Thread-based multi-outstanding MM2S read engine.
// Uses generate_for to unroll N identical read threads.
//
// Work assignment: thread i owns xfer indices i, i+4, i+8, ...
//   (static round-robin — no shared counter, no race)
// Each thread loops, driven by thread_complete[i] (its own completion count).
// Done when sum of all thread_complete[i] == total_xfers.

module ThreadMm2s
  param NUM_OUTSTANDING: const = 4;

  port clk:  in Clock<SysDomain>;
  port rst:  in Reset<Sync>;

  port start:       in Bool;
  port total_xfers: in UInt<16>;
  port base_addr:   in UInt<32>;
  port burst_len:   in UInt<8>;

  port done:     out Bool;
  port halted:   out Bool;
  port idle_out: out Bool;

  port ar_valid: out Bool;
  port ar_ready: in Bool;
  port ar_addr:  out UInt<32>;
  port ar_id:    out UInt<2>;
  port ar_len:   out UInt<8>;
  port ar_size:  out UInt<3>;
  port ar_burst: out UInt<2>;

  port r_valid:  in Bool;
  port r_ready:  out Bool shared(or);
  port r_data:   in UInt<32>;
  port r_id:     in UInt<2>;
  port r_last:   in Bool;

  port push_valid: out Bool shared(or);
  port push_ready: in Bool;
  port push_data:  out UInt<32>;

  // Control latches
  reg total_xfers_r: UInt<16> reset rst => 0;
  reg base_addr_r:   UInt<32> reset rst => 0;
  reg burst_len_r:   UInt<8>  reset rst => 0;
  reg active_r:      Bool     reset rst => false;

  // Per-thread completion counts: thread_complete[i] = rounds completed by thread i
  // Written only by thread i → no multi-driver conflict
  reg thread_complete: Vec<UInt<16>, 4> reset rst => 0;

  // Total completions across all threads
  let tc01: UInt<17> = thread_complete[0] + thread_complete[1];
  let tc23: UInt<17> = thread_complete[2] + thread_complete[3];
  let total_complete: UInt<18> = tc01 + tc23;

  // Done when all xfers have completed
  let all_done: Bool = active_r and (total_xfers_r != 0)
      and (total_complete == total_xfers_r.zext<18>());

  // Combinational active includes start pulse — zero startup latency
  let active: Bool = active_r or (start and not active_r);

  comb
    halted   = false;
    idle_out = not active;
    done = all_done;
  end comb

  // Controller: latch config on start, clear on completion
  seq on clk rising
    if start and not active_r
      total_xfers_r <= total_xfers;
      base_addr_r   <= base_addr;
      burst_len_r   <= burst_len;
      active_r      <= true;
      thread_complete[0] <= 0; thread_complete[1] <= 0;
      thread_complete[2] <= 0; thread_complete[3] <= 0;
    end if
    if all_done
      active_r <= false;
    end if
  end seq

  resource ar_ch : mutex<round_robin>;

  // Read threads — each handles xfer indices i, i+4, i+8, ...
  // Thread i waits until its next xfer index < total_xfers_r, then issues AR.
  generate_for i in 0..3
    thread ReadReq_i on clk rising, rst high
      // Next xfer for this thread: i + thread_complete[i] * 4
      // Wait condition: this xfer index must be within range
      wait until active and ((thread_complete[i] << 2) + i < total_xfers_r);
      // Serialise AR channel access
      lock ar_ch
        do
          ar_valid = 1;
          ar_addr = (base_addr_r + ((thread_complete[i].zext<32>() << 2) + i) * (burst_len_r.zext<32>() << 2)).trunc<32>();
          ar_id = i;
          ar_len = (burst_len_r - 1).trunc<8>(); ar_size = 3'd2; ar_burst = 2'd1;
        until ar_ready;
      end lock ar_ch
      // Collect R beats for this thread's ID
      for b in 0..burst_len_r-1
        do
          r_ready = (r_id == i);
          push_valid = r_valid and (r_id == i);
          push_data = r_data;
        until r_valid and r_id == i and push_ready;
      end for
      // Increment per-thread counter (merged into for-loop exit — no dead cycle)
      thread_complete[i] <= (thread_complete[i] + 1).trunc<16>();
    end thread ReadReq_i
  end generate_for
end module ThreadMm2s
