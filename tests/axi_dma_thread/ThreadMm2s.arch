// Thread-based multi-outstanding MM2S read engine.
// Uses generate_for to unroll N identical read threads.

module ThreadMm2s
  param NUM_OUTSTANDING: const = 4;

  port clk:  in Clock<SysDomain>;
  port rst:  in Reset<Sync>;

  port start:       in Bool;
  port total_xfers: in UInt<16>;
  port base_addr:   in UInt<32>;
  port burst_len:   in UInt<8>;

  port done:     out Bool;
  port halted:   out Bool;
  port idle_out: out Bool;

  port ar_valid: out Bool;
  port ar_ready: in Bool;
  port ar_addr:  out UInt<32>;
  port ar_id:    out UInt<2>;
  port ar_len:   out UInt<8>;
  port ar_size:  out UInt<3>;
  port ar_burst: out UInt<2>;

  port r_valid:  in Bool;
  port reg r_ready:  out Bool reset rst => false shared(or);
  port r_data:   in UInt<32>;
  port r_id:     in UInt<2>;
  port r_last:   in Bool;

  port push_valid: out Bool shared(or);
  port push_ready: in Bool;
  port push_data:  out UInt<32>;

  // Control latches
  reg total_xfers_r: UInt<16> reset rst => 0;
  reg base_addr_r:   UInt<32> reset rst => 0;
  reg burst_len_r:   UInt<8>  reset rst => 0;
  reg active_r:      Bool     reset rst => false;

  // Per-thread done flags (Vec indexed by thread)
  reg done_flags: Vec<Bool, 4> reset rst => 0;

  comb
    halted   = false;
    idle_out = not active_r;
    done = active_r and total_xfers_r != 0
       and (done_flags[0] or (total_xfers_r < 1))
       and (done_flags[1] or (total_xfers_r < 2))
       and (done_flags[2] or (total_xfers_r < 3))
       and (done_flags[3] or (total_xfers_r < 4));
  end comb

  resource ar_ch : mutex<round_robin>;

  // Controller: latches start, waits for completion
  thread Controller on clk rising, rst high
    wait until start;
    total_xfers_r <= total_xfers;
    base_addr_r   <= base_addr;
    burst_len_r   <= burst_len;
    active_r      <= true;
    done_flags[0] <= false; done_flags[1] <= false;
    done_flags[2] <= false; done_flags[3] <= false;
    wait until done;
    active_r <= false;
    wait 1 cycle;
  end thread Controller

  // Read threads — one per outstanding transaction
  generate_for i in 0..3
    thread ReadReq_i on clk rising, rst high
      wait until active_r and (not done_flags[i]) and (total_xfers_r > i);
      lock ar_ch
        do
          ar_valid = 1;
          ar_addr = (base_addr_r + (i * (burst_len_r.zext<32>() << 2))).trunc<32>();
          ar_id = i;
          ar_len = (burst_len_r - 1).trunc<8>(); ar_size = 3'd2; ar_burst = 2'd1;
        until ar_ready;
      end lock ar_ch
      r_ready <= true;
      for b in 0..burst_len_r-1
        wait until r_valid and r_id == i;
        do push_valid = 1; push_data = r_data; until push_ready;
      end for
      r_ready <= false;
      done_flags[i] <= true;
    end thread ReadReq_i
  end generate_for
end module ThreadMm2s
