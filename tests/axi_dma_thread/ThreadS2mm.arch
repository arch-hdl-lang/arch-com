//! ---
//! spec_md: doc/axi_dma_case_study.md
//! tags: [dma, axi4, s2mm, multi_outstanding, thread, fork_join, lock]
//! refs:
//!   - "AXI4 spec ARM IHI 0022, §A3 Single Interface Requirements"
//!   - "AXI4 spec §A5 — write data ordering / write response ordering"
//!   - "Xilinx PG021 (LogiCORE IP AXI DMA) — S2MM write path"
//! ---
//!
//! Multi-outstanding AXI4 S2MM (write) engine — issues up to
//! NUM_OUTSTANDING parallel transactions, each pulling data from the
//! S2MM FIFO and driving AW + W + B. Compare with FsmS2mmMulti.arch (226
//! lines, 4 hand-rolled states); the thread version is ~50% shorter
//! because `fork`/`join` expresses the AW/W parallelism directly, and
//! `resource` + `lock` handles channel arbitration without a manual mux.

/// Multi-outstanding AXI4 S2MM write engine.
///
/// `NUM_OUTSTANDING` parallel `WriteReq_i` threads, one per AXI ID, each
/// running the AW → W → B sequence. AW and W are issued in parallel via
/// `fork ... and ... join`; channel arbitration across threads uses
/// `resource` + `lock`. AW/W use `round_robin` for fairness across IDs
/// (each thread gets even bandwidth on the bus); the done-counter resource
/// uses `priority` because completion order doesn't affect throughput.
module ThreadS2mm
  param NUM_OUTSTANDING: const = 4;
  param ID_W: const = 2;

  port clk:  in Clock<SysDomain>;
  port rst:  in Reset<Sync>;

  port start:       in Bool;
  port total_xfers: in UInt<16>;
  port base_addr:   in UInt<32>;
  port burst_len:   in UInt<8>;

  port done:     out Bool;
  port halted:   out Bool;
  port idle_out: out Bool;

  port aw_valid: out Bool;
  port aw_ready: in Bool;
  port aw_addr:  out UInt<32>;
  port aw_id:    out UInt<2>;
  port aw_len:   out UInt<8>;
  port aw_size:  out UInt<3>;
  port aw_burst: out UInt<2>;

  port w_valid:  out Bool;
  port w_ready:  in Bool;
  port w_data:   out UInt<32>;
  port w_strb:   out UInt<4>;
  port w_last:   out Bool;

  port b_valid:  in Bool;
  port b_ready:  out Bool shared(or);
  port b_id:     in UInt<2>;

  port pop_valid: in Bool;
  port pop_ready: out Bool;
  port pop_data:  in UInt<32>;

  // Shared state — protected by locks
  reg aw_issued_r:   UInt<16> reset rst => 0;
  reg b_received_r:  UInt<16> reset rst => 0;
  reg next_addr_r:   UInt<32> reset rst => 0;

  let halted   = false;
  let idle_out = (aw_issued_r == 0) and (b_received_r == 0);
  let done     = (b_received_r == total_xfers) and (b_received_r != 0);

  /// AW channel arbiter — round-robin keeps bandwidth fair across IDs.
  resource aw_ch  : mutex<round_robin>;
  /// W channel arbiter — same fairness story as AW.
  resource w_ch   : mutex<round_robin>;
  /// Done-counter arbiter — order-independent, priority is fine.
  resource done_ch: mutex<priority>;

  generate_for i in 0..NUM_OUTSTANDING-1
    thread WriteReq_i on clk rising, rst low
      //! Per-ID write transaction. Body shape:
      //!   (1) `wait until start` — block until the host kicks off a run.
      //!   (2) `fork`-`join` of two locked branches that issue AW and W
      //!       in parallel — each branch holds its respective channel
      //!       lock for the duration of its handshake.
      //!   (3) Wait for `b_valid` matching this thread's ID.
      //!   (4) Lock `done_ch` to atomically increment `b_received_r`.
      //!
      //! ID assignment: the `generate_for i in 0..NUM_OUTSTANDING-1` loop
      //! gives each thread a static AXI ID `i`; b_id matching ensures a
      //! thread only consumes its own write response.

      wait until start;

      // AW+W in parallel via fork/join
      fork
        // AW branch: exclusive access to address channel
        lock aw_ch
          aw_valid = 1;
          aw_addr  = next_addr_r;
          aw_id    = i;
          aw_len   = (burst_len - 1).trunc<8>();
          aw_size  = 3'd2;
          aw_burst = 2'd1;
          aw_issued_r <= (aw_issued_r + 1).trunc<16>();
          next_addr_r <= (next_addr_r + (burst_len.zext<32>() << 2)).trunc<32>();
          wait until aw_ready;
          aw_valid = 0;
        end lock aw_ch
      and
        // W branch: exclusive access to data channel
        lock w_ch
          for b in 0..burst_len-1
            w_valid   = 1;
            w_data    = pop_data;
            w_strb    = 4'hF;
            w_last    = (b == (burst_len - 1).trunc<8>());
            pop_ready = 1;
            wait until w_ready and pop_valid;
          end for
          w_valid   = 0;
          pop_ready = 0;
        end lock w_ch
      join

      // B phase: wait for write response matching this ID
      b_ready = 1;
      wait until b_valid and b_id == i;
      b_ready = 0;

      // Mark complete
      lock done_ch
        b_received_r <= (b_received_r + 1).trunc<16>();
        wait 1 cycle;
      end lock done_ch
    end thread WriteReq_i
  end generate_for
end module ThreadS2mm
