//! ---
//! tags: [tlm_method, connect, address_decode, one_to_many]
//! refs:
//!   - "compiler decoded TLM connect regression"
//! ---
//!
//! Regression fixture for decoded one-initiator-to-many-target TLM connect
//! sugar. Repeated ordinary connect statements route blocking read/write
//! traffic to low or high memory targets based on each target instance's
//! address-range param overrides.

/// Blocking memory transaction bus used by decoded connect tests.
bus DecodeMem
  tlm_method read(addr: UInt<32>) -> UInt<64>: blocking;
  tlm_method write(addr: UInt<32>, data: UInt<64>) -> Bool: blocking;
end bus DecodeMem

/// Makes DecodeMem available to the modules in this fixture.
use DecodeMem;

/// Low-address memory target.
module DecodeMemTargetLo
  param SLAVE_START_ADDR: const = 32'h0000_0000;
  param SLAVE_END_ADDR: const = 32'h7fff_ffff;
  port clk: in Clock<SysDomain>;
  port rst: in Reset<Sync>;
  port s: target DecodeMem;

  thread s.read(addr) on clk rising, rst high
    return 64'h1111_0000_0000_0000;
  end thread s.read

  thread s.write(addr, data) on clk rising, rst high
    return data == 64'h1111_0000_0000_0000;
  end thread s.write
end module DecodeMemTargetLo

/// High-address memory target.
module DecodeMemTargetHi
  param SLAVE_START_ADDR: const = 32'h8000_0000;
  param SLAVE_END_ADDR: const = 32'hffff_ffff;
  port clk: in Clock<SysDomain>;
  port rst: in Reset<Sync>;
  port s: target DecodeMem;

  thread s.read(addr) on clk rising, rst high
    return 64'h2222_0000_0000_0000;
  end thread s.read

  thread s.write(addr, data) on clk rising, rst high
    return data == 64'h2222_0000_0000_0000;
  end thread s.write
end module DecodeMemTargetHi

/// Initiator that issues low and high address transactions through one port.
module DecodeInitiator
  port clk: in Clock<SysDomain>;
  port rst: in Reset<Sync>;
  port m: initiator DecodeMem;
  port lo_data_o: out UInt<64>;
  port hi_data_o: out UInt<64>;
  port lo_ack_o: out Bool;
  port hi_ack_o: out Bool;

  reg lo_data: UInt<64> reset rst => 0;
  reg hi_data: UInt<64> reset rst => 0;
  reg lo_ack: Bool reset rst => false;
  reg hi_ack: Bool reset rst => false;

  comb
    lo_data_o = lo_data;
    hi_data_o = hi_data;
    lo_ack_o = lo_ack;
    hi_ack_o = hi_ack;
  end comb

  thread driver on clk rising, rst high
    lo_data <= m.read(32'h0000_1000);
    hi_data <= m.read(32'h8000_1000);
    lo_ack <= m.write(32'h0000_2000, lo_data);
    hi_ack <= m.write(32'h8000_2000, hi_data);
  end thread driver
end module DecodeInitiator

/// Top-level decoded connect example with one initiator and two targets.
module TlmConnectDecodeTop
  port clk: in Clock<SysDomain>;
  port rst: in Reset<Sync>;
  port lo_data_o: out UInt<64>;
  port hi_data_o: out UInt<64>;
  port lo_ack_o: out Bool;
  port hi_ack_o: out Bool;

  inst i: DecodeInitiator
    clk <- clk;
    rst <- rst;
    lo_data_o -> lo_data_o;
    hi_data_o -> hi_data_o;
    lo_ack_o -> lo_ack_o;
    hi_ack_o -> hi_ack_o;
  end inst i

  inst lo_t: DecodeMemTargetLo
    param SLAVE_START_ADDR = 32'h0000_0000;
    param SLAVE_END_ADDR = 32'h7fff_ffff;
    clk <- clk;
    rst <- rst;
  end inst lo_t

  inst hi_t: DecodeMemTargetHi
    param SLAVE_START_ADDR = 32'h8000_0000;
    param SLAVE_END_ADDR = 32'hffff_ffff;
    clk <- clk;
    rst <- rst;
  end inst hi_t

  connect i.m -> lo_t.s;
  connect i.m -> hi_t.s;
end module TlmConnectDecodeTop
