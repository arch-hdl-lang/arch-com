//! ---
//! tags: [tlm_method, connect, address_decode, subtype]
//! refs:
//!   - "decoded TLM connect target method-subset regression"
//! ---
//!
//! Regression fixture for decoded one-initiator-to-many-target TLM connect
//! where one target is a read-only subtype of the full read/write bus.

/// Parameterized memory transaction bus with optional read and write methods.
bus SubtypeMem
  param READ: const = 1;
  param WRITE: const = 1;

  generate_if READ
    tlm_method read(addr: UInt<32>) -> UInt<64>: blocking;
  end generate_if

  generate_if WRITE
    tlm_method write(addr: UInt<32>, data: UInt<64>) -> Bool: blocking;
  end generate_if
end bus SubtypeMem

/// Makes SubtypeMem available to the modules in this fixture.
use SubtypeMem;

/// Full read/write target for the low address range.
module SubtypeMemRwTarget
  param SLAVE_START_ADDR: const = 32'h0000_0000;
  param SLAVE_END_ADDR: const = 32'h7fff_ffff;
  port clk: in Clock<SysDomain>;
  port rst: in Reset<Sync>;
  port s: target SubtypeMem;

  thread s.read(addr) on clk rising, rst high
    return 64'h1111_0000_0000_0000;
  end thread s.read

  thread s.write(addr, data) on clk rising, rst high
    return data == 64'h1111_0000_0000_0000;
  end thread s.write
end module SubtypeMemRwTarget

/// Read-only target for the high address range.
module SubtypeMemRoTarget
  param SLAVE_START_ADDR: const = 32'h8000_0000;
  param SLAVE_END_ADDR: const = 32'hffff_ffff;
  port clk: in Clock<SysDomain>;
  port rst: in Reset<Sync>;
  port s: target SubtypeMem<WRITE=0>;

  thread s.read(addr) on clk rising, rst high
    return 64'h2222_0000_0000_0000;
  end thread s.read
end module SubtypeMemRoTarget

/// Initiator that exercises implemented and missing target methods.
module SubtypeInitiator
  port clk: in Clock<SysDomain>;
  port rst: in Reset<Sync>;
  port m: initiator SubtypeMem;
  port lo_data_o: out UInt<64>;
  port hi_data_o: out UInt<64>;
  port lo_ack_o: out Bool;
  port hi_ack_o: out Bool;

  reg lo_data: UInt<64> reset rst => 0;
  reg hi_data: UInt<64> reset rst => 0;
  reg lo_ack: Bool reset rst => false;
  reg hi_ack: Bool reset rst => true;

  comb
    lo_data_o = lo_data;
    hi_data_o = hi_data;
    lo_ack_o = lo_ack;
    hi_ack_o = hi_ack;
  end comb

  thread driver on clk rising, rst high
    lo_data <= m.read(32'h0000_1000);
    hi_data <= m.read(32'h8000_1000);
    lo_ack <= m.write(32'h0000_2000, lo_data);
    hi_ack <= m.write(32'h8000_2000, hi_data);
  end thread driver
end module SubtypeInitiator

/// Top-level decoded connect with a read/write and read-only target.
module TlmConnectSubtypeTop
  port clk: in Clock<SysDomain>;
  port rst: in Reset<Sync>;
  port lo_data_o: out UInt<64>;
  port hi_data_o: out UInt<64>;
  port lo_ack_o: out Bool;
  port hi_ack_o: out Bool;

  inst i: SubtypeInitiator
    clk <- clk;
    rst <- rst;
    lo_data_o -> lo_data_o;
    hi_data_o -> hi_data_o;
    lo_ack_o -> lo_ack_o;
    hi_ack_o -> hi_ack_o;
  end inst i

  inst rw_t: SubtypeMemRwTarget
    param SLAVE_START_ADDR = 32'h0000_0000;
    param SLAVE_END_ADDR = 32'h7fff_ffff;
    clk <- clk;
    rst <- rst;
  end inst rw_t

  inst ro_t: SubtypeMemRoTarget
    param SLAVE_START_ADDR = 32'h8000_0000;
    param SLAVE_END_ADDR = 32'hffff_ffff;
    clk <- clk;
    rst <- rst;
  end inst ro_t

  connect i.m -> rw_t.s;
  connect i.m -> ro_t.s;
end module TlmConnectSubtypeTop
