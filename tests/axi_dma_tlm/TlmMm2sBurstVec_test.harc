// HARC testbench for TlmMm2sBurstVec.arch.
//
// The DUT issues two outstanding TLM burst-like requests. This test models
// the target side with cycle-synchronous ready/valid behavior, returns the
// second response first, and checks that out_of_order tag routing lands each
// Vec payload in the right destination register.

domain SysDomain
  freq_mhz: 100
end domain SysDomain

testbench TlmMm2sBurstVecTb
    dut : TlmMm2sBurstVec
end testbench TlmMm2sBurstVecTb

function drive_rsp_vec(dut: TlmMm2sBurstVec, base: uint<32>)
    dut.mem_read_burst_rsp_data_0 = base + 0
    dut.mem_read_burst_rsp_data_1 = base + 1
    dut.mem_read_burst_rsp_data_2 = base + 2
    dut.mem_read_burst_rsp_data_3 = base + 3
end function drive_rsp_vec

function clear_rsp_vec(dut: TlmMm2sBurstVec)
    drive_rsp_vec(dut, 0)
end function clear_rsp_vec

impl TlmMm2sBurstVecHarcTest for TlmMm2sBurstVecTb
    clock clk = SysDomain

    run
        log(info, "TlmMm2sBurstVec HARC test")

        dut.rst = 1
        dut.base_addr = 0x2000
        dut.len0_i = 2
        dut.len1_i = 4
        dut.mem_read_burst_req_ready = 0
        dut.mem_read_burst_rsp_valid = 0
        dut.mem_read_burst_rsp_tag = 0
        clear_rsp_vec(dut)
        wait 4 cycles
        dut.rst = 0
        wait 1 cycle

        let req0_addr : uint<32> = 0
        let req1_addr : uint<32> = 0
        let req0_tag  : uint<32> = 0
        let req1_tag  : uint<32> = 0
        let req0_len  : uint<32> = 0
        let req1_len  : uint<32> = 0
        let req_count : uint<32> = 0
        let rsp1_done : uint<32> = 0
        let rsp0_done : uint<32> = 0

        // HARC resumes after clock edges, so sample each request while the
        // target is still backpressuring it, then pulse ready for one cycle to
        // accept that exact request on the next edge.
        dut.mem_read_burst_req_ready = 0
        for _ in 0 .. 20
            wait 1 cycle
            if dut.mem_read_burst_req_valid && req_count < 2
                if req_count == 0
                    req0_addr = dut.mem_read_burst_addr
                    req0_len = dut.mem_read_burst_len
                    req0_tag = dut.mem_read_burst_req_tag
                    log(info, "req0 addr=0x${req0_addr:08x} len=${req0_len} tag=${req0_tag}")
                else
                    req1_addr = dut.mem_read_burst_addr
                    req1_len = dut.mem_read_burst_len
                    req1_tag = dut.mem_read_burst_req_tag
                    log(info, "req1 addr=0x${req1_addr:08x} len=${req1_len} tag=${req1_tag}")
                end if
                req_count = req_count + 1
                dut.mem_read_burst_req_ready = 1
                wait 1 cycle
                dut.mem_read_burst_req_ready = 0
            end if
        end for

        // Return the second, longer request first. All four lanes are driven;
        // the request length tells consumers how many lanes are meaningful.
        dut.mem_read_burst_rsp_valid = 1
        dut.mem_read_burst_rsp_tag = req1_tag
        drive_rsp_vec(dut, 0xB1000000 | req1_addr)
        for _ in 0 .. 10
            wait 1 cycle

            if dut.mem_read_burst_rsp_valid && dut.mem_read_burst_rsp_ready
                log(info, "rsp tag=${dut.mem_read_burst_rsp_tag} lane0=0x${dut.mem_read_burst_rsp_data_0:08x}")
                if rsp1_done == 0 && dut.mem_read_burst_rsp_tag == req1_tag
                    rsp1_done = 1
                    dut.mem_read_burst_rsp_valid = 0
                    dut.mem_read_burst_rsp_tag = 0
                    clear_rsp_vec(dut)
                end if
            end if
        end for

        // Drop valid for one cycle between responses so the response channel
        // sees a clean second transaction.
        dut.mem_read_burst_rsp_valid = 0
        dut.mem_read_burst_rsp_tag = 0
        clear_rsp_vec(dut)
        wait 1 cycle

        dut.mem_read_burst_rsp_valid = 1
        dut.mem_read_burst_rsp_tag = req0_tag
        drive_rsp_vec(dut, 0xB0000000 | req0_addr)
        for _ in 0 .. 20
            wait 1 cycle

            if dut.mem_read_burst_rsp_valid && dut.mem_read_burst_rsp_ready
                log(info, "rsp tag=${dut.mem_read_burst_rsp_tag} lane0=0x${dut.mem_read_burst_rsp_data_0:08x}")
                if rsp0_done == 0 && dut.mem_read_burst_rsp_tag == req0_tag
                    rsp0_done = 1
                    dut.mem_read_burst_rsp_valid = 0
                    dut.mem_read_burst_rsp_tag = 0
                    clear_rsp_vec(dut)
                end if
            end if
        end for

        dut.mem_read_burst_rsp_valid = 0
        dut.mem_read_burst_rsp_tag = 0
        clear_rsp_vec(dut)
        wait 1 cycle

        let exp0 = 0xB0000000 | req0_addr
        let exp1 = 0xB1000000 | req1_addr

        assert req_count == 2
            else fail("expected 2 requests, observed ${req_count}")
        assert req0_len == 2
            else fail("req0 len=${req0_len}, expected 2")
        assert req1_len == 4
            else fail("req1 len=${req1_len}, expected 4")
        assert dut.data0_0 == exp0 + 0 && dut.data0_1 == exp0 + 1 && dut.data0_2 == exp0 + 2 && dut.data0_3 == exp0 + 3
            else fail("data0 mismatch: got 0x${dut.data0_0:08x},0x${dut.data0_1:08x},0x${dut.data0_2:08x},0x${dut.data0_3:08x}")
        assert dut.data1_0 == exp1 + 0 && dut.data1_1 == exp1 + 1 && dut.data1_2 == exp1 + 2 && dut.data1_3 == exp1 + 3
            else fail("data1 mismatch: got 0x${dut.data1_0:08x},0x${dut.data1_1:08x},0x${dut.data1_2:08x},0x${dut.data1_3:08x}")

        log(info, "PASS: TlmMm2sBurstVec HARC len0=${req0_len} len1=${req1_len} data0[0]=0x${dut.data0_0:08x} data1[3]=0x${dut.data1_3:08x}")
    end run
end impl TlmMm2sBurstVecHarcTest
