// ROM lookup table — sine approximation loaded from hex file
ram RomLutFile
  kind rom;
  latency 1;
  init: file("tests/rom_lut_sine.hex", hex);

  param DEPTH: const = 8;
  param WIDTH: type = UInt<8>;

  port clk: in Clock<CoreDomain>;

  port rd
    addr: in UInt<3>;
    en:   in Bool;
    data: out UInt<8>;
  end port rd
end ram RomLutFile
