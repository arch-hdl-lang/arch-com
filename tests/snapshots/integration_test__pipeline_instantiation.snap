// domain SysDomain
//   freq_mhz: 100

module SimplePipe #(
  parameter int XLEN = 32
) (
  input logic clk,
  input logic rst,
  input logic [XLEN-1:0] data_in,
  output logic [XLEN-1:0] data_out
);

  // ── Stage valid registers ──
  logic fetch_valid_r;
  logic writeback_valid_r;
  
  // ── Stage data registers ──
  logic [XLEN-1:0] fetch_captured = 0;
  logic [XLEN-1:0] writeback_result = 0;
  
  // ── Stage register updates ──
  always_ff @(posedge clk) begin
    if (rst) begin
      fetch_valid_r <= 1'b0;
      fetch_captured <= 0;
      writeback_valid_r <= 1'b0;
      writeback_result <= 0;
    end else begin
      fetch_valid_r <= 1'b1;
      fetch_captured <= data_in;
      writeback_valid_r <= fetch_valid_r;
      writeback_result <= fetch_captured;
    end
  end
  
  // ── Combinational outputs ──
  assign data_out = writeback_result;

endmodule

module Top (
  input logic clk,
  input logic rst,
  input logic [31:0] din,
  output logic [31:0] dout
);

  SimplePipe pipe0 (
    .clk(clk),
    .rst(rst),
    .data_in(din),
    .data_out(dout)
  );

endmodule
