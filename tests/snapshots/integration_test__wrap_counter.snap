source: tests/integration_test.rs
expression: sv
---
// domain SysDomain
//   freq_mhz: 100

module WrapCounter #(
  parameter int MAX = 15
) (
  input logic clk,
  input logic rst,
  input logic inc,
  output logic [3:0] value,
  output logic at_max
);

  logic [3:0] count_r;
  always_ff @(posedge clk) begin
    if (rst) count_r <= 0;
    else if (inc) begin
      if (count_r == 4'(MAX)) count_r <= 0;
      else count_r <= count_r + 1;
    end
  end
  assign value = count_r;
  assign at_max = (count_r == 4'(MAX));
  
  // synopsys translate_off
  _auto_count_range: assert property (@(posedge clk) count_r <= 4'(15))
    else $fatal(1, "COUNTER OVERFLOW: WrapCounter.count_r > MAX");
  // synopsys translate_on

endmodule
