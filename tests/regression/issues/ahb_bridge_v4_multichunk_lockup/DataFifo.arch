fifo DataFifo
  param DEPTH: const = 8;
  param T: type = UInt<32>;
  port clk: in Clock<SysDomain>;
  port rst: in Reset<Async, Low>;
  port push_valid: in Bool;
  port push_ready: out Bool;
  port push_data:  in T;
  port pop_valid:  out Bool;
  port pop_ready:  in Bool;
  port pop_data:   out T;
end fifo DataFifo
