// Test: override reset sync/async at instantiation time via `as Reset<...>`.
// The sub-module declares a concrete reset type; the parent overrides it at
// the connection site without changing the sub-module definition.

module GenCounter
  port clk:   in  Clock<SysDomain>;
  port rst:   in  Reset<Sync>;
  port en:    in  Bool;
  port count: out UInt<8>;

  reg count_r: UInt<8> init 0 reset rst=>0;

  seq on clk rising
    if en
      count_r <= (count_r + 1).trunc<8>();
    end if
  end seq

  comb
    count = count_r;
  end comb

end module GenCounter

module ParamResetTop
  port clk:         in  Clock<SysDomain>;
  port rst_sync:    in  Reset<Sync>;
  port rst_async_n: in  Reset<Async, Low>;
  port en_a:        in  Bool;
  port en_b:        in  Bool;
  port count_a:     out UInt<8>;
  port count_b:     out UInt<8>;

  wire cnt_a: UInt<8>;
  wire cnt_b: UInt<8>;

  // Instance A: use the default Sync reset (no override needed)
  inst sync_inst: GenCounter
    clk <- clk; rst <- rst_sync; en <- en_a;
    count -> cnt_a;
  end inst sync_inst

  // Instance B: override to Async, active-low at the connection site
  inst async_inst: GenCounter
    clk <- clk; rst <- rst_async_n as Reset<Async, Low>; en <- en_b;
    count -> cnt_b;
  end inst async_inst

  comb
    count_a = cnt_a;
    count_b = cnt_b;
  end comb

end module ParamResetTop
