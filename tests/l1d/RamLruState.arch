// LRU pseudo-tree state SRAM — one 7-bit tree per set.
// 7 bits = WAYS-1 internal nodes for 8-way pseudo-LRU tree.
// Bit layout: tree[6:0] where bit i steers left(0)/right(1) at node i.
ram RamLruState
  kind simple_dual;
  latency 1;
  param DEPTH: const = 64;
  param T: type  = UInt<7>;
  port clk: in Clock<SysDomain>;
  store
    buf: Vec<T, DEPTH>;
  end store
  ports rd_port
    en:    in  Bool;
    addr:  in  UInt<6>;
    rdata: out T;
  end ports rd_port
  ports wr_port
    en:    in  Bool;
    addr:  in  UInt<6>;
    wdata: in  T;
  end ports wr_port
end ram RamLruState
