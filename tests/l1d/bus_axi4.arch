// AXI4 bus — directions from cache initiator (master) perspective.
// Target (memory controller) sees all directions flipped.
// Subset: no LOCK, PROT, CACHE, QOS, REGION, USER signals.
bus BusAxi4
  param ADDR_W: const = 64;
  param DATA_W: const = 64;
  param ID_W:   const = 4;

  // Write address channel
  aw_valid: out Bool;
  aw_ready: in  Bool;
  aw_addr:  out UInt<ADDR_W>;
  aw_id:    out UInt<ID_W>;
  aw_len:   out UInt<8>;
  aw_size:  out UInt<3>;
  aw_burst: out UInt<2>;

  // Write data channel
  w_valid:  out Bool;
  w_ready:  in  Bool;
  w_data:   out UInt<DATA_W>;
  w_strb:   out UInt<8>;
  w_last:   out Bool;

  // Write response channel
  b_valid:  in  Bool;
  b_ready:  out Bool;
  b_id:     in  UInt<ID_W>;
  b_resp:   in  UInt<2>;

  // Read address channel
  ar_valid: out Bool;
  ar_ready: in  Bool;
  ar_addr:  out UInt<ADDR_W>;
  ar_id:    out UInt<ID_W>;
  ar_len:   out UInt<8>;
  ar_size:  out UInt<3>;
  ar_burst: out UInt<2>;

  // Read data channel
  r_valid:  in  Bool;
  r_ready:  out Bool;
  r_data:   in  UInt<DATA_W>;
  r_id:     in  UInt<ID_W>;
  r_resp:   in  UInt<2>;
  r_last:   in  Bool;
end bus BusAxi4
