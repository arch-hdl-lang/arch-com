// Data SRAM — stores cache line words across all ways.
// Address = {set_index[5:0], way_index[2:0], word_offset[2:0]} = 12 bits
// Depth = SETS(64) x WAYS(8) x WORDS_PER_LINE(8) = 4096 entries
// Byte-enable masking is done externally (RMW in the controller).
ram RamDataArray
  kind simple_dual;
  latency 1;
  param DEPTH: const = 4096;
  param WIDTH: type  = UInt<64>;
  port clk: in Clock<SysDomain>;
  store
    buf: Vec<WIDTH, DEPTH>;
  end store
  ports rd_port
    en:    in  Bool;
    addr:  in  UInt<12>;
    rdata: out WIDTH;
  end ports rd_port
  ports wr_port
    en:    in  Bool;
    addr:  in  UInt<12>;
    wdata: in  WIDTH;
  end ports wr_port
end ram RamDataArray
