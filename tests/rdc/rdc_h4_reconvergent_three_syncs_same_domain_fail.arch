// H4 (phase 2c): three reset synchronisers, all from the same source,
// all into the same destination domain. Same hazard as H1, just
// degree-3 reconvergence.

domain Src
  freq_mhz: 100
end domain Src

domain Dst
  freq_mhz: 200
end domain Dst

synchronizer RstSync
  kind reset;
  param STAGES: const = 2;
  port src_clk:  in Clock<Src>;
  port dst_clk:  in Clock<Dst>;
  port data_in:  in Bool;
  port data_out: out Bool;
end synchronizer RstSync

module M
  port src_clk: in Clock<Src>;
  port dst_clk: in Clock<Dst>;
  port raw_rst: in Bool;
  port o1: out Bool;
  port o2: out Bool;
  port o3: out Bool;

  inst sync_1: RstSync
    src_clk  <- src_clk;
    dst_clk  <- dst_clk;
    data_in  <- raw_rst;
    data_out -> r1;
  end inst sync_1

  inst sync_2: RstSync
    src_clk  <- src_clk;
    dst_clk  <- dst_clk;
    data_in  <- raw_rst;
    data_out -> r2;
  end inst sync_2

  inst sync_3: RstSync
    src_clk  <- src_clk;
    dst_clk  <- dst_clk;
    data_in  <- raw_rst;
    data_out -> r3;
  end inst sync_3

  let o1 = r1;
  let o2 = r2;
  let o3 = r3;
end module M
