domain D
  freq_mhz: 100
end domain D
module M
  port clk: in Clock<D>;
  port rst_a: in Reset<Async>;
  port d: in UInt<8>;
  port q: out UInt<8>;
  reg r1: UInt<8> reset rst_a => 0;
  reg r2: UInt<8> reset rst_a => 0;
  reg r3: UInt<8> reset rst_a => 0;
  seq on clk rising
    r1 <= d;
    r2 <= r1;
    r3 <= r2;
  end seq
  let q = r3;
end module M
