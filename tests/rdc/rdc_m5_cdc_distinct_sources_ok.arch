// M5 (sanity): two synchronisers in the same destination clock
// domain whose `data_in` signals trace back to *different* terminal
// source registers. No common source → no reconvergence. The new
// source-tracing pass must not over-report this case.

domain Src
  freq_mhz: 100
end domain Src

domain Dst
  freq_mhz: 200
end domain Dst

synchronizer FlagSync
  kind ff;
  param STAGES: const = 2;
  port src_clk:  in Clock<Src>;
  port dst_clk:  in Clock<Dst>;
  port data_in:  in Bool;
  port data_out: out Bool;
end synchronizer FlagSync

module M
  port src_clk: in Clock<Src>;
  port dst_clk: in Clock<Dst>;
  port flag_a:  in Bool;
  port flag_b:  in Bool;
  port out_a:   out Bool;
  port out_b:   out Bool;

  inst sync_a: FlagSync
    src_clk  <- src_clk;
    dst_clk  <- dst_clk;
    data_in  <- flag_a;
    data_out -> sync_a_out;
  end inst sync_a

  inst sync_b: FlagSync
    src_clk  <- src_clk;
    dst_clk  <- dst_clk;
    data_in  <- flag_b;
    data_out -> sync_b_out;
  end inst sync_b

  let out_a = sync_a_out;
  let out_b = sync_b_out;
end module M
