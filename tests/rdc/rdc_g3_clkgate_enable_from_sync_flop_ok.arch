// G3 (phase 2b): enable sourced from a sync-reset flop whose own data
// comes from an input port. Sync flop's reach is empty (no async
// upstream); reach for enable is empty → no violation.

domain D
  freq_mhz: 100
end domain D

clkgate IcgCell
  kind latch;
  port clk_in:  in Clock<D>;
  port enable:  in Bool;
  port test_en: in Bool;
  port clk_out: out Clock<D>;
end clkgate IcgCell

module M
  port clk:       in Clock<D>;
  port rst_s:     in Reset<Sync>;
  port want_gate: in Bool;
  port gated_clk: out Clock<D>;

  reg gate_en: Bool reset rst_s => false;

  seq on clk rising
    gate_en <= want_gate;
  end seq

  inst icg: IcgCell
    clk_in  <- clk;
    enable  <- gate_en;
    test_en <- false;
    clk_out -> gated_clk;
  end inst icg
end module M
