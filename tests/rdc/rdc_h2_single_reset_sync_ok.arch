// H2 (phase 2c sanity): one source through ONE reset synchroniser.
// No reconvergence — only one synced output.

domain Src
  freq_mhz: 100
end domain Src

domain Dst
  freq_mhz: 200
end domain Dst

synchronizer RstSync
  kind reset;
  param STAGES: const = 2;
  port src_clk:  in Clock<Src>;
  port dst_clk:  in Clock<Dst>;
  port data_in:  in Bool;
  port data_out: out Bool;
end synchronizer RstSync

module M
  port src_clk: in Clock<Src>;
  port dst_clk: in Clock<Dst>;
  port raw_rst: in Bool;
  port out_a:   out Bool;

  inst sync_a: RstSync
    src_clk  <- src_clk;
    dst_clk  <- dst_clk;
    data_in  <- raw_rst;
    data_out -> rst_a;
  end inst sync_a

  let out_a = rst_a;
end module M
