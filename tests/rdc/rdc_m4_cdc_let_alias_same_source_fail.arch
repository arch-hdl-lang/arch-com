// M4 (CDC reconvergence, let-binding indirection): one synchroniser
// reads the source port directly, another reads a `let` alias that
// reduces to the same port. The source-tracing pass has to walk
// through the let binding to recognise both inputs as one source.

domain Src
  freq_mhz: 100
end domain Src

domain Dst
  freq_mhz: 200
end domain Dst

synchronizer FlagSync
  kind ff;
  param STAGES: const = 2;
  port src_clk:  in Clock<Src>;
  port dst_clk:  in Clock<Dst>;
  port data_in:  in Bool;
  port data_out: out Bool;
end synchronizer FlagSync

module M
  port src_clk:  in Clock<Src>;
  port dst_clk:  in Clock<Dst>;
  port src_flag: in Bool;
  port out_a:    out Bool;
  port out_b:    out Bool;

  let aliased_flag: Bool = src_flag;

  inst sync_a: FlagSync
    src_clk  <- src_clk;
    dst_clk  <- dst_clk;
    data_in  <- src_flag;
    data_out -> flag_a;
  end inst sync_a

  inst sync_b: FlagSync
    src_clk  <- src_clk;
    dst_clk  <- dst_clk;
    data_in  <- aliased_flag;
    data_out -> flag_b;
  end inst sync_b

  let out_a = flag_a;
  let out_b = flag_b;
end module M
