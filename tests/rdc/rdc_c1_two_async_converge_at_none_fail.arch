domain D
  freq_mhz: 100
end domain D
module M
  port clk: in Clock<D>;
  port rst_a: in Reset<Async>;
  port rst_b: in Reset<Async>;
  port da: in UInt<8>;
  port db: in UInt<8>;
  port q: out UInt<8>;
  reg ra: UInt<8> reset rst_a => 0;
  reg rb: UInt<8> reset rst_b => 0;
  reg rx: UInt<8> init 0 reset none;
  seq on clk rising
    ra <= da;
  end seq
  seq on clk rising
    rb <= db;
  end seq
  seq on clk rising
    rx <= (ra + rb).trunc<8>();
  end seq
  let q = rx;
end module M
