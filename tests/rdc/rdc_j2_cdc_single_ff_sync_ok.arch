// J2 (CDC sanity): one source through ONE ff-synchroniser → no
// reconvergence.

domain Src
  freq_mhz: 100
end domain Src

domain Dst
  freq_mhz: 200
end domain Dst

synchronizer FlagSync
  kind ff;
  param STAGES: const = 2;
  port src_clk:  in Clock<Src>;
  port dst_clk:  in Clock<Dst>;
  port data_in:  in Bool;
  port data_out: out Bool;
end synchronizer FlagSync

module M
  port src_clk: in Clock<Src>;
  port dst_clk: in Clock<Dst>;
  port flag:    in Bool;
  port out_a:   out Bool;

  inst sync_a: FlagSync
    src_clk  <- src_clk;
    dst_clk  <- dst_clk;
    data_in  <- flag;
    data_out -> flag_a;
  end inst sync_a

  let out_a = flag_a;
end module M
