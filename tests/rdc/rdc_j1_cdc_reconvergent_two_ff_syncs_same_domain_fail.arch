// J1 (CDC reconvergence): one data signal routed through TWO `kind ff`
// synchronisers both targeting the same destination clock domain.
// The two synced outputs can settle on different cycles → downstream
// logic that consumes both lands in inconsistent state during the
// convergence window. The same hazard as RDC reconvergence (group H),
// just with data synchronisers instead of reset synchronisers.

domain Src
  freq_mhz: 100
end domain Src

domain Dst
  freq_mhz: 200
end domain Dst

synchronizer FlagSync
  kind ff;
  param STAGES: const = 2;
  port src_clk:  in Clock<Src>;
  port dst_clk:  in Clock<Dst>;
  port data_in:  in Bool;
  port data_out: out Bool;
end synchronizer FlagSync

module M
  port src_clk: in Clock<Src>;
  port dst_clk: in Clock<Dst>;
  port flag:    in Bool;
  port out_a:   out Bool;
  port out_b:   out Bool;

  inst sync_a: FlagSync
    src_clk  <- src_clk;
    dst_clk  <- dst_clk;
    data_in  <- flag;
    data_out -> flag_a;
  end inst sync_a

  inst sync_b: FlagSync
    src_clk  <- src_clk;
    dst_clk  <- dst_clk;
    data_in  <- flag;
    data_out -> flag_b;
  end inst sync_b

  let out_a = flag_a;
  let out_b = flag_b;
end module M
