// G1 (phase 2b): an async-reset flop drives a clkgate's enable input.
// On rst_a's async assertion the flop output toggles to its reset
// value mid-cycle, glitching the gate's `en` and producing partial
// clock pulses on `gated_clk`. Should be flagged.

domain D
  freq_mhz: 100
end domain D

clkgate IcgCell
  kind latch;
  port clk_in:  in Clock<D>;
  port enable:  in Bool;
  port test_en: in Bool;
  port clk_out: out Clock<D>;
end clkgate IcgCell

module M
  port clk:        in Clock<D>;
  port rst_a:      in Reset<Async>;
  port want_gate:  in Bool;
  port gated_clk:  out Clock<D>;

  reg gate_en: Bool reset rst_a => false;

  seq on clk rising
    gate_en <= want_gate;
  end seq

  inst icg: IcgCell
    clk_in  <- clk;
    enable  <- gate_en;
    test_en <- false;
    clk_out -> gated_clk;
  end inst icg
end module M
