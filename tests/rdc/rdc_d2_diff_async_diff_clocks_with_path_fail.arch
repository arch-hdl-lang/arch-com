domain DA
  freq_mhz: 100
end domain DA
domain DB
  freq_mhz: 200
end domain DB
module M
  pragma cdc_safe;
  port clk_a: in Clock<DA>;
  port clk_b: in Clock<DB>;
  port rst_a: in Reset<Async>;
  port rst_b: in Reset<Async>;
  port da: in UInt<8>;
  port q:  out UInt<8>;
  reg ra: UInt<8> reset rst_a => 0;
  reg rb: UInt<8> reset rst_b => 0;
  seq on clk_a rising
    ra <= da;
  end seq
  seq on clk_b rising
    rb <= ra;
  end seq
  let q = rb;
end module M
