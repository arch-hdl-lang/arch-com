// M1 (CDC reconvergence, bit-slice): two `kind ff` synchronisers in
// the same destination clock domain, each driven by a different bit
// of the *same* source vector. The Aldec article 2140 case study —
// splitting a bus across multiple synchronisers loses the inter-bit
// timing relationship at the destination, exactly the same
// reconvergence hazard as J1 but masked by the indexing.

domain Src
  freq_mhz: 100
end domain Src

domain Dst
  freq_mhz: 200
end domain Dst

synchronizer FlagSync
  kind ff;
  param STAGES: const = 2;
  port src_clk:  in Clock<Src>;
  port dst_clk:  in Clock<Dst>;
  port data_in:  in Bool;
  port data_out: out Bool;
end synchronizer FlagSync

module M
  port src_clk: in Clock<Src>;
  port dst_clk: in Clock<Dst>;
  port flags:   in Vec<Bool, 4>;
  port out_a:   out Bool;
  port out_b:   out Bool;

  inst sync_a: FlagSync
    src_clk  <- src_clk;
    dst_clk  <- dst_clk;
    data_in  <- flags[0];
    data_out -> flag_a;
  end inst sync_a

  inst sync_b: FlagSync
    src_clk  <- src_clk;
    dst_clk  <- dst_clk;
    data_in  <- flags[1];
    data_out -> flag_b;
  end inst sync_b

  let out_a = flag_a;
  let out_b = flag_b;
end module M
