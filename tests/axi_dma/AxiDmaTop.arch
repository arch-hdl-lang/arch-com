// PG021-compatible AXI DMA — top-level integration (Simple DMA mode).
// Two independent channels: MM2S (mem→stream) and S2MM (stream→mem).
module AxiDmaTop
  port clk: in Clock<SysDomain>;
  port rst: in Reset<Sync>;

  // ── AXI4-Lite slave (register access) ───────────────────────────────
  port s_awaddr:  in UInt<8>;
  port s_awvalid: in Bool;
  port s_awready: out Bool;
  port s_wdata:   in UInt<32>;
  port s_wstrb:   in UInt<4>;
  port s_wvalid:  in Bool;
  port s_wready:  out Bool;
  port s_bresp:   out UInt<2>;
  port s_bvalid:  out Bool;
  port s_bready:  in Bool;
  port s_araddr:  in UInt<8>;
  port s_arvalid: in Bool;
  port s_arready: out Bool;
  port s_rdata:   out UInt<32>;
  port s_rresp:   out UInt<2>;
  port s_rvalid:  out Bool;
  port s_rready:  in Bool;

  // ── AXI4 Read Master (MM2S memory reads) ────────────────────────────
  port mm2s_ar_valid: out Bool;
  port mm2s_ar_ready: in  Bool;
  port mm2s_ar_addr:  out UInt<32>;
  port mm2s_ar_len:   out UInt<8>;
  port mm2s_ar_size:  out UInt<3>;
  port mm2s_ar_burst: out UInt<2>;
  port mm2s_r_valid:  in  Bool;
  port mm2s_r_ready:  out Bool;
  port mm2s_r_data:   in  UInt<32>;
  port mm2s_r_last:   in  Bool;

  // ── AXI4 Write Master (S2MM memory writes) ──────────────────────────
  port s2mm_aw_valid: out Bool;
  port s2mm_aw_ready: in  Bool;
  port s2mm_aw_addr:  out UInt<32>;
  port s2mm_aw_len:   out UInt<8>;
  port s2mm_aw_size:  out UInt<3>;
  port s2mm_aw_burst: out UInt<2>;
  port s2mm_w_valid:  out Bool;
  port s2mm_w_ready:  in  Bool;
  port s2mm_w_data:   out UInt<32>;
  port s2mm_w_strb:   out UInt<4>;
  port s2mm_w_last:   out Bool;
  port s2mm_b_valid:  in  Bool;
  port s2mm_b_ready:  out Bool;

  // ── AXI4-Stream Master (MM2S output) ────────────────────────────────
  port m_axis_tvalid: out Bool;
  port m_axis_tready: in  Bool;
  port m_axis_tdata:  out UInt<32>;
  port m_axis_tlast:  out Bool;
  port m_axis_tkeep:  out UInt<4>;

  // ── AXI4-Stream Slave (S2MM input) ──────────────────────────────────
  port s_axis_tvalid: in  Bool;
  port s_axis_tready: out Bool;
  port s_axis_tdata:  in  UInt<32>;
  port s_axis_tlast:  in  Bool;

  // ── Interrupts ──────────────────────────────────────────────────────
  port mm2s_introut: out Bool;
  port s2mm_introut: out Bool;

  // ── Internal wires ──────────────────────────────────────────────────

  // Register block ↔ FSMs
  wire mm2s_start_w:     Bool;
  wire mm2s_src_addr_w:  UInt<32>;
  wire mm2s_num_beats_w: UInt<8>;
  wire mm2s_done_w:      Bool;
  wire mm2s_halted_w:    Bool;
  wire mm2s_idle_w:      Bool;

  wire s2mm_start_w:     Bool;
  wire s2mm_dst_addr_w:  UInt<32>;
  wire s2mm_num_beats_w: UInt<8>;
  wire s2mm_done_w:      Bool;
  wire s2mm_halted_w:    Bool;
  wire s2mm_idle_w:      Bool;

  wire mm2s_introut_w: Bool;
  wire s2mm_introut_w: Bool;

  // Register block AXI-Lite outputs
  wire s_awready_w: Bool;
  wire s_wready_w:  Bool;
  wire s_bresp_w:   UInt<2>;
  wire s_bvalid_w:  Bool;
  wire s_arready_w: Bool;
  wire s_rdata_w:   UInt<32>;
  wire s_rresp_w:   UInt<2>;
  wire s_rvalid_w:  Bool;

  // MM2S FIFO wires
  wire mm2s_push_valid_w: Bool;
  wire mm2s_push_ready_w: Bool;
  wire mm2s_push_data_w:  UInt<32>;
  wire mm2s_pop_valid_w:  Bool;
  wire mm2s_pop_ready_w:  Bool;
  wire mm2s_pop_data_w:   UInt<32>;

  // S2MM FIFO wires
  wire s2mm_push_valid_w: Bool;
  wire s2mm_push_ready_w: Bool;
  wire s2mm_push_data_w:  UInt<32>;
  wire s2mm_pop_valid_w:  Bool;
  wire s2mm_pop_ready_w:  Bool;
  wire s2mm_pop_data_w:   UInt<32>;

  // MM2S AXI4 read wires
  wire mm2s_ar_valid_w: Bool;
  wire mm2s_ar_addr_w:  UInt<32>;
  wire mm2s_ar_len_w:   UInt<8>;
  wire mm2s_ar_size_w:  UInt<3>;
  wire mm2s_ar_burst_w: UInt<2>;
  wire mm2s_r_ready_w:  Bool;

  // S2MM AXI4 write wires
  wire s2mm_aw_valid_w: Bool;
  wire s2mm_aw_addr_w:  UInt<32>;
  wire s2mm_aw_len_w:   UInt<8>;
  wire s2mm_aw_size_w:  UInt<3>;
  wire s2mm_aw_burst_w: UInt<2>;
  wire s2mm_w_valid_w:  Bool;
  wire s2mm_w_data_w:   UInt<32>;
  wire s2mm_w_strb_w:   UInt<4>;
  wire s2mm_w_last_w:   Bool;
  wire s2mm_b_ready_w:  Bool;

  // Stream beat counters
  reg mm2s_stream_ctr: UInt<8> reset rst=>0;
  reg s2mm_recv_ctr:   UInt<8> reset rst=>0;

  default seq on clk rising;

  // ── Instances ───────────────────────────────────────────────────────

  inst regs: AxiLiteRegs
    clk <- clk;
    rst <- rst;
    awaddr_i  <- s_awaddr;
    awvalid_i <- s_awvalid;
    awready_o -> s_awready_w;
    wdata_i   <- s_wdata;
    wstrb_i   <- s_wstrb;
    wvalid_i  <- s_wvalid;
    wready_o  -> s_wready_w;
    bresp_o   -> s_bresp_w;
    bvalid_o  -> s_bvalid_w;
    bready_i  <- s_bready;
    araddr_i  <- s_araddr;
    arvalid_i <- s_arvalid;
    arready_o -> s_arready_w;
    rdata_o   -> s_rdata_w;
    rresp_o   -> s_rresp_w;
    rvalid_o  -> s_rvalid_w;
    rready_i  <- s_rready;
    mm2s_start     -> mm2s_start_w;
    mm2s_src_addr  -> mm2s_src_addr_w;
    mm2s_num_beats -> mm2s_num_beats_w;
    mm2s_done   <- mm2s_done_w;
    mm2s_halted <- mm2s_halted_w;
    mm2s_idle   <- mm2s_idle_w;
    s2mm_start     -> s2mm_start_w;
    s2mm_dst_addr  -> s2mm_dst_addr_w;
    s2mm_num_beats -> s2mm_num_beats_w;
    s2mm_done   <- s2mm_done_w;
    s2mm_halted <- s2mm_halted_w;
    s2mm_idle   <- s2mm_idle_w;
    mm2s_introut -> mm2s_introut_w;
    s2mm_introut -> s2mm_introut_w;
  end inst regs

  inst mm2s_fsm: FsmMm2s
    clk <- clk;
    rst <- rst;
    start     <- mm2s_start_w;
    src_addr  <- mm2s_src_addr_w;
    num_beats <- mm2s_num_beats_w;
    done      -> mm2s_done_w;
    halted    -> mm2s_halted_w;
    idle_out  -> mm2s_idle_w;
    ar_valid  -> mm2s_ar_valid_w;
    ar_ready  <- mm2s_ar_ready;
    ar_addr   -> mm2s_ar_addr_w;
    ar_len    -> mm2s_ar_len_w;
    ar_size   -> mm2s_ar_size_w;
    ar_burst  -> mm2s_ar_burst_w;
    r_valid   <- mm2s_r_valid;
    r_ready   -> mm2s_r_ready_w;
    r_data    <- mm2s_r_data;
    r_last    <- mm2s_r_last;
    push_valid -> mm2s_push_valid_w;
    push_ready <- mm2s_push_ready_w;
    push_data  -> mm2s_push_data_w;
  end inst mm2s_fsm

  inst mm2s_fifo: Mm2sFifo
    clk <- clk;
    rst <- rst;
    push_valid <- mm2s_push_valid_w;
    push_ready -> mm2s_push_ready_w;
    push_data  <- mm2s_push_data_w;
    pop_valid  -> mm2s_pop_valid_w;
    pop_ready  <- mm2s_pop_ready_w;
    pop_data   -> mm2s_pop_data_w;
  end inst mm2s_fifo

  inst s2mm_fifo: S2mmFifo
    clk <- clk;
    rst <- rst;
    push_valid <- s2mm_push_valid_w;
    push_ready -> s2mm_push_ready_w;
    push_data  <- s2mm_push_data_w;
    pop_valid  -> s2mm_pop_valid_w;
    pop_ready  <- s2mm_pop_ready_w;
    pop_data   -> s2mm_pop_data_w;
  end inst s2mm_fifo

  inst s2mm_fsm: FsmS2mm
    clk <- clk;
    rst <- rst;
    start      <- s2mm_start_w;
    dst_addr   <- s2mm_dst_addr_w;
    num_beats  <- s2mm_num_beats_w;
    recv_count <- s2mm_recv_ctr;
    done       -> s2mm_done_w;
    halted     -> s2mm_halted_w;
    idle_out   -> s2mm_idle_w;
    pop_valid  <- s2mm_pop_valid_w;
    pop_ready  -> s2mm_pop_ready_w;
    pop_data   <- s2mm_pop_data_w;
    aw_valid   -> s2mm_aw_valid_w;
    aw_ready   <- s2mm_aw_ready;
    aw_addr    -> s2mm_aw_addr_w;
    aw_len     -> s2mm_aw_len_w;
    aw_size    -> s2mm_aw_size_w;
    aw_burst   -> s2mm_aw_burst_w;
    w_valid    -> s2mm_w_valid_w;
    w_ready    <- s2mm_w_ready;
    w_data     -> s2mm_w_data_w;
    w_strb     -> s2mm_w_strb_w;
    w_last     -> s2mm_w_last_w;
    b_valid    <- s2mm_b_valid;
    b_ready    -> s2mm_b_ready_w;
  end inst s2mm_fsm

  // ── Stream wiring + beat counters ───────────────────────────────────

  // MM2S: FIFO pop → AXI4-Stream output
  comb
    m_axis_tdata  = mm2s_pop_data_w;
    m_axis_tvalid = mm2s_pop_valid_w;
    m_axis_tkeep  = 0xF;
    mm2s_pop_ready_w = m_axis_tready;
    m_axis_tlast  = mm2s_pop_valid_w & (mm2s_stream_ctr == (mm2s_num_beats_w - 1).trunc<8>());
  end comb

  // S2MM: AXI4-Stream input → FIFO push
  comb
    s2mm_push_data_w  = s_axis_tdata;
    s2mm_push_valid_w = s_axis_tvalid;
    s_axis_tready     = s2mm_push_ready_w;
  end comb

  // Route register block AXI-Lite outputs to top ports
  comb
    s_awready = s_awready_w;
    s_wready  = s_wready_w;
    s_bresp   = s_bresp_w;
    s_bvalid  = s_bvalid_w;
    s_arready = s_arready_w;
    s_rdata   = s_rdata_w;
    s_rresp   = s_rresp_w;
    s_rvalid  = s_rvalid_w;
  end comb

  // Route AXI4 read master (MM2S)
  comb
    mm2s_ar_valid = mm2s_ar_valid_w;
    mm2s_ar_addr  = mm2s_ar_addr_w;
    mm2s_ar_len   = mm2s_ar_len_w;
    mm2s_ar_size  = mm2s_ar_size_w;
    mm2s_ar_burst = mm2s_ar_burst_w;
    mm2s_r_ready  = mm2s_r_ready_w;
  end comb

  // Route AXI4 write master (S2MM)
  comb
    s2mm_aw_valid = s2mm_aw_valid_w;
    s2mm_aw_addr  = s2mm_aw_addr_w;
    s2mm_aw_len   = s2mm_aw_len_w;
    s2mm_aw_size  = s2mm_aw_size_w;
    s2mm_aw_burst = s2mm_aw_burst_w;
    s2mm_w_valid  = s2mm_w_valid_w;
    s2mm_w_data   = s2mm_w_data_w;
    s2mm_w_strb   = s2mm_w_strb_w;
    s2mm_w_last   = s2mm_w_last_w;
    s2mm_b_ready  = s2mm_b_ready_w;
  end comb

  // Route interrupts
  comb
    mm2s_introut = mm2s_introut_w;
    s2mm_introut = s2mm_introut_w;
  end comb

  // ── Beat counters (registered) ──────────────────────────────────────

  seq
    // MM2S stream output beat counter — counts pops for tlast generation
    if mm2s_start_w
      mm2s_stream_ctr <= 0;
    elsif mm2s_pop_valid_w & m_axis_tready
      mm2s_stream_ctr <= (mm2s_stream_ctr + 1).trunc<8>();
    end if

    // S2MM stream input beat counter — counts received beats
    if s2mm_start_w
      s2mm_recv_ctr <= 0;
    elsif s_axis_tvalid & s2mm_push_ready_w
      s2mm_recv_ctr <= (s2mm_recv_ctr + 1).trunc<8>();
    end if
  end seq

end module AxiDmaTop
