// AXI4 write-only master bus (AW + W + B channels).
// Direction: from initiator (master) perspective.
bus BusAxi4Write
  param ADDR_W: const = 32;
  param DATA_W: const = 32;
  param ID_W:   const = 1;

  // Write address channel
  aw_valid: out Bool;
  aw_ready: in  Bool;
  aw_addr:  out UInt<ADDR_W>;
  aw_id:    out UInt<ID_W>;
  aw_len:   out UInt<8>;
  aw_size:  out UInt<3>;
  aw_burst: out UInt<2>;

  // Write data channel
  w_valid:  out Bool;
  w_ready:  in  Bool;
  w_data:   out UInt<DATA_W>;
  w_strb:   out UInt<4>;
  w_last:   out Bool;

  // Write response channel
  b_valid:  in  Bool;
  b_ready:  out Bool;
  b_id:     in  UInt<ID_W>;
  b_resp:   in  UInt<2>;
end bus BusAxi4Write
