// S2MM channel FSM — pops data from FIFO, writes to memory via AXI4.
// States: Idle → WaitRecv → SendAW → SendW → WaitB → Done
fsm FsmS2mm
  port clk: in Clock<SysDomain>;
  port rst: in Reset<Sync>;

  // Control interface (from register block)
  port start:      in  Bool;
  port dst_addr:   in  UInt<32>;
  port num_beats:  in  UInt<8>;
  port recv_count: in  UInt<8>;

  // Status outputs
  port done:     out Bool;
  port halted:   out Bool;
  port idle_out: out Bool;

  // FIFO pop interface
  port pop_valid: in  Bool;
  port pop_ready: out Bool;
  port pop_data:  in  UInt<32>;

  // AXI4 Write Master
  port axi_wr: initiator BusAxi4Write;

  // Internal registers
  reg dst_addr_r:  UInt<32> reset none;
  reg num_beats_r: UInt<8>  reset none;
  reg beat_ctr_r:  UInt<8>  reset rst=>0;

  state [Idle, WaitRecv, SendAW, SendW, WaitB, Done]
  default state Idle;
  default seq on clk rising;

  default
    comb
      done      = false;
      halted    = false;
      idle_out  = false;
      pop_ready = false;
      axi_wr.aw_valid = false;
      axi_wr.aw_addr  = 0;
      axi_wr.aw_len   = 0;
      axi_wr.aw_size  = 0;
      axi_wr.aw_burst = 0;
      axi_wr.aw_id    = 0;
      axi_wr.w_valid  = false;
      axi_wr.w_data   = 0;
      axi_wr.w_strb   = 0;
      axi_wr.w_last   = false;
      axi_wr.b_ready  = false;
    end comb
  end default

  state Idle
    comb
      halted   = true;
      idle_out = true;
    end comb
    seq
      if start
        dst_addr_r  <= dst_addr;
        num_beats_r <= num_beats;
        beat_ctr_r  <= 0;
      end if
    end seq
    -> WaitRecv when start;
  end state Idle

  state WaitRecv
    -> SendAW when recv_count >= num_beats_r;
  end state WaitRecv

  state SendAW
    comb
      axi_wr.aw_valid = true;
      axi_wr.aw_addr  = dst_addr_r;
      axi_wr.aw_len   = (num_beats_r - 1).trunc<8>();
      axi_wr.aw_size  = 2;
      axi_wr.aw_burst = 1;
    end comb
    -> SendW when axi_wr.aw_ready;
  end state SendAW

  state SendW
    comb
      axi_wr.w_valid = pop_valid;
      axi_wr.w_data  = pop_data;
      axi_wr.w_strb  = 0xF;
      axi_wr.w_last  = (beat_ctr_r == (num_beats_r - 1).trunc<8>());
      pop_ready      = axi_wr.w_ready;
    end comb
    seq
      if axi_wr.w_ready & pop_valid
        beat_ctr_r <= (beat_ctr_r + 1).trunc<8>();
      end if
    end seq
    -> WaitB when axi_wr.w_ready & pop_valid & axi_wr.w_last;
  end state SendW

  state WaitB
    comb
      axi_wr.b_ready = true;
    end comb
    -> Done when axi_wr.b_valid;
  end state WaitB

  state Done
    comb
      done = true;
    end comb
    -> Idle when true;
  end state Done

end fsm FsmS2mm
