// Test for +: and -: part-select syntax
module PartSelectTest
  port clk: in Clock<SysDomain>;
  port rst: in Reset<Sync>;
  port data_in:  in  UInt<32>;
  port offset:   in  UInt<5>;
  // +: extract: data_in[offset +: 8]
  port byte_out: out UInt<8>;
  // -: extract: data_in[offset -: 8]  (offset = MSB)
  port byte_msb_out: out UInt<8>;
  // static +: extract: data_in[16 +: 8]
  port hi_byte: out UInt<8>;

  comb
    byte_out     = data_in[offset +: 8];
    byte_msb_out = data_in[offset -: 8];
    hi_byte      = data_in[16 +: 8];
  end comb
end module PartSelectTest
