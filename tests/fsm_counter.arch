// Simple FSM with datapath registers to test reg/seq in FSM

fsm FsmCounter
  port clk:    in Clock<SysDomain>;
  port rst:    in Reset<Sync>;
  port go:     in Bool;
  port target: in UInt<8>;
  port done:   out Bool;
  port count:  out UInt<8>;

  reg cnt_r: UInt<8> init 0 reset rst;
  reg tgt_r: UInt<8> init 0 reset rst;

  state Idle, Counting, Done;
  default state Idle;

  state Idle
    comb
      done = false;
      count = cnt_r;
    end comb

    seq on clk rising
      if go
        cnt_r <= 0;
        tgt_r <= target;
      end if
    end seq

    transition to Counting when go;
    transition to Idle when true;
  end state Idle

  state Counting
    comb
      done = false;
      count = cnt_r;
    end comb

    seq on clk rising
      cnt_r <= (cnt_r + 1).trunc<8>();
    end seq

    transition to Done when cnt_r == tgt_r;
    transition to Counting when true;
  end state Counting

  state Done
    comb
      done = true;
      count = cnt_r;
    end comb

    transition to Idle when true;
  end state Done

end fsm FsmCounter
