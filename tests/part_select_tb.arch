// Sim testbench for +: / -: part-select
module PartSelectTb
  port clk: in Clock<SysDomain>;
  port rst: in Reset<Sync>;

  wire byte_out:     UInt<8>;
  wire byte_msb_out: UInt<8>;
  wire hi_byte:      UInt<8>;

  inst dut: PartSelectTest
    clk          <- clk;
    rst          <- rst;
    data_in      <- 32'hABCDEF12;
    offset       <- 5'h08;
    byte_out     -> byte_out;
    byte_msb_out -> byte_msb_out;
    hi_byte      -> hi_byte;
  end inst dut

  // data_in = 0xABCDEF12, offset = 8
  // byte_out     = data_in[8 +: 8] = bits[15:8] = 0xEF
  // hi_byte      = data_in[16 +: 8] = bits[23:16] = 0xCD
  seq on clk rising
    if byte_out == 8'hEF & hi_byte == 8'hCD
      $display("PASS");
      $finish;
    else
      $display("FAIL: byte_out=0x%h hi_byte=0x%h", byte_out, hi_byte);
      $finish;
    end if
  end seq
end module PartSelectTb
