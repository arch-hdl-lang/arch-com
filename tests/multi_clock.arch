domain FastDomain
  freq_mhz: 200
end domain FastDomain

domain SlowDomain
  freq_mhz: 50
end domain SlowDomain

module MultiClockSync
  port fast_clk: in Clock<FastDomain>;
  port slow_clk: in Clock<SlowDomain>;
  port rst: in Reset<Sync>;
  port data_in: in UInt<8>;
  port data_out: out UInt<8>;
  port fast_count: out UInt<8>;

  reg fast_r: UInt<8> init 0 reset rst;
  reg slow_r: UInt<8> init 0 reset rst;

  seq on fast_clk rising
    fast_r <= (fast_r + 1).trunc<8>();
  end seq

  seq on slow_clk rising
    slow_r <= data_in;
  end seq

  comb data_out = slow_r; end comb
  comb fast_count = fast_r; end comb
end module MultiClockSync
