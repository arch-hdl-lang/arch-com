domain SysDomain
  freq_mhz: 100,
end domain SysDomain

ram SimpleMem
  param DEPTH: const = 256;
  param WIDTH: type = UInt<8>;
  port clk: in Clock<SysDomain>;
  kind single;
  read: sync;
  write: no_change;
  store
    data: Vec<WIDTH, DEPTH>;
  end store
  port access
    en: in Bool;
    wen: in Bool;
    addr: in UInt<8>;
    wdata: in WIDTH;
    rdata: out WIDTH;
  end port access
  init: zero;
end ram SimpleMem
