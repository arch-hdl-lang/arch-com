domain SrcDomain
  freq_mhz: 100
end domain SrcDomain

domain DstDomain
  freq_mhz: 133
end domain DstDomain

synchronizer DataSync
  param STAGES: const = 3;
  port src_clk: in Clock<SrcDomain>;
  port dst_clk: in Clock<DstDomain>;
  port rst: in Reset<Sync>;
  port data_in: in UInt<8>;
  port data_out: out UInt<8>;
end synchronizer DataSync
