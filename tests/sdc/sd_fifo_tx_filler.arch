// SD FIFO TX Filler
// DMA: reads data from system memory via Wishbone master, fills TX FIFO.

module sd_fifo_tx_filler

  port clk:        in Clock<SysDomain>;
  port rst:        in Reset<Async, High>;

  port m_wb_adr_o: out UInt<32>;
  port m_wb_we_o:  out Bool;
  port m_wb_dat_i: in UInt<32>;
  port m_wb_cyc_o: out Bool;
  port m_wb_stb_o: out Bool;
  port m_wb_ack_i: in Bool;
  port m_wb_cti_o: out UInt<3>;
  port m_wb_bte_o: out UInt<2>;

  port en:  in Bool;
  port adr: in UInt<32>;

  port sd_clk: in Clock<SysDomain>;
  port dat_o:  out UInt<32>;
  port rd:     in Bool;
  port empty:  out Bool;
  port fe:     out Bool;

  reg offset_r: UInt<32> reset rst => 0;
  reg din_r:    UInt<32> reset rst => 0;
  reg wr_tx_r:  Bool reset rst => false;
  reg delay_r:  Bool reset rst => false;
  reg ackd_r:   Bool reset rst => true;
  reg cyc_r:    Bool reset rst => false;
  reg stb_r:    Bool reset rst => false;

  wire fe_w: Bool;
  wire empty_w: Bool;
  wire mem_empt_w: UInt<6>;

  inst u_fifo: sd_tx_fifo
    wclk  <- clk;
    rclk  <- sd_clk;
    rst   <- rst;
    d     <- din_r;
    wr    <- wr_tx_r;
    q     -> dat_o;
    rd    <- rd;
    full  -> fe_w;
    empty -> empty_w;
    mem_empt -> mem_empt_w;
  end inst u_fifo

  default seq on clk rising;

  seq
    if ~en
      offset_r <= 0;
      wr_tx_r  <= false;
      delay_r  <= false;
      ackd_r   <= true;
      cyc_r    <= false;
      stb_r    <= false;
    else
      // Default: clear write pulse
      wr_tx_r <= false;

      if delay_r
        // Delay cycle: increment offset, toggle ackd
        delay_r  <= false;
        offset_r <= (offset_r + 4).trunc<32>();
        ackd_r   <= ~ackd_r;
      elsif m_wb_ack_i
        // WB ack: capture data, deassert bus
        din_r   <= m_wb_dat_i;
        wr_tx_r <= true;
        cyc_r   <= false;
        stb_r   <= false;
        delay_r <= true;
      elsif (~fe_w) & (~m_wb_ack_i) & ackd_r
        // Start WB read: FIFO not full, no ack pending, previous done
        cyc_r <= true;
        stb_r <= true;
      end if
    end if
  end seq

  comb
    m_wb_adr_o = (adr + offset_r).trunc<32>();
    m_wb_we_o  = false;
    m_wb_cyc_o = cyc_r;
    m_wb_stb_o = stb_r;
    m_wb_cti_o = 0;
    m_wb_bte_o = 0;
    fe    = fe_w;
    empty = empty_w;
  end comb
end module sd_fifo_tx_filler
