// SD RX FIFO (Dual-clock, 4-bit input -> 32-bit output, depth 8)
// Nibble packing: accumulates 8 nibbles into 32-bit word.
// BIG_ENDIAN: we[7] stores first nibble at tmp[3:0] (LSB), we[0] stores last at tmp[31:28].
// RAM write triggers on we[0] & ft. Matches OpenCores SDC reference (BIG_ENDIAN config).

module sd_rx_fifo

  port wclk:  in Clock<SysDomain>;
  port rclk:  in Clock<SysDomain>;
  port rst:   in Reset<Async, High>;

  port d:     in UInt<4>;
  port wr:    in Bool;
  port q:     out UInt<32>;
  port rd:    in Bool;
  port full:  out Bool;
  port empty: out Bool;
  port mem_empt: out UInt<2>;

  reg mem: Vec<UInt<32>, 8> reset none;
  reg adr_i: UInt<4> reset rst => 0;
  reg adr_o: UInt<4> reset rst => 0;

  reg we_r: UInt<8> reset rst => 1;
  reg tmp:  UInt<32> reset rst => 0;
  reg ft:   Bool reset rst => false;

  let full_w:  Bool = (adr_i[2:0] == adr_o[2:0]) & (adr_i[3:3] != adr_o[3:3]);
  let empty_w: Bool = (adr_i == adr_o);

  // ram_we: write to memory when we[0] is active AND ft is set AND wr is active
  wire ram_we_w: Bool;

  seq on wclk rising
    if wr
      we_r <= {we_r[6:0], we_r[7:7]};

      // BIG_ENDIAN nibble packing (matching reference sd_defines.v)
      if we_r[7:7]
        tmp[3:0] <= d;
        ft <= true;
      end if
      if we_r[6:6]
        tmp[7:4] <= d;
      end if
      if we_r[5:5]
        tmp[11:8] <= d;
      end if
      if we_r[4:4]
        tmp[15:12] <= d;
      end if
      if we_r[3:3]
        tmp[19:16] <= d;
      end if
      if we_r[2:2]
        tmp[23:20] <= d;
      end if
      if we_r[1:1]
        tmp[27:24] <= d;
      end if
      if we_r[0:0]
        tmp[31:28] <= d;
      end if
    end if
  end seq

  // RAM write: separate so it uses OLD tmp value (before current nibble update)
  // In the reference, ram_we = wr & we[0] & ft is combinational, and
  // ram[adr_i] <= ram_din happens in a separate always block.
  // Since ARCH uses non-blocking, tmp in the same seq block still holds old value.
  comb
    ram_we_w = wr & we_r[0:0] & ft;
  end comb

  seq on wclk rising
    if ram_we_w
      mem[adr_i[2:0]] <= tmp;
    end if
  end seq

  // Write address counter
  seq on wclk rising
    if ram_we_w
      if adr_i == 7
        adr_i[2:0] <= 0;
        adr_i[3:3] <= ~adr_i[3:3];
      else
        adr_i <= (adr_i + 1).trunc<4>();
      end if
    end if
  end seq

  // Read address counter
  seq on rclk rising
    if (~empty_w) & rd
      if adr_o == 7
        adr_o[2:0] <= 0;
        adr_o[3:3] <= ~adr_o[3:3];
      else
        adr_o <= (adr_o + 1).trunc<4>();
      end if
    end if
  end seq

  comb
    q = mem[adr_o[2:0]];
    full  = full_w;
    empty = empty_w;
    mem_empt = (adr_i - adr_o).trunc<2>();
  end comb
end module sd_rx_fifo
