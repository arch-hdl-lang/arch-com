// SD Buffer Descriptor Manager
// RAM_MEM_WIDTH_16 variant: 16-bit x 32 RAM, 4 writes per BD (2x16-bit address + 2x16-bit data).
// free_bd resets to BD_SIZE/4 = 8. Matches OpenCores SDC reference.

module sd_bd

  port clk:       in Clock<SysDomain>;
  port rst:       in Reset<Async, High>;
  port we_m:      in Bool;
  port dat_in_m:  in UInt<16>;
  port free_bd:   out UInt<5>;
  port re_s:      in Bool;
  port ack_o_s:   out Bool;
  port a_cmp:     in Bool;
  port dat_out_s: out UInt<16>;

  // BD memory: 32 entries x 16 bits
  reg bd_mem: Vec<UInt<16>, 32> reset none;

  // Master write pointer (5-bit, indexes into bd_mem)
  reg m_wr_pnt: UInt<5> reset rst => 0;

  // Write counter: tracks 4 writes per BD (0,1,2,3)
  reg write_cnt: UInt<2> reset rst => 0;

  // new_bw: pulses when a BD is fully written
  reg new_bw: Bool reset rst => false;

  // Free BD counter: starts at BD_SIZE/4 = 8
  reg free_bd_r: UInt<5> reset rst => 8;

  // last_a_cmp: edge detection for a_cmp
  reg last_a_cmp: Bool reset rst => false;

  // Slave read pointer
  reg s_rd_pnt: UInt<5> reset rst => 0;

  // Slave read sub-word counter
  reg read_s_cnt: UInt<2> reset rst => 0;

  // Slave ack
  reg ack_o_s_r: Bool reset rst => false;

  // Slave data output
  reg dat_out_s_r: UInt<16> reset rst => 0;

  default seq on clk rising;

  // Master write logic
  seq
    new_bw <= false;

    if we_m
      if free_bd_r > 0
        write_cnt <= (write_cnt + 1).trunc<2>();
        m_wr_pnt <= (m_wr_pnt + 1).trunc<5>();
        if ~write_cnt[1]
          // First two writes: address part
          bd_mem[m_wr_pnt] <= dat_in_m;
        else
          // Second two writes: data part
          bd_mem[m_wr_pnt] <= dat_in_m;
          new_bw <= write_cnt[0];  // Complete BD on 4th write (cnt goes 0->1->2->3)
        end if
      end if
    end if
  end seq

  // Free BD counter
  seq
    if new_bw
      free_bd_r <= (free_bd_r - 1).trunc<5>();
    elsif a_cmp
      last_a_cmp <= a_cmp;
      if ~last_a_cmp
        free_bd_r <= (free_bd_r + 1).trunc<5>();
      end if
    else
      last_a_cmp <= a_cmp;
    end if
  end seq

  // Slave read logic
  seq
    ack_o_s_r <= false;
    if re_s
      read_s_cnt <= (read_s_cnt + 1).trunc<2>();
      s_rd_pnt <= (s_rd_pnt + 1).trunc<5>();
      ack_o_s_r <= true;
      if ~read_s_cnt[1]
        dat_out_s_r <= bd_mem[s_rd_pnt];
      else
        dat_out_s_r <= bd_mem[s_rd_pnt];
      end if
    end if
  end seq

  comb
    free_bd   = free_bd_r;
    ack_o_s   = ack_o_s_r;
    dat_out_s = dat_out_s_r;
  end comb
end module sd_bd
