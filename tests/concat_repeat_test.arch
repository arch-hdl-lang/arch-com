// Test: bit concatenation {a, b} and bit replication {N{expr}}

domain SysDomain
  freq_mhz: 100
end domain SysDomain

module ConcatRepeatTest
  port clk: in Clock<SysDomain>;
  port rst: in Reset<Sync>;

  port a: in UInt<8>;
  port b: in UInt<8>;
  port sign_bit: in Bool;

  // Concatenation: {a, b} → 16-bit result
  port cat_out: out UInt<16>;

  // Replication: {4{sign_bit}} → 4-bit sign extension mask
  port rep_out: out UInt<4>;

  // Mixed: {sign_bit, a} → 9-bit result
  port mixed_out: out UInt<9>;

  // Replication in concat: {{8{sign_bit}}, a} → 16-bit sign-extended
  port sext_out: out UInt<16>;

  comb
    cat_out = {a, b};
    rep_out = {4{sign_bit}};
    mixed_out = {sign_bit, a};
    sext_out = {{8{sign_bit}}, a};
  end comb

end module ConcatRepeatTest
